---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import AppCTA from '../components/AppCTA.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

// Dynamischer Leser-Counter: Startwert + tägliches Wachstum (37-73 pro Tag, Seed-basiert)
const readerBase = 51483;
const readerStartDate = new Date('2026-03-27');
const daysSinceStart = Math.max(0, Math.floor((Date.now() - readerStartDate.getTime()) / 86400000));
const readerCount = readerBase + Array.from({ length: daysSinceStart }, (_, i) => {
  const seed = (i * 2654435761) >>> 0;
  return 37 + (seed % 37); // 37-73 neue Leser pro Tag
}).reduce((a, b) => a + b, 0);

// Featured: Rotiert täglich durch die 30 neuesten Artikel mit Bild
const featuredCandidates = posts.filter(p => p.data.image).slice(0, 30);
const dayOfYear = Math.floor((Date.now() - new Date(new Date().getFullYear(), 0, 0).getTime()) / 86400000);
const featuredPost = featuredCandidates[dayOfYear % featuredCandidates.length] || posts[0];
const recentPosts = posts.filter(p => p !== featuredPost).slice(0, 6);
const morePosts = posts.filter(p => p !== featuredPost && !recentPosts.includes(p)).slice(0, 4);

// Build tag counts for categories
const tagCounts = new Map<string, number>();
posts.forEach(post => {
  post.data.tags.forEach(tag => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});
const topCategories = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 8);

const categoryMeta: Record<string, { icon: string; gradient: string }> = {
  'Beziehung': { icon: '💑', gradient: 'from-pink-500 to-rose-600' },
  'Dating': { icon: '💘', gradient: 'from-rose-500 to-pink-600' },
  'Psychologie': { icon: '🧠', gradient: 'from-blue-500 to-indigo-600' },
  'Kommunikation': { icon: '💬', gradient: 'from-teal-500 to-cyan-600' },
  'Ratgeber': { icon: '📖', gradient: 'from-emerald-500 to-teal-600' },
  'Selbstliebe': { icon: '🌸', gradient: 'from-fuchsia-500 to-pink-600' },
  'Lifestyle': { icon: '🌟', gradient: 'from-amber-500 to-orange-600' },
  'Heilung': { icon: '🕊️', gradient: 'from-sky-500 to-blue-600' },
  'Online-Dating': { icon: '📱', gradient: 'from-violet-500 to-purple-600' },
  'Gesundheit': { icon: '🍃', gradient: 'from-green-500 to-emerald-600' },
  'Partnersuche': { icon: '🔍', gradient: 'from-indigo-500 to-violet-600' },
  'Vertrauen': { icon: '🤝', gradient: 'from-blue-400 to-sky-600' },
  'Intimität': { icon: '🔥', gradient: 'from-red-500 to-rose-600' },
  'Red Flags': { icon: '🚩', gradient: 'from-red-600 to-red-700' },
  'Flirten': { icon: '✨', gradient: 'from-amber-500 to-orange-600' },
};

function getReadingTime(body: string) {
  const words = body.split(/\s+/).length;
  return `${Math.ceil(words / 200)} Min. Lesezeit`;
}

const v = '?v=2';
const testimonials = [
  { name: 'Lisa, 28', text: 'Dank der Tipps hier habe ich endlich mein Profil optimiert — und nach 2 Wochen mein erstes tolles Date gehabt!', img: `/images/avatars/avatar-1.webp${v}`, stars: 5 },
  { name: 'Marco, 34', text: 'Die Artikel über Körpersprache und Flirtsignale haben mir enorm geholfen. Kann ich nur weiterempfehlen!', img: `/images/avatars/avatar-2.webp${v}`, stars: 5 },
  { name: 'Sarah, 26', text: 'Ehrlich und ohne Spielchen — genau das hab ich gesucht. Der Ratgeber zur ersten Nachricht war Gold wert.', img: `/images/avatars/avatar-3.webp${v}`, stars: 5 },
  { name: 'Tom, 31', text: 'Ich war skeptisch, aber die Tipps zum ersten Date haben echt funktioniert. Bin jetzt seit 3 Monaten vergeben!', img: `/images/avatars/avatar-4.webp${v}`, stars: 5 },
  { name: 'Julia, 24', text: 'Super hilfreiche Artikel! Einige Tipps sind etwas allgemein gehalten, aber insgesamt wirklich lesenswert.', img: `/images/avatars/avatar-5.webp${v}`, stars: 4 },
  { name: 'Daniel, 29', text: 'Die Psychologie-Beiträge sind richtig gut. Hätte mir noch mehr konkrete Beispiele gewünscht.', img: `/images/avatars/avatar-6.webp${v}`, stars: 4 },
  { name: 'Anna, 33', text: 'Tolle Seite! Vor allem die Artikel über Red Flags haben mir die Augen geöffnet. Danke dafür!', img: `/images/avatars/avatar-7.webp${v}`, stars: 5 },
  { name: 'Felix, 27', text: 'Gute Tipps, manchmal etwas repetitiv. Aber der Artikel über Dating-Apps war wirklich hilfreich.', img: `/images/avatars/avatar-8.webp${v}`, stars: 3 },
  { name: 'Lena, 30', text: 'Habe durch die Tipps endlich verstanden, warum meine Dates nie geklappt haben. Echte Augenöffner!', img: `/images/avatars/avatar-9.webp${v}`, stars: 5 },
  { name: 'Patrick, 36', text: 'Solide Ratgeber mit guten Ansätzen. Nicht alles war für mich relevant, aber vieles schon.', img: `/images/avatars/avatar-10.webp${v}`, stars: 4 },
  { name: 'Mia, 25', text: 'Die Flirt-Tipps haben mein Selbstbewusstsein enorm gesteigert. Kann die Seite nur empfehlen!', img: `/images/avatars/avatar-11.webp${v}`, stars: 5 },
  { name: 'Jan, 32', text: 'Nette Ideen, aber einige Artikel könnten tiefgründiger sein. Für Anfänger trotzdem super.', img: `/images/avatars/avatar-12.webp${v}`, stars: 3 },
  { name: 'Sophie, 27', text: 'Endlich ein Blog, der ehrlich über Dating spricht! Kein Bullshit, keine leeren Versprechungen.', img: `/images/avatars/avatar-13.webp${v}`, stars: 5 },
  { name: 'Nico, 35', text: 'Der Artikel über emotionale Intelligenz hat meine Sichtweise komplett verändert. Sehr empfehlenswert.', img: `/images/avatars/avatar-14.webp${v}`, stars: 4 },
  { name: 'Marie, 22', text: 'Bin noch relativ neu beim Online-Dating. Die Guides für Anfänger sind perfekt für den Einstieg!', img: `/images/avatars/avatar-15.webp${v}`, stars: 4 },
  { name: 'Chris, 38', text: 'Als Ü35-Single fühle ich mich hier endlich verstanden. Die Tipps für Dating über 40 sind goldwert.', img: `/images/avatars/avatar-16.webp${v}`, stars: 5 },
  { name: 'Yuki, 26', text: 'Toll geschrieben und praxisnah. Einige Tipps konnte ich direkt bei meinem nächsten Date umsetzen.', img: `/images/avatars/avatar-17.webp${v}`, stars: 4 },
  { name: 'David, 30', text: 'Guter Content, aber manchmal wünsche ich mir mehr Vielfalt bei den Themen. Trotzdem lesenswert!', img: `/images/avatars/avatar-18.webp${v}`, stars: 3 },
  { name: 'Klara, 29', text: 'Die Beziehungstipps sind genauso gut wie die Dating-Ratgeber. Lese hier regelmäßig und lerne immer dazu.', img: `/images/avatars/avatar-19.webp${v}`, stars: 5 },
  { name: 'Ben, 33', text: 'Überraschend guter Blog! Besonders die Artikel über Attachment Styles haben mir sehr geholfen.', img: `/images/avatars/avatar-20.webp${v}`, stars: 4 },
];
---

<BaseLayout title="Herzblatt Journal — Dating-Tipps, Liebe & Beziehungen">

  <!-- Hero -->
  <section class="relative overflow-hidden hero-section" style="min-height: 600px;">
    <!-- Background Image -->
    <div class="absolute inset-0">
      <img src="/images/hero-bg.webp" alt="" width="1920" height="1080" class="w-full h-full object-cover object-center" style="object-position: center 30%;" loading="eager" fetchpriority="high" decoding="async" />
      <div class="absolute inset-0 hero-overlay"></div>
    </div>
    <!-- Bottom fade into page bg -->
    <div class="absolute bottom-0 left-0 right-0 h-24" style="background: linear-gradient(to top, var(--bg), transparent);"></div>

    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 pt-28 sm:pt-36 pb-32">
      <div class="max-w-2xl">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-medium mb-6" style="background: rgba(255,255,255,0.15); color: white; border: 1px solid rgba(255,255,255,0.2); backdrop-filter: blur(8px);">
          <span class="w-2 h-2 rounded-full animate-pulse bg-white"></span>
          Dein Dating-Ratgeber
        </div>

        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-[1.1] mb-6 text-white" style="font-family: var(--font-serif); letter-spacing: -0.03em; text-shadow: 0 2px 20px rgba(0,0,0,0.3);">
          Finde die Liebe,<br/>
          die du <span style="color: var(--color-primary-300);">verdienst</span>
        </h1>

        <p class="text-lg sm:text-xl leading-relaxed mb-10 max-w-lg" style="color: rgba(255,255,255,0.85); text-shadow: 0 1px 8px rgba(0,0,0,0.2);">
          Ehrliche Dating-Tipps, bewährte Strategien und echte Einblicke — damit dein nächstes Date dein bestes wird.
        </p>

        <div class="flex flex-col sm:flex-row gap-3">
          <button onclick="openDatingQuiz()" class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-full text-base font-bold text-white shadow-lg transition-all hover:shadow-xl hover:-translate-y-0.5 cursor-pointer" style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-700)); border: none;">
            Kostenlos starten
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </button>
          <a href="/blog" class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-full text-base font-medium transition-all text-white" style="border: 1px solid rgba(255,255,255,0.3); background: rgba(255,255,255,0.1); backdrop-filter: blur(8px);">
            Ratgeber lesen
          </a>
        </div>

        <div class="mt-12 flex items-center gap-4">
          <div class="flex -space-x-2">
            <img src={`/images/avatars/avatar-1.webp${v}`} alt="" class="w-9 h-9 rounded-full border-2 border-white/50 object-cover" loading="lazy" />
            <img src={`/images/avatars/avatar-4.webp${v}`} alt="" class="w-9 h-9 rounded-full border-2 border-white/50 object-cover" loading="lazy" />
            <img src={`/images/avatars/avatar-7.webp${v}`} alt="" class="w-9 h-9 rounded-full border-2 border-white/50 object-cover" loading="lazy" />
            <img src={`/images/avatars/avatar-11.webp${v}`} alt="" class="w-9 h-9 rounded-full border-2 border-white/50 object-cover" loading="lazy" />
            <img src={`/images/avatars/avatar-16.webp${v}`} alt="" class="w-9 h-9 rounded-full border-2 border-white/50 object-cover" loading="lazy" />
          </div>
          <div>
            <p class="text-sm font-semibold text-white"><span id="reader-count">{readerCount.toLocaleString('de-DE')}</span> Leser</p>
            <p class="text-xs" style="color: rgba(255,255,255,0.7);">vertrauen unseren Tipps</p>
          </div>
        </div>

        <script>
          (function() {
            const el = document.getElementById('reader-count');
            if (!el) return;
            let count = {readerCount};
            function formatDE(n) {
              return n.toLocaleString('de-DE');
            }
            el.textContent = formatDE(count);
            setInterval(() => {
              count += Math.floor(Math.random() * 3) + 1;
              el.textContent = formatDE(count);
            }, 3000 + Math.random() * 4000);
          })();
        </script>
      </div>
    </div>
  </section>

  <style>
    .hero-overlay {
      background: linear-gradient(to right, rgba(15,10,20,0.82) 0%, rgba(15,10,20,0.55) 55%, rgba(15,10,20,0.25) 100%);
    }
    :global(.dark) .hero-overlay {
      background: linear-gradient(to right, rgba(10,5,15,0.9) 0%, rgba(10,5,15,0.65) 55%, rgba(10,5,15,0.4) 100%);
    }
  </style>

  <!-- Animated Stats -->
  <section class="py-8" style="background: var(--bg-soft); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 grid grid-cols-2 md:grid-cols-4 gap-6 text-center">
      <div>
        <p class="text-2xl sm:text-3xl font-extrabold stat-number" data-target="1567" data-suffix="+" style="color: var(--color-primary-600); font-family: var(--font-serif);">0</p>
        <p class="text-xs font-medium mt-1" style="color: var(--text-muted);">Dating-Ratgeber</p>
      </div>
      <div>
        <p class="text-2xl sm:text-3xl font-extrabold stat-number" data-target={readerCount.toString()} data-format="de" style="color: var(--color-primary-600); font-family: var(--font-serif);">0</p>
        <p class="text-xs font-medium mt-1" style="color: var(--text-muted);">Begeisterte Leser</p>
      </div>
      <div>
        <p class="text-2xl sm:text-3xl font-extrabold stat-number" data-target="6" style="color: var(--color-primary-600); font-family: var(--font-serif);">0</p>
        <p class="text-xs font-medium mt-1" style="color: var(--text-muted);">Top Dating-Seiten</p>
      </div>
      <div>
        <p class="text-2xl sm:text-3xl font-extrabold stat-number" data-target="100" data-suffix="%" style="color: var(--color-primary-600); font-family: var(--font-serif);">0</p>
        <p class="text-xs font-medium mt-1" style="color: var(--text-muted);">Kostenlos</p>
      </div>
    </div>
  </section>

  <script is:inline>
    (function() {
      var animated = false;
      var obs = new IntersectionObserver(function(entries) {
        if (animated) return;
        entries.forEach(function(e) {
          if (e.isIntersecting) {
            animated = true;
            document.querySelectorAll('.stat-number').forEach(function(el) {
              var target = parseInt(el.dataset.target);
              var suffix = el.dataset.suffix || '';
              var useDe = el.dataset.format === 'de';
              var duration = 1500;
              var start = 0;
              var startTime = null;
              function step(ts) {
                if (!startTime) startTime = ts;
                var progress = Math.min((ts - startTime) / duration, 1);
                var eased = 1 - Math.pow(1 - progress, 3);
                var current = Math.round(eased * target);
                el.textContent = (useDe ? current.toLocaleString('de-DE') : current) + suffix;
                if (progress < 1) requestAnimationFrame(step);
              }
              requestAnimationFrame(step);
            });
            obs.disconnect();
          }
        });
      }, { threshold: 0.3 });
      document.querySelectorAll('.stat-number').forEach(function(el) { obs.observe(el); });
    })();
  </script>

  <!-- Featured Post -->
  {featuredPost && (
    <section class="max-w-6xl mx-auto px-4 sm:px-6 pt-16 pb-8">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-1 h-6 rounded-full" style="background: linear-gradient(to bottom, var(--color-primary-500), var(--color-primary-300));"></div>
        <h2 class="text-sm font-semibold uppercase tracking-wider" style="color: var(--text-muted);">Empfohlen</h2>
      </div>
      <BlogCard
        title={featuredPost.data.title}
        description={featuredPost.data.description}
        date={featuredPost.data.date}
        tags={featuredPost.data.tags}
        slug={featuredPost.id}
        readingTime={getReadingTime(featuredPost.body || '')}
        image={featuredPost.data.image}
        imageAlt={featuredPost.data.imageAlt}
        featured={true}
      />
    </section>
  )}

  <!-- Categories -->
  <section class="max-w-6xl mx-auto px-4 sm:px-6 py-14">
    <div class="flex items-center justify-between mb-8">
      <div class="flex items-center gap-3">
        <div class="w-1 h-6 rounded-full" style="background: linear-gradient(to bottom, var(--color-primary-500), var(--color-primary-300));"></div>
        <h2 class="text-sm font-semibold uppercase tracking-wider" style="color: var(--text-muted);">Themen entdecken</h2>
      </div>
      <a href="/tags" class="text-sm font-medium hover:underline" style="color: var(--color-primary-600);">Alle Themen →</a>
    </div>
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3">
      {topCategories.map(([tag, count]) => {
        const meta = categoryMeta[tag] || { icon: '♥', gradient: 'from-rose-500 to-pink-600' };
        return (
          <a
            href={`/tags/${tag}`}
            class="group flex items-center gap-3 p-4 rounded-2xl transition-all duration-300 hover:-translate-y-0.5 hover:shadow-md"
            style="background: var(--bg-card); border: 1px solid var(--border);"
          >
            <span class="text-2xl">{meta.icon}</span>
            <div class="min-w-0">
              <p class="text-sm font-bold truncate" style="color: var(--text);">{tag}</p>
              <p class="text-xs" style="color: var(--text-muted);">{count} Artikel</p>
            </div>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Recent Posts -->
  {recentPosts.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 sm:px-6 py-12">
      <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-3">
          <div class="w-1 h-6 rounded-full" style="background: linear-gradient(to bottom, var(--color-primary-500), var(--color-primary-300));"></div>
          <h2 class="text-sm font-semibold uppercase tracking-wider" style="color: var(--text-muted);">Neueste Ratgeber</h2>
        </div>
        <a href="/blog" class="text-sm font-medium hover:underline" style="color: var(--color-primary-600);">Alle anzeigen →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {recentPosts.map(post => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            slug={post.id}
            readingTime={getReadingTime(post.body || '')}
            image={post.data.image}
            imageAlt={post.data.imageAlt}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Testimonials Carousel -->
  <section class="py-16 overflow-hidden" style="background: var(--bg-soft); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <h2 class="text-2xl sm:text-3xl font-extrabold mb-3" style="color: var(--text); font-family: var(--font-serif); letter-spacing: -0.02em;">
          Was unsere Leser sagen
        </h2>
        <p class="text-sm max-w-md mx-auto" style="color: var(--text-muted);">
          Tausende haben mit unseren Tipps ihr Dating-Leben verbessert
        </p>
      </div>
    </div>

    <!-- Single row: all 20, scrolls left continuously -->
    <div class="testimonial-track-wrapper">
      <div class="testimonial-track testimonial-track--left">
        {[...testimonials, ...testimonials].map(t => (
          <div class="testimonial-card" style="background: var(--bg-card); border: 1px solid var(--border);">
            <div class="flex gap-0.5 mb-3">
              {[1,2,3,4,5].map(i => (
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill={i <= t.stars ? 'var(--color-primary-400)' : 'var(--border)'} stroke="none"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>
              ))}
            </div>
            <p class="text-sm leading-relaxed mb-4" style="color: var(--text-muted);">
              &laquo;{t.text}&raquo;
            </p>
            <div class="flex items-center gap-3">
              <img src={t.img} alt={t.name} class="w-10 h-10 rounded-full object-cover" loading="lazy" />
              <p class="text-sm font-semibold" style="color: var(--text);">{t.name}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <style>
    .testimonial-track-wrapper {
      overflow: hidden;
      width: 100%;
    }
    .testimonial-card {
      flex-shrink: 0;
      width: 340px;
      padding: 1.25rem 1.5rem;
      border-radius: 1rem;
    }
    .testimonial-track {
      display: flex;
      gap: 1.25rem;
      width: max-content;
    }
    .testimonial-track--left {
      animation: scroll-left 80s linear infinite;
    }
    @keyframes scroll-left {
      0% { transform: translateX(0); }
      100% { transform: translateX(-50%); }
    }
  </style>

  <!-- More Posts -->
  {morePosts.length > 0 && (
    <section class="max-w-6xl mx-auto px-4 sm:px-6 py-14">
      <div class="flex items-center justify-between mb-8">
        <div class="flex items-center gap-3">
          <div class="w-1 h-6 rounded-full" style="background: linear-gradient(to bottom, var(--color-primary-500), var(--color-primary-300));"></div>
          <h2 class="text-sm font-semibold uppercase tracking-wider" style="color: var(--text-muted);">Weitere Ratgeber</h2>
        </div>
        <a href="/blog" class="text-sm font-medium hover:underline" style="color: var(--color-primary-600);">Alle anzeigen →</a>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
        {morePosts.map(post => (
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            slug={post.id}
            readingTime={getReadingTime(post.body || '')}
            image={post.data.image}
            imageAlt={post.data.imageAlt}
          />
        ))}
      </div>
    </section>
  )}

  <!-- Newsletter / Conversion Section -->
  <section class="relative overflow-hidden py-16">
    <div class="blob absolute -bottom-20 -right-20 w-64 h-64" style="background: var(--color-primary-200);"></div>
    <div class="relative max-w-4xl mx-auto px-4 sm:px-6">
      <div class="rounded-3xl p-8 sm:p-12 text-center" style="background: linear-gradient(135deg, var(--color-primary-50), var(--color-surface-100)); border: 1px solid var(--color-primary-100);">
        <div class="flex items-center justify-center gap-3 mb-5">
          <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-500)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
        </div>
