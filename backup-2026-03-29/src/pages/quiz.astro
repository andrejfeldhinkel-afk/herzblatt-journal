    var currentQ = 0;
    var scores = { bold: 0, slow: 0, digital: 0, intuitive: 0 };

    function renderStars(rating, white) {
      var full = Math.floor(rating);
      var half = rating % 1 >= 0.3;
      var empty = 5 - full - (half ? 1 : 0);
      var fillColor = white ? '#fff' : '#f43f5e';
      var emptyColor = white ? 'rgba(255,255,255,0.35)' : '#d1d5db';
      var stars = '';
      for (var i = 0; i < full; i++) stars += '<span style="color:' + fillColor + '">&#9733;</span>';
      if (half) stars += '<span style="color:' + fillColor + ';opacity:0.5">&#9733;</span>';
      for (var j = 0; j < empty; j++) stars += '<span style="color:' + emptyColor + '">&#9733;</span>';
      return stars;
    }

    function showQuestion() {
      var q = questions[currentQ];
      document.getElementById('question-number').textContent = 'Frage ' + (currentQ + 1) + ' von ' + questions.length;
      document.getElementById('question-text').textContent = q.q;
      document.getElementById('progress-bar').style.width = ((currentQ / questions.length) * 100) + '%';

      var answersDiv = document.getElementById('answers');
      answersDiv.innerHTML = '';
      q.a.forEach(function(a) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.textContent = a.text;
        btn.onclick = function() { selectAnswer(a.type); };
        btn.style.cssText = 'display:block;width:100%;text-align:left;padding:16px 20px;border-radius:12px;font-size:15px;font-weight:500;cursor:pointer;transition:all 0.2s;border:2px solid var(--border);background:var(--bg-card);color:var(--text);';
        btn.onmouseover = function() { this.style.borderColor='var(--color-primary-400)'; this.style.background='var(--color-primary-50)'; };
        btn.onmouseout = function() { this.style.borderColor='var(--border)'; this.style.background='var(--bg-card)'; };
        answersDiv.appendChild(btn);
      });
    }

    function selectAnswer(type) {
      scores[type]++;
      currentQ++;
      if (currentQ < questions.length) {
        showQuestion();
      } else {
        showResult();
      }
    }

    function showResult() {
      document.getElementById('progress-bar').style.width = '100%';
      document.getElementById('quiz-content').classList.add('hidden');
      document.getElementById('result-area').classList.remove('hidden');

      var maxType = Object.keys(scores).reduce(function(a, b) { return scores[a] > scores[b] ? a : b; });
      var r = results[maxType];

      // Personality result
      document.getElementById('result-icon').textContent = r.icon;
      document.getElementById('result-title').textContent = r.title;
      document.getElementById('result-subtitle').textContent = r.subtitle;
      document.getElementById('result-description').innerHTML = r.description;

      // Top dating site recommendation
      var topSite = datingSites[r.topSite];
      var topCard = document.getElementById('top-site-card');
      topCard.href = topSite.url;
      document.getElementById('top-site-logo').src = topSite.logo;
      document.getElementById('top-site-logo').alt = topSite.name;
      document.getElementById('top-site-name').textContent = topSite.name;
      document.getElementById('top-site-rating').textContent = topSite.rating + '/5';
      document.getElementById('top-site-stars').innerHTML = renderStars(topSite.rating, true);
      document.getElementById('top-site-reason').textContent = r.topReason;
      document.getElementById('top-site-desc').textContent = topSite.desc;

      // Other dating sites
      var otherList = document.getElementById('other-sites-list');
      otherList.innerHTML = '';
      r.siteOrder.forEach(function(sKey, idx) {
        if (sKey === r.topSite) return;
        var s = datingSites[sKey];
        var a = document.createElement('a');
        a.href = s.url;
        a.target = '_blank';
        a.rel = 'noopener';
        a.style.cssText = 'display:flex;align-items:center;gap:0.875rem;padding:0.875rem 1rem;border-radius:0.75rem;border:1px solid var(--border);background:var(--bg-card);text-decoration:none;color:var(--text);transition:all 0.2s;';
        a.onmouseover = function() { this.style.borderColor='var(--color-primary-300)'; this.style.boxShadow='0 4px 16px rgba(244,63,94,0.08)'; };
        a.onmouseout = function() { this.style.borderColor='var(--border)'; this.style.boxShadow='none'; };
        a.innerHTML =
          '<div style="width:40px;height:40px;border-radius:0.625rem;background:#1a1a2e;border:1px solid #2a2a3e;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><img src="' + s.logo + '" alt="' + s.name + '" style="height:20px;width:auto;object-fit:contain;" /></div>' +
          '<div style="flex:1;min-width:0;">' +
            '<div style="display:flex;align-items:center;gap:0.4rem;flex-wrap:wrap;">' +
              '<span style="font-size:0.9rem;font-weight:700;">' + s.name + '</span>' +
              '<span style="font-size:0.6rem;font-weight:700;text-transform:uppercase;letter-spacing:0.03em;color:var(--color-primary-600);background:var(--color-primary-50);padding:0.125rem 0.375rem;border-radius:0.25rem;">' + s.tag + '</span>' +
            '</div>' +
            '<div style="display:flex;align-items:center;gap:0.3rem;margin-top:0.125rem;">' +
              '<span style="font-size:0.8rem;font-weight:600;color:var(--color-primary-600);">' + s.rating + '</span>' +
              '<span style="font-size:0.75rem;letter-spacing:1px;">' + renderStars(s.rating, false) + '</span>' +
            '</div>' +
          '</div>' +
          '<span style="flex-shrink:0;padding:0.4rem 0.85rem;border-radius:999px;font-size:0.75rem;font-weight:700;color:#fff;background:linear-gradient(135deg,var(--color-primary-500),var(--color-primary-600));white-space:nowrap;">Testen &rarr;</span>';
        otherList.appendChild(a);
      });

      // Articles
      var listDiv = document.getElementById('articles-list');
      listDiv.innerHTML = '';
      r.articles.forEach(function(art) {
        var a = document.createElement('a');
        a.href = art.url;
        a.style.cssText = 'display:flex;align-items:center;gap:12px;padding:14px 18px;border-radius:12px;text-decoration:none;transition:all 0.2s;border:1px solid var(--border);background:var(--bg-card);';
        a.innerHTML = '<span style="color:var(--color-primary-500)"><svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1 0-5H20"/></svg></span><span style="font-weight:600;color:var(--text);font-size:14px;">' + art.title + '</span><span style="margin-left:auto;color:var(--color-primary-500);font-size:13px;">Lesen &rarr;</span>';
        a.onmouseover = function() { this.style.borderColor='var(--color-primary-300)'; };
        a.onmouseout = function() { this.style.borderColor='var(--border)'; };
        listDiv.appendChild(a);
      });

      // Track quiz completion
      try { navigator.sendBeacon('/api/track-click', JSON.stringify({ site: r.topSite, event: 'quiz_result', type: maxType })); } catch(e) {}

      // Update counter
      var countEl = document.getElementById('quiz-count');
      var base = 47832;
      var start = new Date('2026-03-17').getTime();
      var days = Math.floor((Date.now() - start) / 86400000);
      countEl.textContent = (base + days * 23 + Math.floor(Math.random() * 10)).toLocaleString('de-DE');

      window.scrollTo({ top: 0, behavior: 'smooth' });
      window._quizResult = maxType;
    }

    window.restartQuiz = function() {
      currentQ = 0;
      scores = { bold: 0, slow: 0, digital: 0, intuitive: 0 };
      document.getElementById('quiz-content').classList.remove('hidden');
      document.getElementById('result-area').classList.add('hidden');
      showQuestion();
    };

    window.shareResult = function() {
      var maxType = Object.keys(scores).reduce(function(a, b) { return scores[a] > scores[b] ? a : b; });
      var r = results[maxType];
      var text = 'Ich bin "' + r.title + '" — welcher Dating-Typ bist du? Mach das kostenlose Quiz: https://herzblatt-journal.com/quiz';
      if (navigator.share) {
        navigator.share({ title: 'Mein Dating-Typ', text: text, url: 'https://herzblatt-journal.com/quiz' });
      } else {
        navigator.clipboard.writeText(text).then(function() { alert('Link kopiert! Teile ihn mit deinen Freunden.'); });
      }
    };

    showQuestion();

    // Dynamic counter
    var countEl = document.getElementById('quiz-count');
    var base = 47832;
    var start = new Date('2026-03-17').getTime();
    var days = Math.floor((Date.now() - start) / 86400000);
    countEl.textContent = (base + days * 23).toLocaleString('de-DE');
  })();
  </script>
</BaseLayout>
