---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Dating-Typ Quiz: Welcher Dating-Typ bist du? | Kostenloses Quiz";
const description = "Finde in 2 Minuten heraus, welcher Dating-Typ du bist und welche Dating-Strategie am besten zu dir passt. Wissenschaftlich fundiert, 100% kostenlos.";
---

<BaseLayout title={title} description={description}>
  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-12">
    <!-- Quiz Header -->
    <div class="text-center mb-10">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-semibold mb-4" style="background: var(--color-primary-100); color: var(--color-primary-700);">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"/><circle cx="12" cy="12" r="10"/><path d="M12 17h.01"/></svg>
        Kostenloses Quiz — 2 Min.
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold mb-4" style="color: var(--text); font-family: var(--font-serif); letter-spacing: -0.02em;">
        Welcher Dating-Typ bist du?
      </h1>
      <p class="text-base max-w-xl mx-auto" style="color: var(--text-muted);">
        Beantworte 10 Fragen und erfahre deinen persönlichen Dating-Typ — mit individuellen Tipps und der perfekten Dating-Seite für dich.
      </p>
    </div>

    <!-- Quiz Container -->
    <div id="quiz-container" class="rounded-3xl overflow-hidden" style="background: var(--bg-card); border: 1px solid var(--border); box-shadow: 0 4px 24px rgba(0,0,0,0.06);">
      <!-- Progress Bar -->
      <div class="h-1.5" style="background: var(--bg-soft);">
        <div id="progress-bar" class="h-full rounded-full transition-all duration-500" style="background: linear-gradient(90deg, var(--color-primary-400), var(--color-primary-600)); width: 0%;"></div>
      </div>

      <!-- Question Area -->
      <div id="quiz-content" class="p-6 sm:p-10">
        <div id="question-number" class="text-xs font-bold uppercase tracking-wider mb-3" style="color: var(--color-primary-500);">Frage 1 von 10</div>
        <h2 id="question-text" class="text-xl sm:text-2xl font-bold mb-8" style="color: var(--text); font-family: var(--font-serif);">Laden...</h2>
        <div id="answers" class="space-y-3"></div>
      </div>

      <!-- Result Area (hidden initially) -->
      <div id="result-area" class="hidden p-6 sm:p-10">
        <!-- Personality Result -->
        <div class="text-center mb-8">
          <div id="result-icon" class="text-6xl mb-4"></div>
          <h2 id="result-title" class="text-2xl sm:text-3xl font-extrabold mb-3" style="color: var(--text); font-family: var(--font-serif);"></h2>
          <p id="result-subtitle" class="text-base font-medium mb-6" style="color: var(--color-primary-600);"></p>
          <div id="result-description" class="text-left rounded-2xl p-6 mb-6" style="background: var(--bg-soft); border: 1px solid var(--border);"></div>
        </div>

        <!-- TOP Dating-Seite Empfehlung -->
        <div class="mb-6">
          <div class="text-center mb-4">
            <p class="text-xs font-bold uppercase tracking-wider" style="color: var(--color-primary-500);">Unsere Empfehlung für deinen Typ</p>
            <h3 class="text-xl sm:text-2xl font-extrabold mt-1" style="color: var(--text); font-family: var(--font-serif);">Dein perfektes Dating-Portal</h3>
          </div>
          <a id="top-site-card" href="#" target="_blank" rel="noopener" style="display:block;padding:1.5rem;border-radius:1rem;background:linear-gradient(135deg,var(--color-primary-500),var(--color-primary-700));color:#fff;text-decoration:none;position:relative;box-shadow:0 8px 32px rgba(244,63,94,0.25);transition:all 0.2s;" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 12px 40px rgba(244,63,94,0.35)'" onmouseout="this.style.transform='none';this.style.boxShadow='0 8px 32px rgba(244,63,94,0.25)'">
            <span style="position:absolute;top:0.75rem;right:0.75rem;padding:0.25rem 0.75rem;border-radius:999px;font-size:0.7rem;font-weight:700;background:rgba(255,255,255,0.2);backdrop-filter:blur(10px);">⭐ Top-Empfehlung</span>
            <div style="display:flex;align-items:center;gap:1rem;margin-bottom:0.75rem;">
              <div style="width:56px;height:56px;border-radius:0.75rem;background:#1a1a2e;display:flex;align-items:center;justify-content:center;flex-shrink:0;">
                <img id="top-site-logo" src="" alt="" style="height:30px;width:auto;object-fit:contain;" />
              </div>
              <div>
                <div id="top-site-name" style="font-size:1.2rem;font-weight:800;"></div>
                <div style="display:flex;align-items:center;gap:0.4rem;">
                  <span id="top-site-rating" style="font-size:0.9rem;font-weight:600;color:rgba(255,255,255,0.9);"></span>
                  <span id="top-site-stars" style="font-size:0.9rem;letter-spacing:1px;"></span>
                </div>
              </div>
            </div>
            <p id="top-site-reason" style="font-size:0.9rem;color:rgba(255,255,255,0.9);line-height:1.6;margin-bottom:0.5rem;font-weight:500;"></p>
            <p id="top-site-desc" style="font-size:0.85rem;color:rgba(255,255,255,0.75);line-height:1.5;margin-bottom:1.25rem;"></p>
            <span style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.75rem 1.75rem;border-radius:999px;background:#fff;color:var(--color-primary-600);font-size:0.9rem;font-weight:700;">
              Jetzt kostenlos testen
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </span>
          </a>
        </div>

        <!-- Weitere Dating-Seiten -->
        <div class="mb-8">
          <p class="text-sm font-bold mb-3" style="color: var(--text-muted);">Weitere Top-Seiten für dich:</p>
          <div id="other-sites-list" class="space-y-2"></div>
        </div>

        <!-- Share + Restart -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4 mb-8 pt-6" style="border-top: 1px solid var(--border);">
          <button onclick="shareResult()" class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-bold text-white" style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-700)); border: none; cursor: pointer;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="18" cy="5" r="3"/><circle cx="6" cy="12" r="3"/><circle cx="18" cy="19" r="3"/><line x1="8.59" y1="13.51" x2="15.42" y2="17.49"/><line x1="15.41" y1="6.51" x2="8.59" y2="10.49"/></svg>
            Ergebnis teilen
          </button>
          <button onclick="restartQuiz()" class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-medium" style="background: var(--bg-soft); border: 1px solid var(--border); color: var(--text); cursor: pointer;">
            Quiz wiederholen
          </button>
          <a href="/top-dating-seiten" class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-medium" style="background: var(--bg-soft); border: 1px solid var(--border); color: var(--text); text-decoration: none; cursor: pointer;">
            Alle Seiten vergleichen
          </a>
        </div>

        <!-- Recommended Articles -->
        <div id="recommended-articles" class="text-left">
          <h3 class="text-lg font-bold mb-4" style="color: var(--text); font-family: var(--font-serif);">Passende Ratgeber für dich:</h3>
          <div id="articles-list" class="space-y-3"></div>
        </div>
      </div>
    </div>

    <!-- Social Proof -->
    <div class="text-center mt-8">
      <p class="text-sm" style="color: var(--text-muted);">
        <span id="quiz-count" class="font-bold" style="color: var(--text);">47.832</span> Personen haben dieses Quiz bereits gemacht
      </p>
    </div>

    <!-- Schema.org Quiz Markup -->
    <script type="application/ld+json" is:inline>
    {
      "@context": "https://schema.org",
      "@type": "Quiz",
      "name": "Welcher Dating-Typ bist du?",
      "description": "Finde in 2 Minuten heraus, welcher Dating-Typ du bist und welche Dating-Strategie am besten zu dir passt.",
      "educationalAlignment": {
        "@type": "AlignmentObject",
        "alignmentType": "educationalSubject",
        "targetName": "Dating & Beziehungen"
      },
      "provider": {
        "@type": "Organization",
        "name": "Herzblatt Journal",
        "url": "https://herzblatt-journal.com"
      }
    }
    </script>
  </section>

