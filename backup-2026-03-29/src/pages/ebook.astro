---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Kostenloser Dating-Guide 2026 — Dein Weg zum erfolgreichen Dating";
const description = "Lade dir unseren kostenlosen Dating-Guide herunter: 50+ Seiten mit Expertentipps für Online-Dating, erstes Date, Beziehungsaufbau und mehr.";

const chapters = [
  { num: '01', title: 'Selbstkenntnis als Fundament', desc: 'Lerne dich selbst kennen, bevor du andere kennenlernen willst. Bindungsstile, Werte und was du wirklich suchst.' },
  { num: '02', title: 'Dein Online-Dating Profil', desc: 'So erstellst du ein Profil, das authentisch ist und die richtigen Menschen anzieht. Mit Foto-Tipps und Bio-Vorlagen.' },
  { num: '03', title: 'Die erste Nachricht', desc: 'Schluss mit "Hey". Kreative Opener, die wirklich Antworten bekommen — mit 20 Beispielen.' },
  { num: '04', title: 'Vom Chat zum Date', desc: 'Wann ist der richtige Zeitpunkt? Wie fragst du nach einem Treffen, ohne zu pushy zu wirken?' },
  { num: '05', title: 'Das perfekte erste Date', desc: 'Location, Gesprächsthemen, Körpersprache — alles was du wissen musst, um entspannt zu bleiben.' },
  { num: '06', title: 'Red Flags & Green Flags', desc: 'Woran erkennst du toxische Muster frühzeitig? Und welche Zeichen sprechen für eine gesunde Verbindung?' },
  { num: '07', title: 'Nach dem Date', desc: 'Follow-up Nachrichten, zweites Date planen, und wie du mit Ghosting umgehst.' },
  { num: '08', title: 'Beziehung aufbauen', desc: 'Von den ersten Wochen zur festen Beziehung: Kommunikation, Vertrauen und gemeinsames Wachstum.' },
];

const benefits = [
  '50+ Seiten Expertenwissen',
  '20 Nachrichtenvorlagen zum Kopieren',
  'Checklisten für jede Dating-Phase',
  'Übungen zur Selbstreflexion',
  'Bonus: Red-Flag Spickzettel',
];
---

<BaseLayout title={title} description={description}>
  <!-- Hero -->
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, var(--color-primary-50) 0%, var(--bg) 100%);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-16 sm:py-24">
      <div class="grid md:grid-cols-2 gap-12 items-center">
        <div>
          <span class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-6" style="background: var(--color-primary-100); color: var(--color-primary-700);">
            Kostenloser Download
          </span>
          <h1 class="text-3xl sm:text-4xl lg:text-5xl font-extrabold leading-tight mb-6" style="color: var(--text); font-family: var(--font-serif); letter-spacing: -0.02em;">
            Der ultimative<br/>
            <span style="color: var(--color-primary-600);">Dating-Guide 2026</span>
          </h1>
          <p class="text-lg leading-relaxed mb-8" style="color: var(--text-muted);">
            Alles, was du über modernes Dating wissen musst — von der ersten Nachricht bis zur festen Beziehung. Geschrieben von Dating-Experten, basierend auf aktueller Forschung.
          </p>
          <div class="space-y-3 mb-8">
            {benefits.map(b => (
              <div class="flex items-center gap-3">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-500)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 6 9 17l-5-5"/></svg>
                <span class="text-sm font-medium" style="color: var(--text);">{b}</span>
              </div>
            ))}
          </div>
          <a href="#download" class="inline-flex items-center gap-2 px-8 py-4 rounded-full text-base font-bold text-white transition-all hover:shadow-xl hover:-translate-y-1" style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-600));">
            Jetzt kostenlos herunterladen
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" x2="12" y1="15" y2="3"/></svg>
          </a>
        </div>
        <div class="relative">
          <div class="rounded-2xl p-8 shadow-2xl" style="background: var(--bg-card); border: 1px solid var(--border);">
            <div class="aspect-[3/4] rounded-xl flex items-center justify-center" style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-700));">
              <div class="text-center text-white p-8">
                <div class="text-6xl mb-4">💕</div>
                <div class="text-2xl font-extrabold mb-2" style="font-family: var(--font-serif);">Dating-Guide</div>
                <div class="text-sm opacity-80">Herzblatt Journal · 2026</div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Chapters -->
  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-16">
    <div class="text-center mb-12">
      <h2 class="text-2xl sm:text-3xl font-extrabold mb-4" style="color: var(--text); font-family: var(--font-serif);">Was dich erwartet</h2>
      <p class="text-base" style="color: var(--text-muted);">8 Kapitel voller praktischer Tipps und Strategien</p>
    </div>
    <div class="space-y-4">
      {chapters.map(ch => (
        <div class="flex gap-5 p-5 rounded-xl transition-all hover:-translate-y-px" style="background: var(--bg-card); border: 1px solid var(--border);">
          <div class="shrink-0 w-12 h-12 rounded-xl flex items-center justify-center text-sm font-extrabold" style="background: var(--color-primary-50); color: var(--color-primary-600);">
            {ch.num}
          </div>
          <div>
            <h3 class="text-base font-bold mb-1" style="color: var(--text);">{ch.title}</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">{ch.desc}</p>
          </div>
        </div>
      ))}
    </div>
  </section>

  <!-- Download CTA -->
  <section id="download" class="max-w-2xl mx-auto px-4 sm:px-6 py-16">
    <div class="rounded-2xl p-8 sm:p-12 text-center" style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-700));">
      <h2 class="text-2xl sm:text-3xl font-extrabold text-white mb-4" style="font-family: var(--font-serif);">Bereit für besseres Dating?</h2>
      <p class="text-base text-white/80 mb-8">Trag deine E-Mail ein und erhalte den Guide sofort kostenlos.</p>
      <form id="ebook-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
        <input type="email" placeholder="Deine E-Mail-Adresse" required class="flex-1 px-5 py-3.5 rounded-full text-sm border-0 outline-none" style="background: white; color: #1e293b;"/>
        <button type="submit" class="px-6 py-3.5 rounded-full text-sm font-bold text-white transition-all hover:shadow-lg" style="background: #1e293b;">
          Herunterladen
        </button>
      </form>
      <p class="text-xs text-white/60 mt-4">Kein Spam. Du kannst dich jederzeit abmelden.</p>
    </div>
  </section>
</BaseLayout>

<script>
  const form = document.getElementById('ebook-form') as HTMLFormElement;
  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const input = form.querySelector('input[type="email"]') as HTMLInputElement;
    const btn = form.querySelector('button') as HTMLButtonElement;
    const email = input?.value;
    if (!email) return;
    btn.textContent = '...';
    btn.disabled = true;
    try {
      const res = await fetch('/api/newsletter', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email }),
      });
      const data = await res.json();
      if (data.success) {
        btn.textContent = 'Gesendet!';
        btn.style.background = '#22c55e';
        btn.style.color = 'white';
        input.value = '';
      } else {
        btn.textContent = data.message;
        btn.disabled = false;
      }
    } catch {
      btn.textContent = 'Fehler';
      btn.disabled = false;
    }
  });
</script>
