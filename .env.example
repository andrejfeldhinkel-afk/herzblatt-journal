# Herzblatt Journal — Environment Variables
# Kopiere diese Datei nach .env und fülle die Werte aus.
# Auf Railway: Projekt → Variables → Alle hier aufgelisteten Keys setzen.

# ── Herzraum Admin-Dashboard ────────────────────────────────
# Passwort für das /herzraum Admin-Dashboard.
# Erzeugung: openssl rand -base64 24 (oder beliebiges sicheres Passwort)
# Mindestlänge: 8 Zeichen (wird im Code geprüft, sonst ist der Login deaktiviert).
HERZRAUM_PASSWORD=

# ── IP-Salt ─────────────────────────────────────────────────
# Für SHA-256(ip + salt) bei Newsletter, Rate-Limit, Login-Attempts.
# Erzeugung: openssl rand -hex 16
IP_SALT=

# ── Admin-CSV-Download (Newsletter-Pull-Script) ─────────────
# Getrennt vom Herzraum-Passwort, wird von scripts/pull-subscribers.sh
# via Bearer-Token verwendet. Mindestens 20 Zeichen.
# Erzeugung: openssl rand -hex 32
ADMIN_TOKEN=

# ── External APIs ───────────────────────────────────────────
REGISTER_API_URL=https://be.xloves.com/api/auth/register
