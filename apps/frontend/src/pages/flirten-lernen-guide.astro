---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import AppCTA from '../components/AppCTA.astro';
import { getCollection } from 'astro:content';

const title = 'Flirten lernen 2026: Komplett-Guide vom Ansprechen bis Date';
const description = 'Flirten lernen leicht gemacht: Körpersprache, Gesprächsstarter, Anmachsprüche die funktionieren und vom Match zum echten Date — dein Flirt-Guide.';
const keywords = ['flirten lernen', 'flirt tipps', 'ansprechen', 'kennenlernen', 'körpersprache flirten', 'dating tipps', 'gesprächsstarter'];

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => (b.data.date?.valueOf?.() || 0) - (a.data.date?.valueOf?.() || 0));

function getPostsByTags(tags: string[]) {
  const tagSet = new Set(tags.map(t => t.toLowerCase()));
  return allPosts
    .filter(p => p.data.tags.some((t: string) => tagSet.has(t.toLowerCase())))
    .slice(0, 6);
}

function getReadingTime(body: string) {
  return `${Math.ceil(body.split(/\s+/).length / 200)} Min. Lesezeit`;
}

const sections = [
  {
    id: 'grundlagen',
    emoji: '🎯',
    title: 'Die Grundlagen des Flirtens',
    description: 'Bevor du jemanden ansprichst, ist Selbstbewusstsein der Schlüssel. Verstehe die Psychologie hinter Anziehung und warum echtes Interesse attraktiver ist als jeder Trick.',
    tags: ['flirten', 'selbstbewusstsein', 'persönlichkeitsentwicklung', 'dating'],
  },
  {
    id: 'koerpersprache',
    emoji: '👀',
    title: 'Körpersprache & Signale',
    description: 'Über 90% der Kommunikation ist nonverbal. Lerne, die Signale deines Gegenübers zu lesen — und die richtigen selbst zu senden.',
    tags: ['körpersprache', 'flirten', 'signale', 'ausstrahlung'],
  },
  {
    id: 'ansprechen',
    emoji: '💬',
    title: 'Ansprechen & Gesprächsstarter',
    description: 'Der erste Schritt ist der schwierigste. Hier findest du bewährte Gesprächseinstiege für jede Situation — von der Bar bis zum Supermarkt.',
    tags: ['kennenlernen', 'flirten', 'ansprechen', 'dating-tipps'],
  },
  {
    id: 'online-flirten',
    emoji: '📱',
    title: 'Online-Flirten & Dating-Apps',
    description: 'Das perfekte Profil, die erste Nachricht, vom Chat zum Treffen. Alles über erfolgreiches Online-Dating in der App-Welt.',
    tags: ['online-dating', 'dating-apps', 'profil', 'erste nachricht'],
  },
  {
    id: 'erstes-date',
    emoji: '☕',
    title: 'Das erste Date meistern',
    description: 'Nervös? Muss nicht sein! Lerne alles über Vorbereitung, Gesprächsthemen, die richtige Location und den perfekten Abschluss.',
    tags: ['erstes date', 'date-ideen', 'kennenlernen', 'dating-tipps'],
  },
  {
    id: 'fuer-introvertierte',
    emoji: '🌙',
    title: 'Flirten für Introvertierte',
    description: 'Du musst kein Partylöwe sein, um zu flirten. Introvertierte haben besondere Stärken beim Dating — lerne, sie zu nutzen.',
    tags: ['introvertiert', 'selbstbewusstsein', 'schüchternheit', 'angst'],
  },
];

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Flirten lernen', url: '/flirten-lernen-guide' },
];
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  breadcrumbs={breadcrumbs}
  faq={[
    { question: 'Kann man Flirten wirklich lernen?', answer: 'Ja! Flirten ist eine soziale Fähigkeit wie jede andere. Es geht nicht um auswendig gelernte Sprüche, sondern um echtes Interesse, aktives Zuhören und authentische Kommunikation. Mit Übung wird es natürlicher und entspannter.' },
    { question: 'Was sind die besten Flirt-Tipps für Anfänger?', answer: 'Augenkontakt halten, lächeln, offene Körpersprache zeigen, echte Fragen stellen und aktiv zuhören. Der wichtigste Tipp: Sei du selbst und zeige echtes Interesse an deinem Gegenüber statt Tricks anzuwenden.' },
    { question: 'Wie erkenne ich, ob jemand mit mir flirtet?', answer: 'Typische Flirtsignale sind: häufiger Augenkontakt, Lächeln, die Person lehnt sich zu dir, berührt dich leicht, spielt mit den Haaren, stellt persönliche Fragen und lacht über deine Witze — auch wenn sie nicht besonders lustig sind.' },
    { question: 'Was soll ich als Erstes sagen, wenn ich jemanden anspreche?', answer: 'Die besten Gesprächsstarter sind situationsbezogen und authentisch. Kommentiere etwas aus der Umgebung, stelle eine ehrliche Frage oder mache ein spezifisches Kompliment. Vermeide auswendig gelernte Anmachsprüche — sie wirken meist unnatürlich.' },
  ]}
>
  <!-- Hero -->
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, #9f1239 0%, #be185d 40%, #e11d48 80%, #f43f5e 100%);">
    <div class="absolute inset-0" style="background: radial-gradient(circle at 20% 30%, rgba(255,255,255,0.12) 0%, transparent 50%);"></div>
    <div class="absolute inset-0" style="background: radial-gradient(circle at 80% 70%, rgba(255,255,255,0.08) 0%, transparent 50%);"></div>
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-16 sm:py-24 text-center relative">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold mb-6" style="background: rgba(255,255,255,0.15); color: white; border: 1px solid rgba(255,255,255,0.2); backdrop-filter: blur(8px);">
        ✨ Vom Anfänger zum Flirt-Profi · Wissenschaftlich fundiert
      </div>
      <h1 class="text-3xl sm:text-5xl lg:text-6xl font-extrabold text-white mb-6" style="font-family: var(--font-serif); letter-spacing: -0.02em; text-shadow: 0 2px 20px rgba(0,0,0,0.2);">
        Flirten lernen:<br/>Der komplette Guide
      </h1>
      <p class="text-lg sm:text-xl max-w-2xl mx-auto mb-8" style="color: rgba(255,255,255,0.9);">
        Alles was du brauchst — von der Körpersprache über Gesprächsstarter bis zum erfolgreichen ersten Date.
      </p>

      <div class="flex flex-wrap justify-center gap-2">
        {sections.map(s => (
          <a href={`#${s.id}`} class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium transition-all hover:-translate-y-0.5" style="background: rgba(255,255,255,0.15); color: white; border: 1px solid rgba(255,255,255,0.2); backdrop-filter: blur(8px);">
            <span>{s.emoji}</span> {s.title.split(' ')[0]}
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Die 7 Flirt-Regeln -->
  <section style="background: var(--bg-soft); border-bottom: 1px solid var(--border); padding: 4rem 1rem;">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-semibold mb-4" style="background: var(--color-primary-50); color: var(--color-primary-700);">
          💎 Die Fundamente
        </div>
        <h2 class="text-2xl sm:text-3xl font-extrabold mb-3" style="color: var(--text); font-family: var(--font-serif);">Die 7 Flirt-Regeln, die wirklich funktionieren</h2>
        <p class="text-base max-w-2xl mx-auto" style="color: var(--text-muted);">Bevor du Techniken lernst, brauchst du die Fundamente. Diese 7 Regeln machen den Unterschied zwischen Manipulation und echter Anziehung.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4">
        <div class="rounded-2xl p-6" style="background: var(--bg-card); border: 1px solid var(--border);">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-full mb-3 text-sm font-bold" style="background: var(--color-primary-100); color: var(--color-primary-700);">1</div>
          <h3 class="font-bold mb-2" style="color: var(--text);">Authentisch sein</h3>
          <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Keine Pick-Up-Sprüche, keine aufgesetzte Rolle. Die attraktivste Version deiner selbst ist immer die echte Version.</p>
        </div>
        <div class="rounded-2xl p-6" style="background: var(--bg-card); border: 1px solid var(--border);">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-full mb-3 text-sm font-bold" style="background: var(--color-primary-100); color: var(--color-primary-700);">2</div>
          <h3 class="font-bold mb-2" style="color: var(--text);">Echtes Interesse zeigen</h3>
          <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Fragen stellen, zuhören, nachhaken. Menschen spüren sofort, ob du wirklich neugierig bist oder nur performierst.</p>
        </div>
        <div class="rounded-2xl p-6" style="background: var(--bg-card); border: 1px solid var(--border);">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-full mb-3 text-sm font-bold" style="background: var(--color-primary-100); color: var(--color-primary-700);">3</div>
          <h3 class="font-bold mb-2" style="color: var(--text);">Augenkontakt halten</h3>
          <p class="text-sm leading-relaxed" style="color: var(--text-muted);">2-3 Sekunden länger als gewohnt. Augenkontakt ist das stärkste nonverbale Signal und signalisiert Selbstbewusstsein.</p>
        </div>
        <div class="rounded-2xl p-6" style="background: var(--bg-card); border: 1px solid var(--border);">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-full mb-3 text-sm font-bold" style="background: var(--color-primary-100); color: var(--color-primary-700);">4</div>
          <h3 class="font-bold mb-2" style="color: var(--text);">Grenzen respektieren</h3>
          <p class="text-sm leading-relaxed" style="color: var(--text-muted);">"Nein" heißt Nein. Nicht drängen, nicht überreden, nicht nachhaken. Respekt ist sexier als jede Technik.</p>
        </div>
        <div class="rounded-2xl p-6" style="background: var(--bg-card); border: 1px solid var(--border);">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-full mb-3 text-sm font-bold" style="background: var(--color-primary-100); color: var(--color-primary-700);">5</div>
          <h3 class="font-bold mb-2" style="color: var(--text);">Humor statt Witze</h3>
          <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Auswendig gelernte Sprüche fallen sofort auf. Echter Humor ist situativ, spielerisch und selbstironisch.</p>
        </div>
        <div class="rounded-2xl p-6" style="background: var(--bg-card); border: 1px solid var(--border);">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-full mb-3 text-sm font-bold" style="background: var(--color-primary-100); color: var(--color-primary-700);">6</div>
          <h3 class="font-bold mb-2" style="color: var(--text);">Präsent sein</h3>
          <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Handy weg. Voll im Moment. Wer mit seiner Aufmerksamkeit bei der Person ist, wirkt zehnmal attraktiver als jemand der abgelenkt scrollt.</p>
        </div>
        <div class="rounded-2xl p-6" style="background: var(--bg-card); border: 1px solid var(--border);">
          <div class="inline-flex items-center justify-center w-10 h-10 rounded-full mb-3 text-sm font-bold" style="background: var(--color-primary-100); color: var(--color-primary-700);">7</div>
          <h3 class="font-bold mb-2" style="color: var(--text);">Kein Outcome-Attachment</h3>
          <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Flirten ohne das Ziel, unbedingt die Nummer zu bekommen. Je entspannter du bist, desto mehr funktioniert es — paradoxerweise.</p>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16">
    {sections.map((section, idx) => {
      const posts = getPostsByTags(section.tags);
      return (
        <section id={section.id} class="mb-16 scroll-mt-24">
          <div class="flex items-start gap-4 mb-8">
            <div class="shrink-0 w-12 h-12 rounded-2xl flex items-center justify-center text-2xl" style="background: var(--color-primary-50); border: 1px solid var(--color-primary-100);">
              {section.emoji}
            </div>
            <div>
              <h2 class="text-2xl font-extrabold mb-2" style="color: var(--text); font-family: var(--font-serif);">{section.title}</h2>
              <p class="text-sm" style="color: var(--text-muted);">{section.description}</p>
            </div>
          </div>
          <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
            {posts.slice(0, 6).map(p => (
              <BlogCard
                title={p.data.title}
                description={p.data.description}
                date={p.data.date}
                tags={p.data.tags}
                slug={p.id}
                readingTime={getReadingTime(p.body || '')}
                image={p.data.image}
                imageAlt={p.data.imageAlt}
              />
            ))}
          </div>
          {idx < sections.length - 1 && <hr class="mt-12" style="border-color: var(--border);" />}
        </section>
      );
    })}

    <AppCTA variant="inline" />

    <!-- Weiter lesen: Related Guides -->
    <section class="mt-16 pt-10" style="border-top: 1px solid var(--border);">
      <div class="text-center mb-10">
        <h2 class="text-2xl sm:text-3xl font-extrabold mb-3" style="color: var(--text); font-family: var(--font-serif);">Passende Guides für dich</h2>
        <p class="text-base" style="color: var(--text-muted);">Nach dem Flirten kommt meist das erste Date — hier sind die nächsten Schritte.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="/erstes-date-guide" class="group rounded-2xl p-6 transition-all hover:-translate-y-1 hover:shadow-lg" style="background: var(--bg-card); border: 1px solid var(--border); text-decoration: none; color: inherit;">
          <div class="text-3xl mb-3">💫</div>
          <h3 class="text-lg font-bold mb-2" style="color: var(--color-primary-600); font-family: var(--font-serif);">Erstes-Date-Guide</h3>
          <p class="text-sm" style="color: var(--text-muted);">Vom Flirten zum unvergesslichen ersten Treffen.</p>
        </a>
        <a href="/date-ideen" class="group rounded-2xl p-6 transition-all hover:-translate-y-1 hover:shadow-lg" style="background: var(--bg-card); border: 1px solid var(--border); text-decoration: none; color: inherit;">
          <div class="text-3xl mb-3">🎯</div>
          <h3 class="text-lg font-bold mb-2" style="color: var(--color-primary-600); font-family: var(--font-serif);">100+ Date-Ideen</h3>
          <p class="text-sm" style="color: var(--text-muted);">Was unternehmen beim ersten Date? Hier findest du Inspiration.</p>
        </a>
        <a href="/dating-typ-test" class="group rounded-2xl p-6 transition-all hover:-translate-y-1 hover:shadow-lg" style="background: var(--bg-card); border: 1px solid var(--border); text-decoration: none; color: inherit;">
          <div class="text-3xl mb-3">🧩</div>
          <h3 class="text-lg font-bold mb-2" style="color: var(--color-primary-600); font-family: var(--font-serif);">Dating-Typ Test</h3>
          <p class="text-sm" style="color: var(--text-muted);">Welcher der 6 Dating-Typen bist du? 2-Min-Test.</p>
        </a>
        <a href="/online-dating-guide" class="group rounded-2xl p-6 transition-all hover:-translate-y-1 hover:shadow-lg" style="background: var(--bg-card); border: 1px solid var(--border); text-decoration: none; color: inherit;">
          <div class="text-3xl mb-3">📱</div>
          <h3 class="text-lg font-bold mb-2" style="color: var(--color-primary-600); font-family: var(--font-serif);">Online-Dating</h3>
          <p class="text-sm" style="color: var(--text-muted);">Flirten per App: Profil, Bio, erste Nachricht perfekt machen.</p>
        </a>
        <a href="/bindungsstile" class="group rounded-2xl p-6 transition-all hover:-translate-y-1 hover:shadow-lg" style="background: var(--bg-card); border: 1px solid var(--border); text-decoration: none; color: inherit;">
          <div class="text-3xl mb-3">🧬</div>
          <h3 class="text-lg font-bold mb-2" style="color: var(--color-primary-600); font-family: var(--font-serif);">Bindungsstile verstehen</h3>
          <p class="text-sm" style="color: var(--text-muted);">Warum flirtest du, wie du flirst? Die Psychologie dahinter.</p>
        </a>
        <a href="/red-flags" class="group rounded-2xl p-6 transition-all hover:-translate-y-1 hover:shadow-lg" style="background: var(--bg-card); border: 1px solid var(--border); text-decoration: none; color: inherit;">
          <div class="text-3xl mb-3">🚩</div>
          <h3 class="text-lg font-bold mb-2" style="color: var(--color-primary-600); font-family: var(--font-serif);">Red Flags erkennen</h3>
          <p class="text-sm" style="color: var(--text-muted);">Warnsignale beim Flirten früh erkennen und dich schützen.</p>
        </a>
      </div>
    </section>

    <!-- Link to city pages -->
    <section class="mt-16 pt-10" style="border-top: 1px solid var(--border);">
      <h2 class="text-xl font-bold mb-4" style="color: var(--text); font-family: var(--font-serif);">Flirten & Dating in deiner Stadt</h2>
      <div class="flex flex-wrap gap-2">
        {['Berlin', 'München', 'Hamburg', 'Köln', 'Frankfurt', 'Stuttgart', 'Düsseldorf', 'Leipzig', 'Dresden', 'Nürnberg', 'Freiburg', 'Münster'].map(city => (
          <a href={`/dating-in/${city.toLowerCase().replace('ü', 'ue')}`} class="text-xs font-medium px-3 py-1.5 rounded-full transition-all hover:-translate-y-0.5" style="background: var(--bg-soft); color: var(--text-muted); border: 1px solid var(--border);">
            Dating in {city}
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
