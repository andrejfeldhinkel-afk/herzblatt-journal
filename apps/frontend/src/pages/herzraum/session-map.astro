// ─── 1. Node-Depth-Assignment (near/mid/far) für 3D-Parallax ──────────
(function setupDepth() {
  document.querySelectorAll('.node').forEach((el, i) => {
    const n = NODES[i];
    // Main in center = mid; type "artifact" (PRs) = near; agents = far
    let depth = 'mid';
    if (n.type === 'artifact') depth = 'near';
    else if (n.type === 'general' || n.type === 'specialist' || n.type === 'infra') depth = 'far';
    el.setAttribute('data-depth', depth);
  });
})();

// ─── 2. 3D-Parallax via Mouse-Move ────────────────────────────────────
(function setupParallax() {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  const stage = document.getElementById('stage');
  const parallax = document.getElementById('parallax');
  if (!stage || !parallax) return;
  let targetX = 0, targetY = 0, currentX = 0, currentY = 0;
  stage.addEventListener('mousemove', (e) => {
    const rect = stage.getBoundingClientRect();
    const nx = (e.clientX - rect.left) / rect.width - 0.5;
    const ny = (e.clientY - rect.top) / rect.height - 0.5;
    targetX = nx * 40;
    targetY = ny * 28;
    parallax.style.setProperty('--par-rx', (nx * 6) + 'deg');
    parallax.style.setProperty('--par-ry', (-ny * 4) + 'deg');
  });
  stage.addEventListener('mouseleave', () => {
    targetX = 0; targetY = 0;
    parallax.style.setProperty('--par-rx', '0deg');
    parallax.style.setProperty('--par-ry', '0deg');
  });
  function smoothParallax() {
    currentX += (targetX - currentX) * 0.08;
    currentY += (targetY - currentY) * 0.08;
    parallax.style.setProperty('--par-x', currentX.toFixed(1) + 'px');
    parallax.style.setProperty('--par-y', currentY.toFixed(1) + 'px');
    requestAnimationFrame(smoothParallax);
  }
  requestAnimationFrame(smoothParallax);
})();

// ─── 3. Focus-Mode on Node-Click (ersetzt Deep-Dive-Only-Tooltip) ──
(function setupFocusMode() {
  const stage = document.getElementById('stage');
  if (!stage) return;

  const nodeEls = {};
  document.querySelectorAll('.node').forEach((el, i) => { nodeEls[NODES[i].id] = el; });

  function enterFocus(nodeId) {
    stage.classList.add('focus-mode');
    // Clear previous focus
    Object.values(nodeEls).forEach(el => el.classList.remove('focused'));
    // Mark focused node
    if (nodeEls[nodeId]) nodeEls[nodeId].classList.add('focused');
    // Mark connected edges
    document.querySelectorAll('.edge, .edge-curve').forEach(edge => {
      edge.classList.remove('connected');
    });
    const edgeEls = Array.from(document.querySelectorAll('.edge'));
    EDGES.forEach((e, i) => {
      if (e.s === nodeId || e.t === nodeId) {
        const eEl = edgeEls[i];
        if (eEl) eEl.classList.add('connected');
      }
    });
  }
  function exitFocus() {
    stage.classList.remove('focus-mode');
    Object.values(nodeEls).forEach(el => el.classList.remove('focused'));
    document.querySelectorAll('.edge').forEach(edge => edge.classList.remove('connected'));
  }

  document.querySelectorAll('.node').forEach((el, i) => {
    const n = NODES[i];
    el.addEventListener('click', (ev) => {
      ev.stopPropagation();
      if (stage.classList.contains('focus-mode') && el.classList.contains('focused')) {
        exitFocus();
      } else {
        enterFocus(n.id);
      }
    });
  });
  // Klick auf Hintergrund = exit
  stage.addEventListener('click', (e) => {
    if (!e.target.closest('.node')) exitFocus();
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') exitFocus();
  });
})();

