---
export const prerender = false;
import HerzraumLayout from '../../layouts/HerzraumLayout.astro';
---
<HerzraumLayout title="Session-Map" active="session-map" fullscreen>
<style is:global>
  :root {
    --fg: #f3f4f8;
    --muted: #7a7d8f;
    --muted-2: #a5a7b8;
    --line: rgba(255,255,255,.09);
    --rose: #ff3868;
    --magenta: #ec4899;
    --cyan: #22d3ee;
    --violet: #a78bfa;
    --amber: #fbbf24;
    --green: #22c55e;
    --green-2: #10b981;
    --panel: rgba(10,8,24,.82);
    --panel-border: rgba(255,255,255,.08);
  }
  * { box-sizing: border-box; -webkit-font-smoothing: antialiased; }
  html, body { margin:0; padding:0; height:100%; overflow:hidden;
    background: radial-gradient(ellipse at 20% 30%, rgba(139,92,246,.15) 0%, transparent 50%),
                radial-gradient(ellipse at 80% 70%, rgba(244,63,94,.10) 0%, transparent 50%),
                radial-gradient(ellipse at 50% 50%, rgba(34,211,238,.05) 0%, transparent 60%),
                linear-gradient(180deg, #04040c 0%, #0a0818 100%);
    color: var(--fg);
    font-family: 'SF Pro Display', -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif; }

  .stars { position: fixed; inset: 0; pointer-events: none; opacity: 0.22; z-index: 0;
    background-image:
      radial-gradient(1px 1px at 20% 30%, white, transparent),
      radial-gradient(1px 1px at 60% 70%, white, transparent),
      radial-gradient(1px 1px at 50% 50%, white, transparent),
      radial-gradient(2px 2px at 30% 80%, white, transparent),
      radial-gradient(1px 1px at 80% 10%, white, transparent),
      radial-gradient(1px 1px at 90% 60%, white, transparent),
      radial-gradient(1px 1px at 40% 40%, white, transparent),
      radial-gradient(2px 2px at 70% 20%, white, transparent);
    background-repeat: repeat; background-size: 250px 250px;
    animation: starDrift 120s linear infinite; }
  @keyframes starDrift { to { background-position: 1000px 500px,800px 400px,600px 300px,900px 450px,700px 350px,500px 250px,400px 200px,300px 150px; } }

  /* ── Header ── */
  .sm-header { position: fixed; top: 0; left: 0; right: 0; height: 56px; padding: 0 20px;
    display: flex; align-items: center; gap: 18px; z-index: 20;
    background: linear-gradient(180deg, rgba(4,4,12,.95), rgba(4,4,12,.6));
    border-bottom: 1px solid var(--line); }
  .brand { font-size: 11px; color: var(--muted); text-transform: uppercase; letter-spacing: .2em;
    font-weight: 600; display: inline-flex; align-items: center; gap: 10px; }
  .brand-dot { width: 8px; height: 8px; border-radius: 50%; background: var(--rose);
    box-shadow: 0 0 16px var(--rose); animation: pulse 2s infinite; }
  @keyframes pulse { 50%{opacity:.6;transform:scale(1.2)} }
  .sm-header h1 { margin: 0; font-size: 18px; font-weight: 800; letter-spacing: -.03em;
    background: linear-gradient(90deg, #ff3868, #ec4899 35%, #a78bfa 65%, #22d3ee);
    background-size: 200% auto; -webkit-background-clip: text; background-clip: text; color: transparent;
    animation: titleShift 8s linear infinite; }
  @keyframes titleShift { to { background-position: 200% center; } }
  .sub { font-size: 11px; color: var(--muted-2); }
  .status-live { margin-left: auto; font-size: 11px; color: var(--green); font-weight: 600;
    display: inline-flex; align-items: center; gap: 6px; }
  .status-live::before { content:''; width:6px; height:6px; border-radius:50%; background: var(--green);
    box-shadow: 0 0 10px var(--green); }

  /* ── Stage + Layers ── */
  .sm-stage { position: fixed; top: 56px; left: 0; right: 0; bottom: 84px;
    z-index: 1; overflow: hidden; cursor: grab; }
  .sm-stage:active { cursor: grabbing; }
  .sm-stage.dragging-node { cursor: grabbing; }

  .sm-viewport { position: absolute; inset: 0;
    transform-origin: center center;
    transition: transform .12s cubic-bezier(.25,.8,.25,1); }

  .sm-svg { position: absolute; inset: 0; width: 100%; height: 100%; pointer-events: none; }
  .edge { stroke: rgba(255,255,255,.12); stroke-width: 1; fill: none;
    transition: stroke .3s, stroke-width .3s, stroke-opacity .3s; }
  .edge.thin { stroke-width: 0.8; stroke: rgba(255,255,255,.06); }
  .edge.connected { stroke: var(--rose); stroke-width: 2; stroke-opacity: 1;
    filter: drop-shadow(0 0 6px var(--rose)); }
  .edge.time-hidden, .node.time-hidden { opacity: 0; pointer-events: none; }

  /* ── Panels (Glass) ── */
  .panel { position: fixed; padding: 16px 18px; background: var(--panel);
    backdrop-filter: blur(24px) saturate(140%); -webkit-backdrop-filter: blur(24px) saturate(140%);
    border: 1px solid var(--panel-border); border-radius: 14px;
    box-shadow: 0 12px 48px rgba(0,0,0,.6), inset 0 1px 0 rgba(255,255,255,.05); z-index: 10; }
  .panel h3 { margin: 0 0 10px; font-size: 11px; color: var(--rose); text-transform: uppercase;
    letter-spacing: .15em; font-weight: 700; }
  #legend { top: 76px; left: 20px; width: 220px; font-size: 11.5px; }
  #stats { top: 76px; right: 20px; width: 280px; }
  #activity { bottom: 104px; left: 20px; width: 380px; max-height: 240px; overflow-y: auto; font-size: 11px; }
  #detail-panel { top: 76px; right: 20px; width: 340px; display: none; z-index: 30; }
  #detail-panel.open { display: block; }

  .leg-row { display: flex; align-items: center; gap: 10px; margin: 5px 0; color: var(--muted); }
  .leg-row b { color: var(--fg); font-weight: 500; }
  .leg-dot { width: 11px; height: 11px; border-radius: 50%; flex-shrink: 0;
    box-shadow: 0 0 12px currentColor; }
  .leg-note { margin-top: 12px; padding-top: 10px; border-top: 1px solid var(--line);
    font-size: 10.5px; color: var(--muted); line-height: 1.5; }

  .stat-row { display: flex; justify-content: space-between; align-items: center; margin: 5px 0;
    color: var(--muted); font-size: 12px; }
  .stat-row b { color: var(--fg); font-weight: 600; font-variant-numeric: tabular-nums; }
  .stat-big { display: flex; align-items: baseline; gap: 6px; font-size: 26px; font-weight: 800;
    letter-spacing: -.02em; }
  .stat-big small { font-size: 10px; color: var(--muted); text-transform: uppercase; letter-spacing: .15em; }
  .stat-divider { height: 1px; background: var(--line); margin: 12px 0; }

  .log-row { display: flex; gap: 10px; align-items: baseline; padding: 4px 0;
    border-bottom: 1px dashed rgba(255,255,255,.04); }
  .log-row:last-child { border: none; }
  .log-time { color: var(--cyan); font-size: 10px; font-variant-numeric: tabular-nums; flex-shrink: 0; }
  .log-cat { font-size: 9px; padding: 1px 6px; border-radius: 3px; text-transform: uppercase;
    letter-spacing: .1em; font-weight: 700; flex-shrink: 0; }
  .log-cat.pr { background: rgba(34,197,94,.15); color: var(--green); }
  .log-cat.sec { background: rgba(255,56,104,.15); color: var(--rose); }
  .log-cat.deploy { background: rgba(251,191,36,.15); color: var(--amber); }
  .log-text { flex: 1; color: var(--muted-2); line-height: 1.4; font-size: 11px; }

  /* ── Nodes ── */
  .node { position: absolute; left: 0; top: 0; transform: translate(-50%, -50%);
    display: flex; flex-direction: column; align-items: center; gap: 6px;
    text-align: center; cursor: grab; z-index: 3; user-select: none;
    transition: filter .25s ease, opacity .25s ease; }
  .node:active { cursor: grabbing; }
  .node[data-id="main"] { cursor: default; }
  .node .circle { border-radius: 50%; background: currentColor;
    border: 2px solid rgba(255,255,255,.15);
    transition: transform .18s cubic-bezier(.25,.8,.25,1), box-shadow .18s; }
  .node.done .circle { box-shadow: 0 0 12px currentColor; }
  .node:hover .circle {
    transform: scale(1.22);
    box-shadow: 0 0 24px currentColor, 0 0 48px currentColor;
  }
  .node[data-id="main"] .circle {
    animation: pulseMain 2.4s ease-in-out infinite;
  }
  @keyframes pulseMain {
    0%,100% { box-shadow: 0 0 16px currentColor, 0 0 32px currentColor; }
    50% { box-shadow: 0 0 28px currentColor, 0 0 64px currentColor; }
  }
  .node .label { font-size: 11px; font-weight: 600; color: var(--fg);
    text-shadow: 0 2px 6px rgba(0,0,0,.9); max-width: 140px; line-height: 1.2;
    pointer-events: none; }
  .node .node-sub { font-size: 9px; color: var(--muted); text-transform: uppercase; letter-spacing: .05em;
    max-width: 140px; line-height: 1.3; pointer-events: none; }

  /* Agent cluster coloring — PRs get outer ring in origin-agent color */
  .node[data-origin-color] .circle {
    box-shadow: 0 0 0 2.5px var(--origin-color, transparent), 0 0 16px currentColor;
  }

  /* Focus-Mode: clicked node highlighted, others dim */
  .sm-stage.focus-mode .node:not(.focused) { opacity: 0.18; filter: saturate(0.4); }
  .sm-stage.focus-mode .node.focused .circle {
    transform: scale(1.4);
    box-shadow: 0 0 32px currentColor, 0 0 80px currentColor, 0 0 120px currentColor;
  }
  .sm-stage.focus-mode .edge { opacity: 0.08; }
  .sm-stage.focus-mode .edge.connected {
    opacity: 1 !important; stroke-width: 2.5; stroke: var(--rose);
    filter: drop-shadow(0 0 6px var(--rose)) drop-shadow(0 0 12px var(--rose));
  }

  /* ── Detail-Panel ── */
  #detail-panel { padding: 20px 22px; }
  #detail-panel .dp-type { font-size: 10px; color: var(--rose); text-transform: uppercase;
    letter-spacing: .18em; font-weight: 700; margin-bottom: 10px; display: inline-flex;
    align-items: center; gap: 8px; }
  #detail-panel .dp-close { position: absolute; top: 12px; right: 12px;
    width: 26px; height: 26px; border-radius: 50%; border: 1px solid var(--line);
    background: transparent; color: var(--muted-2); cursor: pointer;
    font-size: 18px; line-height: 1; display: flex; align-items: center;
    justify-content: center; transition: all .15s; }
  #detail-panel .dp-close:hover { border-color: var(--rose); color: var(--rose); }
  #detail-panel h4 { margin: 0 0 4px; font-size: 18px; font-weight: 800; letter-spacing: -.02em; }
  #detail-panel .dp-sub { font-size: 11px; color: var(--muted-2); text-transform: uppercase;
    letter-spacing: .12em; margin-bottom: 14px; }
  #detail-panel .dp-desc { font-size: 13px; line-height: 1.55; color: var(--muted-2);
    padding-top: 14px; border-top: 1px solid var(--line); }
  #detail-panel .dp-impact { margin-top: 14px; padding: 12px 14px; border-radius: 10px;
    background: rgba(255,56,104,.08); border: 1px solid rgba(255,56,104,.2); }
  #detail-panel .dp-impact-label { font-size: 9px; color: var(--rose); text-transform: uppercase;
    letter-spacing: .14em; font-weight: 700; margin-bottom: 4px; }
  #detail-panel .dp-impact-metric { font-size: 14px; font-weight: 700; margin-bottom: 4px; }
  #detail-panel .dp-impact-cost { font-size: 11px; color: var(--muted-2); line-height: 1.5; }

  /* ── Bottom Scrubber ── */
  .sm-scrubber { position: fixed; bottom: 0; left: 0; right: 0; height: 84px; z-index: 25;
    padding: 14px 24px 16px;
    background: linear-gradient(180deg, transparent 0%, rgba(4,4,12,.85) 40%, rgba(4,4,12,.95) 100%);
    backdrop-filter: blur(20px) saturate(140%);
    border-top: 1px solid rgba(255,255,255,.08);
    display: flex; flex-direction: column; gap: 8px; }
  .scrubber-head { display: flex; align-items: center; gap: 14px;
    font-size: 10.5px; color: var(--muted-2); letter-spacing: .08em;
    text-transform: uppercase; font-weight: 600; }
  .scrubber-head .sc-label { color: var(--rose); font-weight: 700; letter-spacing: .16em; }
  .scrubber-head .sc-time {
    font-family: 'SF Mono', ui-monospace, Menlo, monospace;
    color: var(--cyan); font-size: 12px;
    text-shadow: 0 0 8px rgba(34,211,238,.5);
    font-variant-numeric: tabular-nums; letter-spacing: .03em; }
  .sc-btn { display: inline-flex; align-items: center; gap: 6px;
    padding: 4px 12px; font-size: 10.5px; font-weight: 700;
    color: var(--fg); background: rgba(255,56,104,.22);
    border: 1px solid rgba(255,56,104,.4);
    border-radius: 6px; cursor: pointer;
    transition: all .15s; text-transform: uppercase; letter-spacing: .1em;
    font-family: inherit; }
  .sc-btn:hover { background: rgba(255,56,104,.38); transform: translateY(-1px); }
  .sc-btn.secondary { background: rgba(255,255,255,.05); border-color: rgba(255,255,255,.12); }
  .sc-btn.secondary:hover { background: rgba(255,255,255,.1); }
  .sc-track { position: relative; height: 28px; display: flex; align-items: center; }
  .sc-ticks { position: absolute; inset: 0; pointer-events: none; }
  .sc-tick span { position: absolute; top: -2px; font-size: 9px;
    color: var(--muted); font-family: 'SF Mono', monospace; letter-spacing: .05em; white-space: nowrap; }
  .sc-range { -webkit-appearance: none; appearance: none;
    width: 100%; height: 4px;
    background: linear-gradient(90deg,
      var(--rose) 0%, var(--rose) var(--fill, 100%),
      rgba(255,255,255,.08) var(--fill, 100%), rgba(255,255,255,.08) 100%);
    border-radius: 4px; outline: none; cursor: pointer; position: relative; z-index: 2; }
  .sc-range::-webkit-slider-thumb {
    -webkit-appearance: none; width: 18px; height: 18px; border-radius: 50%;
    background: radial-gradient(circle at 35% 35%, #ff6b8a, var(--rose) 60%, var(--magenta));
    border: 2px solid #fff;
    box-shadow: 0 0 0 2px rgba(255,56,104,.3), 0 0 16px rgba(255,56,104,.6);
    cursor: grab; }
  .sc-markers { position: absolute; inset: 0; pointer-events: none; display: flex; align-items: center; }
  .sc-marker { position: absolute; width: 2px; height: 14px; background: #fff;
    border-radius: 1px; box-shadow: 0 0 10px #fff, 0 0 20px var(--rose);
    top: 50%; transform: translateY(-50%); }
  .sc-speed { display: inline-flex; gap: 2px; margin-left: 6px;
    background: rgba(15,15,30,.4); border: 1px solid rgba(255,255,255,.08);
    border-radius: 6px; padding: 2px; }
  .sc-speed-btn { padding: 3px 9px; font-size: 10px; font-weight: 700;
    color: var(--muted-2); background: transparent; border: 0; border-radius: 4px; cursor: pointer;
    font-family: 'SF Mono', monospace; transition: all .12s; }
  .sc-speed-btn:hover { color: var(--fg); background: rgba(255,255,255,.05); }
  .sc-speed-btn.active { color: var(--fg); background: rgba(34,211,238,.25);
    box-shadow: inset 0 0 0 1px rgba(34,211,238,.4); }

  /* ── Responsive ── */
  @media (max-width: 1100px) { #legend, #stats, #detail-panel { display: none; }
    #activity { width: calc(100vw - 40px); max-width: 380px; } }
  @media (max-width: 700px) { .sm-scrubber { display: none; } .sm-stage { bottom: 0; } }

  /* Reduce motion */
  @media (prefers-reduced-motion: reduce) {
    .stars { animation: none; } .sm-header h1 { animation: none; }
    .brand-dot { animation: none; } .node[data-id="main"] .circle { animation: none; }
  }
</style>

<div class="stars"></div>

<header class="sm-header">
  <span class="brand"><span class="brand-dot"></span>Herzblatt Journal · 38-PR Vollautomatik</span>
  <h1>Agent Session Map</h1>
  <span class="sub">~6 h · 10 Agents · 38 PRs · 6 CRITICAL</span>
  <span class="status-live">LIVE</span>
</header>

<aside id="legend" class="panel">
  <h3>Legende</h3>
  <div class="leg-row"><span class="leg-dot" style="color:#ff3868;background:#ff3868"></span><b>Coordinator</b></div>
  <div class="leg-row"><span class="leg-dot" style="color:#a78bfa;background:#a78bfa"></span><b>General Agent</b></div>
  <div class="leg-row"><span class="leg-dot" style="color:#22d3ee;background:#22d3ee"></span><b>Spezialist (gsd-*)</b></div>
  <div class="leg-row"><span class="leg-dot" style="color:#fbbf24;background:#fbbf24"></span><b>Infra / Browser</b></div>
  <div class="leg-row"><span class="leg-dot" style="color:#22c55e;background:#22c55e"></span><b>Artefakt (PR)</b></div>
  <div class="leg-row"><span class="leg-dot" style="color:#ff3868;background:#ff3868"></span><b>CRITICAL Fix</b></div>
  <div class="leg-note">Klick Node für Details · Drag = bewegen · Wheel = Zoom · BG-Drag = Pan</div>
</aside>

<aside id="stats" class="panel">
  <h3>Session-Ergebnis</h3>
  <div class="stat-big"><span>38</span><small>PRs ausgeliefert</small></div>
  <div class="stat-divider"></div>
  <div class="stat-row"><span>Agents koordiniert</span><b>10+</b></div>
  <div class="stat-row"><span>Audit-Phasen</span><b>7 / 9</b></div>
  <div class="stat-row"><span>Secrets rotiert</span><b>6</b></div>
  <div class="stat-row"><span>CRITICAL Fixes</span><b>6</b></div>
  <div class="stat-divider"></div>
  <div class="stat-row"><span>Ebook-Kapitel</span><b>15 / 15</b></div>
  <div class="stat-row"><span>Bonus-Materialien</span><b>5 / 5</b></div>
  <div class="stat-row"><span>Code-Zeilen geändert</span><b>~8.000</b></div>
  <div class="stat-row"><span>Content-Wörter</span><b>~73k</b></div>
  <div class="stat-row"><span>Prod-Outages</span><b style="color:#22c55e">0</b></div>
  <div class="stat-row"><span>Session-Dauer</span><b>~6 h</b></div>
</aside>

<aside id="detail-panel" class="panel">
  <button class="dp-close" id="dp-close" aria-label="Schließen">×</button>
  <div class="dp-type" id="dp-type"></div>
  <h4 id="dp-title"></h4>
  <div class="dp-sub" id="dp-sub"></div>
  <div class="dp-desc" id="dp-desc"></div>
  <div class="dp-impact" id="dp-impact" style="display:none">
    <div class="dp-impact-label">Impact</div>
    <div class="dp-impact-metric" id="dp-impact-metric"></div>
    <div class="dp-impact-cost" id="dp-impact-cost"></div>
  </div>
</aside>

<aside id="activity" class="panel">
  <h3>Activity Feed</h3>
  <div id="logList"></div>
</aside>

<div class="sm-stage" id="stage">
  <div class="sm-viewport" id="viewport">
    <svg class="sm-svg" id="edges" viewBox="0 0 1600 900" preserveAspectRatio="xMidYMid meet"></svg>
    <div id="nodes-layer"></div>
  </div>
</div>

<!-- Timeline Scrubber -->
<aside class="sm-scrubber" id="scrubber">
  <div class="scrubber-head">
    <span class="sc-label">Session Timeline</span>
    <button class="sc-btn" id="scPlay" aria-label="Abspielen">
      <span id="scPlayLabel">▶ Replay</span>
    </button>
    <button class="sc-btn secondary" id="scReset" aria-label="Reset-Layout">↻ Reset</button>
    <span class="sc-time" id="scTime">20:00</span>
    <span>·</span>
    <span><span id="scVisible">49</span> / <span id="scTotal">49</span> Nodes</span>
    <div class="sc-speed">
      <button class="sc-speed-btn" data-speed="0.5">0.5×</button>
      <button class="sc-speed-btn active" data-speed="1">1×</button>
      <button class="sc-speed-btn" data-speed="2">2×</button>
      <button class="sc-speed-btn" data-speed="4">4×</button>
    </div>
    <span style="margin-left:auto; font-size:10px; color:var(--muted);">Drag Node · Wheel = Zoom · Drag BG = Pan</span>
  </div>
  <div class="sc-track">
    <div class="sc-ticks" id="scTicks"></div>
    <div class="sc-markers" id="scMarkers"></div>
    <input type="range" class="sc-range" id="scRange" min="0" max="480" value="480" step="1">
  </div>
</aside>

<script is:inline>
// ═══════════════════════════════════════════════════════════════════════
// NODES · EDGES · IMPACT · TIMES · LOGS
// ═══════════════════════════════════════════════════════════════════════
const NODES = [
  { id:'main', x:800, y:450, r:28, color:'#ff3868', type:'coord', state:'done', label:'Main Agent', sub:'Coordinator · Opus 4.7', desc:'Koordinierte 10+ Sub-Agents, 38 PRs merged, 6 Secrets rotiert, Railway-Deploys getriggert.' },
  { id:'a-p1', x:380, y:230, r:16, color:'#a78bfa', type:'general', state:'done', label:'general-purpose', sub:'Phase 1 Inventar', desc:'23 Admin-Pages, 37 Backend-Routes, 15 DB-Tabellen kartografiert.' },
  { id:'a-p2', x:520, y:130, r:16, color:'#a78bfa', type:'general', state:'done', label:'general-purpose', sub:'Phase 2 Admin', desc:'2 CRITICAL XSS + data.clear-Reauth-Lücke entdeckt.' },
  { id:'a-p5', x:700, y:100, r:16, color:'#a78bfa', type:'general', state:'done', label:'general-purpose', sub:'Phase 5 DB', desc:'Retention-Gaps + UNIQUE-Missing + GDPR-Lücke erkannt.' },
  { id:'a-ebook', x:880, y:100, r:18, color:'#a78bfa', type:'general', state:'done', label:'general-purpose', sub:'Ebook-Writer · 12 Kapitel', desc:'Kapitel 04-15, ~31.250 Wörter.' },
  { id:'a-bonus', x:1050, y:130, r:18, color:'#a78bfa', type:'general', state:'done', label:'general-purpose', sub:'Bonus-Materialien · 5', desc:'Workbook + 30 Nachrichten + Red-Flags + Bindungstest (~14.900 W).' },
  { id:'a-delivery', x:1200, y:220, r:18, color:'#a78bfa', type:'general', state:'done', label:'general-purpose', sub:'Ebook-Delivery-System', desc:'Token-Access + /ebook/lesen + SendGrid + Admin-Resend.' },
  { id:'a-adminlive', x:1050, y:780, r:16, color:'#a78bfa', type:'general', state:'done', label:'general-purpose', sub:'Live-Admin-Durchklick', desc:'Fand CRITICAL Artikel-Editor-Bug (1164 Artikel gefährdet).' },
