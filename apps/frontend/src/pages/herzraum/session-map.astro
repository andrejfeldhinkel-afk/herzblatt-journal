  animation: shockwave 1.4s cubic-bezier(.2,.6,.2,1) forwards;
}
@keyframes shockwave {
  0%   { width: 40px; height: 40px; opacity: 1; border-width: 3px;
         box-shadow: 0 0 20px var(--rose), inset 0 0 20px var(--rose); }
  60%  { opacity: 0.6; }
  100% { width: 2200px; height: 2200px; opacity: 0; border-width: 0.5px;
         box-shadow: 0 0 0 transparent; }
}

/* Camera-shake on CRITICAL events */
@keyframes cameraShake {
