    <div class="label">${n.label}</div>
    <div class="node-sub">${n.sub}</div>
  `;
  el.addEventListener('mouseover', (e) => showTip(e, n));
  el.addEventListener('mouseout', hideTip);
  stage.appendChild(el);
});

function showTip(e, n) {
  tooltip.innerHTML = `
    <div class="tt-sub">${n.type}</div>
    <h4>${n.label}</h4>
    <p>${n.sub}</p>
    ${n.desc ? `<p style="margin-top:8px">${n.desc}</p>` : ''}
    <span class="tt-state">${n.state}</span>
  `;
  tooltip.style.left = (e.clientX + 18) + 'px';
  tooltip.style.top = (e.clientY + 18) + 'px';
