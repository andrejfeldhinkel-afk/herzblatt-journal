// ─── Radar-Ping: Wenn Conic-Gradient-Sweep einen Node überstreicht ───
(function setupRadarPing() {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  const mainX = nodeMap.main.x, mainY = nodeMap.main.y;
  // Conic-Gradient start = 0deg (oben), rotiert 360°/7s → 51.43°/s
  // Sweep-Fenster: ~320deg bis ~360deg → ping beim Durchgang
  const SWEEP_CENTER_DEG = 354; // etwa Mitte des Gradient-Keils
  function nodeAngle(n) {
    // SVG-viewBox-Koord → Winkel (0° = oben, CCW negativ, CW positiv)
    const dx = n.x - mainX, dy = n.y - mainY;
    const deg = (Math.atan2(dx, -dy) * 180 / Math.PI + 360) % 360;
    return deg;
  }
  const nodesByAngle = NODES
    .filter(n => n.id !== 'main')
    .map(n => ({ n, angle: nodeAngle(n), el: null, lastPing: 0 }));
  // Element-Refs zum Pingen einsammeln (nach Render)
  document.querySelectorAll('.node').forEach((el, i) => {
    const n = NODES[i];
    const rec = nodesByAngle.find(r => r.n.id === n.id);
    if (rec) rec.el = el;
  });
  const rotationStart = performance.now();
  function radarLoop() {
    if (document.body.dataset.mode !== 'map') {
      requestAnimationFrame(radarLoop); return;
    }
    const elapsed = (performance.now() - rotationStart) / 1000;
    const currentAngle = (elapsed * (360 / 7) + SWEEP_CENTER_DEG) % 360;
    const now = performance.now();
    nodesByAngle.forEach(rec => {
      if (!rec.el) return;
      if (rec.el.classList.contains('time-hidden')) return;
      const diff = Math.min(Math.abs(currentAngle - rec.angle), 360 - Math.abs(currentAngle - rec.angle));
      if (diff < 4 && (now - rec.lastPing) > 3000) {
        rec.el.classList.add('radar-ping');
        rec.lastPing = now;
        setTimeout(() => rec.el && rec.el.classList.remove('radar-ping'), 1200);
      }
    });
    requestAnimationFrame(radarLoop);
  }
  requestAnimationFrame(radarLoop);
})();

// ─── Particle-Flows: Canvas-Partikel wandern Main → PR/Agent ───────
(function setupParticles() {
  if (window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;
  const canvas = document.getElementById('particles');
  if (!canvas) return;
  const ctx = canvas.getContext('2d');
  let W = 0, H = 0, vbScaleX = 1, vbScaleY = 1;
  function resize() {
    const rect = canvas.parentElement.getBoundingClientRect();
    const dpr = window.devicePixelRatio || 1;
    W = rect.width; H = rect.height;
    canvas.width = W * dpr; canvas.height = H * dpr;
    canvas.style.width = W + 'px'; canvas.style.height = H + 'px';
    ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
    // SVG viewBox ist 1600×900, aspect-preserving = xMidYMid meet
    const scale = Math.min(W / 1600, H / 900);
    vbScaleX = vbScaleY = scale;
  }
  resize();
  window.addEventListener('resize', resize);

  // viewBox → screen coordinates
  function vb(vx, vy) {
    const offX = (W - 1600 * vbScaleX) / 2;
    const offY = (H - 900 * vbScaleY) / 2;
    return [offX + vx * vbScaleX, offY + vy * vbScaleY];
  }

  const particles = [];
  // Mögliche Ziele = alle Edges von main
  const targets = EDGES.filter(e => e.s === 'main').map(e => e.t);

  function spawnParticle() {
    if (document.body.dataset.mode !== 'map') return;
    const tid = targets[(Math.random() * targets.length) | 0];
    const target = nodeMap[tid];
    if (!target) return;
    // Nur wenn Target derzeit sichtbar (nicht zeit-versteckt)
    const el = document.querySelector(`.node[data-id="${tid}"]`);
    if (el && el.classList.contains('time-hidden')) return;
    const toPR = target.type === 'artifact';
    // Bezier control-point: perpendicular-offset from midpoint, random side + magnitude
    const dx = target.x - nodeMap.main.x, dy = target.y - nodeMap.main.y;
    const len = Math.hypot(dx, dy) || 1;
    const side = Math.random() > 0.5 ? 1 : -1;
    const curveMag = 40 + Math.random() * 80;
    const mx = (nodeMap.main.x + target.x) / 2 + (-dy / len) * curveMag * side;
    const my = (nodeMap.main.y + target.y) / 2 + ( dx / len) * curveMag * side;
    particles.push({
      from: nodeMap.main, to: target,
      cx: mx, cy: my, // bezier control
      p: 0, speed: 0.008 + Math.random() * 0.01,
      size: toPR ? 2.2 : 2.8,
      color: toPR ? [34, 197, 94] : [255, 56, 104], // green from PR, rose to agent
      reverse: toPR,
    });
  }
  setInterval(spawnParticle, 140);

  // Quadratic Bezier: B(t) = (1-t)² P0 + 2(1-t)t P1 + t² P2
  function bezier(t, p0, p1, p2) {
    const u = 1 - t;
    return u * u * p0 + 2 * u * t * p1 + t * t * p2;
  }

  function draw() {
    ctx.clearRect(0, 0, W, H);
    for (let i = particles.length - 1; i >= 0; i--) {
      const p = particles[i];
      p.p += p.speed;
      if (p.p >= 1) { particles.splice(i, 1); continue; }
      const progress = p.reverse ? 1 - p.p : p.p;
      const x = bezier(progress, p.from.x, p.cx, p.to.x);
      const y = bezier(progress, p.from.y, p.cy, p.to.y);
      const [sx, sy] = vb(x, y);
      const fade = Math.sin(p.p * Math.PI);
      const [r, g, b] = p.color;
      // Trail along the curve
      for (let k = 0; k < 6; k++) {
        const backP = Math.max(0, p.p - k * 0.01);
        const prog2 = p.reverse ? 1 - backP : backP;
        const tx = bezier(prog2, p.from.x, p.cx, p.to.x);
        const ty = bezier(prog2, p.from.y, p.cy, p.to.y);
        const [tsx, tsy] = vb(tx, ty);
        const a = fade * (0.55 - k * 0.08);
        if (a <= 0) continue;
        ctx.fillStyle = `rgba(${r},${g},${b},${a})`;
        ctx.beginPath();
        ctx.arc(tsx, tsy, p.size * (1 - k * 0.13), 0, Math.PI * 2);
        ctx.fill();
      }
      // Core with glow
      ctx.fillStyle = `rgba(${r},${g},${b},${fade})`;
      ctx.shadowColor = `rgba(${r},${g},${b},${fade})`;
      ctx.shadowBlur = 12;
      ctx.beginPath();
      ctx.arc(sx, sy, p.size, 0, Math.PI * 2);
      ctx.fill();
      ctx.shadowBlur = 0;
    }
    requestAnimationFrame(draw);
  }
  requestAnimationFrame(draw);
})();

