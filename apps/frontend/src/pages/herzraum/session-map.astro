(function setupScrubber() {
  const range = document.getElementById('scRange');
  const timeLbl = document.getElementById('scTime');
  const visLbl = document.getElementById('scVisible');
  const totalLbl = document.getElementById('scTotal');
  const playBtn = document.getElementById('scPlay');
  const playLbl = document.getElementById('scPlayLabel');
  const ticksEl = document.getElementById('scTicks');
  const markersEl = document.getElementById('scMarkers');
  if (!range) return;

  totalLbl.textContent = String(NODES.length);

  // Render Tick-Labels (jede volle Stunde: 12, 13, …, 20)
  for (let h = 12; h <= 20; h++) {
    const tick = document.createElement('div');
    tick.className = 'sc-tick';
    tick.style.position = 'absolute';
    tick.style.left = ((h - 12) * 60 / 480 * 100) + '%';
    tick.innerHTML = `<span>${h}:00</span>`;
    ticksEl.appendChild(tick);
  }

  // Critical-Event-Marker auf der Timeline (aus IMPACT + Node-Times)
  const criticalIds = ['pr17', 'pr18', 'pr19', 'pr20', 'pr30'];
  criticalIds.forEach(id => {
    const t = NODE_TIMES[id];
    if (t == null) return;
    const m = document.createElement('div');
    m.className = 'sc-marker critical';
    m.style.left = (t / 480 * 100) + '%';
    m.title = 'CRITICAL ' + id.toUpperCase();
    markersEl.appendChild(m);
  });

  // Collect node refs by id for fast lookup
  const nodeEls = {};
  document.querySelectorAll('.node').forEach((el, i) => { nodeEls[NODES[i].id] = el; });
  const edgeEls = Array.from(document.querySelectorAll('.edge'));
  // EDGES array index mirrors edgeEls
  function applyTime(tMinutes) {
    let visible = 0;
    NODES.forEach(n => {
      const el = nodeEls[n.id];
      if (!el) return;
      const wasHidden = el.classList.contains('time-hidden');
      if (n.t > tMinutes) {
        el.classList.add('time-hidden');
      } else {
        if (wasHidden) {
          el.classList.remove('time-hidden');
          el.classList.add('just-born');
          setTimeout(() => el.classList.remove('just-born'), 1000);
        }
        visible++;
      }
    });
    // Edges: hide if either endpoint hidden
    EDGES.forEach((e, i) => {
      const eEl = edgeEls[i]; if (!eEl) return;
      const tS = (nodeMap[e.s] && nodeMap[e.s].t) || 0;
      const tT = (nodeMap[e.t] && nodeMap[e.t].t) || 0;
      if (Math.max(tS, tT) > tMinutes) eEl.classList.add('time-hidden');
      else eEl.classList.remove('time-hidden');
    });
    // Label-Update
    const h = Math.floor(tMinutes / 60) + 12;
    const m = String(tMinutes % 60).padStart(2, '0');
    timeLbl.textContent = `${h}:${m}`;
    visLbl.textContent = String(visible);
    range.style.setProperty('--fill', (tMinutes / 480 * 100) + '%');
    // Hook für Shockwaves + Achievements
    if (window.__onMapTime) window.__onMapTime(tMinutes);
  }
  // Expose applyTime for programmatic use (Achievement-Banner Re-Play etc.)
  window.__mapApplyTime = applyTime;

  range.addEventListener('input', (e) => {
    stopPlayback();
    applyTime(+e.target.value);
  });

  // Play/Pause: animiere Slider von 0 → 480 über 30s (by default, speed=1)
  let playing = false, playStart = 0, startValue = 0, rafId = 0;
  const BASE_PLAY_DURATION_MS = 30000;
  window.__mapPlaySpeed = 1;
  function playFrame() {
    if (!playing) return;
    const elapsed = performance.now() - playStart;
    const duration = BASE_PLAY_DURATION_MS / (window.__mapPlaySpeed || 1);
    const fraction = Math.min(1, elapsed / duration);
    const tMin = Math.round(startValue + (480 - startValue) * fraction);
    range.value = String(tMin);
    applyTime(tMin);
    if (fraction < 1) rafId = requestAnimationFrame(playFrame);
    else stopPlayback();
  }
  function startPlayback() {
    playing = true;
    startValue = +range.value >= 480 ? 0 : +range.value;
    range.value = String(startValue);
    applyTime(startValue);
    playStart = performance.now();
    playBtn.classList.add('playing');
    playLbl.textContent = 'Pause';
    rafId = requestAnimationFrame(playFrame);
  }
  function stopPlayback() {
    playing = false;
    cancelAnimationFrame(rafId);
    playBtn.classList.remove('playing');
    playLbl.textContent = 'Replay';
  }
  playBtn.addEventListener('click', () => {
    if (playing) stopPlayback();
    else startPlayback();
  });

  // Initial: alles sichtbar (Slider auf Max)
  applyTime(480);
})();

