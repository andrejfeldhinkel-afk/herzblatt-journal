.sm-stage.focus-mode .sm-radar { opacity: 0; }
.sm-stage.focus-mode .sm-particles { opacity: 0.3; }

/* Shockwave ripple on CRITICAL PRs during replay */
.shockwave {
  position: absolute; left: 50%; top: 50%;
  width: 40px; height: 40px;
  transform: translate(-50%, -50%);
  border-radius: 50%;
  border: 3px solid var(--rose);
