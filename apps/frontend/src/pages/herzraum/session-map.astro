// Render tick-hours (12-20)
for (let h = 12; h <= 20; h++) {
  const tick = document.createElement('div');
  tick.className = 'sc-tick';
  tick.style.position = 'absolute';
  tick.style.left = ((h - 12) * 60 / 480 * 100) + '%';
  tick.innerHTML = `<span>${h}:00</span>`;
  ticksEl.appendChild(tick);
}
// Critical markers
[200, 205, 210, 220, 350].forEach(t => {
  const m = document.createElement('div');
  m.className = 'sc-marker';
  m.style.left = (t / 480 * 100) + '%';
  markersEl.appendChild(m);
});

function applyTime(tMin) {
  let visible = 0;
  NODES.forEach(n => {
    const el = nodeEls[n.id];
    if (!el) return;
    if (n.t > tMin) el.classList.add('time-hidden');
    else { el.classList.remove('time-hidden'); visible++; }
  });
  edgeEls.forEach(e => {
    const tS = (nodeMap[e.s] && nodeMap[e.s].t) || 0;
    const tT = (nodeMap[e.t] && nodeMap[e.t].t) || 0;
    if (Math.max(tS, tT) > tMin) e.el.classList.add('time-hidden');
    else e.el.classList.remove('time-hidden');
  });
  const h = Math.floor(tMin / 60) + 12;
  const m = String(tMin % 60).padStart(2, '0');
  timeLbl.textContent = `${h}:${m}`;
  visLbl.textContent = String(visible);
  range.style.setProperty('--fill', (tMin / 480 * 100) + '%');
}

range.addEventListener('input', (ev) => {
  stopPlayback();
  applyTime(+ev.target.value);
});

// Playback
let playing = false, playStart = 0, startValue = 0, rafId = 0;
let playSpeed = 1;
const BASE_MS = 30000;
function playFrame() {
  if (!playing) return;
  const elapsed = performance.now() - playStart;
  const duration = BASE_MS / playSpeed;
  const fraction = Math.min(1, elapsed / duration);
  const tMin = Math.round(startValue + (480 - startValue) * fraction);
  range.value = String(tMin);
  applyTime(tMin);
  if (fraction < 1) rafId = requestAnimationFrame(playFrame);
  else stopPlayback();
}
function startPlayback() {
  playing = true;
  startValue = +range.value >= 480 ? 0 : +range.value;
  range.value = String(startValue);
  applyTime(startValue);
  playStart = performance.now();
  playLbl.textContent = '❚❚ Pause';
  rafId = requestAnimationFrame(playFrame);
}
function stopPlayback() {
  playing = false;
  cancelAnimationFrame(rafId);
  playLbl.textContent = '▶ Replay';
}
playBtn.addEventListener('click', () => { playing ? stopPlayback() : startPlayback(); });

// Speed buttons
document.querySelectorAll('.sc-speed-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    document.querySelectorAll('.sc-speed-btn').forEach(b => b.classList.toggle('active', b === btn));
    playSpeed = parseFloat(btn.dataset.speed);
  });
});

// Reset button
resetBtn.addEventListener('click', () => {
  NODES.forEach(n => {
    n.x = n.homeX;
    n.y = n.homeY;
    updateNodePosition(n);
  });
  zoom = 1; panX = 0; panY = 0;
  applyTransform();
  exitFocus();
  range.value = '480';
  applyTime(480);
  stopPlayback();
});

// Initial: all visible
applyTime(480);
</script>
</HerzraumLayout>
