// ═══════════════════════════════════════════════════════════════════════
// STORY-MODE — Scroll-triggered Chapter-Activation + Node-Highlighting
// ═══════════════════════════════════════════════════════════════════════
const storyContainer = document.getElementById('story-container');
const chapters = document.querySelectorAll('.chapter');

function activateChapter(num) {
  chapters.forEach(ch => ch.classList.toggle('active', +ch.dataset.chapter === num));
  const ch = document.querySelector(`.chapter[data-chapter="${num}"]`);
  if (!ch) return;
  const highlights = new Set((ch.dataset.highlight || '').split(',').map(s => s.trim()).filter(Boolean));
  // Story-mode always dims + highlights; map-mode resets
  stage.classList.add('story-dim');
  document.querySelectorAll('.node').forEach((el, i) => {
    const n = NODES[i];
    el.classList.toggle('highlight', highlights.has(n.id));
  });
}
function resetHighlight() {
  stage.classList.remove('story-dim');
  document.querySelectorAll('.node').forEach(el => el.classList.remove('highlight'));
}

// IntersectionObserver: aktiviert Kapitel wenn es im Viewport ist
const storyObs = new IntersectionObserver((entries) => {
  if (document.body.dataset.mode !== 'story') return;
  let bestEntry = null, bestRatio = 0;
  entries.forEach(e => { if (e.isIntersecting && e.intersectionRatio > bestRatio) { bestEntry = e; bestRatio = e.intersectionRatio; } });
  if (bestEntry) activateChapter(+bestEntry.target.dataset.chapter);
}, { root: storyContainer, threshold: [0.3, 0.5, 0.7] });
chapters.forEach(ch => storyObs.observe(ch));

// Reset highlight when switching away from story
new MutationObserver(() => {
  if (document.body.dataset.mode !== 'story') resetHighlight();
}).observe(document.body, { attributes: true, attributeFilter: ['data-mode'] });

