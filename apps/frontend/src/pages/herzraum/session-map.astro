}
.node { will-change: transform; }
.node[data-depth="near"] { transform: translate(-50%, -50%) translateZ(30px); }
.node[data-depth="mid"]  { transform: translate(-50%, -50%) translateZ(0px); }
.node[data-depth="far"]  { transform: translate(-50%, -50%) translateZ(-40px); }
.node[data-depth="near"]:hover { transform: translate(-50%, -50%) translateZ(30px) scale(1.1); }
.node[data-depth="mid"]:hover { transform: translate(-50%, -50%) translateZ(0px) scale(1.1); }
.node[data-depth="far"]:hover { transform: translate(-50%, -50%) translateZ(-40px) scale(1.1); }
.node[data-depth="near"].time-hidden { transform: translate(-50%, -50%) translateZ(30px) scale(0.3); }
.node[data-depth="mid"].time-hidden  { transform: translate(-50%, -50%) translateZ(0px) scale(0.3); }
.node[data-depth="far"].time-hidden  { transform: translate(-50%, -50%) translateZ(-40px) scale(0.3); }

