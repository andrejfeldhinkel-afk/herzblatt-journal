  pr45: { metric: 'CSRF-Tokens + KPI-Widgets + PII-Redaction', cost: 'DSGVO-konformes Auditing + Admin-Härtung', category: 'COMPLIANCE' },
  pr46: { metric: 'SEO-Hijacking · 3 Brand-Reviews', cost: '~11.800 Wörter · Badoo/Poppen/Lovoo → eigene Brands', category: 'SEO' },
};

// ═══════════════════════════════════════════════════════════════════════
// MODE-SWITCH — Map / Story / Live
// ═══════════════════════════════════════════════════════════════════════
document.body.dataset.mode = 'map';
document.querySelectorAll('.mode-btn').forEach(btn => {
  btn.addEventListener('click', () => {
    const mode = btn.dataset.mode;
    document.body.dataset.mode = mode;
    document.querySelectorAll('.mode-btn').forEach(b => b.classList.toggle('active', b === btn));
    if (mode === 'story') activateChapter(1);
  });
});

// ═══════════════════════════════════════════════════════════════════════
// STORY-MODE — Scroll-triggered Chapter-Activation + Node-Highlighting
// ═══════════════════════════════════════════════════════════════════════
const storyContainer = document.getElementById('story-container');
const chapters = document.querySelectorAll('.chapter');

function activateChapter(num) {
  chapters.forEach(ch => ch.classList.toggle('active', +ch.dataset.chapter === num));
  const ch = document.querySelector(`.chapter[data-chapter="${num}"]`);
  if (!ch) return;
  const highlights = new Set((ch.dataset.highlight || '').split(',').map(s => s.trim()).filter(Boolean));
  // Story-mode always dims + highlights; map-mode resets
  stage.classList.add('story-dim');
  document.querySelectorAll('.node').forEach((el, i) => {
    const n = NODES[i];
    el.classList.toggle('highlight', highlights.has(n.id));
  });
}
function resetHighlight() {
  stage.classList.remove('story-dim');
  document.querySelectorAll('.node').forEach(el => el.classList.remove('highlight'));
}

// IntersectionObserver: aktiviert Kapitel wenn es im Viewport ist
const storyObs = new IntersectionObserver((entries) => {
  if (document.body.dataset.mode !== 'story') return;
  let bestEntry = null, bestRatio = 0;
  entries.forEach(e => { if (e.isIntersecting && e.intersectionRatio > bestRatio) { bestEntry = e; bestRatio = e.intersectionRatio; } });
  if (bestEntry) activateChapter(+bestEntry.target.dataset.chapter);
}, { root: storyContainer, threshold: [0.3, 0.5, 0.7] });
chapters.forEach(ch => storyObs.observe(ch));

// Reset highlight when switching away from story
new MutationObserver(() => {
  if (document.body.dataset.mode !== 'story') resetHighlight();
}).observe(document.body, { attributes: true, attributeFilter: ['data-mode'] });

// ═══════════════════════════════════════════════════════════════════════
// DEEP-DIVE auf Click (ergänzt Tooltip auf Hover)
// ═══════════════════════════════════════════════════════════════════════
document.querySelectorAll('.node').forEach((el, i) => {
  const n = NODES[i];
  el.addEventListener('click', (ev) => {
    ev.stopPropagation();
    const imp = IMPACT[n.id];
    tooltip.innerHTML = `
      <div class="tt-sub">${n.type}${imp ? ' · ' + imp.category : ''}</div>
      <h4>${n.label} ${n.sub ? '· ' + n.sub : ''}</h4>
      ${n.desc ? `<p>${n.desc}</p>` : ''}
      ${imp ? `
        <div style="margin-top: 12px; padding-top: 10px; border-top: 1px solid rgba(255,255,255,.08);">
          <div style="font-size: 10px; color: #ff3868; text-transform: uppercase; letter-spacing: 0.14em; font-weight: 700; margin-bottom: 4px;">Impact</div>
          <div style="font-size: 14px; font-weight: 700; color: #f3f4f8; margin-bottom: 4px;">${imp.metric}</div>
          <div style="font-size: 11px; color: #a5a7b8; line-height: 1.5;">${imp.cost}</div>
          ${imp.severity === 'critical' ? '<div style="margin-top: 8px; display: inline-block; padding: 2px 8px; background: rgba(255,56,104,.2); color: #ff3868; border-radius: 4px; font-size: 10px; font-weight: 700; letter-spacing: 0.08em;">CRITICAL</div>' : ''}
        </div>
      ` : ''}
      <span class="tt-state">${n.state}</span>
    `;
    // Position centered for detail view
    tooltip.style.left = Math.min(ev.clientX + 18, window.innerWidth - 380) + 'px';
    tooltip.style.top = Math.min(ev.clientY + 18, window.innerHeight - 300) + 'px';
    tooltip.style.opacity = '1';
    tooltip.style.maxWidth = '360px';
  });
});
// Click outside closes deep-dive
document.addEventListener('click', (e) => {
  if (!tooltip.contains(e.target) && !e.target.closest('.node')) {
    tooltip.style.opacity = '0';
  }
});

// ═══════════════════════════════════════════════════════════════════════
// LIVE-VITALS — T+ Clock + Fake-Metrics (polling-ready)
// ═══════════════════════════════════════════════════════════════════════
const sessionStartTs = new Date(); sessionStartTs.setHours(12, 0, 0, 0);
function tickVitals() {
  const s = Math.max(0, Math.floor((Date.now() - sessionStartTs.getTime()) / 1000));
  const h = String(Math.floor(s/3600)).padStart(2,'0');
  const m = String(Math.floor(s/60)%60).padStart(2,'0');
  const ss = String(s%60).padStart(2,'0');
  const tp = document.getElementById('lv-tplus'); if (tp) tp.textContent = `${h}:${m}:${ss}`;
  // PRs/h based on 38 PRs in 6h
  const rate = s > 0 ? (38 / (s / 3600)).toFixed(1) : '—';
  const pr = document.getElementById('lv-prrate'); if (pr) pr.textContent = rate + ' / h';
  const up = document.getElementById('lv-uptime'); if (up) up.textContent = '100.0 %';
  const ag = document.getElementById('lv-agents'); if (ag) ag.textContent = '10+';
}
tickVitals();
setInterval(tickVitals, 1000);
</script>
</HerzraumLayout>
