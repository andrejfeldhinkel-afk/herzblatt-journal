  20% { transform: translate(4px, -1px) rotate(0.4deg); }
  30% { transform: translate(-2px, -2px) rotate(-0.2deg); }
  40% { transform: translate(3px, 3px) rotate(0.3deg); }
  50% { transform: translate(-4px, 1px) rotate(-0.4deg); }
  60% { transform: translate(2px, -3px) rotate(0.2deg); }
  70% { transform: translate(-1px, 2px) rotate(-0.1deg); }
  80% { transform: translate(2px, -1px) rotate(0.1deg); }
