// ═══════════════════════════════════════════════════════════════════════
// DRAG NODES (except main)
// ═══════════════════════════════════════════════════════════════════════
let draggingNode = null;

function getStageScale() {
  const rect = stage.getBoundingClientRect();
  // viewBox 1600x900 is rendered inside stage preserveAspectRatio=xMidYMid meet
  const scale = Math.min(rect.width / VB_W, rect.height / VB_H) * zoom;
  return scale;
}

function updateNodePosition(n) {
  const el = nodeEls[n.id];
  if (el) {
    el.style.left = pctX(n.x);
    el.style.top = pctY(n.y);
  }
  // Update connected edges
  edgeEls.forEach(e => {
    if (e.s === n.id) { e.el.setAttribute('x1', n.x); e.el.setAttribute('y1', n.y); }
    if (e.t === n.id) { e.el.setAttribute('x2', n.x); e.el.setAttribute('y2', n.y); }
  });
}

Object.entries(nodeEls).forEach(([id, el]) => {
  if (id === 'main') return; // main is fixed
  const n = nodeMap[id];
  let dragStartX = 0, dragStartY = 0, nodeStartX = 0, nodeStartY = 0;
  let moved = false;

  el.addEventListener('mousedown', (ev) => {
    ev.preventDefault(); ev.stopPropagation();
    draggingNode = n; moved = false;
    dragStartX = ev.clientX; dragStartY = ev.clientY;
    nodeStartX = n.x; nodeStartY = n.y;
    el.style.zIndex = '50';
    stage.classList.add('dragging-node');
  });

  function onMove(ev) {
    if (draggingNode !== n) return;
    const dx = ev.clientX - dragStartX;
    const dy = ev.clientY - dragStartY;
    if (Math.abs(dx) + Math.abs(dy) > 3) moved = true;
    const scale = getStageScale();
    n.x = nodeStartX + dx / scale;
    n.y = nodeStartY + dy / scale;
    updateNodePosition(n);
  }
  function onUp(ev) {
    if (draggingNode !== n) return;
    draggingNode = null;
    el.style.zIndex = '';
    stage.classList.remove('dragging-node');
    // If no drag happened, treat as click → open detail
    if (!moved) showDetail(n);
  }
  window.addEventListener('mousemove', onMove);
  window.addEventListener('mouseup', onUp);
});

// ═══════════════════════════════════════════════════════════════════════
// ZOOM (wheel) + PAN (drag background)
// ═══════════════════════════════════════════════════════════════════════
stage.addEventListener('wheel', (ev) => {
  ev.preventDefault();
  const factor = ev.deltaY > 0 ? 0.92 : 1.09;
  zoom = Math.max(0.4, Math.min(3, zoom * factor));
  applyTransform();
}, { passive: false });

let panning = false, panStartX = 0, panStartY = 0;
stage.addEventListener('mousedown', (ev) => {
  if (ev.target.closest('.node, .panel, .sm-header, .sm-scrubber')) return;
  panning = true;
  panStartX = ev.clientX - panX;
  panStartY = ev.clientY - panY;
});
window.addEventListener('mousemove', (ev) => {
  if (!panning) return;
  panX = ev.clientX - panStartX;
  panY = ev.clientY - panStartY;
  applyTransform();
});
window.addEventListener('mouseup', () => { panning = false; });

// ═══════════════════════════════════════════════════════════════════════
// CLICK: Focus-Mode + Detail-Panel
// ═══════════════════════════════════════════════════════════════════════
const detailPanel = document.getElementById('detail-panel');
let focusedNodeId = null;

function showDetail(n) {
  // Enter focus mode
  stage.classList.add('focus-mode');
  focusedNodeId = n.id;
  Object.values(nodeEls).forEach(el => el.classList.remove('focused'));
  nodeEls[n.id].classList.add('focused');
  edgeEls.forEach(e => {
    e.el.classList.toggle('connected', e.s === n.id || e.t === n.id);
  });
  // Populate panel
  document.getElementById('dp-type').textContent = n.type;
  document.getElementById('dp-title').textContent = n.label;
  document.getElementById('dp-sub').textContent = n.sub || '';
  document.getElementById('dp-desc').textContent = n.desc || 'Keine weiteren Details erfasst.';
  const imp = IMPACT[n.id];
  const impEl = document.getElementById('dp-impact');
  if (imp) {
    impEl.style.display = '';
    document.getElementById('dp-impact-metric').textContent = imp.metric;
    document.getElementById('dp-impact-cost').textContent = imp.cost;
  } else {
    impEl.style.display = 'none';
  }
  detailPanel.classList.add('open');
}

function exitFocus() {
  stage.classList.remove('focus-mode');
  focusedNodeId = null;
  Object.values(nodeEls).forEach(el => el.classList.remove('focused'));
  edgeEls.forEach(e => e.el.classList.remove('connected'));
  detailPanel.classList.remove('open');
}

document.getElementById('dp-close').addEventListener('click', exitFocus);
stage.addEventListener('click', (ev) => {
  if (!ev.target.closest('.node') && focusedNodeId) exitFocus();
});
document.addEventListener('keydown', (ev) => {
  if (ev.key === 'Escape' && focusedNodeId) exitFocus();
});

// Main-Agent click opens its detail
nodeEls.main.addEventListener('click', (ev) => {
  ev.stopPropagation();
  showDetail(nodeMap.main);
});

