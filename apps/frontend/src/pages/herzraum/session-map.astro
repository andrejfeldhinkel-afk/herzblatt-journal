---
export const prerender = false;
import HerzraumLayout from '../../layouts/HerzraumLayout.astro';

// Session-Map — komplett neu aufgebaut als Live-Visitor-Dashboard.
// Vorher: 2010-Zeilen Force-Directed-Graph mit Agents/PRs (Dev-Tool).
// Jetzt: clean Analytics-Panel mit 4 Tiles + Sparkline + Top-Pages + Activity-Feed.
// Keine Canvas, kein SVG-Force-Sim, kein Timeline-Scrubber, kein Replay.
---
<HerzraumLayout title="Live-Sessions" active="session-map">

  <!-- Row 1: KPI-Tiles -->
  <section class="hz-kpi-grid" style="margin-bottom: 1rem;">
    <div class="hz-kpi hz-live">
      <div class="hz-kpi-label">
        <span class="hz-live-dot"></span> Gerade online
      </div>
      <div class="hz-kpi-value" id="sm-live-count">—</div>
      <div class="hz-kpi-hint">letzte 5 Min aktiv</div>
    </div>
    <div class="hz-kpi">
      <div class="hz-kpi-label">Pageviews · letzte Std</div>
      <div class="hz-kpi-value" id="sm-hour-count">—</div>
      <div class="hz-kpi-hint" id="sm-hour-trend">—</div>
    </div>
    <div class="hz-kpi">
      <div class="hz-kpi-label">Peak heute</div>
      <div class="hz-kpi-value" id="sm-peak-count">—</div>
      <div class="hz-kpi-hint" id="sm-peak-hour">—</div>
    </div>
    <div class="hz-kpi">
      <div class="hz-kpi-label">Mobile-Anteil</div>
      <div class="hz-kpi-value" id="sm-mobile-pct">—</div>
      <div class="hz-kpi-hint" id="sm-device-split">—</div>
    </div>
  </section>

  <!-- Row 2: Sparkline -->
  <div class="hz-card" style="margin-bottom: 1rem;">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 0.75rem;">
      <h3 style="margin: 0;">📈 Pageviews pro Minute · letzte 60 Min</h3>
      <span style="font-size: 0.75rem; color: var(--hz-text-muted);" id="sm-updated">—</span>
    </div>
    <div id="sm-sparkline" style="display: flex; align-items: flex-end; gap: 2px; height: 80px;">
      <!-- wird clientseitig gefüllt -->
    </div>
  </div>

  <!-- Row 3: Two-column — Top-Pages + Activity-Feed -->
  <div class="sm-two-col" style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem;">
    <div class="hz-card">
      <h3 style="margin: 0 0 0.75rem;">🔥 Top-Pfade · letzte Std</h3>
      <div id="sm-top-pages">
        <div style="color: var(--hz-text-muted); font-size: 0.85rem;">Lade…</div>
      </div>
    </div>

    <div class="hz-card">
      <h3 style="margin: 0 0 0.75rem;">⚡ Activity-Feed · Live</h3>
      <div id="sm-feed" style="max-height: 480px; overflow-y: auto;">
        <div style="color: var(--hz-text-muted); font-size: 0.85rem;">Lade…</div>
      </div>
    </div>
  </div>

  <style>
    .hz-live-dot {
      display: inline-block;
      width: 8px; height: 8px;
      border-radius: 50%;
      background: #10b981;
      box-shadow: 0 0 8px rgba(16, 185, 129, 0.6);
      margin-right: 0.35rem;
      animation: hz-live-pulse 2s ease-in-out infinite;
    }
    @keyframes hz-live-pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.5; transform: scale(1.3); }
    }
    .sm-bar {
      flex: 1;
      background: linear-gradient(180deg, #f43f5e, rgba(244,63,94,0.25));
      border-radius: 2px 2px 0 0;
      min-height: 2px;
      transition: height 0.3s ease-out;
    }
    .sm-bar.recent { background: linear-gradient(180deg, #f43f5e, #be123c); }
    .sm-page-row {
      display: flex; align-items: center; gap: 0.75rem;
      padding: 0.45rem 0;
      border-bottom: 1px solid var(--hz-border);
    }
    .sm-page-row:last-child { border-bottom: 0; }
    .sm-page-path {
      flex: 1;
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      font-size: 0.82rem;
      color: var(--hz-text);
      text-decoration: none;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
    }
    .sm-page-path:hover { color: var(--hz-primary); text-decoration: underline; }
    .sm-page-bar-wrap {
      width: 80px; height: 6px;
      background: rgba(244, 63, 94, 0.1);
      border-radius: 3px; overflow: hidden;
    }
    .sm-page-bar {
      height: 100%;
      background: linear-gradient(90deg, #f43f5e, #fb7185);
      transition: width 0.3s ease-out;
    }
    .sm-page-count {
      min-width: 40px; text-align: right;
      font-weight: 700; font-size: 0.85rem;
      font-variant-numeric: tabular-nums;
    }
    .sm-feed-item {
      display: grid;
      grid-template-columns: 32px 1fr auto;
      gap: 0.5rem;
      align-items: center;
      padding: 0.4rem 0;
      border-bottom: 1px solid var(--hz-border);
      font-size: 0.82rem;
    }
    .sm-feed-item:last-child { border-bottom: 0; }
    .sm-feed-item.new { animation: sm-fade-in 0.45s ease-out; }
    @keyframes sm-fade-in {
      from { opacity: 0; transform: translateY(-4px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .sm-feed-device {
      font-size: 1rem;
      text-align: center;
    }
    .sm-feed-path {
      font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, monospace;
      overflow: hidden; text-overflow: ellipsis; white-space: nowrap;
      color: var(--hz-text);
      text-decoration: none;
    }
    .sm-feed-path:hover { color: var(--hz-primary); text-decoration: underline; }
    .sm-feed-time {
      color: var(--hz-text-muted);
      font-variant-numeric: tabular-nums;
      font-size: 0.75rem;
      white-space: nowrap;
    }
    .hz-kpi-hint {
      font-size: 0.75rem; color: var(--hz-text-muted); margin-top: 0.25rem;
    }
    @media (max-width: 768px) {
      .sm-two-col { grid-template-columns: 1fr !important; }
    }
  </style>

  <script is:inline>
    (function() {
      const esc = (s) => String(s == null ? '' : s)
        .replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;').replace(/'/g, '&#39;');

      const fmt = (n) => (n || 0).toLocaleString('de-DE');

      function relativeTime(iso) {
        const then = new Date(iso).getTime();
        if (!Number.isFinite(then)) return '—';
        const sec = Math.floor((Date.now() - then) / 1000);
        if (sec < 10) return 'gerade eben';
        if (sec < 60) return 'vor ' + sec + 's';
        if (sec < 3600) return 'vor ' + Math.floor(sec / 60) + 'm';
        return 'vor ' + Math.floor(sec / 3600) + 'h';
      }

      const deviceEmoji = {
        mobile: '📱',
        desktop: '🖥️',
        tablet: '📱',
        bot: '🤖',
      };

      let seenIds = new Set();

      async function tick() {
        let data;
        try {
          const res = await fetch('/api/herzraum/session-map-live');
          if (!res.ok) throw new Error('HTTP ' + res.status);
          data = await res.json();
          if (!data.ok) throw new Error(data.error || 'backend');
        } catch (err) {
          console.error('[session-map] fetch failed:', err);
          const el = document.getElementById('sm-updated');
          if (el) {
            el.textContent = '⚠ Fehler: ' + (err && err.message || 'unbekannt');
            el.style.color = 'var(--hz-danger)';
          }
          return;
        }

        // KPI-Tiles
        document.getElementById('sm-live-count').textContent = fmt(data.liveCount);
        document.getElementById('sm-hour-count').textContent = fmt(data.lastHourCount);
        const peak = data.peakMinuteToday || { hour: 0, count: 0 };
        document.getElementById('sm-peak-count').textContent = fmt(peak.count);
        document.getElementById('sm-peak-hour').textContent = peak.hour != null
          ? 'um ' + String(peak.hour).padStart(2, '0') + ':00 Uhr (UTC)'
          : '—';

        const dev = data.deviceBreakdown || {};
        const total = (dev.mobile || 0) + (dev.desktop || 0) + (dev.tablet || 0) + (dev.bot || 0);
        const mobilePct = total > 0 ? Math.round(((dev.mobile || 0) + (dev.tablet || 0)) / total * 100) : 0;
        document.getElementById('sm-mobile-pct').textContent = mobilePct + '%';
        document.getElementById('sm-device-split').textContent =
          '📱 ' + fmt(dev.mobile || 0) + ' · 🖥 ' + fmt(dev.desktop || 0) + ' · 🤖 ' + fmt(dev.bot || 0);

        // Sparkline: 60 Buckets (min 0 = now, max 59 = vor 59min)
        const spark = document.getElementById('sm-sparkline');
        const mins = data.pageviewsByMinute || [];
        const maxCount = Math.max(1, ...mins.map((m) => m.count));
        spark.innerHTML = mins.map((m, i) => {
          const pct = Math.max(2, (m.count / maxCount) * 100);
          const cls = i >= mins.length - 5 ? 'sm-bar recent' : 'sm-bar';
          return '<div class="' + cls + '" style="height: ' + pct + '%;" title="vor ' + m.minuteOffset + 'm: ' + fmt(m.count) + '"></div>';
        }).join('');

        // Top-Pages
        const topEl = document.getElementById('sm-top-pages');
        const top = data.topPages || [];
        if (top.length === 0) {
          topEl.innerHTML = '<div style="color: var(--hz-text-muted); font-size: 0.85rem;">Noch keine Aufrufe in der letzten Stunde.</div>';
        } else {
          const topMax = top[0].count || 1;
          topEl.innerHTML = top.map((p) => {
            const pct = Math.round((p.count / topMax) * 100);
            const pathDisplay = p.path.length > 50 ? p.path.slice(0, 48) + '…' : p.path;
            const safeHref = p.path && p.path.startsWith('/') ? esc(p.path) : '#';
            return '<div class="sm-page-row">'
              + '<a class="sm-page-path" href="' + safeHref + '" target="_blank" rel="noopener" title="' + esc(p.path) + '">' + esc(pathDisplay) + '</a>'
              + '<div class="sm-page-bar-wrap"><div class="sm-page-bar" style="width: ' + pct + '%"></div></div>'
              + '<div class="sm-page-count">' + fmt(p.count) + '</div>'
              + '</div>';
          }).join('');
        }

        // Activity-Feed
        const feedEl = document.getElementById('sm-feed');
        const feed = data.activityFeed || [];
        if (feed.length === 0) {
          feedEl.innerHTML = '<div style="color: var(--hz-text-muted); font-size: 0.85rem;">Keine aktuellen Aktivitäten.</div>';
        } else {
          feedEl.innerHTML = feed.map((ev) => {
            const id = ev.ts + '|' + ev.path;
            const isNew = !seenIds.has(id);
            seenIds.add(id);
            const pathShort = ev.path.length > 45 ? ev.path.slice(0, 43) + '…' : ev.path;
            const safeHref = ev.path && ev.path.startsWith('/') ? esc(ev.path) : '#';
            const emoji = deviceEmoji[ev.device] || '·';
            const refTitle = ev.referrer && ev.referrer !== 'direct' ? ' · Referrer: ' + ev.referrer : '';
            return '<div class="sm-feed-item' + (isNew ? ' new' : '') + '">'
              + '<div class="sm-feed-device" title="' + esc(ev.device) + '">' + emoji + '</div>'
              + '<a class="sm-feed-path" href="' + safeHref + '" target="_blank" rel="noopener" title="' + esc(ev.path) + esc(refTitle) + '">' + esc(pathShort) + '</a>'
              + '<div class="sm-feed-time">' + esc(relativeTime(ev.ts)) + '</div>'
              + '</div>';
          }).join('');
        }

        if (seenIds.size > 200) {
          const keep = feed.slice(0, 50).map((ev) => ev.ts + '|' + ev.path);
          seenIds = new Set(keep);
        }

        const upEl = document.getElementById('sm-updated');
        if (upEl) {
          upEl.textContent = 'Aktualisiert ' + new Date().toLocaleTimeString('de-DE', { hour: '2-digit', minute: '2-digit', second: '2-digit' });
          upEl.style.color = 'var(--hz-text-muted)';
        }
      }

      tick();
      let timer = null;
      function startPoll() {
        if (timer) return;
        timer = setInterval(tick, 5000);
      }
      function stopPoll() {
        if (timer) { clearInterval(timer); timer = null; }
      }
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) stopPoll();
        else { tick(); startPoll(); }
      });
      if (!document.hidden) startPoll();
    })();
  </script>
</HerzraumLayout>
