// STATE + RENDERING
// ═══════════════════════════════════════════════════════════════════════
const VB_W = 1600, VB_H = 900;
const nodeMap = Object.fromEntries(NODES.map(n => [n.id, n]));
NODES.forEach(n => { n.homeX = n.x; n.homeY = n.y; n.t = NODE_TIMES[n.id] ?? 0; });

const stage = document.getElementById('stage');
const viewport = document.getElementById('viewport');
const svg = document.getElementById('edges');
const nodesLayer = document.getElementById('nodes-layer');

// Zoom/Pan state
let zoom = 1, panX = 0, panY = 0;
function applyTransform() {
  viewport.style.transform = `translate(${panX}px, ${panY}px) scale(${zoom})`;
}

// ── Render edges ──
const edgeEls = [];
EDGES.forEach((e, i) => {
  const a = nodeMap[e.s], b = nodeMap[e.t];
  if (!a || !b) return;
  const line = document.createElementNS('http://www.w3.org/2000/svg', 'line');
  line.setAttribute('x1', a.x); line.setAttribute('y1', a.y);
  line.setAttribute('x2', b.x); line.setAttribute('y2', b.y);
  line.setAttribute('class', 'edge' + (e.thin ? ' thin' : ''));
  line.dataset.source = e.s;
  line.dataset.target = e.t;
  svg.appendChild(line);
  edgeEls.push({ el: line, s: e.s, t: e.t });
});

// ── Render nodes ──
function pctX(v) { return (v / VB_W) * 100 + '%'; }
function pctY(v) { return (v / VB_H) * 100 + '%'; }

const nodeEls = {};
NODES.forEach(n => {
  const el = document.createElement('div');
  el.className = 'node ' + n.state;
  el.setAttribute('data-id', n.id);
  el.setAttribute('data-t', String(n.t));
  el.style.color = n.color;
  el.style.left = pctX(n.x);
  el.style.top = pctY(n.y);
  // Agent-cluster coloring for PRs
  const originAgentId = PR_ORIGIN[n.id];
  if (originAgentId && nodeMap[originAgentId]) {
    el.setAttribute('data-origin-color', '');
    el.style.setProperty('--origin-color', nodeMap[originAgentId].color);
  }
  el.innerHTML = `
    <div class="circle" style="width:${n.r*2}px;height:${n.r*2}px"></div>
    <div class="label">${n.label}</div>
    <div class="node-sub">${n.sub || ''}</div>
  `;
  nodesLayer.appendChild(el);
  nodeEls[n.id] = el;
});

// ── Render Activity Feed ──
document.getElementById('logList').innerHTML = LOG_EVENTS.map(e =>
