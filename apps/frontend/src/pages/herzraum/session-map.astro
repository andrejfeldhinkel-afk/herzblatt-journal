  // Mapping PR → Agent (basiert auf LOG_EVENTS-Zeiten + Session-Wissen)
  const PR_ORIGIN = {
    // Early Wave (general-purpose)
    pr11:'a-p1', pr12:'a-p2', pr13:'a-p2', pr14:'a-p2', pr15:'a-p2', pr16:'a-p2',
