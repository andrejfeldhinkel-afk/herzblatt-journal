---
export const prerender = false;

import HerzraumLayout from '../../layouts/HerzraumLayout.astro';
import { getCollection } from 'astro:content';

// Artikel-Anzahl live aus Collection
const blog = await getCollection('blog');
const articleCount = blog.length;
---
<HerzraumLayout title="Dashboard" active="overview">
  <!-- Today-Widget: die wichtigsten Live-Zahlen für den aktuellen Tag
       in einer eigenen, visuell hervorgehobenen Zeile. -->
  <div class="hz-card" style="margin-bottom: 1rem; background: linear-gradient(135deg, rgba(244,63,94,0.05), rgba(244,63,94,0.02)); border-left: 4px solid #f43f5e;">
    <h3 style="margin: 0 0 0.75rem; font-size: 1rem; display: flex; align-items: center; gap: 0.5rem;">
      <span style="width: 8px; height: 8px; border-radius: 50%; background: #10b981; box-shadow: 0 0 12px #10b981; animation: hz-pulse 2s ease-in-out infinite;"></span>
      Heute
      <span id="today-date" style="font-size: 0.75rem; font-weight: 400; color: var(--hz-text-muted);"></span>
    </h3>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 0.75rem;">
      <div>
        <div style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--hz-text-muted); margin-bottom: 0.25rem;">💰 Umsatz</div>
        <div style="font-size: 1.5rem; font-weight: 700; color: var(--hz-text);" data-kpi="revenue.todayEur">—</div>
        <div style="font-size: 0.75rem; color: var(--hz-text-muted);"><span data-kpi="purchases.today">—</span> Käufe</div>
      </div>
      <div>
        <div style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--hz-text-muted); margin-bottom: 0.25rem;">📩 Newsletter</div>
        <div style="font-size: 1.5rem; font-weight: 700; color: var(--hz-text);" data-kpi="newsletter.today">—</div>
        <div style="font-size: 0.75rem; color: var(--hz-text-muted);">neue Signups heute</div>
      </div>
      <div>
        <div style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--hz-text-muted); margin-bottom: 0.25rem;">👤 Registrierungen</div>
        <div style="font-size: 1.5rem; font-weight: 700; color: var(--hz-text);" data-kpi="registrations.today">—</div>
        <div style="font-size: 0.75rem; color: var(--hz-text-muted);">neue User heute</div>
      </div>
      <div>
        <div style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--hz-text-muted); margin-bottom: 0.25rem;">👁️ Pageviews</div>
        <div style="font-size: 1.5rem; font-weight: 700; color: var(--hz-text);" data-kpi="pageviews.today">—</div>
        <div style="font-size: 0.75rem; color: var(--hz-text-muted);"><span data-kpi="clicks.today">—</span> Affiliate-Klicks</div>
      </div>
    </div>
  </div>
  <style>
    @keyframes hz-pulse {
      0%, 100% { opacity: 1; transform: scale(1); }
      50% { opacity: 0.6; transform: scale(1.3); }
    }
  </style>

  <section class="hz-kpi-grid">
    <div class="hz-kpi">
      <div class="hz-kpi-label">Seitenaufrufe heute</div>
      <div class="hz-kpi-value" data-kpi="pageviews.today">—</div>
      <div class="hz-kpi-delta flat" data-kpi-delta="pageviews">—</div>
    </div>
    <div class="hz-kpi">
      <div class="hz-kpi-label">Seitenaufrufe · 7 Tage</div>
      <div class="hz-kpi-value" data-kpi="pageviews.week">—</div>
    </div>
    <div class="hz-kpi">
      <div class="hz-kpi-label">Artikel gesamt</div>
      <div class="hz-kpi-value">{articleCount.toLocaleString('de-DE')}</div>
    </div>
    <div class="hz-kpi">
      <div class="hz-kpi-label">Newsletter-Abonnenten</div>
      <div class="hz-kpi-value" data-kpi="newsletter.total">—</div>
    </div>
    <div class="hz-kpi">
      <div class="hz-kpi-label">Registrierte User</div>
      <div class="hz-kpi-value" data-kpi="registrations.total">—</div>
    </div>
    <div class="hz-kpi">
      <div class="hz-kpi-label">Affiliate-Klicks heute</div>
      <div class="hz-kpi-value" data-kpi="clicks.today">—</div>
    </div>
    <div class="hz-kpi">
      <div class="hz-kpi-label">Produkte aktiv</div>
      <div class="hz-kpi-value" id="kpi-products-active">—</div>
      <div class="hz-kpi-delta flat" id="kpi-products-sub">—</div>
    </div>
  </section>

  <!-- Conversion-Funnel (30 Tage) -->
  <div class="hz-card" style="margin-bottom: 1rem;">
    <h3>🔻 Conversion-Funnel · letzte 30 Tage</h3>
    <div id="funnel" style="display: grid; grid-template-columns: repeat(auto-fit, minmax(180px, 1fr)); gap: 0.75rem; margin-top: 1rem;">
      <div class="funnel-step" data-step="pageviews">
        <div class="funnel-label">Seitenaufrufe</div>
        <div class="funnel-value">—</div>
        <div class="funnel-rate">100%</div>
      </div>
      <div class="funnel-step" data-step="clicks">
        <div class="funnel-label">Affiliate-Klicks</div>
        <div class="funnel-value">—</div>
        <div class="funnel-rate">—</div>
      </div>
      <div class="funnel-step" data-step="subscribers">
        <div class="funnel-label">Newsletter-Signups</div>
        <div class="funnel-value">—</div>
        <div class="funnel-rate">—</div>
      </div>
      <div class="funnel-step" data-step="purchases">
        <div class="funnel-label">E-Book-Käufe</div>
        <div class="funnel-value">—</div>
        <div class="funnel-rate">—</div>
      </div>
    </div>
  </div>

  <style>
    .funnel-step {
      padding: 1rem 1.25rem;
      background: linear-gradient(145deg, var(--hz-surface), var(--hz-bg-2));
      border: 1px solid var(--hz-border);
      border-radius: 12px;
      position: relative;
    }
    .funnel-step::after {
      content: '→';
      position: absolute;
      right: -8px;
      top: 50%;
      transform: translateY(-50%);
      color: var(--hz-text-dim);
      font-weight: 300;
      font-size: 1.2rem;
      z-index: 1;
      text-shadow: 0 0 4px var(--hz-bg);
    }
    .funnel-step:last-child::after { display: none; }
    .funnel-label {
      font-size: 0.72rem;
      color: var(--hz-text-muted);
      text-transform: uppercase;
      letter-spacing: 0.1em;
      margin-bottom: 0.4rem;
      font-weight: 600;
    }
    .funnel-value {
      font-size: 1.5rem;
      font-weight: 800;
      font-family: 'Playfair Display', serif;
      color: var(--hz-text);
      letter-spacing: -0.02em;
    }
    .funnel-rate {
      font-size: 0.78rem;
      color: var(--hz-primary);
      margin-top: 0.25rem;
      font-weight: 600;
      font-variant-numeric: tabular-nums;
    }
    @media (max-width: 640px) {
      .funnel-step::after { display: none; }
    }
  </style>

  <div class="hz-card">
    <h3>Seitenaufrufe · letzte 30 Tage</h3>
    <div style="position: relative; height: 280px;">
      <canvas id="chart-pageviews"></canvas>
    </div>
  </div>

  <div class="hz-grid-2" style="margin-top: 1rem;">
    <div class="hz-card">
      <h3>Top 10 Artikel · 30 Tage</h3>
      <table class="hz-table" id="table-top-articles">
        <thead><tr><th>#</th><th>Pfad</th><th class="right">Aufrufe</th></tr></thead>
        <tbody><tr><td colspan="3" class="muted">Lade…</td></tr></tbody>
      </table>
    </div>
    <div class="hz-card">
      <h3>Top Referrer · 30 Tage</h3>
      <table class="hz-table" id="table-top-referrers">
        <thead><tr><th>#</th><th>Quelle</th><th class="right">Aufrufe</th></tr></thead>
        <tbody><tr><td colspan="3" class="muted">Lade…</td></tr></tbody>
      </table>
    </div>
  </div>

  <div class="hz-card" style="margin-top: 1rem;">
    <h3>Letzte Aktivität</h3>
    <table class="hz-table" id="table-activity">
      <thead><tr><th>Zeit</th><th>Pfad</th><th>Referrer</th></tr></thead>
      <tbody><tr><td colspan="3" class="muted">Lade…</td></tr></tbody>
    </table>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js" is:inline></script>

  <script is:inline>
    (function() {
      const BASE = '/api/herzraum/stats';
      let chart = null;

      function setKpi(path, value) {
        const els = document.querySelectorAll('[data-kpi="' + path + '"]');
        els.forEach((el) => { el.textContent = (value || 0).toLocaleString('de-DE'); });
      }

      function fmtTs(iso) {
        try { return new Date(iso).toLocaleString('de-DE', { hour: '2-digit', minute: '2-digit', day: '2-digit', month: '2-digit' }); }
        catch { return '—'; }
      }

      function renderTable(id, rows) {
        const tbody = document.querySelector('#' + id + ' tbody');
        if (!tbody) return;
        if (!rows.length) {
          tbody.innerHTML = '<tr><td colspan="3" class="muted">Noch keine Daten</td></tr>';
          return;
        }
        tbody.innerHTML = rows.join('');
      }

      function renderChart(data) {
        const canvas = document.getElementById('chart-pageviews');
        if (!canvas) return;
        const ctx = canvas.getContext('2d');
        const labels = data.map((d) => d.date.slice(5));
        const values = data.map((d) => d.count);
        if (chart) chart.destroy();
        chart = new Chart(ctx, {
          type: 'line',
          data: {
            labels,
            datasets: [{
              label: 'Seitenaufrufe',
              data: values,
              borderColor: '#f43f5e',
              backgroundColor: 'rgba(244,63,94,0.12)',
              borderWidth: 2,
              pointRadius: 3,
              pointHoverRadius: 6,
              fill: true,
              tension: 0.35,
            }],
          },
          options: {
            responsive: true, maintainAspectRatio: false,
            plugins: { legend: { display: false } },
            scales: {
              x: { ticks: { color: '#64748b', maxRotation: 0 }, grid: { color: 'rgba(15,23,42,0.06)' } },
              y: { ticks: { color: '#64748b', precision: 0 }, grid: { color: 'rgba(15,23,42,0.06)' }, beginAtZero: true },
            },
          },
        });
      }

      function renderFunnel(pv, cl, nl, purchases) {
        const steps = [
          { key: 'pageviews', value: pv },
          { key: 'clicks', value: cl },
          { key: 'subscribers', value: nl },
          { key: 'purchases', value: purchases },
        ];
        steps.forEach((s, i) => {
          const el = document.querySelector(`.funnel-step[data-step="${s.key}"]`);
          if (!el) return;
          el.querySelector('.funnel-value').textContent = s.value.toLocaleString('de-DE');
          const rate = pv > 0 && i > 0 ? ((s.value / pv) * 100) : (i === 0 ? 100 : 0);
          el.querySelector('.funnel-rate').textContent = i === 0 ? '100%' : (rate.toFixed(2) + '%');
        });
      }

      async function loadProducts() {
        try {
          const res = await fetch('/api/herzraum/products');
          const data = await res.json();
          if (!data.ok) return;
          const prods = data.products || [];
          const active = prods.filter((p) => p.active).length;
          const totalClicks = prods.reduce((s, p) => s + (p.clicks || 0), 0);
          const el = document.getElementById('kpi-products-active');
          const sub = document.getElementById('kpi-products-sub');
          if (el) el.textContent = active.toLocaleString('de-DE');
          if (sub) sub.textContent = totalClicks > 0 ? (totalClicks.toLocaleString('de-DE') + ' Klicks gesamt') : ((prods.length - active) + ' inaktiv');
        } catch (e) { /* silent */ }
      }

      async function load() {
        try {
          const res = await fetch(BASE + '?range=30d');
          if (!res.ok) throw new Error('HTTP ' + res.status);
          const d = await res.json();
          if (!d.ok) throw new Error('API error');

          setKpi('pageviews.today', d.kpis.pageviews.today);
          setKpi('pageviews.week', d.kpis.pageviews.week);
          setKpi('newsletter.total', d.kpis.newsletter.total);
          setKpi('registrations.total', d.kpis.registrations.total);
          setKpi('clicks.today', d.kpis.clicks.today);

          // Today-Widget füllen
          setKpi('newsletter.today', d.kpis.newsletter?.today ?? 0);
          setKpi('registrations.today', d.kpis.registrations?.today ?? 0);
          setKpi('purchases.today', d.kpis.purchases?.today ?? 0);
          const revCents = d.kpis.revenue?.todayCents ?? 0;
          const revEur = (revCents / 100).toLocaleString('de-DE', {
            style: 'currency', currency: 'EUR',
          });
          document.querySelectorAll('[data-kpi="revenue.todayEur"]').forEach((el) => { el.textContent = revEur; });
          // Datum im Today-Header
          const dateEl = document.getElementById('today-date');
          if (dateEl) {
            dateEl.textContent = '· ' + new Date().toLocaleDateString('de-DE', {
              weekday: 'long', day: '2-digit', month: 'long',
            });
          }

          // Conversion-Funnel (30-Tage-Werte)
          const pv = d.kpis.pageviews.month || 0;
          const cl = d.kpis.clicks.month || 0;
          const nl = d.kpis.newsletter.month || 0;
          // purchases-count fetch separate (not in stats) — Bug-F8: Timeout damit Funnel
          // nicht ewig hängt wenn /purchases langsam ist
          Promise.race([
            fetch('/api/herzraum/purchases?limit=0', { cache: 'no-store' }).then(r => r.json()),
            new Promise((_, rej) => setTimeout(() => rej(new Error('purchase-timeout')), 5000))
          ]).then((pData) => {
            const purchases = pData && typeof pData.total === 'number' ? pData.total : 0;
            renderFunnel(pv, cl, nl, purchases);
          }).catch(() => renderFunnel(pv, cl, nl, 0));

          // Products-KPI parallel
          loadProducts();

          // DEFENSIV: Tabellen ZUERST (damit Chart-Fehler die Daten nicht killt)
          renderTable('table-top-articles',
            d.topArticles.map((a, i) => {
              const slug = a.slug || '—';
              return '<tr><td class="muted">' + (i + 1) + '</td><td><a href="' + slug + '" target="_blank" rel="noopener">' + slug + '</a></td><td class="right">' + a.count.toLocaleString('de-DE') + '</td></tr>';
            })
          );
          renderTable('table-top-referrers',
            d.topReferrers.map((r, i) => '<tr><td class="muted">' + (i + 1) + '</td><td>' + r.key + '</td><td class="right">' + r.count.toLocaleString('de-DE') + '</td></tr>')
          );
          renderTable('table-activity',
            d.recentActivity.map((a) => '<tr><td class="muted">' + fmtTs(a.ts) + '</td><td><a href="' + a.path + '" target="_blank" rel="noopener">' + a.path + '</a></td><td>' + a.referrer + '</td></tr>')
          );

          if (typeof Chart !== 'undefined') {
            try { renderChart(d.charts.pageviewsByDay); }
            catch (err) { console.error('[dashboard] chart:', err); }
          }
        } catch (e) {
          console.error('Stats load failed:', e);
        }
      }

      load();
      // Polling pausieren wenn Tab nicht sichtbar — spart API-Calls + Strom.
      // Außerdem sofort refreshen, sobald der Tab wieder sichtbar wird
      // (User kommt zurück → soll nicht mit stalen Daten starren).
      let pollTimer = null;
      function startPolling() {
        if (pollTimer) return;
        pollTimer = setInterval(load, 60_000);
      }
      function stopPolling() {
        if (pollTimer) { clearInterval(pollTimer); pollTimer = null; }
      }
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) { stopPolling(); }
        else { load(); startPolling(); }
      });
      if (!document.hidden) startPolling();
    })();
  </script>
</HerzraumLayout>
