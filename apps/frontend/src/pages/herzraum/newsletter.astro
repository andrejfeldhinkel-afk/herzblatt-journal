---
export const prerender = false;
import HerzraumLayout from '../../layouts/HerzraumLayout.astro';
---
<HerzraumLayout title="Newsletter" active="newsletter">

  <section class="hz-kpi-grid">
    <div class="hz-kpi">
      <div class="hz-kpi-label">Abonnenten gesamt</div>
      <div class="hz-kpi-value" data-kpi="nl.total">—</div>
    </div>
    <div class="hz-kpi">
      <div class="hz-kpi-label">Neu heute</div>
      <div class="hz-kpi-value" data-kpi="nl.today">—</div>
    </div>
    <div class="hz-kpi">
      <div class="hz-kpi-label">Neu · 7 Tage</div>
      <div class="hz-kpi-value" data-kpi="nl.week">—</div>
    </div>
    <div class="hz-kpi">
      <div class="hz-kpi-label">Neu · 30 Tage</div>
      <div class="hz-kpi-value" data-kpi="nl.month">—</div>
    </div>
  </section>

  <div class="hz-card">
    <h3>Wachstum · 60 Tage</h3>
    <div style="position: relative; height: 280px;">
      <canvas id="chart-growth"></canvas>
    </div>
  </div>

  <div class="hz-card" style="margin-top: 1rem;">
    <div class="hz-row" style="margin-bottom: 0.75rem;">
      <h3 style="margin: 0;">Abonnenten</h3>
      <div class="hz-spacer"></div>
      <label style="display: inline-flex; align-items: center; gap: 0.4rem; font-size: 0.85rem; color: var(--hz-text-muted); cursor: pointer; user-select: none;">
        <input type="checkbox" id="show-full-emails" style="accent-color: var(--hz-primary);">
        Volle E-Mails zeigen
      </label>
      <a class="hz-btn primary" href="/api/herzraum/newsletter/export" download>📥 CSV-Export</a>
    </div>
    <p style="font-size: 0.8rem; color: var(--hz-text-muted); margin-bottom: 0.75rem;">
      E-Mails werden standardmäßig maskiert (a***@gmail.com). Toggle ↑ für volle Adressen.
    </p>
    <div style="overflow-x: auto; max-height: 560px; overflow-y: auto;">
      <table class="hz-table" id="table-nl">
        <thead><tr><th>E-Mail</th><th>Datum</th><th>Quelle</th></tr></thead>
        <tbody><tr><td colspan="3" class="muted">Lade…</td></tr></tbody>
      </table>
    </div>
  </div>

  <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.2/dist/chart.umd.min.js" is:inline></script>

  <script is:inline>
    (function() {
      function fmt(n) { return (n || 0).toLocaleString('de-DE'); }
      function setKpi(p, v) { document.querySelectorAll('[data-kpi="'+p+'"]').forEach(el => el.textContent = fmt(v)); }

      async function load() {
        const showFull = document.getElementById('show-full-emails')?.checked;
        const listUrl = '/api/herzraum/newsletter/list' + (showFull ? '?mask=false' : '');
        const [statsRes, listRes] = await Promise.all([
          fetch('/api/herzraum/stats?range=30d').then(r => r.json()),
          fetch(listUrl).then(r => r.json()),
        ]);
        if (statsRes.ok) {
          setKpi('nl.total', statsRes.kpis.newsletter.total);
          setKpi('nl.today', statsRes.kpis.newsletter.today);
          setKpi('nl.week', statsRes.kpis.newsletter.week);
          setKpi('nl.month', statsRes.kpis.newsletter.month);
        }

        if (listRes.ok) {
          // STEP 1 — Tabelle IMMER ZUERST füllen (defensiv: damit Chart-Error die Daten nicht killt)
          const rows = [...listRes.entries].reverse().slice(0, 500);
          const tbody = document.querySelector('#table-nl tbody');
          tbody.innerHTML = rows.length
            ? rows.map(e => {
                const ts = e.ts ? new Date(e.ts).toLocaleString('de-DE', { day: '2-digit', month: '2-digit', year: 'numeric', hour: '2-digit', minute: '2-digit' }) : '—';
                return '<tr><td>' + e.email + '</td><td class="muted">' + ts + '</td><td><span class="hz-badge muted">' + (e.source || 'unknown') + '</span></td></tr>';
              }).join('')
            : '<tr><td colspan="3" class="muted">Noch keine Abonnenten</td></tr>';

          // STEP 2 — Chart (nur wenn Chart.js geladen ist)
          if (typeof Chart !== 'undefined') {
            try {
              const days60 = {};
              const now = new Date();
              for (let i = 59; i >= 0; i--) {
                const d = new Date(now.getTime() - i * 86_400_000);
                days60[d.toISOString().slice(0,10)] = 0;
              }
              listRes.entries.forEach(e => {
                const key = (e.ts || '').slice(0, 10);
                if (key in days60) days60[key]++;
              });
              let running = listRes.total - Object.values(days60).reduce((s, v) => s + v, 0);
              const labels = Object.keys(days60);
              const values = labels.map(k => { running += days60[k]; return running; });
              new Chart(document.getElementById('chart-growth').getContext('2d'), {
                type: 'line',
                data: { labels: labels.map(l => l.slice(5)), datasets: [{ label: 'Abonnenten', data: values, borderColor: '#f43f5e', backgroundColor: 'rgba(244,63,94,0.15)', tension: 0.25, fill: true, borderWidth: 2 }] },
                options: { responsive: true, maintainAspectRatio: false, plugins: { legend: { display: false } }, scales: { x: { ticks: { color: '#64748b', maxTicksLimit: 12 }, grid: { color: 'rgba(15,23,42,0.06)' } }, y: { ticks: { color: '#64748b', precision: 0 }, grid: { color: 'rgba(15,23,42,0.06)' }, beginAtZero: true } } },
              });
            } catch (err) { console.error('[newsletter] chart error:', err); }
          } else {
            // Chart.js geblockt/nicht verfügbar — fallback: kleine Info
            const chartEl = document.getElementById('chart-growth');
            if (chartEl && chartEl.parentElement) {
              chartEl.parentElement.innerHTML = '<p style="color: var(--hz-text-muted); font-size: 0.85rem; text-align: center; padding: 2rem;">Chart-Library nicht geladen. Daten siehe Tabelle unten.</p>';
            }
          }
        }
      }
      load();

      // Toggle: Volle E-Mails zeigen → reload nur Tabelle (ohne Chart neu zu bauen)
      document.getElementById('show-full-emails')?.addEventListener('change', async () => {
        const showFull = document.getElementById('show-full-emails').checked;
        const listUrl = '/api/herzraum/newsletter/list' + (showFull ? '?mask=false' : '');
        const tbody = document.querySelector('#table-nl tbody');
        tbody.innerHTML = '<tr><td colspan="3" class="muted">Lade…</td></tr>';
        try {
          const r = await fetch(listUrl).then(r => r.json());
          if (r.ok) {
            const rows = [...r.entries].reverse().slice(0, 500);
            tbody.innerHTML = rows.length
              ? rows.map(e => {
                  const ts = e.ts ? new Date(e.ts).toLocaleString('de-DE', { day:'2-digit', month:'2-digit', year:'numeric', hour:'2-digit', minute:'2-digit' }) : '—';
                  return '<tr><td>' + e.email + '</td><td class="muted">' + ts + '</td><td><span class="hz-badge muted">' + (e.source||'unknown') + '</span></td></tr>';
                }).join('')
              : '<tr><td colspan="3" class="muted">Keine Abonnenten</td></tr>';
          }
        } catch { /* ignore */ }
      });
    })();
  </script>
</HerzraumLayout>
