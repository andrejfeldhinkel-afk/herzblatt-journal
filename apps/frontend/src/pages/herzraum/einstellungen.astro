---
export const prerender = false;
import HerzraumLayout from '../../layouts/HerzraumLayout.astro';
---
<HerzraumLayout title="Einstellungen" active="einstellungen">

  <div class="hz-card">
    <h3>Passwort ändern</h3>
    <p style="color: var(--hz-text-muted); font-size: 0.85rem; margin-bottom: 1rem;">
      Das Herzraum-Passwort wird über die Umgebungsvariable <code style="background:var(--hz-surface-2);padding:2px 6px;border-radius:4px;">HERZRAUM_PASSWORD</code> gesetzt.
      Zum Ändern:
    </p>
    <ol style="color: var(--hz-text-muted); padding-left: 1.2rem; font-size: 0.9rem; line-height: 1.8;">
      <li>Railway Dashboard öffnen → Projekt Herzblatt-Journal → <strong>Variables</strong></li>
      <li>Variable <code style="background:var(--hz-surface-2);padding:2px 6px;border-radius:4px;">HERZRAUM_PASSWORD</code> editieren</li>
      <li>Railway triggert automatisch einen Redeploy (~3 Min.)</li>
      <li>Danach alle offenen Sessions abmelden (aus Sicherheitsgründen)</li>
    </ol>
    <form id="verify-form" style="margin-top: 1rem; display: flex; gap: 0.5rem; align-items: end;">
      <div style="flex: 1;">
        <label style="font-size: 0.75rem; color: var(--hz-text-muted); text-transform: uppercase;">Aktuelles Passwort testen</label>
        <input type="password" id="current-pw" style="width: 100%; margin-top: 0.25rem;" />
      </div>
      <button class="hz-btn" type="submit">Prüfen</button>
      <span id="verify-result" style="font-size: 0.85rem;"></span>
    </form>
  </div>

  <div class="hz-card">
    <h3>Daten-Export</h3>
    <p style="color: var(--hz-text-muted); font-size: 0.85rem; margin-bottom: 1rem;">
      Vollständiges Backup aller Tracking-Daten als JSON. Enthält Pageviews, Klicks, Registrierungen und Newsletter-Abonnenten.
    </p>
    <a href="/api/herzraum/data/export" download class="hz-btn primary">📦 Alle Daten herunterladen</a>
  </div>

  <div class="hz-card">
    <h3>Cache leeren</h3>
    <p style="color: var(--hz-text-muted); font-size: 0.85rem; margin-bottom: 1rem;">
      Löscht die pre-aggregierte Daily-Stats-Datei (wird beim nächsten Dashboard-Load neu aufgebaut).
    </p>
    <button class="hz-btn" data-clear="daily-stats">🧹 Stats-Cache leeren</button>
  </div>

  <div class="hz-card">
    <h3>💾 Backup-Export</h3>
    <p style="color: var(--hz-text-muted); font-size: 0.85rem; margin-bottom: 0.75rem;">
      Zieht einen JSON-Snapshot aller wichtigen Tabellen (Subscribers, Verkäufe ohne raw_payload, Todos, Newsletter-Broadcasts, Audit-Log letzte 30 Tage, Produkte, Redirects). <strong>Offline speichern</strong> — Railway-Hobby hat keine Point-in-Time-Recovery.
    </p>
    <div class="hz-row" style="gap: 0.5rem; flex-wrap: wrap;">
      <button class="hz-btn" id="backup-preview">Counts anzeigen</button>
      <button class="hz-btn primary" id="backup-download">📥 Backup herunterladen</button>
      <span id="backup-status" style="font-size: 0.85rem; color: var(--hz-text-muted);"></span>
    </div>
    <pre id="backup-summary" style="display: none; margin-top: 0.75rem; padding: 0.75rem; background: var(--hz-surface-2); border-radius: 6px; font-size: 0.75rem; color: var(--hz-text); overflow-x: auto;"></pre>
  </div>

  <div class="hz-card" style="border-color: rgba(239,68,68,0.4);">
    <h3 style="color: var(--hz-danger);">⚠ Gefahrenzone</h3>
    <p style="color: var(--hz-text-muted); font-size: 0.85rem; margin-bottom: 1rem;">
      Die folgenden Aktionen sind <strong>nicht rückgängig machbar</strong>. Daten nach dem Löschen wiederherzustellen ist nicht möglich.
    </p>
    <div class="hz-row">
      <button class="hz-btn danger" data-clear="pageviews">Pageviews löschen</button>
      <button class="hz-btn danger" data-clear="clicks">Klicks löschen</button>
      <button class="hz-btn danger" data-clear="registrations">Registrierungen löschen</button>
    </div>
    <p style="color: var(--hz-text-dim); font-size: 0.75rem; margin-top: 0.75rem;">
      Newsletter-Abonnenten können hier <strong>nicht</strong> gelöscht werden (DSGVO-Anfragen manuell in <code>data/subscribers.csv</code>).
    </p>
  </div>

  <div class="hz-card">
    <h3>Railway-Hinweis</h3>
    <p style="color: var(--hz-text-muted); font-size: 0.85rem;">
      ⚠ <strong>Railway-Filesystem ist ephemeral</strong>: Bei jedem Git-Push wird <code>data/*.json</code> gelöscht.
      Regelmäßig Backups ziehen! Nutze dazu das <strong>Daten-Export</strong>-Feature oder das Script <code>scripts/pull-subscribers.sh</code> für die Newsletter-CSV.
    </p>
  </div>

  <script is:inline>
    (function() {
      // Backup-Preview: counts vom Backend holen
      const btnPreview = document.getElementById('backup-preview');
      const btnDownload = document.getElementById('backup-download');
      const statusEl = document.getElementById('backup-status');
      const summaryEl = document.getElementById('backup-summary');

      if (btnPreview) btnPreview.addEventListener('click', async () => {
        statusEl.textContent = 'Lade Counts…';
        statusEl.style.color = 'var(--hz-text-muted)';
        try {
          const res = await fetch('/api/herzraum/backup/summary');
          const data = await res.json();
          if (data.ok) {
            summaryEl.style.display = 'block';
            summaryEl.textContent = JSON.stringify(data, null, 2);
            statusEl.textContent = '';
          } else {
            statusEl.textContent = 'Fehler beim Laden';
            statusEl.style.color = 'var(--hz-danger)';
          }
        } catch (err) {
          statusEl.textContent = 'Netzwerk-Fehler';
          statusEl.style.color = 'var(--hz-danger)';
        }
      });

      if (btnDownload) btnDownload.addEventListener('click', async () => {
        btnDownload.disabled = true;
        btnDownload.textContent = 'Generiere Backup…';
        statusEl.textContent = '';
        try {
          const res = await fetch('/api/herzraum/backup');
          if (!res.ok) throw new Error('HTTP ' + res.status);
          const blob = await res.blob();
          // Filename aus Content-Disposition ziehen, sonst Fallback
          const cd = res.headers.get('content-disposition') || '';
          const m = cd.match(/filename="?([^";]+)"?/);
          const filename = m ? m[1] : 'herzblatt-backup-' + new Date().toISOString().slice(0,10) + '.json';
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url; a.download = filename;
          document.body.appendChild(a); a.click(); document.body.removeChild(a);
          URL.revokeObjectURL(url);
          const sizeMb = (blob.size / 1024 / 1024).toFixed(2);
          statusEl.textContent = '✓ Heruntergeladen (' + sizeMb + ' MB). Offline speichern!';
          statusEl.style.color = '#10b981';
        } catch (err) {
          statusEl.textContent = 'Fehler: ' + (err && err.message || 'Unbekannt');
          statusEl.style.color = 'var(--hz-danger)';
        } finally {
          btnDownload.disabled = false;
          btnDownload.textContent = '📥 Backup herunterladen';
        }
      });

      // Passwort verifizieren
      document.getElementById('verify-form').addEventListener('submit', async (e) => {
        e.preventDefault();
        const pw = document.getElementById('current-pw').value;
        const out = document.getElementById('verify-result');
        out.textContent = '…';
        try {
          const res = await fetch('/api/herzraum/password/verify', {
            method: 'POST', headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ password: pw }),
          });
          if (res.ok) { out.textContent = '✓ korrekt'; out.style.color = 'var(--hz-success)'; }
          else { out.textContent = '✗ falsch'; out.style.color = 'var(--hz-danger)'; }
        } catch {
          out.textContent = 'Fehler'; out.style.color = 'var(--hz-danger)';
        }
      });

      // Clear-Buttons
      // Backend erzwingt bei destruktiven Targets (pageviews/clicks/registrations)
      // die Bestätigungsphrase "LOESCHEN" im Request-Body. Frontend-seitig muss
      // der User das Wort explizit eintippen — kein Single-Click-Delete mehr.
      document.querySelectorAll('[data-clear]').forEach((btn) => {
        btn.addEventListener('click', async () => {
          const target = btn.getAttribute('data-clear');
          const danger = btn.classList.contains('danger');

          let confirmationPhrase = '';
          if (danger) {
            // Zwei-Stufen-Bestätigung: (1) Warnung, (2) Phrase eintippen
            const ack = confirm(
              'Wirklich alle "' + target + '"-Daten löschen?\n\n' +
              'Das lässt sich NICHT rückgängig machen.\n\n' +
              'Im nächsten Dialog musst du "LOESCHEN" (genau so, GROSSBUCHSTABEN) eintippen.'
            );
            if (!ack) return;
            const phrase = prompt(
              'Bestätigungsphrase eintippen:\n\nBitte das Wort LOESCHEN exakt so (GROSSBUCHSTABEN) eingeben,\n' +
              'um das Löschen von "' + target + '" endgültig zu bestätigen.'
            );
            if (phrase === null) return; // Cancel
            if (phrase !== 'LOESCHEN') {
              alert('Bestätigungsphrase falsch. Aktion abgebrochen (nichts gelöscht).');
              return;
            }
            confirmationPhrase = phrase;
          } else {
            // Non-danger (daily-stats) — einfache Bestätigung
            if (!confirm('Stats-Cache leeren?')) return;
            // Backend verlangt trotzdem die Phrase (Schema ist uniform).
            confirmationPhrase = 'LOESCHEN';
          }

          btn.disabled = true;
          const orig = btn.textContent;
          btn.textContent = 'Löschen…';
          try {
            const res = await fetch('/api/herzraum/data/clear', {
              method: 'POST', headers: { 'Content-Type': 'application/json' },
              body: JSON.stringify({ target, confirmationPhrase }),
            });
            const d = await res.json();
            if (d.ok) {
              const msg = typeof d.count === 'number'
                ? '✓ gelöscht (' + d.count + ')'
                : '✓ gelöscht';
              btn.textContent = msg;
              setTimeout(() => { btn.textContent = orig; btn.disabled = false; }, 1800);
            } else {
              alert('Fehler: ' + (d.message || ''));
              btn.textContent = orig; btn.disabled = false;
            }
          } catch (e) {
            alert('Fehler: ' + e); btn.textContent = orig; btn.disabled = false;
          }
        });
      });
    })();
  </script>
</HerzraumLayout>
