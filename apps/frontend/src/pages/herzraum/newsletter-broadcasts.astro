---
export const prerender = false;
import HerzraumLayout from '../../layouts/HerzraumLayout.astro';
---
<HerzraumLayout title="Newsletter-Broadcasts" active="newsletter-broadcasts">

  <!-- Header / KPIs -->
  <section class="hz-kpi-grid">
    <div class="hz-kpi">
      <div class="hz-kpi-label">Aktive Abonnenten</div>
      <div class="hz-kpi-value" data-kpi="active-subs">—</div>
      <div class="hz-kpi-hint" style="font-size: 0.75rem; color: var(--hz-text-muted);">werden bei Send benachrichtigt</div>
    </div>
    <div class="hz-kpi">
      <div class="hz-kpi-label">SendGrid-Status</div>
      <div class="hz-kpi-value" data-kpi="sg-status" style="font-size: 1.15rem;">—</div>
    </div>
  </section>

  <!-- SendGrid-Warnung -->
  <div id="sg-warn" class="hz-card hidden" style="margin-top: 1rem; border-left: 4px solid #f59e0b; background: rgba(245, 158, 11, 0.08);">
    <div style="display: flex; gap: 0.75rem; align-items: flex-start;">
      <div style="font-size: 1.5rem;">⚠️</div>
      <div>
        <h3 style="margin: 0 0 0.35rem 0; color: #f59e0b;">SendGrid nicht konfiguriert</h3>
        <p style="margin: 0; font-size: 0.9rem; color: var(--hz-text-muted);">
          Mass-Send ist deaktiviert bis <code>SENDGRID_API_KEY</code> als Env-Var im
          Railway-Backend-Service gesetzt ist. Drafts können erstellt, aber noch nicht
          versendet werden.
        </p>
      </div>
    </div>
  </div>

  <!-- Toolbar -->
  <div class="hz-row" style="justify-content: space-between; align-items: center; margin-top: 1.5rem; gap: 1rem; flex-wrap: wrap;">
    <h2 style="margin: 0;">Broadcasts</h2>
    <button type="button" id="btn-new" class="hz-btn primary">+ Neuer Broadcast</button>
  </div>

  <!-- Liste -->
  <div class="hz-card" style="margin-top: 1rem;">
    <div style="overflow-x: auto;">
      <table class="hz-table" id="table-broadcasts">
        <thead>
          <tr>
            <th>Betreff</th>
            <th>Erstellt</th>
            <th>Versendet</th>
            <th>Empfänger</th>
            <th>Status</th>
            <th>Aktionen</th>
          </tr>
        </thead>
        <tbody>
          <tr><td colspan="6" class="muted" style="text-align: center; padding: 2rem;">Lade…</td></tr>
        </tbody>
      </table>
    </div>
    <div id="pagination" style="display: flex; justify-content: center; gap: 0.5rem; margin-top: 1rem; flex-wrap: wrap;"></div>
  </div>

  <!-- ─── Modal: Neuer Broadcast ───────────────────────── -->
  <div id="modal-new" class="hz-modal-backdrop hidden">
    <div class="hz-modal" style="max-width: 860px;">
      <div class="hz-modal-head">
        <h3 style="margin: 0;">📣 Neuer Newsletter-Broadcast</h3>
        <button type="button" class="hz-modal-close" data-close>✕</button>
      </div>
      <form id="form-new" class="hz-modal-body" style="display: grid; gap: 1.25rem;">

        <!-- Modus-Wahl -->
        <div class="hz-row" style="gap: 0.5rem; background: var(--hz-surface-2); padding: 0.35rem; border-radius: 8px; width: fit-content;">
          <button type="button" class="hz-tab-btn active" data-mode="manual">✍️ Manuell</button>
          <button type="button" class="hz-tab-btn" data-mode="article">📰 Aus Artikel</button>
        </div>

        <!-- Artikel-Auswahl (nur im article-Modus) -->
        <div id="article-picker" class="hidden">
          <label style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 0.35rem;">Artikel-Slug</label>
          <input type="text" id="f-articleSlug" maxlength="80"
                 placeholder="bindungsangst-erkennen"
                 style="width: 100%; padding: 0.7rem 0.85rem; font-size: 0.95rem;">
          <p style="font-size: 0.8rem; color: var(--hz-text-muted); margin-top: 0.35rem;">
            Der Slug bezieht sich auf <code>/blog/&lt;slug&gt;</code>. Wird nur als Referenz gespeichert.
            Betreff und Body musst du trotzdem ausfüllen.
          </p>
          <button type="button" id="btn-prefill" class="hz-btn" style="margin-top: 0.5rem;">
            Betreff + Link vorbefüllen
          </button>
        </div>

        <!-- Subject -->
        <div>
          <label for="f-subject" style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 0.35rem;">Betreff *</label>
          <input type="text" id="f-subject" required minlength="3" maxlength="300"
                 placeholder="Neuer Artikel: Wie du Bindungsangst erkennst"
                 style="width: 100%; padding: 0.7rem 0.85rem; font-size: 0.95rem;">
          <!-- Live Subject-Line-Scorer: Heuristik gegen Spam-Triggers,
               Länge, Emoji-Dichte, ALL-CAPS. Rein clientseitig, rein
               informativ — blockt keinen Send. -->
          <div id="subject-score" style="margin-top: 0.5rem; display: flex; gap: 0.5rem; align-items: center; flex-wrap: wrap; font-size: 0.78rem;">
            <span id="subject-score-badge" style="padding: 0.2rem 0.55rem; border-radius: 999px; font-weight: 600; background: var(--hz-surface-2); color: var(--hz-text-muted);">—</span>
            <span id="subject-score-len" style="color: var(--hz-text-muted);">0 Zeichen</span>
            <span id="subject-score-tips" style="color: var(--hz-text-muted); flex: 1; min-width: 150px;"></span>
          </div>
        </div>

        <!-- Body (HTML) -->
        <div>
          <label for="f-bodyHtml" style="display: block; font-size: 0.85rem; font-weight: 600; margin-bottom: 0.35rem;">
            Body (HTML) *
            <span style="color: var(--hz-text-muted); font-weight: 400;">
              — nutze <code>{{UNSUBSCRIBE_URL}}</code> als Platzhalter, sonst wird ein Footer angehängt
            </span>
          </label>
          <textarea id="f-bodyHtml" required rows="14" minlength="20" maxlength="200000"
                    style="width: 100%; padding: 0.7rem 0.85rem; font-size: 0.9rem; font-family: 'SF Mono', Menlo, monospace; resize: vertical;"
                    placeholder="<h1>Hallo!</h1>&#10;&#10;<p>Hier ist unser neuer Artikel:</p>&#10;&#10;<p><a href=&quot;https://herzblatt-journal.com/blog/slug&quot;>Jetzt lesen</a></p>"></textarea>
        </div>

        <!-- Preview: iframe-gesandboxed damit das Admin-CSS nicht reinleuchtet
             und man sieht was der Subscriber im Email-Client ungefähr kriegt. -->
        <details>
          <summary style="cursor: pointer; user-select: none; font-size: 0.9rem; font-weight: 600;">👁️ Vorschau (isoliertes iframe — Email-Client-Simulation)</summary>
          <div style="margin-top: 0.5rem; border: 1px dashed var(--hz-border); border-radius: 10px; overflow: hidden; background: white;">
            <iframe
              id="preview-frame"
              sandbox="allow-same-origin"
              title="Newsletter-Vorschau"
              style="width: 100%; height: 420px; border: 0; background: white; display: block;"
            ></iframe>
          </div>
          <p style="font-size: 0.72rem; color: var(--hz-text-muted); margin: 0.35rem 0 0;">
            Hinweis: Links sind hier gesandboxed — real ist <code>{{UNSUBSCRIBE_URL}}</code> pro
            Empfänger individuell. Whitespace / Header / Footer können je nach Email-Client abweichen
            (Gmail stript Style-Tags, Outlook rendert strenger).
          </p>
        </details>

        <!-- Scheduling — optional; wenn gesetzt wird der Send zum Zeitpunkt
             durch den Backend-Scheduler getriggert. -->
        <div style="border: 1px solid var(--hz-border); border-radius: 10px; padding: 0.85rem 1rem; background: var(--hz-surface);">
          <label style="display: flex; align-items: center; gap: 0.5rem; font-size: 0.9rem; font-weight: 600; margin-bottom: 0.5rem;">
            <input type="checkbox" id="chk-schedule" style="width: 1rem; height: 1rem;">
            ⏰ Später senden (Draft + Zeitpunkt setzen)
          </label>
          <div id="schedule-wrap" class="hidden" style="margin-top: 0.5rem;">
            <input type="datetime-local" id="input-schedule" class="hz-input" style="max-width: 260px;">
            <p style="font-size: 0.75rem; color: var(--hz-text-muted); margin-top: 0.35rem;">
              Mind. 2 Min in der Zukunft, max. 90 Tage. Lokale Zeitzone.
              Scheduled Drafts senden auch wenn du nicht eingeloggt bist.
            </p>
          </div>
        </div>

        <!-- Action buttons -->
        <div class="hz-row" style="gap: 0.75rem; justify-content: space-between; flex-wrap: wrap;">
          <div style="display: flex; gap: 0.5rem; flex-wrap: wrap;">
            <button type="button" id="btn-save-draft" class="hz-btn">Als Draft speichern</button>
            <button type="button" id="btn-test" class="hz-btn">📧 Testmail an mich</button>
          </div>
          <div style="display: flex; gap: 0.5rem;">
            <button type="button" class="hz-btn" data-close>Abbrechen</button>
            <button type="submit" id="btn-send" class="hz-btn primary">📣 Jetzt senden</button>
          </div>
        </div>

        <div id="form-result" class="hidden" style="padding: 0.85rem 1rem; border-radius: 8px; font-size: 0.9rem;"></div>
      </form>
    </div>
  </div>

  <style>
    .hz-kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 0.75rem; }
    .hz-kpi { background: var(--hz-surface); border: 1px solid var(--hz-border); border-radius: var(--hz-radius); padding: 1rem; }
    .hz-kpi-label { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.08em; color: var(--hz-text-muted); }
    .hz-kpi-value { font-size: 1.75rem; font-weight: 700; margin-top: 0.35rem; color: var(--hz-text); }
    .hz-row { display: flex; align-items: center; }
    .hz-card { background: var(--hz-surface); border: 1px solid var(--hz-border); border-radius: var(--hz-radius); padding: 1.25rem; }
    .hz-table { width: 100%; border-collapse: collapse; font-size: 0.9rem; }
    .hz-table th { text-align: left; padding: 0.65rem 0.5rem; border-bottom: 1px solid var(--hz-border); color: var(--hz-text-muted); font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.05em; font-weight: 600; }
    .hz-table td { padding: 0.75rem 0.5rem; border-bottom: 1px solid var(--hz-border); vertical-align: middle; }
    .hz-table tr:last-child td { border-bottom: none; }
    .hz-table .muted { color: var(--hz-text-muted); }
    .hz-btn {
      display: inline-block; padding: 0.55rem 1rem; border: 1px solid var(--hz-border-strong);
      background: var(--hz-surface-2); color: var(--hz-text); border-radius: 8px;
      font-weight: 600; font-size: 0.85rem; cursor: pointer; transition: all 0.15s;
    }
    .hz-btn:hover:not(:disabled) { background: var(--hz-surface-3); border-color: var(--hz-primary); }
    .hz-btn.primary { background: linear-gradient(135deg, var(--hz-primary), var(--hz-primary-dark)); border-color: var(--hz-primary-dark); color: white; }
    .hz-btn.primary:hover:not(:disabled) { transform: translateY(-1px); box-shadow: 0 4px 12px var(--hz-primary-glow); }
    .hz-btn:disabled { opacity: 0.5; cursor: not-allowed; }
    .hz-btn.danger { color: #fca5a5; border-color: rgba(239, 68, 68, 0.3); }
    .hz-btn.danger:hover:not(:disabled) { background: rgba(239, 68, 68, 0.15); border-color: var(--hz-danger); }
    .hidden { display: none !important; }
    .status-badge { display: inline-block; padding: 0.15rem 0.55rem; border-radius: 999px; font-size: 0.72rem; font-weight: 600; text-transform: uppercase; letter-spacing: 0.05em; }
    .status-draft { background: rgba(148, 163, 184, 0.2); color: #cbd5e1; }
    .status-scheduled { background: rgba(234, 179, 8, 0.2); color: #fde047; }
    .status-sending { background: rgba(56, 189, 248, 0.2); color: #7dd3fc; }
    .status-sent { background: rgba(16, 185, 129, 0.2); color: #6ee7b7; }
    .status-failed { background: rgba(239, 68, 68, 0.2); color: #fca5a5; }

    /* Modal */
    .hz-modal-backdrop {
      position: fixed; inset: 0; background: rgba(0, 0, 0, 0.7); backdrop-filter: blur(4px);
      display: flex; align-items: flex-start; justify-content: center; padding: 2rem 1rem;
      z-index: 100; overflow-y: auto;
    }
    .hz-modal { background: var(--hz-surface); border: 1px solid var(--hz-border); border-radius: var(--hz-radius-lg); width: 100%; max-width: 680px; box-shadow: var(--hz-shadow-lg); }
    .hz-modal-head { display: flex; align-items: center; justify-content: space-between; padding: 1.25rem; border-bottom: 1px solid var(--hz-border); }
    .hz-modal-body { padding: 1.5rem; }
    .hz-modal-close { background: none; border: none; color: var(--hz-text-muted); font-size: 1.5rem; cursor: pointer; padding: 0.25rem 0.5rem; }
    .hz-modal-close:hover { color: var(--hz-text); }

    .hz-tab-btn {
      padding: 0.4rem 0.85rem; border: none; background: transparent; color: var(--hz-text-muted);
      font-size: 0.85rem; font-weight: 600; cursor: pointer; border-radius: 6px; transition: all 0.15s;
    }
    .hz-tab-btn.active { background: var(--hz-surface); color: var(--hz-text); }

    @media (max-width: 600px) {
      .hz-table th:nth-child(3), .hz-table td:nth-child(3) { display: none; }
      .hz-kpi-value { font-size: 1.35rem; }
    }
  </style>

  <script is:inline>
    (function () {
      const API_BASE = '/api/herzraum/newsletter-broadcast';
      let currentPage = 1;
      let currentMode = 'manual';
      let currentDraftId = null;

      function fmt(n) { return (n || 0).toLocaleString('de-DE'); }
      function fmtDate(iso) {
        if (!iso) return '—';
        try {
          return new Date(iso).toLocaleString('de-DE', {
            day: '2-digit', month: '2-digit', year: '2-digit',
            hour: '2-digit', minute: '2-digit'
          });
        } catch { return iso; }
      }
      function escapeHtml(s) {
        return String(s == null ? '' : s).replace(/[&<>"']/g, c =>
          ({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));
      }
      function $(id) { return document.getElementById(id); }

      function getCsrfToken() {
        const m = document.cookie.match(/(?:^|;\s*)hz_csrf=([^;]+)/);
        return m ? decodeURIComponent(m[1]) : '';
      }
      async function api(path, options) {
        options = options || {};
        const headers = Object.assign(
          { 'Content-Type': 'application/json' },
          options.headers || {},
        );
        const csrf = getCsrfToken();
        if (csrf) headers['x-csrf-token'] = csrf;
        const res = await fetch(API_BASE + path, Object.assign({}, options, { headers }));
        const ct = res.headers.get('content-type') || '';
        const data = ct.includes('application/json') ? await res.json() : null;
        return { ok: res.ok, status: res.status, data };
      }

      function showResult(msg, ok) {
        const el = $('form-result');
        el.classList.remove('hidden');
        el.style.background = ok ? 'rgba(16, 185, 129, 0.12)' : 'rgba(239, 68, 68, 0.12)';
        el.style.color = ok ? '#6ee7b7' : '#fca5a5';
        el.textContent = msg;
      }

      function renderStatusBadge(status) {
        return `<span class="status-badge status-${escapeHtml(status)}">${escapeHtml(status)}</span>`;
      }

      async function loadList(page) {
        currentPage = page || 1;
        const tbody = document.querySelector('#table-broadcasts tbody');
        tbody.innerHTML = '<tr><td colspan="6" class="muted" style="text-align: center; padding: 2rem;">Lade…</td></tr>';

        const resp = await api(`/?page=${currentPage}`);
        if (!resp.ok) {
          tbody.innerHTML = '<tr><td colspan="6" class="muted" style="text-align: center; padding: 2rem; color: #fca5a5;">Fehler beim Laden.</td></tr>';
          return;
        }
        const { broadcasts, total, totalPages, sendgridEnabled } = resp.data;

        // SendGrid-Status
        $('sg-status').textContent = sendgridEnabled ? '✓ aktiv' : '✗ aus';
        $('sg-status').style.color = sendgridEnabled ? '#10b981' : '#f59e0b';
        if (!sendgridEnabled) $('sg-warn').classList.remove('hidden');

        if (!broadcasts || broadcasts.length === 0) {
          tbody.innerHTML = '<tr><td colspan="6" class="muted" style="text-align: center; padding: 2rem;">Noch keine Broadcasts. Klick auf "+ Neuer Broadcast".</td></tr>';
          $('pagination').innerHTML = '';
          return;
        }

        tbody.innerHTML = broadcasts.map((b) => {
          const canDelete = b.status === 'draft';
          const canSend = b.status === 'draft';
          const canUnschedule = b.status === 'scheduled';
          const subjectHtml = b.articleSlug
            ? `${escapeHtml(b.subject)} <span style="font-size: 0.7rem; color: var(--hz-text-muted);">[${escapeHtml(b.articleSlug)}]</span>`
            : escapeHtml(b.subject);
          const recipientsCell = b.recipientCount != null
            ? `${fmt(b.successCount || 0)} / ${fmt(b.recipientCount)}`
            : '—';
          // Bei scheduled: zeigen wir scheduledFor in der "Versendet"-Spalte mit Präfix
          const sentCell = b.status === 'scheduled' && b.scheduledFor
            ? `<span style="color: #eab308;">⏰ ${escapeHtml(fmtDate(b.scheduledFor))}</span>`
            : fmtDate(b.sentAt);
          return `
            <tr data-id="${b.id}">
              <td style="max-width: 320px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;" title="${escapeHtml(b.subject)}">${subjectHtml}</td>
              <td style="font-size: 0.82rem; color: var(--hz-text-muted);">${fmtDate(b.createdAt)}</td>
              <td style="font-size: 0.82rem; color: var(--hz-text-muted);">${sentCell}</td>
              <td>${recipientsCell}</td>
              <td>${renderStatusBadge(b.status)}</td>
              <td>
                <div style="display: flex; gap: 0.35rem; flex-wrap: wrap;">
                  ${canSend ? `<button class="hz-btn primary" data-action="send">Senden</button>` : ''}
                  ${canUnschedule ? `<button class="hz-btn" data-action="unschedule">Zurück zu Draft</button>` : ''}
                  ${canDelete ? `<button class="hz-btn" data-action="edit">Bearbeiten</button>` : ''}
                  ${canDelete ? `<button class="hz-btn danger" data-action="delete">Löschen</button>` : ''}
                </div>
              </td>
            </tr>`;
        }).join('');

        // Pagination
        const pg = $('pagination');
        if (totalPages > 1) {
          let html = '';
          for (let i = 1; i <= totalPages; i++) {
            const active = i === currentPage;
            html += `<button class="hz-btn${active ? ' primary' : ''}" data-page="${i}" ${active ? 'disabled' : ''}>${i}</button>`;
          }
          pg.innerHTML = html;
          pg.querySelectorAll('button').forEach(btn => {
            btn.addEventListener('click', () => loadList(parseInt(btn.dataset.page, 10)));
          });
        } else {
          pg.innerHTML = '';
        }
      }

      async function loadStats() {
        const resp = await api('/meta/stats');
        if (!resp.ok) return;
        $('active-subs').textContent = fmt(resp.data.activeSubscribers);
      }

      // Row actions (delegation)
      document.querySelector('#table-broadcasts').addEventListener('click', async (e) => {
        const btn = e.target.closest('button[data-action]');
        if (!btn) return;
        const tr = btn.closest('tr');
        const id = tr && tr.dataset.id;
        if (!id) return;
        const action = btn.dataset.action;

        if (action === 'send') {
          const subj = tr.querySelector('td').textContent.trim();
          const stats = await api('/meta/stats');
          const count = stats.ok ? stats.data.activeSubscribers : '?';
          if (!confirm(`Wirklich an ${count} Empfänger senden?\n\nBetreff: ${subj}\n\nDieser Vorgang ist nicht rückgängig machbar.`)) return;
          btn.disabled = true;
          btn.textContent = 'Sende…';
          const resp = await api(`/${id}/send`, { method: 'POST' });
          btn.disabled = false;
          if (resp.ok && resp.data && resp.data.ok) {
            alert(`✓ Gesendet an ${fmt(resp.data.recipientCount)} Empfänger — ${fmt(resp.data.successCount)} zugestellt, ${fmt(resp.data.failureCount)} Fehler.`);
          } else {
            alert('Fehler: ' + (resp.data && (resp.data.error || resp.data.message) || resp.status));
          }
          loadList(currentPage);
        } else if (action === 'delete') {
          if (!confirm('Draft wirklich löschen?')) return;
          const resp = await api(`/${id}`, { method: 'DELETE' });
          if (resp.ok && resp.data && resp.data.ok) {
            loadList(currentPage);
          } else {
            alert('Fehler: ' + (resp.data && (resp.data.error || resp.data.message) || resp.status));
          }
        } else if (action === 'edit') {
          // Draft im Modal nachladen und zum Editieren öffnen
          const detail = await api(`/${id}`);
          if (!detail.ok || !detail.data || !detail.data.broadcast) {
            alert('Fehler beim Laden des Drafts.');
            return;
          }
          openModalForEdit(detail.data.broadcast);
        } else if (action === 'unschedule') {
          if (!confirm('Geplanten Send abbrechen und zurück zu Draft?')) return;
          const resp = await api(`/${id}/unschedule`, { method: 'POST' });
          if (resp.ok && resp.data && resp.data.ok) {
            loadList(currentPage);
          } else {
            alert('Fehler: ' + (resp.data && (resp.data.error || resp.data.message) || resp.status));
          }
        }
      });

      // Schedule-Checkbox: zeigt/versteckt den Datetime-Picker,
      // ändert gleichzeitig den Submit-Button-Text.
      const chkSchedule = document.getElementById('chk-schedule');
      if (chkSchedule) {
        chkSchedule.addEventListener('change', () => {
          const on = chkSchedule.checked;
          document.getElementById('schedule-wrap').classList.toggle('hidden', !on);
          const sendBtn = document.getElementById('btn-send');
          if (on) {
            sendBtn.textContent = '⏰ Planen';
            // Default-Wert: jetzt + 1 Stunde (lokale Zeit als input-value)
            const inp = document.getElementById('input-schedule');
            if (!inp.value) {
              const d = new Date(Date.now() + 60 * 60 * 1000);
              const pad = (n) => String(n).padStart(2, '0');
              inp.value = d.getFullYear() + '-' + pad(d.getMonth()+1) + '-' + pad(d.getDate())
                + 'T' + pad(d.getHours()) + ':' + pad(d.getMinutes());
            }
          } else {
            sendBtn.textContent = '📣 Jetzt senden';
          }
        });
      }

      // ─── Autosave (localStorage) ──────────────────────────
      // Schutz gegen Tab-Close / F5 / Crash bevor der User auf "Draft
      // speichern" klickt. Nur NEU-Drafts (currentDraftId == null),
      // Edit-Mode lädt die echten Daten vom Server, der ist nie stale.
      const AUTOSAVE_KEY = 'hz-newsletter-draft-v1';
      const AUTOSAVE_THROTTLE_MS = 800;
      let autosaveTimer = null;

      function saveAutosave() {
        if (currentDraftId) return; // Edit-Mode überspringt Autosave
        try {
          const payload = {
            subject: $('f-subject').value,
            bodyHtml: $('f-bodyHtml').value,
            articleSlug: $('f-articleSlug').value,
            mode: currentMode,
            savedAt: Date.now(),
          };
          // Nur speichern wenn WIRKLICH was drin ist — sonst räumen wir auf.
          if (!payload.subject.trim() && !payload.bodyHtml.trim()) {
            localStorage.removeItem(AUTOSAVE_KEY);
            return;
          }
          localStorage.setItem(AUTOSAVE_KEY, JSON.stringify(payload));
        } catch { /* QuotaExceeded etc. — silently skip */ }
      }
      function scheduleAutosave() {
        if (autosaveTimer) clearTimeout(autosaveTimer);
        autosaveTimer = setTimeout(saveAutosave, AUTOSAVE_THROTTLE_MS);
      }
      function clearAutosave() {
        try { localStorage.removeItem(AUTOSAVE_KEY); } catch {}
      }
      function loadAutosave() {
        try {
          const raw = localStorage.getItem(AUTOSAVE_KEY);
          if (!raw) return null;
          const p = JSON.parse(raw);
          // Sanity-Check: nicht älter als 7 Tage
          if (!p || !p.savedAt || Date.now() - p.savedAt > 7 * 86_400_000) {
            clearAutosave();
            return null;
          }
          return p;
        } catch { return null; }
      }

      // ─── Modal ─────────────────────────────────────────
      function openModal() {
        $('modal-new').classList.remove('hidden');
        $('form-result').classList.add('hidden');
        currentDraftId = null;
        $('f-subject').value = '';
        $('f-bodyHtml').value = '';
        $('f-articleSlug').value = '';
        $('btn-send').disabled = false;
        $('btn-send').textContent = '📣 Jetzt senden';
        const chk = document.getElementById('chk-schedule');
        if (chk) { chk.checked = false; document.getElementById('schedule-wrap').classList.add('hidden'); }
        const inp = document.getElementById('input-schedule');
        if (inp) inp.value = '';
        setMode('manual');
        // Autosave-Restore: wenn was im localStorage liegt, fragen
        const saved = loadAutosave();
        if (saved && (saved.subject || saved.bodyHtml)) {
          const ageMin = Math.round((Date.now() - saved.savedAt) / 60_000);
          const ageLabel = ageMin < 60
            ? ageMin + ' Min'
            : Math.round(ageMin / 60) + ' Std';
          if (confirm('Autosave-Entwurf von vor ' + ageLabel + ' gefunden.\n\nBetreff: ' + (saved.subject || '(leer)').slice(0, 80) + '\n\nWiederherstellen? [OK]\nVerwerfen? [Abbrechen]')) {
            $('f-subject').value = saved.subject || '';
            $('f-bodyHtml').value = saved.bodyHtml || '';
            $('f-articleSlug').value = saved.articleSlug || '';
            setMode(saved.mode || 'manual');
          } else {
            clearAutosave();
          }
        }
        renderPreview();
      }
      function closeModal() { $('modal-new').classList.add('hidden'); }
      function openModalForEdit(b) {
        $('modal-new').classList.remove('hidden');
        $('form-result').classList.add('hidden');
        currentDraftId = b.id;
        $('f-subject').value = b.subject || '';
        $('f-bodyHtml').value = b.bodyHtml || '';
        $('f-articleSlug').value = b.articleSlug || '';
        $('btn-send').disabled = false;
        $('btn-send').textContent = '📣 Jetzt senden';
        setMode(b.articleSlug ? 'article' : 'manual');
        renderPreview();
      }
      function setMode(mode) {
        currentMode = mode;
        document.querySelectorAll('.hz-tab-btn').forEach(b => {
          b.classList.toggle('active', b.dataset.mode === mode);
        });
        $('article-picker').classList.toggle('hidden', mode !== 'article');
      }

      $('btn-new').addEventListener('click', openModal);
      document.querySelectorAll('[data-close]').forEach(el =>
        el.addEventListener('click', closeModal));
      $('modal-new').addEventListener('click', (e) => {
        if (e.target === $('modal-new')) closeModal();
      });
      document.querySelectorAll('.hz-tab-btn').forEach(b =>
        b.addEventListener('click', () => setMode(b.dataset.mode)));

      $('btn-prefill').addEventListener('click', () => {
        const slug = $('f-articleSlug').value.trim();
        if (!slug) { alert('Bitte Slug eingeben.'); return; }
        const subj = $('f-subject').value.trim();
        if (!subj) {
          $('f-subject').value = `Neuer Artikel: ${slug.replace(/-/g, ' ')}`;
        }
        const body = $('f-bodyHtml').value.trim();
        if (!body) {
          const url = `https://herzblatt-journal.com/blog/${slug}`;
          $('f-bodyHtml').value =
`<h1 style="font-family: Georgia, serif; color: #1f2937;">Neuer Artikel im Herzblatt Journal</h1>

<p style="font-size: 16px; line-height: 1.6; color: #1f2937;">
  Hallo,<br><br>
  wir haben einen neuen Artikel für dich geschrieben, den wir dir nicht vorenthalten wollten.
</p>

<p style="font-size: 16px; line-height: 1.6; color: #1f2937;">
  <strong>${slug.replace(/-/g, ' ')}</strong>
</p>

<p style="margin: 28px 0;">
  <a href="${url}" style="display: inline-block; background: #e11d48; color: white; padding: 14px 28px; border-radius: 8px; text-decoration: none; font-weight: 600;">
    Jetzt lesen
  </a>
</p>

<p style="font-size: 15px; color: #64748b; line-height: 1.5;">
  Herzlich,<br>
  Sarah Kellner<br>
  Chefredakteurin, Herzblatt Journal
</p>`;
        }
        renderPreview();
      });

      // Live-Preview im Sandbox-iframe.
      // sandbox="allow-same-origin" erlaubt uns weiterhin via srcdoc content
      // zu setzen, verhindert aber Script-Execution + Form-Submission +
      // Popup-Windows + Top-Navigation. Email-Content soll ja genau KEIN
      // Script ausführen — und wenn der Admin mal eine fremde HTML-Quelle
      // reinkopiert die <script> enthält, wird das hier safe angezeigt.
      function renderPreview() {
        const html = $('f-bodyHtml').value;
        const frame = document.getElementById('preview-frame');
        if (!frame) return;
        if (!html || html.trim().length < 5) {
          frame.srcdoc = '<!doctype html><html><body style="margin:0;padding:2rem;font-family:-apple-system,BlinkMacSystemFont,sans-serif;color:#94a3b8;font-size:0.85rem;">Body eingeben für Preview…</body></html>';
          return;
        }
        // Platzhalter durch Demo-URL ersetzen + ein minimalistisches HTML-
        // Shell drumwickeln (kein DOCTYPE = Quirks Mode in manchen Mail-
        // Clients, darum DOCTYPE + viewport-meta).
        const rendered = html.split('{{UNSUBSCRIBE_URL}}').join('https://herzblatt-journal.com/unsubscribe?email=demo&token=DEMO');
        frame.srcdoc = '<!doctype html><html><head><meta charset="utf-8"><meta name="viewport" content="width=device-width,initial-scale=1"><base target="_blank"></head><body style="margin:0;padding:1.5rem;font-family:-apple-system,BlinkMacSystemFont,\'Segoe UI\',sans-serif;color:#1f2937;background:#fff;">'
          + rendered + '</body></html>';
      }
      $('f-bodyHtml').addEventListener('input', () => { renderPreview(); scheduleAutosave(); });
      $('f-subject').addEventListener('input', scheduleAutosave);
      $('f-articleSlug').addEventListener('input', scheduleAutosave);

      // ─── Subject-Line-Scorer ─────────────────────────────────────
      // Heuristik gegen Spam-Triggers + Best-Practices. Rein informativ,
      // blockt keinen Send. Score 0-100, Badge-Farbe abhängig.
      const SPAM_WORDS = [
        'gratis','free','jetzt kaufen','100%','garantiert','nur heute',
        'klick hier','gewinn','!!!','kostenlos','sofort','reich','earn',
        'cash','credit','loan','viagra','casino','betrug','dringend',
      ];
      function scoreSubject(s) {
        const raw = (s || '').trim();
        if (!raw) return { score: 0, label: '—', tips: 'Betreff eingeben…', color: 'var(--hz-text-muted)' };
        let score = 100;
        const tips = [];

        // Länge: ideal 30-60, akzeptabel 20-80
        const len = raw.length;
        if (len < 20) { score -= 15; tips.push('zu kurz (<20)'); }
        else if (len < 30) { score -= 5; tips.push('kurz'); }
        else if (len > 80) { score -= 15; tips.push('zu lang (>80)'); }
        else if (len > 60) { score -= 5; tips.push('lang'); }

        // ALL-CAPS-Wörter (> 3 Buchstaben)
        const capsWords = (raw.match(/\b[A-Z]{4,}\b/g) || []).length;
        if (capsWords > 0) { score -= Math.min(25, capsWords * 12); tips.push(capsWords + 'x ALL-CAPS'); }

        // Mehrfach-Ausrufezeichen
        if (/!{2,}/.test(raw)) { score -= 15; tips.push('Mehrfach-!'); }
        // Mehrfach-Fragezeichen
        if (/\?{2,}/.test(raw)) { score -= 10; tips.push('Mehrfach-?'); }

        // Emoji-Count (grober Count über Unicode-Ranges)
        const emojiMatches = raw.match(/[\u{1F300}-\u{1F9FF}\u{2600}-\u{27BF}]/gu) || [];
        if (emojiMatches.length > 3) { score -= 15; tips.push('>3 Emojis'); }
        else if (emojiMatches.length >= 1 && emojiMatches.length <= 2) { tips.push('✓ Emojis'); }

        // Spam-Words
        const lower = raw.toLowerCase();
        const hits = SPAM_WORDS.filter(w => lower.includes(w));
        if (hits.length > 0) {
          score -= Math.min(30, hits.length * 10);
          tips.push('Spam-Wörter: ' + hits.slice(0, 3).join(', '));
        }

        // €-Zeichen / Preis-Indikator alleine → Downgrade (typisches Sales-Subject)
        if (/€|EUR|\$/.test(raw)) { score -= 5; tips.push('Währung'); }

        // Persönlicher Ton-Boost (Zahlen/Fragen am Anfang)
        if (/^(wie|warum|was|wann|wo|wer|\d)/i.test(raw)) { tips.push('✓ Hook'); }

        score = Math.max(0, Math.min(100, score));
        let label, color;
        if (score >= 80) { label = 'Sehr gut'; color = '#10b981'; }
        else if (score >= 60) { label = 'OK'; color = '#f59e0b'; }
        else if (score >= 40) { label = 'Schwach'; color = '#f97316'; }
        else { label = 'Spam-Risiko'; color = 'var(--hz-danger)'; }

        return { score, label, tips: tips.length ? tips.join(' · ') : '✓ Sauber', color };
      }

      function renderSubjectScore() {
        const val = $('f-subject').value;
        const { score, label, tips, color } = scoreSubject(val);
        const badge = document.getElementById('subject-score-badge');
        const lenEl = document.getElementById('subject-score-len');
        const tipsEl = document.getElementById('subject-score-tips');
        if (badge) {
          badge.textContent = label + ' · ' + score;
          badge.style.background = color + '22';
          badge.style.color = color;
        }
        if (lenEl) lenEl.textContent = val.length + ' Zeichen';
        if (tipsEl) tipsEl.textContent = tips;
      }
      $('f-subject').addEventListener('input', renderSubjectScore);
      renderSubjectScore();

      async function saveDraft() {
        const payload = {
          subject: $('f-subject').value.trim(),
          bodyHtml: $('f-bodyHtml').value,
        };
        if (currentMode === 'article') {
          const slug = $('f-articleSlug').value.trim();
          payload.articleSlug = slug || null;
        } else {
          // manual-Modus: existierenden Slug explizit nullen
          payload.articleSlug = null;
        }

        // Wenn currentDraftId gesetzt → PATCH (Update bestehender Draft),
        // sonst POST (neuer Draft).
        const resp = currentDraftId
          ? await api(`/${currentDraftId}`, { method: 'PATCH', body: JSON.stringify(payload) })
          : await api('/', { method: 'POST', body: JSON.stringify(payload) });

        if (resp.ok && resp.data && resp.data.ok) {
          currentDraftId = resp.data.broadcast.id;
          // Erfolgreich in DB → Autosave löschen, sonst wird's beim nächsten
          // Modal-Öffnen wieder als Vorschlag angezeigt.
          clearAutosave();
          showResult(`✓ Draft #${currentDraftId} gespeichert.`, true);
          return currentDraftId;
        }
        showResult('Fehler: ' + (resp.data && (resp.data.error || JSON.stringify(resp.data.issues)) || resp.status), false);
        return null;
      }

      $('btn-save-draft').addEventListener('click', async () => {
        await saveDraft();
        loadList(currentPage);
      });

      $('btn-test').addEventListener('click', async () => {
        const id = currentDraftId || await saveDraft();
        if (!id) return;
        const email = prompt('Testmail an welche Adresse? (Leer lassen → service@herzblatt-journal.com)');
        if (email === null) return;
        const target = (email || '').trim() || 'service@herzblatt-journal.com';
        const resp = await api(`/${id}/test`, { method: 'POST', body: JSON.stringify({ email: target }) });
        if (resp.ok && resp.data && resp.data.ok) {
          showResult(`✓ Testmail an ${target} gesendet.`, true);
        } else {
          showResult('Fehler: ' + (resp.data && (resp.data.error || resp.data.message) || resp.status), false);
        }
      });

      $('form-new').addEventListener('submit', async (e) => {
        e.preventDefault();
        const id = currentDraftId || await saveDraft();
        if (!id) return;

        const scheduleOn = document.getElementById('chk-schedule')?.checked;
        if (scheduleOn) {
          // Schedule-Pfad: client konvertiert lokale Zeit → ISO-UTC.
          const raw = document.getElementById('input-schedule').value;
          if (!raw) { alert('Bitte Datum und Uhrzeit wählen.'); return; }
          const local = new Date(raw);
          if (!Number.isFinite(local.getTime())) { alert('Ungültiger Zeitpunkt.'); return; }
          if (local.getTime() - Date.now() < 2 * 60 * 1000) {
            alert('Mind. 2 Minuten in der Zukunft wählen.');
            return;
          }
          const statsResp = await api('/meta/stats');
          const count = statsResp.ok ? statsResp.data.activeSubscribers : '?';
          const pretty = local.toLocaleString('de-DE', { dateStyle: 'full', timeStyle: 'short' });
          if (!confirm('Broadcast planen?\n\nAn: ' + count + ' Empfänger\nWann: ' + pretty + '\nBetreff: ' + $('f-subject').value + '\n\nDer Scheduler startet automatisch den Send.')) return;

          $('btn-send').disabled = true;
          $('btn-send').textContent = 'Plane…';
          const resp = await api('/' + id + '/schedule', {
            method: 'POST',
            body: JSON.stringify({ scheduledFor: local.toISOString() }),
          });
          $('btn-send').disabled = false;
          $('btn-send').textContent = '⏰ Planen';
          if (resp.ok && resp.data && resp.data.ok) {
            showResult('✓ Geplant für ' + pretty + '.', true);
            setTimeout(() => { closeModal(); loadList(1); }, 1200);
          } else {
            showResult('Fehler: ' + (resp.data && (resp.data.error || resp.data.message) || resp.status), false);
          }
          return;
        }

        // Immediate-Send-Pfad (wie bisher)
        const statsResp = await api('/meta/stats');
        const count = statsResp.ok ? statsResp.data.activeSubscribers : '?';
        if (!confirm(`Wirklich an ${count} Empfänger senden?\n\nBetreff: ${$('f-subject').value}\n\nDieser Vorgang ist nicht rückgängig machbar.`)) return;

        $('btn-send').disabled = true;
        $('btn-send').textContent = 'Sende…';
        const resp = await api(`/${id}/send`, { method: 'POST' });
        $('btn-send').disabled = false;
        $('btn-send').textContent = '📣 Jetzt senden';
        if (resp.ok && resp.data && resp.data.ok) {
          showResult(`✓ Gesendet an ${fmt(resp.data.recipientCount)} — ${fmt(resp.data.successCount)} zugestellt, ${fmt(resp.data.failureCount)} Fehler.`, true);
          setTimeout(() => { closeModal(); loadList(1); }, 1200);
        } else {
          showResult('Fehler: ' + (resp.data && (resp.data.error || resp.data.message) || resp.status), false);
        }
      });

      // Initial load
      loadStats();
      loadList(1);
    })();
  </script>
</HerzraumLayout>
