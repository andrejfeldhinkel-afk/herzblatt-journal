---
export const prerender = false;
import HerzraumLayout from '../../layouts/HerzraumLayout.astro';
import { getCollection } from 'astro:content';
import fs from 'node:fs';
import path from 'node:path';

/**
 * BILDER-DASHBOARD — Zwei-Stufen-Lade-Strategie:
 *
 * 1. Build-Time-Index (primär, Railway-safe):
 *    `public/images/blog/index.json` wird von `scripts/generate-images-index.mjs`
 *    zur Build-Zeit generiert (via prebuild-Hook in package.json). Die
 *    index.json wird als statisches Asset deployed und via fetch('/images/blog/index.json')
 *    zur Runtime geladen.
 *
 * 2. Filesystem-Scan (Fallback, lokaler Dev):
 *    Wenn die index.json noch nicht existiert (erster Dev-Run), fallen wir
 *    auf fs.readdirSync zurück. Funktioniert nur lokal, nicht im
 *    Railway-SSR-Container.
 *
 * Das Dashboard lädt den Index client-side via fetch, damit die index.json
 * auch auf Railway immer aktuell aus dem deployten dist/client/images/blog/
 * gelesen wird — nicht aus dem Backend-Build-Context.
 */

// Bilder zur Build-Zeit via Index-JSON einlesen (funktioniert lokal UND auf Railway).
const imagesDir = path.resolve(process.cwd(), 'public/images/blog');
const indexPath = path.join(imagesDir, 'index.json');
let imageFiles: string[] = [];
let indexSource: 'index.json' | 'readdir' | 'client-fetch' = 'client-fetch';
try {
  if (fs.existsSync(indexPath)) {
    const parsed = JSON.parse(fs.readFileSync(indexPath, 'utf8'));
    if (Array.isArray(parsed?.files)) {
      imageFiles = parsed.files.filter((f: unknown): f is string =>
        typeof f === 'string' && /\.(webp|jpg|jpeg|png|avif|gif|svg)$/i.test(f)
      );
      indexSource = 'index.json';
    }
  } else if (fs.existsSync(imagesDir)) {
    imageFiles = fs.readdirSync(imagesDir).filter((f) =>
      /\.(webp|jpg|jpeg|png|avif)$/i.test(f)
    );
    indexSource = 'readdir';
  }
} catch (err) {
  console.warn('[bilder] Build-time image list failed:', err);
}

// Artikel-Collection einlesen + referenzierte Bilder extrahieren
const blog = await getCollection('blog');
const referencedImages = new Set<string>();
const imageToArticles = new Map<string, string[]>();
for (const a of blog) {
  const img = (a.data as any).image as string | undefined;
  if (img) {
    const fname = img.replace(/^\/images\/blog\//, '');
    referencedImages.add(fname);
    if (!imageToArticles.has(fname)) imageToArticles.set(fname, []);
    imageToArticles.get(fname)!.push(a.slug);
  }
}

// Orphans: existieren als File, werden aber nicht referenziert
const orphans = imageFiles.filter((f) => !referencedImages.has(f));
// Missing: werden referenziert, existieren aber nicht als File
const allReferenced = Array.from(referencedImages);
const missing = imageFiles.length > 0
  ? allReferenced.filter((f) => !imageFiles.includes(f))
  : []; // unknown wenn wir die dir nicht lesen können

const total = imageFiles.length;
const referenced = referencedImages.size;

const imgArr = imageFiles.map((f) => ({
  file: f,
  articles: imageToArticles.get(f) || [],
  orphan: !referencedImages.has(f),
}));

// Für Client-Side-Fallback: welche Artikel referenzieren welches Bild?
// Wird dem Client-JS als JSON übergeben, damit auch beim Runtime-fetch die
// Orphan-Liste berechnet werden kann.
const articlesByImage: Record<string, string[]> = {};
for (const [fname, slugs] of imageToArticles.entries()) {
  articlesByImage[fname] = slugs;
}
---
<HerzraumLayout title="Bilder" active="bilder">

  <section class="hz-kpi-grid">
    <div class="hz-kpi">
      <div class="hz-kpi-label">Bilder total (Dateisystem)</div>
      <div class="hz-kpi-value">{total.toLocaleString('de-DE')}</div>
    </div>
    <div class="hz-kpi">
      <div class="hz-kpi-label">Von Artikeln referenziert</div>
      <div class="hz-kpi-value">{referenced.toLocaleString('de-DE')}</div>
    </div>
    <div class="hz-kpi">
      <div class="hz-kpi-label">Verwaiste (orphans)</div>
      <div class="hz-kpi-value" style={orphans.length > 0 ? 'color: #f59e0b;' : ''}>{orphans.length.toLocaleString('de-DE')}</div>
    </div>
    <div class="hz-kpi">
      <div class="hz-kpi-label">Fehlende (referenziert aber weg)</div>
      <div class="hz-kpi-value" style={missing.length > 0 ? 'color: var(--hz-danger);' : ''}>{missing.length.toLocaleString('de-DE')}</div>
    </div>
  </section>

  <div class="hz-card" style="margin-bottom: 1rem;">
    <div class="hz-row" style="margin-bottom: 0.5rem;">
      <h3 style="margin: 0;">⬆︎ Neues Bild hochladen</h3>
      <div class="hz-spacer"></div>
    </div>
    <p style="color: var(--hz-text-muted); font-size: 0.8rem; margin: 0 0 0.75rem;">
      Upload landet in <code>apps/frontend/public/images/blog/&lt;slug&gt;.&lt;ext&gt;</code> als
      Commit in den <code>main</code>-Branch. Max. 8 MB. Erlaubt: jpg, png, webp, gif, avif.
      <strong>Live nach nächstem Railway-Deploy</strong> (wenige Minuten).
    </p>
    <form id="upload-form" enctype="multipart/form-data" style="display: grid; gap: 0.75rem; grid-template-columns: 1fr 1fr; align-items: end;">
      <div style="grid-column: 1 / 3;">
        <label style="display: block; font-size: 0.8rem; font-weight: 600; margin-bottom: 0.25rem;">Datei</label>
        <input type="file" id="up-file" name="file" required accept="image/*"
               style="width: 100%; padding: 0.4rem; border: 1px solid var(--hz-border); border-radius: 0.35rem; background: var(--hz-surface); color: var(--hz-text);">
      </div>
      <div>
        <label style="display: block; font-size: 0.8rem; font-weight: 600; margin-bottom: 0.25rem;">
          Slug <span style="color: var(--hz-text-muted); font-weight: 400;">(optional — aus Dateinamen abgeleitet)</span>
        </label>
        <input type="text" id="up-slug" name="slug" placeholder="z.b. hero-paar-beziehungstips"
               pattern="[a-z0-9][a-z0-9-]{2,79}"
               style="width: 100%; padding: 0.4rem 0.6rem; border: 1px solid var(--hz-border); border-radius: 0.35rem; background: var(--hz-surface); color: var(--hz-text);">
      </div>
      <div>
        <label style="display: flex; align-items: center; gap: 0.35rem; font-size: 0.85rem; padding-top: 1.4rem;">
          <input type="checkbox" id="up-overwrite" name="overwrite" value="1">
          Bestehende Datei überschreiben
        </label>
      </div>
      <div style="grid-column: 1 / 3; display: flex; align-items: center; gap: 0.75rem;">
        <button type="submit" id="up-submit" class="hz-btn primary">Hochladen</button>
        <span id="up-result" style="font-size: 0.85rem;"></span>
      </div>
    </form>
  </div>

  <div class="hz-card">
    <div class="hz-row" style="margin-bottom: 0.75rem;">
      <h3 style="margin: 0;">Grid ({total} Bilder)</h3>
      <div class="hz-spacer"></div>
      <label style="font-size: 0.85rem; color: var(--hz-text-muted);">
        <input type="checkbox" id="filter-orphans"> Nur Orphans zeigen
      </label>
    </div>
    <p id="index-source-hint" style="color: var(--hz-text-muted); font-size: 0.75rem; margin: 0 0 0.5rem 0;">
      Quelle: <code>{indexSource}</code>{total === 0 && ' — Client-Side-Fetch wird versucht…'}
    </p>
    <div id="img-grid" style="display: grid; grid-template-columns: repeat(auto-fill, minmax(150px, 1fr)); gap: 0.75rem; max-height: 70vh; overflow-y: auto;">
      {imgArr.map((img) => (
        <div class="img-tile" data-orphan={String(img.orphan)} style="border: 1px solid var(--hz-border); border-radius: 0.375rem; overflow: hidden; background: var(--hz-bg); position: relative;">
          <img src={`/images/blog/${img.file}`} alt={img.file} style="width: 100%; height: 100px; object-fit: cover; display: block;" loading="lazy"/>
          {img.orphan && (
            <span style="position: absolute; top: 0.25rem; left: 0.25rem; background: #f59e0b; color: white; font-size: 0.65rem; padding: 0.15rem 0.4rem; border-radius: 0.25rem; font-weight: 600;">ORPHAN</span>
          )}
          <div style="padding: 0.4rem; font-size: 0.65rem; word-break: break-all;">
            <div style="font-weight: 600; margin-bottom: 0.15rem;">{img.file}</div>
            {img.articles.length > 0 ? (
              <div style="color: var(--hz-text-muted);">
                → {img.articles.slice(0, 2).map((s) => <a href={`/blog/${s}`} target="_blank" style="color: var(--hz-primary);">{s.slice(0, 20)}{s.length > 20 ? '…' : ''}</a>).reduce((acc: any, el, i) => i === 0 ? [el] : [...acc, ', ', el], [])}
                {img.articles.length > 2 && <span> +{img.articles.length - 2}</span>}
              </div>
            ) : (
              <div style="color: #f59e0b;">Nicht referenziert</div>
            )}
          </div>
        </div>
      ))}
    </div>
  </div>

  <script is:inline define:vars={{ articlesByImage, buildTimeCount: total }}>
    // Filter-Logic — orphans toggle
    const filterEl = document.getElementById('filter-orphans');
    if (filterEl) {
      filterEl.addEventListener('change', (e) => {
        const showOnlyOrphans = e.target.checked;
        document.querySelectorAll('.img-tile').forEach((tile) => {
          const orphan = tile.dataset.orphan === 'true';
          tile.style.display = showOnlyOrphans ? (orphan ? 'block' : 'none') : 'block';
        });
      });
    }

    // Client-Side-Fallback: Wenn Build-Time-Scan 0 Bilder lieferte, lade die
    // index.json über HTTP — sie wird auf Railway als statisches Asset deployed.
    async function clientFallbackLoad() {
      if (buildTimeCount > 0) return;
      const hint = document.getElementById('index-source-hint');
      try {
        const res = await fetch('/images/blog/index.json', { cache: 'no-store' });
        if (!res.ok) throw new Error('HTTP ' + res.status);
        const data = await res.json();
        const files = Array.isArray(data?.files) ? data.files : [];
        if (files.length === 0) {
          if (hint) hint.textContent = 'index.json leer — Build hat keine Bilder erfasst.';
          return;
        }

        // KPIs aktualisieren
        const total = files.length;
        const referencedSet = new Set(Object.keys(articlesByImage || {}));
        const orphans = files.filter((f) => !referencedSet.has(f));
        const missing = Array.from(referencedSet).filter((f) => !files.includes(f));
        const kpiEls = document.querySelectorAll('.hz-kpi-value');
        if (kpiEls[0]) kpiEls[0].textContent = total.toLocaleString('de-DE');
        // "referenziert" behalten wir vom Server (stimmt immer)
        if (kpiEls[2]) {
          kpiEls[2].textContent = orphans.length.toLocaleString('de-DE');
          kpiEls[2].style.color = orphans.length > 0 ? '#f59e0b' : '';
        }
        if (kpiEls[3]) {
          kpiEls[3].textContent = missing.length.toLocaleString('de-DE');
          kpiEls[3].style.color = missing.length > 0 ? 'var(--hz-danger)' : '';
        }

        // Grid aufbauen
        const grid = document.getElementById('img-grid');
        if (grid) {
          const esc = (s) => String(s).replace(/[&<>"']/g, (c) =>
            ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' }[c])
          );
          grid.innerHTML = files.map((f) => {
            const slugs = articlesByImage[f] || [];
            const isOrphan = slugs.length === 0;
            const slugHtml = slugs.length > 0
              ? '<div style="color: var(--hz-text-muted);">→ ' + slugs.slice(0, 2).map((s) =>
                  '<a href="/blog/' + esc(s) + '" target="_blank" style="color: var(--hz-primary);">'
                    + esc(s.slice(0, 20)) + (s.length > 20 ? '…' : '') + '</a>'
                ).join(', ') + (slugs.length > 2 ? ' <span>+' + (slugs.length - 2) + '</span>' : '') + '</div>'
              : '<div style="color: #f59e0b;">Nicht referenziert</div>';
            return '<div class="img-tile" data-orphan="' + (isOrphan ? 'true' : 'false')
              + '" style="border: 1px solid var(--hz-border); border-radius: 0.375rem; overflow: hidden; background: var(--hz-bg); position: relative;">'
              + '<img src="/images/blog/' + encodeURIComponent(f) + '" alt="' + esc(f) + '" loading="lazy" style="width: 100%; height: 100px; object-fit: cover; display: block;">'
              + (isOrphan ? '<span style="position: absolute; top: 0.25rem; left: 0.25rem; background: #f59e0b; color: white; font-size: 0.65rem; padding: 0.15rem 0.4rem; border-radius: 0.25rem; font-weight: 600;">ORPHAN</span>' : '')
              + '<div style="padding: 0.4rem; font-size: 0.65rem; word-break: break-all;">'
              + '<div style="font-weight: 600; margin-bottom: 0.15rem;">' + esc(f) + '</div>'
              + slugHtml
              + '</div></div>';
          }).join('');
        }

        // Grid-Header + Hint updaten
        const gridTitle = document.querySelector('.hz-card h3');
        if (gridTitle) gridTitle.textContent = 'Grid (' + total + ' Bilder)';
        if (hint) hint.textContent = 'Quelle: client-fetch (index.json)';
      } catch (err) {
        if (hint) hint.textContent = 'Fehler beim Laden von index.json: ' + (err?.message || 'unknown');
      }
    }
    clientFallbackLoad();

    // ─── Upload-Form ────────────────────────────────────────
    // POST /api/herzraum/images/upload mit multipart/form-data.
    // Backend committet das File in den main-Branch; Live nach nächstem Deploy.
    (function wireUpload() {
      const form = document.getElementById('upload-form');
      if (!form) return;
      const fileInput = document.getElementById('up-file');
      const slugInput = document.getElementById('up-slug');
      const overInput = document.getElementById('up-overwrite');
      const btn = document.getElementById('up-submit');
      const result = document.getElementById('up-result');

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        result.textContent = '';
        const file = fileInput.files && fileInput.files[0];
        if (!file) { result.textContent = 'Bitte Datei wählen.'; result.style.color = 'var(--hz-danger)'; return; }
        if (file.size === 0) { result.textContent = 'Datei ist leer.'; result.style.color = 'var(--hz-danger)'; return; }

        btn.disabled = true;
        btn.textContent = 'Lädt hoch…';
        result.style.color = 'var(--hz-text-muted)';
        result.textContent = 'Upload + Commit auf GitHub…';

        const fd = new FormData();
        fd.append('file', file);
        if (slugInput.value.trim()) fd.append('slug', slugInput.value.trim());
        if (overInput.checked) fd.append('overwrite', '1');

        try {
          const res = await fetch('/api/herzraum/images/upload', { method: 'POST', body: fd });
          const data = await res.json().catch(() => ({}));
          if (res.ok && data.ok) {
            result.style.color = '#10b981';
            result.innerHTML = '✓ Upload erfolgreich: <code>' + data.publicUrl + '</code>'
              + (data.commitUrl ? ' (<a href="' + data.commitUrl + '" target="_blank" style="color: var(--hz-primary);">Commit</a>)' : '')
              + ' — live nach nächstem Deploy.';
            form.reset();
          } else {
            result.style.color = 'var(--hz-danger)';
            const msg = data.error || data.message || ('HTTP ' + res.status);
            result.textContent = 'Fehler: ' + msg + (data.hint ? ' — ' + data.hint : '');
          }
        } catch (err) {
          result.style.color = 'var(--hz-danger)';
          result.textContent = 'Netzwerk-Fehler: ' + (err && err.message || 'Unbekannt');
        } finally {
          btn.disabled = false;
          btn.textContent = 'Hochladen';
        }
      });
    })();
  </script>
</HerzraumLayout>
