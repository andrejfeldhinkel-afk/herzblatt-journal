---
export const prerender = false;
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

// Extrahiere die angefragte URL und versuche den Slug zu parsen
const requestedPath = Astro.url.pathname;
const slugGuess = requestedPath
  .replace(/^\/+|\/+$/g, '')
  .replace(/^(blog|autor|tags)\//, '')
  .replace(/^\/+/, '');

// Lade alle Posts — wir picken die 4 besten Matches basierend auf Slug-Ähnlichkeit
const allPosts = await getCollection('blog', ({ data }) => !data.draft);

// Token-basiertes Matching: Slug-Tokens aus requested URL vs Post-Slug + Tags + Keywords
function tokenize(s: string): string[] {
  return String(s).toLowerCase()
    .replace(/[^a-z0-9\s-]/g, ' ')
    .split(/[\s-]+/)
    .filter(t => t.length >= 3);
}

const requestTokens = new Set(tokenize(slugGuess));

function score(post: any): number {
  if (requestTokens.size === 0) return 0;
  const slug = post.slug || post.id?.replace(/\.md$/, '') || '';
  const postTokens = new Set([
    ...tokenize(slug),
    ...tokenize(post.data.title || ''),
    ...(post.data.tags || []).flatMap((t: string) => tokenize(t)),
    ...(post.data.keywords || []).flatMap((k: string) => tokenize(k)),
  ]);
  let overlap = 0;
  requestTokens.forEach(t => { if (postTokens.has(t)) overlap++; });
  return overlap;
}

const suggestions = allPosts
  .map((p: any) => ({ post: p, s: score(p) }))
  .filter(x => x.s > 0)
  .sort((a, b) => b.s - a.s)
  .slice(0, 4)
  .map(x => ({
    slug: x.post.slug || x.post.id?.replace(/\.md$/, ''),
    title: x.post.data.title,
    description: x.post.data.description,
    image: x.post.data.image,
    imageAlt: x.post.data.imageAlt,
    score: x.s,
  }));

// Fallback: beliebte Artikel wenn keine Matches
const hasSuggestions = suggestions.length > 0;
---

<BaseLayout title="Seite nicht gefunden — Herzblatt Journal" description="Die gesuchte Seite wurde leider nicht gefunden." noindex={true}>
  <!-- Auto-redirect for old /tags/* URLs -->
  <script is:inline>
    if (window.location.pathname.startsWith('/tags/') && window.location.pathname !== '/tags/') {
      window.location.replace('/tags/');
    }
  </script>

  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-16 sm:py-20">
    <div class="text-center mb-12">
      <div class="text-8xl mb-6">💔</div>

      <h1 class="text-4xl sm:text-5xl font-extrabold mb-4" style="color: var(--text); font-family: var(--font-serif); letter-spacing: -0.02em;">
        404
      </h1>

      <p class="text-xl font-medium mb-2" style="color: var(--text);">
        Diese Seite hat dich leider geghostet.
      </p>

      <p class="text-base mb-2" style="color: var(--text-muted);">
        Die Seite <code style="background: var(--bg-soft); padding: 1px 8px; border-radius: 4px; font-size: 0.85em;">{requestedPath}</code> existiert nicht.
      </p>

      <p class="text-base mb-10" style="color: var(--text-muted);">
        Aber wir haben vermutlich etwas, das dir trotzdem hilft.
      </p>

      <div class="flex flex-col sm:flex-row items-center justify-center gap-3 mb-10">
        <a href="/" class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-bold text-white transition-all hover:opacity-90 hover:-translate-y-0.5" style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-700));">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m3 9 9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>
          Zur Startseite
        </a>
        <a href="/blog" class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-medium transition-all hover:-translate-y-0.5" style="color: var(--color-primary-600); background: var(--color-primary-50); border: 1px solid var(--color-primary-100);">
          Alle 1.800+ Ratgeber
        </a>
        <a href="/top-dating-seiten" class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-medium transition-all hover:-translate-y-0.5" style="color: var(--color-primary-600); background: var(--color-primary-50); border: 1px solid var(--color-primary-100);">
          Top Dating-Seiten
        </a>
      </div>

      <div style="max-width: 500px; margin: 0 auto;">
        <form action="/suche" method="get" style="display: flex; gap: 8px; align-items: center; background: var(--bg-soft); border: 1px solid var(--border); border-radius: 999px; padding: 6px 8px 6px 18px;">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="color: var(--text-muted); flex-shrink: 0;"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/></svg>
          <input
            name="q"
            type="search"
            placeholder={`"${slugGuess}" suchen...`}
            value={slugGuess}
            style="flex: 1; background: transparent; border: 0; outline: none; color: var(--text); font-size: 15px; padding: 8px 0;"
          />
          <button type="submit" style="background: var(--color-primary-500); color: #fff; border: 0; border-radius: 999px; padding: 8px 16px; font-weight: 600; font-size: 14px; cursor: pointer;">
            Suchen
          </button>
        </form>
      </div>
    </div>

    {hasSuggestions && (
      <div class="mt-16">
        <div class="flex items-center gap-3 mb-6">
          <div style="width: 3px; height: 22px; border-radius: 3px; background: linear-gradient(to bottom, var(--color-primary-500), var(--color-primary-700));"></div>
          <h2 style="font-family: var(--font-serif); font-size: 1.3rem; font-weight: 700; letter-spacing: -0.01em; color: var(--text);">
            Das könnte gemeint sein
          </h2>
          <span style="font-size: 0.72rem; color: var(--text-muted); margin-left: auto; background: var(--bg-soft); padding: 3px 10px; border-radius: 999px; border: 1px solid var(--border);">
            Passend zu <code style="font-size: 0.9em;">{slugGuess}</code>
          </span>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {suggestions.map((s) => (
            <a href={`/blog/${s.slug}`} class="group flex gap-3 p-4 rounded-xl transition-all hover:-translate-y-0.5" style="background: var(--bg-card); border: 1px solid var(--border);">
              {s.image && (
                <div style="flex-shrink: 0; width: 72px; height: 72px; border-radius: 8px; overflow: hidden;">
                  <img src={s.image} alt={s.imageAlt || s.title} loading="lazy" style="width: 100%; height: 100%; object-fit: cover;" />
                </div>
              )}
              <div style="flex: 1; min-width: 0;">
                <h3 class="group-hover:text-[var(--color-primary-600)]" style="font-family: var(--font-serif); font-size: 1rem; font-weight: 700; line-height: 1.25; margin: 0 0 4px 0; color: var(--text); letter-spacing: -0.01em; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                  {s.title}
                </h3>
                <p style="font-size: 0.82rem; color: var(--text-muted); line-height: 1.4; margin: 0; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;">
                  {s.description}
                </p>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    {!hasSuggestions && (
      <div class="mt-10 pt-10" style="border-top: 1px solid var(--border);">
        <p class="text-xs font-bold uppercase tracking-wider mb-4 text-center" style="color: var(--text-muted);">Beliebte Artikel</p>
        <div class="flex flex-wrap items-center justify-center gap-2">
          <a href="/blog/erstes-date-tipps" class="text-sm px-4 py-2 rounded-full transition-all hover:-translate-y-0.5" style="background: var(--bg-soft); color: var(--text); border: 1px solid var(--border);">Erstes Date Tipps</a>
          <a href="/blog/online-dating-profil" class="text-sm px-4 py-2 rounded-full transition-all hover:-translate-y-0.5" style="background: var(--bg-soft); color: var(--text); border: 1px solid var(--border);">Online-Dating Profil</a>
          <a href="/blog/dating-red-flags-maenner-erkennen" class="text-sm px-4 py-2 rounded-full transition-all hover:-translate-y-0.5" style="background: var(--bg-soft); color: var(--text); border: 1px solid var(--border);">Red Flags erkennen</a>
          <a href="/blog/flirten-lernen" class="text-sm px-4 py-2 rounded-full transition-all hover:-translate-y-0.5" style="background: var(--bg-soft); color: var(--text); border: 1px solid var(--border);">Flirten lernen</a>
          <a href="/top-dating-seiten" class="text-sm px-4 py-2 rounded-full transition-all hover:-translate-y-0.5" style="background: var(--bg-soft); color: var(--text); border: 1px solid var(--border);">Top Dating Seiten</a>
        </div>
      </div>
    )}
  </section>
</BaseLayout>
