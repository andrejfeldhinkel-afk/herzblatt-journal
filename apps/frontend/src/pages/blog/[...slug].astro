---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AppCTA from '../../components/AppCTA.astro';
import ReadingProgress from '../../components/ReadingProgress.astro';
import BlogCard from '../../components/BlogCard.astro';
import ProductGrid from '../../components/ProductGrid.astro';
import { getCollection, render } from 'astro:content';
import { getAuthor } from '../../data/authors';

export async function getStaticPaths() {
  // Scheduled Posts: Artikel mit date > heute werden nicht generiert
  const now = new Date();
  const posts = await getCollection('blog', ({ data }) => !data.draft && data.date <= now);
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content, headings } = await render(post);
const author = getAuthor((post.data as any).author || "redaktion");

const formattedDate = new Intl.DateTimeFormat('de-DE', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(post.data.date);

const formattedUpdated = post.data.updated ? new Intl.DateTimeFormat('de-DE', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
}).format(post.data.updated) : null;

const words = (post.body || '').split(/\s+/).length;
const readingTime = Math.ceil(words / 200);

// Related articles: same tags, excluding current post
const allPosts = (await getCollection('blog', ({ data }) => !data.draft && data.date <= new Date()))
  .sort((a, b) => (b.data.date?.valueOf?.() || 0) - (a.data.date?.valueOf?.() || 0));

const currentTags = new Set(post.data.tags);
const relatedPosts = allPosts
  .filter(p => p.id !== post.id)
  .map(p => ({
    post: p,
    score: p.data.tags.filter((t: string) => currentTags.has(t)).length
  }))
  .filter(p => p.score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 3)
  .map(p => p.post);

function getReadingTime(body: string) {
  return `${Math.ceil(body.split(/\s+/).length / 200)} Min. Lesezeit`;
}

const shareUrl = `https://herzblatt-journal.com/blog/${post.id}`;
const shareTitle = post.data.title;

// Build internal link map: for each tag, get other posts with that tag
const internalLinks = allPosts
  .filter(p => p.id !== post.id)
  .filter(p => p.data.tags.some((t: string) => currentTags.has(t)))
  .slice(0, 5)
  .map(p => ({ title: p.data.title, slug: p.id }));

// Prev/Next navigation
const currentIndex = allPosts.findIndex(p => p.id === post.id);
const prevPost = currentIndex < allPosts.length - 1 ? allPosts[currentIndex + 1] : null;
const nextPost = currentIndex > 0 ? allPosts[currentIndex - 1] : null;

// Popular posts (longest articles = most in-depth = "beliebt")
const popularPosts = [...allPosts]
  .map(p => ({ ...p, wordCount: (p.body || '').split(/\s+/).length }))
  .sort((a, b) => b.wordCount - a.wordCount)
  .filter(p => p.id !== post.id)
  .slice(0, 5);

// Breadcrumbs for SEO
const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Ratgeber', url: '/blog' },
  { name: post.data.title, url: `/blog/${post.id}` },
];

// OG image (generated branded image, falls back to post image)
// OG: Nutze gebrandetes OG-Bild falls vorhanden, sonst Artikel-Bild, sonst Default
const ogImage = post.data.image || `/og-default.png`;

// Auto-detect listicle articles ("Die 15 X", "10 Y", "12 Z" usw.) und extrahiere Listenpunkte
const titleHasNumber = /\b(\d{1,2})\s+[A-ZÄÖÜa-zäöü]/.test(post.data.title);
const isListicle = titleHasNumber || /\b(top|liste)\b/i.test(post.data.title);
let itemListItems: { name: string }[] | undefined;
if (isListicle && post.body) {
  // Extract H3 headings of pattern "### N. Foo" or "### Foo" (numbered sections)
  const h3Matches = [...post.body.matchAll(/^###\s+(?:\d+\.\s+)?(.+)$/gm)];
  const items = h3Matches
    .map(m => m[1].replace(/\*+/g, '').trim())
    .filter(name => name.length > 3 && name.length < 120)
    .slice(0, 30);
  if (items.length >= 3) {
    itemListItems = items.map(name => ({ name }));
  }
}

// Auto-detect HowTo articles ("In N Schritten", "Schritt für Schritt", "Anleitung")
const isHowTo = /\b(in\s+\d+\s+schritten|schritt[\s-]für[\s-]schritt|anleitung|so\s+(geht|machst|funktioniert))/i.test(post.data.title);
let howToSteps: { name: string; text: string }[] | undefined;
if (isHowTo && post.body) {
  // Extract H2/H3 sections starting with a number, followed by their first paragraph
  const stepRegex = /^(?:##|###)\s+(?:Schritt\s+)?(\d+)[.:]?\s+(.+?)$\n+([^#\n][^\n]*(?:\n[^#\n][^\n]*){0,2})/gm;
  const stepMatches = [...post.body.matchAll(stepRegex)];
  if (stepMatches.length >= 2) {
    howToSteps = stepMatches.slice(0, 12).map(m => ({
      name: m[2].replace(/\*+/g, '').trim().slice(0, 120),
      text: m[3].replace(/\*+/g, '').trim().slice(0, 500)
    }));
  }
}

// Author for Person Schema (E-E-A-T)
const articleAuthor = {
  name: author.name,
  slug: author.slug,
  role: author.role,
  image: author.image,
  knowsAbout: (author as any).knowsAbout,
  alumniOf: (author as any).alumniOf,
};
---

<BaseLayout
  title={`${post.data.title} — Herzblatt Journal`}
  description={post.data.description}
  image={ogImage}
  type="article"
  isArticle={true}
  keywords={post.data.keywords || post.data.tags || []}
  datePublished={post.data.date.toISOString()}
  dateModified={post.data.updated ? post.data.updated.toISOString() : post.data.date.toISOString()}
  breadcrumbs={breadcrumbs}
  faq={post.data.faq || []}
  articleAuthor={articleAuthor}
  itemListItems={itemListItems}
  howToSteps={howToSteps}
>
  <ReadingProgress />

  <div class="max-w-7xl mx-auto px-4 sm:px-6 py-12 sm:py-16">
    <!-- Breadcrumbs (visual + SEO) -->
    <nav aria-label="Breadcrumb" class="mb-6">
      <ol class="flex items-center gap-1.5 text-xs font-medium flex-wrap" style="color: var(--text-muted);">
        <li><a href="/" class="hover:underline" style="color: var(--text-muted);">Home</a></li>
        <li><span class="mx-1">/</span></li>
        <li><a href="/blog" class="hover:underline" style="color: var(--text-muted);">Ratgeber</a></li>
        <li><span class="mx-1">/</span></li>
        <li class="truncate max-w-[200px] sm:max-w-none" style="color: var(--color-primary-600);">{post.data.title}</li>
      </ol>
    </nav>

    <!-- 2-Column Layout -->
    <div class="flex flex-col lg:flex-row gap-8 lg:gap-10">

      <!-- Article (Main Column) -->
      <article class="flex-1 min-w-0 max-w-3xl">
        <!-- Hero Image -->
        {post.data.image && (
          <div class="mb-8 rounded-2xl overflow-hidden" style="aspect-ratio: 16/9; background: linear-gradient(135deg, var(--color-primary-100), var(--color-primary-50));">
            <img src={post.data.image} alt={post.data.imageAlt || post.data.title} width="1200" height="675" class="w-full h-full object-cover" loading="eager" fetchpriority="high" decoding="async" />
          </div>
        )}

        <!-- Header -->
        <header class="mb-10">
          <div class="flex flex-wrap gap-2 mb-5">
            {(post.data.tags || []).map((tag: string) => (
              <a href={`/tags/${tag}`} class="text-xs font-medium px-3 py-1.5 rounded-full transition-colors hover:opacity-80" style="background: var(--color-primary-50); color: var(--color-primary-700); border: 1px solid var(--color-primary-100);">
                {tag}
              </a>
            ))}
          </div>

          <h1 class="text-3xl sm:text-4xl font-extrabold leading-tight mb-5" style="color: var(--text); font-family: var(--font-serif); letter-spacing: -0.02em;">
            {post.data.title}
          </h1>

          <p class="text-lg leading-relaxed mb-5" style="color: var(--text-muted);">
            {post.data.description}
          </p>

          <div class="flex items-center justify-between py-4" style="border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
            <div class="flex items-center gap-4">
              <a href={`/autor/${author.slug}`}><img src={author.image} alt={author.name} class="w-10 h-10 rounded-full object-cover" style="border: 2px solid var(--color-primary-200);" loading="lazy" /></a>
              <div>
                <a href={`/autor/${author.slug}`} class="text-sm font-semibold hover:underline" style="color: var(--text); text-decoration: none;">{author.name}</a>
                <div class="flex items-center gap-2 text-xs flex-wrap" style="color: var(--text-muted);">
                  <time datetime={post.data.date.toISOString()}>{formattedDate}</time>
                  {formattedUpdated && (
                    <>
                      <span>·</span>
                      <time datetime={post.data.updated.toISOString()} style="color: var(--color-primary-600); font-weight: 500;">Aktualisiert: {formattedUpdated}</time>
                    </>
                  )}
                  <span>·</span>
                  <span>{readingTime} Min. Lesezeit</span>
                </div>
              </div>
            </div>

            <!-- Share Buttons (Desktop) -->
            <div class="hidden sm:flex items-center gap-1">
              <a href={`https://wa.me/?text=${encodeURIComponent(shareTitle + ' ' + shareUrl)}`} target="_blank" rel="noopener" class="share-btn" title="WhatsApp" style="color: var(--text-muted);">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
              </a>
              <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`} target="_blank" rel="noopener" class="share-btn" title="Facebook" style="color: var(--text-muted);">
                <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
              </a>
              <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(shareTitle)}&url=${encodeURIComponent(shareUrl)}`} target="_blank" rel="noopener" class="share-btn" title="X / Twitter" style="color: var(--text-muted);">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
              </a>
              <button onclick="navigator.clipboard.writeText(window.location.href); this.querySelector('span').textContent='Kopiert!'; setTimeout(()=>this.querySelector('span').textContent='',1500);" class="share-btn flex items-center gap-1" title="Link kopieren" style="color: var(--text-muted);">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
                <span class="text-[10px] font-medium"></span>
              </button>
            </div>
          </div>
        </header>

        <!-- TOC -->
        {headings.length > 2 && (
          <details class="mb-10 rounded-2xl p-5" style="background: var(--bg-soft); border: 1px solid var(--border);">
            <summary class="font-semibold cursor-pointer text-sm" style="color: var(--text);">Inhaltsverzeichnis</summary>
            <nav class="mt-3">
              <ul class="space-y-2 text-sm">
                {headings.filter((h: any) => h.depth <= 3).map((h: any) => (
                  <li style={`padding-left: ${(h.depth - 2) * 1}rem;`}>
                    <a href={`#${h.slug}`} class="hover:underline" style="color: var(--color-primary-600);">{h.text}</a>
                  </li>
                ))}
              </ul>
            </nav>
          </details>
        )}

        <!-- Content -->
        <div class="prose" id="article-content">
          <Content />
        </div>

        <!-- Produkte-Grid: explizit via Frontmatter ODER Fallback auf Featured-Produkte -->
        {post.data.products && post.data.products.length > 0 ? (
          <ProductGrid
            slugs={post.data.products}
            title="Unsere Empfehlungen zu diesem Thema"
            intro="Passend zum Thema dieses Artikels — sorgfältig kuratiert."
          />
        ) : (
          <ProductGrid
            featured={true}
            limit={2}
            title="Passend zum Thema"
            intro="Das hat uns selbst am meisten geholfen beim Thema Beziehung und Selbstreflexion."
          />
        )}

        <!-- Mid-article CTA (injected after 3rd h2 via JS) -->
        <template id="mid-cta-template">
          <div class="not-prose my-10 rounded-2xl p-8 sm:p-10 text-center relative overflow-hidden" style="background: linear-gradient(135deg, var(--color-primary-600), var(--color-primary-800)); border: none;">
            <div style="position: absolute; top: 0; right: 0; width: 200px; height: 200px; border-radius: 50%; background: rgba(255,255,255,0.08); transform: translate(40%, -40%);"></div>
            <div style="position: absolute; bottom: 0; left: 0; width: 120px; height: 120px; border-radius: 50%; background: rgba(255,255,255,0.05); transform: translate(-30%, 30%);"></div>
            <div style="position: relative;">
              <p style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.7); margin-bottom: 0.5rem;">In 30 Sekunden zum Ergebnis</p>
              <p class="text-xl sm:text-2xl font-extrabold mb-3" style="color: white; font-family: var(--font-serif); letter-spacing: -0.02em;">Welche Dating-Seite passt zu dir?</p>
              <p class="text-sm mb-6" style="color: rgba(255,255,255,0.8); max-width: 400px; margin: 0 auto;">Beantworte 4 kurze Fragen und finde dein perfektes Match — kostenlos.</p>
              <button onclick="window.openDatingQuiz()" class="inline-flex items-center gap-2 px-7 py-3.5 rounded-full text-sm font-bold bg-white hover:bg-white/95 transition-all shadow-lg hover:shadow-xl hover:-translate-y-0.5 cursor-pointer" style="color: var(--color-primary-700); border: none;">
                Quiz starten
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </button>
              <p style="font-size: 0.7rem; color: rgba(255,255,255,0.5); margin-top: 0.75rem;">6 Plattformen · Kostenlos · Keine Anmeldung</p>
            </div>
          </div>
        </template>

        <script is:inline>
          // Insert mid-article CTA after the 3rd h2 in the article
          document.addEventListener('DOMContentLoaded', () => {
            const article = document.getElementById('article-content');
            const template = document.getElementById('mid-cta-template');
            if (!article || !template) return;
            const h2s = article.querySelectorAll('h2');
            if (h2s.length >= 4) {
              const targetH2 = h2s[2]; // after 3rd h2
              const cta = template.content.cloneNode(true);
              targetH2.parentNode.insertBefore(cta, targetH2);
            }
          });
        </script>

        <!-- FAQ Section -->
        {post.data.faq && post.data.faq.length > 0 && (
          <section class="mt-10 rounded-2xl p-6 sm:p-8" style="background: var(--bg-soft); border: 1px solid var(--border);">
            <h2 class="text-xl font-bold mb-6" style="color: var(--text); font-family: var(--font-serif);">Häufig gestellte Fragen</h2>
            <div class="space-y-4">
              {post.data.faq.map((item: { question: string; answer: string }) => (
                <details class="group rounded-xl p-4" style="background: var(--bg-card); border: 1px solid var(--border);">
                  <summary class="font-semibold text-sm cursor-pointer list-none flex items-center justify-between gap-4" style="color: var(--text);">
                    {item.question}
                    <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 transition-transform group-open:rotate-180" style="color: var(--text-muted);"><path d="m6 9 6 6 6-6"/></svg>
                  </summary>
                  <p class="mt-3 text-sm leading-relaxed" style="color: var(--text-muted);">{item.answer}</p>
                </details>
              ))}
            </div>
          </section>
        )}

        <!-- Internal Links (SEO) -->
        {internalLinks.length > 0 && (
          <div class="mt-10 rounded-2xl p-6" style="background: var(--bg-soft); border: 1px solid var(--border);">
            <h3 class="text-sm font-bold uppercase tracking-wider mb-4" style="color: var(--text-muted);">Weiterlesen zum Thema</h3>
            <ul class="space-y-2">
              {internalLinks.map(link => (
                <li>
                  <a href={`/blog/${link.slug}`} class="text-sm font-medium hover:underline inline-flex items-center gap-1.5" style="color: var(--color-primary-600);">
                    <span>→</span> {link.title}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        )}

        <!-- Share Bar (after article) -->
        <div class="mt-10 py-5 flex items-center justify-between" style="border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
          <p class="text-sm font-medium" style="color: var(--text-muted);">Artikel teilen:</p>
          <div class="flex items-center gap-2">
            <a href={`https://wa.me/?text=${encodeURIComponent(shareTitle + ' ' + shareUrl)}`} target="_blank" rel="noopener" class="share-btn-lg" style="background: #25D366;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
            </a>
            <a href={`https://www.facebook.com/sharer/sharer.php?u=${encodeURIComponent(shareUrl)}`} target="_blank" rel="noopener" class="share-btn-lg" style="background: #1877F2;">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="white"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
            </a>
            <a href={`https://twitter.com/intent/tweet?text=${encodeURIComponent(shareTitle)}&url=${encodeURIComponent(shareUrl)}`} target="_blank" rel="noopener" class="share-btn-lg" style="background: #0f1419;">
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="white"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
            </a>
            <button onclick="navigator.clipboard.writeText(window.location.href); this.textContent='Kopiert!'; setTimeout(()=>this.innerHTML='<svg xmlns=\'http://www.w3.org/2000/svg\' width=\'16\' height=\'16\' viewBox=\'0 0 24 24\' fill=\'none\' stroke=\'white\' stroke-width=\'2\' stroke-linecap=\'round\' stroke-linejoin=\'round\'><path d=\'M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71\'/><path d=\'M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71\'/></svg>',1500);" class="share-btn-lg text-xs font-medium text-white" style="background: var(--color-primary-500);">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"/><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"/></svg>
            </button>
          </div>
        </div>

        <!-- Author Bio Box -->
        <div class="mt-14 rounded-2xl p-6" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <div class="flex items-start gap-4">
            <a href={`/autor/${author.slug}`} class="shrink-0">
              <img src={author.image} alt={author.name} class="w-16 h-16 rounded-full object-cover" style="border: 3px solid var(--color-primary-200);" loading="lazy" />
            </a>
            <div>
              <p class="text-xs font-bold uppercase tracking-wider mb-1" style="color: var(--color-primary-600);">Über den Autor</p>
              <a href={`/autor/${author.slug}`} class="text-lg font-bold hover:underline" style="color: var(--text); font-family: var(--font-serif); text-decoration: none;">{author.name}</a>
              <p class="text-xs font-medium mb-2" style="color: var(--color-primary-600);">{author.role}</p>
              <p class="text-sm leading-relaxed" style="color: var(--text-muted);">{author.shortBio}</p>
              <a href={`/autor/${author.slug}`} class="inline-block mt-3 text-xs font-semibold" style="color: var(--color-primary-600);">Alle Artikel von {author.name} →</a>
            </div>
          </div>
        </div>

        <!-- CTA -->
        <div class="mt-14 mb-8">
          <AppCTA variant="inline" />
        </div>

        <!-- Related Articles -->
        {relatedPosts.length > 0 && (
          <section class="mt-10 pt-10" style="border-top: 1px solid var(--border);">
            <div class="flex items-center gap-3 mb-6">
              <div class="w-1 h-6 rounded-full" style="background: linear-gradient(to bottom, var(--color-primary-500), var(--color-primary-300));"></div>
              <h2 class="text-sm font-semibold uppercase tracking-wider" style="color: var(--text-muted);">Das könnte dich auch interessieren</h2>
            </div>
            <div class="grid grid-cols-1 sm:grid-cols-3 gap-4">
              {relatedPosts.map(rp => (
                <BlogCard
                  title={rp.data.title}
                  description={rp.data.description}
                  date={rp.data.date}
                  tags={rp.data.tags}
                  slug={rp.id}
                  readingTime={getReadingTime(rp.body || '')}
                  image={rp.data.image}
                  imageAlt={rp.data.imageAlt}
                />
              ))}
            </div>
          </section>
        )}

        <!-- Footer Tags -->
        <footer class="mt-8 pt-8" style="border-top: 1px solid var(--border);">
          <div class="flex flex-wrap gap-2 mb-6">
            {(post.data.tags || []).map((tag: string) => (
              <a href={`/tags/${tag}`} class="text-sm px-3 py-1.5 rounded-full hover:opacity-80 transition-opacity" style="background: var(--bg-soft); color: var(--text-muted); border: 1px solid var(--border);">
                #{tag}
              </a>
            ))}
          </div>
        </footer>

        <!-- Prev/Next Navigation -->
        <nav class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-4" aria-label="Weitere Artikel">
          {prevPost ? (
            <a href={`/blog/${prevPost.id}`} class="group flex items-start gap-3 rounded-2xl p-4 transition-all hover:-translate-y-0.5" style="background: var(--bg-soft); border: 1px solid var(--border);">
              <span class="mt-0.5 shrink-0 text-lg" style="color: var(--text-muted);">←</span>
              <div class="min-w-0">
                <span class="text-[10px] font-bold uppercase tracking-wider" style="color: var(--text-muted);">Vorheriger Artikel</span>
                <p class="text-sm font-semibold mt-1 line-clamp-2 group-hover:text-[var(--color-primary-600)]" style="color: var(--text); font-family: var(--font-serif);">{prevPost.data.title}</p>
              </div>
            </a>
          ) : <div />}
          {nextPost ? (
            <a href={`/blog/${nextPost.id}`} class="group flex items-start gap-3 rounded-2xl p-4 text-right transition-all hover:-translate-y-0.5 sm:flex-row-reverse" style="background: var(--bg-soft); border: 1px solid var(--border);">
              <span class="mt-0.5 shrink-0 text-lg" style="color: var(--text-muted);">→</span>
              <div class="min-w-0">
                <span class="text-[10px] font-bold uppercase tracking-wider" style="color: var(--text-muted);">Nächster Artikel</span>
                <p class="text-sm font-semibold mt-1 line-clamp-2 group-hover:text-[var(--color-primary-600)]" style="color: var(--text); font-family: var(--font-serif);">{nextPost.data.title}</p>
              </div>
            </a>
          ) : <div />}
        </nav>
      </article>

      <!-- Sidebar -->
      <div class="w-full lg:w-[340px] shrink-0">
        <div class="lg:sticky lg:top-24">
          <!-- Newsletter Banner -->
          <div class="rounded-2xl overflow-hidden" style="background: linear-gradient(135deg, var(--color-primary-600), var(--color-primary-800));">
            <div class="relative p-6 text-center">
              <div style="position: absolute; top: -20px; right: -20px; width: 100px; height: 100px; border-radius: 50%; background: rgba(255,255,255,0.08);"></div>
              <div style="position: absolute; bottom: -15px; left: -15px; width: 70px; height: 70px; border-radius: 50%; background: rgba(255,255,255,0.05);"></div>
              <div class="relative">
                <div class="text-3xl mb-3">💌</div>
                <h3 class="text-lg font-extrabold text-white mb-1.5" style="font-family: var(--font-serif); letter-spacing: -0.02em;">Date-Vorschläge direkt<br/>in dein Postfach</h3>
                <p class="text-xs mb-4" style="color: rgba(255,255,255,0.75);">Kreative Date-Ideen, neue Hotspots & Inspiration — kostenlos.</p>
                <form id="blog-newsletter-form" class="space-y-2.5">
                  <input
                    type="email"
                    name="email"
                    placeholder="Deine E-Mail-Adresse"
                    required
                    class="w-full px-4 py-2.5 rounded-xl text-sm outline-none transition-all focus:ring-2 focus:ring-white/30"
                    style="background: rgba(255,255,255,0.15); color: white; border: 1px solid rgba(255,255,255,0.2); backdrop-filter: blur(4px);"
                  />
                  <button
                    type="submit"
                    id="blog-nl-btn"
                    class="w-full py-2.5 rounded-xl text-sm font-bold transition-all hover:shadow-lg hover:-translate-y-0.5 cursor-pointer"
                    style="background: white; color: var(--color-primary-700); border: none;"
                  >
                    Kostenlos anmelden
                  </button>
                </form>
                <p id="blog-nl-msg" class="text-[10px] mt-3" style="color: rgba(255,255,255,0.7); min-height: 1em;">Kein Spam · Jederzeit abmeldbar</p>
              </div>
            </div>
          </div>

          <!-- Beliebte Beiträge -->
          <div class="mt-5 rounded-2xl p-5" style="background: var(--bg-soft); border: 1px solid var(--border);">
            <h3 class="text-xs font-bold uppercase tracking-wider mb-4 flex items-center gap-2" style="color: var(--text-muted);">
              <span style="color: var(--color-primary-500);">🔥</span> Beliebt
            </h3>
            <ul class="space-y-3">
              {popularPosts.map((pp, i) => (
                <li>
                  <a href={`/blog/${pp.id}`} class="group flex items-start gap-3">
                    <span class="shrink-0 w-6 h-6 rounded-full flex items-center justify-center text-[10px] font-bold" style={`background: ${i < 3 ? 'var(--color-primary-100)' : 'var(--bg-soft)'}; color: ${i < 3 ? 'var(--color-primary-700)' : 'var(--text-muted)'}; border: 1px solid var(--border);`}>{i + 1}</span>
                    <span class="text-xs font-medium leading-snug line-clamp-2 group-hover:text-[var(--color-primary-600)]" style="color: var(--text);">{pp.data.title}</span>
                  </a>
                </li>
              ))}
            </ul>
          </div>

          <!-- Gutschein under widget -->
          <div class="mt-5 rounded-2xl p-5 text-center" style="background: var(--bg-soft); border: 1px solid var(--border);">
            <p class="text-xs font-bold uppercase tracking-wider mb-2" style="color: var(--color-primary-600);">Exklusiver Gutschein</p>
            <p class="text-sm mb-3" style="color: var(--text);">
              <span class="font-bold">25% mehr Coins</span> auf deinen ersten Kauf:
            </p>
            <button
              onclick="navigator.clipboard.writeText('Herzblatt25'); this.textContent='Kopiert!'; setTimeout(()=>this.textContent='Herzblatt25', 2000);"
              class="inline-block px-5 py-2 rounded-lg text-sm font-mono font-bold cursor-pointer transition-all hover:scale-105"
              style="background: var(--color-primary-50); color: var(--color-primary-700); border: 2px dashed var(--color-primary-300);"
            >Herzblatt25</button>
            <p class="text-[10px] mt-2" style="color: var(--text-muted);">Klicken zum Kopieren</p>
          </div>
        </div>
      </div>
    </div>
  </div>
</BaseLayout>

<style>
  .share-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    transition: all 0.2s;
  }
  .share-btn:hover {
    background: var(--bg-soft);
    color: var(--text) !important;
  }
  .share-btn-lg {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    transition: all 0.2s;
  }
  .share-btn-lg:hover {
    opacity: 0.85;
    transform: translateY(-1px);
  }
</style>

<script is:inline>
  (function () {
    const form = document.getElementById('blog-newsletter-form');
    if (!form) return;
    const btn = document.getElementById('blog-nl-btn');
    const msg = document.getElementById('blog-nl-msg');
    const input = form.querySelector('input[name="email"]');
    form.addEventListener('submit', async function (e) {
      e.preventDefault();
      const email = input ? input.value.trim() : '';
      if (!email) return;
      const orig = btn ? btn.textContent : '';
      if (btn) { btn.disabled = true; btn.textContent = '…'; }
      if (msg) msg.textContent = '';
      try {
        const res = await fetch('/api/newsletter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email, source: 'blog-cta' }),
        });
        const data = await res.json();
        if (data && data.success) {
          form.reset();
          if (btn) { btn.textContent = 'Angemeldet ✓'; btn.style.background = '#16a34a'; btn.style.color = 'white'; }
          if (msg) { msg.textContent = data.message || 'Willkommen!'; msg.style.color = 'rgba(255,255,255,0.95)'; }
        } else {
          if (btn) { btn.disabled = false; btn.textContent = orig || 'Kostenlos anmelden'; }
          if (msg) msg.textContent = (data && data.message) || 'Bitte erneut versuchen.';
        }
      } catch (err) {
        if (btn) { btn.disabled = false; btn.textContent = orig || 'Kostenlos anmelden'; }
        if (msg) msg.textContent = 'Verbindungsfehler.';
      }
    });
  })();
</script>
