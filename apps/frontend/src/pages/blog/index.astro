---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const POSTS_PER_PAGE = 24;

const allPosts = (await getCollection('blog', ({ data }) => !data.draft && data.date <= new Date()))
  .sort((a, b) => (b.data.date?.valueOf?.() || 0) - (a.data.date?.valueOf?.() || 0));

const totalPages = Math.ceil(allPosts.length / POSTS_PER_PAGE);
// Server-side Pagination: index.astro rendert Seite 1. Weitere Seiten via /blog/[page].astro
const postsToDisplay = allPosts.slice(0, POSTS_PER_PAGE);

function getReadingTime(body: string) {
  const words = body.split(/\s+/).length;
  const minutes = Math.ceil(words / 200);
  return `${minutes} Min. Lesezeit`;
}

// Build tag counts
const tagCounts = new Map<string, number>();
allPosts.forEach(post => {
  (post.data.tags || []).forEach(tag => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});
const topTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 8);

const categoryIcons: Record<string, string> = {
  'Dating-Tipps': '💡',
  'Online-Dating': '📱',
  'Beziehungen': '💑',
  'Flirten': '✨',
  'Psychologie': '🧠',
  'Ratgeber': '📖',
  'Date-Ideen': '🎯',
  'Erstes Date': '🦋',
  'Selbstbewusstsein': '💪',
  'Kommunikation': '💬',
  'Red-Flags': '🚩',
  'Selbstliebe': '💖',
  'Sicherheit': '🔒',
};

const nextPage = totalPages > 1 ? 2 : null;
---

<BaseLayout title="Dating-Ratgeber — Herzblatt Journal" description="Tipps und Ratgeber rund um Dating, Flirten und Beziehungen.">
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16">

    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-extrabold mb-2" style="color: var(--text); font-family: var(--font-serif);">Alle Ratgeber</h1>
      <p style="color: var(--text-muted);">
        {allPosts.length} Artikel rund um Dating, Liebe & Beziehungen
      </p>
    </div>

    <!-- Kategorien (Links auf /tags/:tag — server-side statt Client-Filter) -->
    <nav class="flex flex-wrap gap-2 mb-10" aria-label="Kategorien">
      <a
        href="/blog"
        class="filter-chip active inline-flex items-center px-4 rounded-full text-sm font-medium transition-all"
        style="min-height: 44px;"
        aria-current="page"
      >
        Alle
      </a>
      {topTags.map(([tag, count]) => (
        <a
          href={`/tags/${encodeURIComponent(tag)}`}
          class="filter-chip inline-flex items-center px-4 rounded-full text-sm font-medium transition-all"
          style="min-height: 44px;"
        >
          <span class="mr-1" aria-hidden="true">{categoryIcons[tag] || '♥'}</span>
          {tag}
          <span class="ml-1.5 text-xs opacity-60">({count})</span>
        </a>
      ))}
    </nav>

    <!-- Posts Grid (nur Seite 1 — 24 Artikel) -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="posts-grid">
      {postsToDisplay.map((post, i) => (
        <BlogCard
          title={post.data.title}
          description={post.data.description}
          date={post.data.date}
          tags={post.data.tags}
          slug={post.id}
          readingTime={getReadingTime(post.body || '')}
          image={post.data.image}
          imageAlt={post.data.imageAlt}
          priority={i < 2}
        />
      ))}
    </div>

    <!-- Server-Side Pagination -->
    {totalPages > 1 && (
      <nav class="mt-16 mb-4" aria-label="Seitennavigation">
        <div class="flex flex-col items-center gap-5">
          <div class="flex items-center gap-1 flex-wrap justify-center">
            <span class="inline-flex items-center justify-center w-10 h-10 rounded-full text-sm font-bold text-white" style="background: var(--color-primary-500); box-shadow: 0 2px 8px rgba(244,63,94,0.3);">1</span>
            {Array.from({ length: totalPages }, (_, i) => i + 1)
              .filter(p => p !== 1 && p <= 4)
              .map(p => (
                <a
                  href={`/blog/${p}`}
                  class="inline-flex items-center justify-center w-10 h-10 rounded-full text-sm font-semibold transition-all hover:opacity-80"
                  style="color: var(--text-muted); background: var(--bg-card); border: 1px solid var(--border);"
                >
                  {p}
                </a>
              ))}
            {totalPages > 5 && (
              <span class="inline-flex items-center justify-center w-10 h-10 text-sm" style="color: var(--text-muted);">···</span>
            )}
            {totalPages > 4 && (
              <a
                href={`/blog/${totalPages}`}
                class="inline-flex items-center justify-center w-10 h-10 rounded-full text-sm font-semibold transition-all hover:opacity-80"
                style="color: var(--text-muted); background: var(--bg-card); border: 1px solid var(--border);"
              >
                {totalPages}
              </a>
            )}
          </div>
          {nextPage && (
            <a
              href={`/blog/${nextPage}`}
              class="inline-flex items-center gap-2 px-5 rounded-xl text-sm font-medium transition-all hover:opacity-80"
              style="background: var(--color-primary-500); color: white; min-height: 44px;"
            >
              Weiter
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="m9 18 6-6-6-6"/></svg>
            </a>
          )}
          <p class="text-sm" style="color: var(--text-muted);">
            Seite 1 von {totalPages} · {allPosts.length} Artikel
          </p>
        </div>
      </nav>
    )}

  </section>
</BaseLayout>

<style>
  .filter-chip {
    background: var(--bg-card);
    color: var(--text-muted);
    border: 1px solid var(--border);
    text-decoration: none;
  }
  .filter-chip:hover {
    border-color: var(--color-primary-300);
    color: var(--text);
  }
  .filter-chip.active {
    background: var(--color-primary-500);
    color: white;
    border-color: var(--color-primary-500);
  }
</style>
