---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
import { getAllAuthors } from '../data/authors';

// Alle Autoren aus der zentralen Quelle (data/authors.ts) laden.
// Das Redaktions-Profil (slug 'redaktion') wird nicht einzeln gelistet —
// es dient nur als Default-Fallback für Artikel ohne expliziten Author-Slug.
const allAuthors = getAllAuthors().filter(a => a.slug !== 'redaktion');

// Artikel-Counts pro Author berechnen (Posts ohne author-Feld zählen als 'redaktion')
const posts = await getCollection('blog', ({ data }) => !data.draft && data.date <= new Date());
const articlesByAuthor = new Map<string, number>();
for (const post of posts) {
  const slug = ((post.data as any).author as string | undefined) || 'redaktion';
  articlesByAuthor.set(slug, (articlesByAuthor.get(slug) || 0) + 1);
}

// Sortierung: Gründerin/Chefredakteurin zuerst, dann nach Artikelanzahl absteigend
const authorsWithStats = allAuthors
  .map(author => ({
    ...author,
    articleCount: articlesByAuthor.get(author.slug) || 0,
  }))
  .sort((a, b) => {
    const aLead = /Gründer|Chefredakteur/i.test(a.role) ? 0 : 1;
    const bLead = /Gründer|Chefredakteur/i.test(b.role) ? 0 : 1;
    if (aLead !== bLead) return aLead - bLead;
    return b.articleCount - a.articleCount;
  });

// Schema.org Person markup (pro Autor)
const personSchemas = authorsWithStats.map(author => ({
  "@context": "https://schema.org",
  "@type": "Person",
  "name": author.name,
  "jobTitle": author.role,
  "description": author.shortBio,
  "image": `https://herzblatt-journal.com${author.image}`,
  "url": `https://herzblatt-journal.com/autor/${author.slug}`,
  "worksFor": {
    "@type": "Organization",
    "name": "Herzblatt Journal",
    "url": "https://herzblatt-journal.com"
  },
  ...(author.knowsAbout ? { "knowsAbout": author.knowsAbout } : {}),
  ...(author.alumniOf ? {
    "alumniOf": {
      "@type": "EducationalOrganization",
      "name": author.alumniOf
    }
  } : {}),
  ...(author.credentials ? { "hasCredential": author.credentials } : {}),
}));
---

<BaseLayout
  title="Unsere Autoren — Herzblatt Journal"
  description="Lerne das Redaktionsteam hinter Herzblatt Journal kennen. Psycholog:innen, zertifizierte Coaches und erfahrene Fachjournalist:innen schreiben für dich."
>
  {personSchemas.map(schema => (
    <script type="application/ld+json" set:html={JSON.stringify(schema)} />
  ))}

  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-16">
    <!-- Header -->
    <div class="text-center mb-14">
      <h1 class="text-3xl sm:text-4xl font-extrabold mb-4" style="color: var(--text); font-family: var(--font-serif);">Unsere Autoren</h1>
      <p class="text-lg max-w-2xl mx-auto" style="color: var(--text-muted);">
        Hinter jedem Artikel steht ein Experte, der sich mit Leidenschaft für dein Liebesleben einsetzt.
      </p>
    </div>

    <!-- Authors -->
    <div class="space-y-12">
      {authorsWithStats.map((author, i) => (
        <article class="rounded-2xl overflow-hidden" style="background: var(--bg-card); border: 1px solid var(--border); box-shadow: 0 2px 12px rgba(0,0,0,0.04);">
          <div class="flex flex-col sm:flex-row">
            <!-- Photo -->
            <div class="sm:w-64 shrink-0">
              <div class="aspect-square sm:aspect-auto sm:h-full overflow-hidden">
                <a href={`/autor/${author.slug}`} aria-label={`Zum Profil von ${author.name}`}>
                  <img src={author.image} alt={author.name} class="w-full h-full object-cover" loading={i === 0 ? "eager" : "lazy"} />
                </a>
              </div>
            </div>

            <!-- Info -->
            <div class="p-6 sm:p-8 flex-1">
              <div class="mb-4">
                <h2 class="text-xl font-bold mb-1" style="color: var(--text); font-family: var(--font-serif);">
                  <a href={`/autor/${author.slug}`} style="color: inherit; text-decoration: none;">{author.name}</a>
                </h2>
                <p class="text-sm font-medium" style="color: var(--color-primary-600);">{author.role}</p>
              </div>

              <p class="text-sm leading-relaxed mb-5" style="color: var(--text-muted);">{author.bio}</p>

              <!-- Specialties -->
              <div class="flex flex-wrap gap-2 mb-5">
                {author.expertise.map(s => (
                  <span class="text-xs font-medium px-3 py-1 rounded-full" style="background: var(--color-primary-50); color: var(--color-primary-700);">{s}</span>
                ))}
              </div>

              <!-- Stats -->
              <div class="flex items-center gap-6 pt-4" style="border-top: 1px solid var(--border);">
                {author.articleCount > 0 && (
                  <div>
                    <p class="text-lg font-bold" style="color: var(--color-primary-600);">{author.articleCount}</p>
                    <p class="text-[10px] uppercase tracking-wider font-medium" style="color: var(--text-muted);">Artikel</p>
                  </div>
                )}
                {author.yearsExperience && (
                  <div>
                    <p class="text-lg font-bold" style="color: var(--color-primary-600);">{author.yearsExperience}+</p>
                    <p class="text-[10px] uppercase tracking-wider font-medium" style="color: var(--text-muted);">Jahre Erfahrung</p>
                  </div>
                )}
                <div class="ml-auto">
                  <a
                    href={`/autor/${author.slug}`}
                    class="inline-flex items-center gap-1 text-sm font-medium"
                    style="color: var(--color-primary-600);"
                  >
                    Profil ansehen
                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
                  </a>
                </div>
              </div>
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- E-E-A-T Statement -->
    <div class="mt-14 rounded-2xl p-8 text-center" style="background: var(--bg-soft); border: 1px solid var(--border);">
      <h2 class="text-lg font-bold mb-3" style="color: var(--text); font-family: var(--font-serif);">Unser Qualitätsversprechen</h2>
      <p class="text-sm leading-relaxed max-w-2xl mx-auto" style="color: var(--text-muted);">
        Alle Artikel bei Herzblatt Journal werden von zertifizierten Beziehungsberatern und erfahrenen Dating-Experten verfasst.
        Wir stützen unsere Inhalte auf aktuelle psychologische Forschung und jahrelange Praxiserfahrung.
        Unser Ziel: Dir fundierte, ehrliche und alltagstaugliche Ratschläge zu geben, die wirklich funktionieren.
      </p>
    </div>

    <!-- Link to latest articles -->
    <div class="mt-10 text-center">
      <a href="/blog" class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-semibold text-white transition-all hover:shadow-lg hover:-translate-y-0.5" style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-600));">
        Unsere neuesten Artikel lesen
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
    </div>
  </section>
</BaseLayout>
