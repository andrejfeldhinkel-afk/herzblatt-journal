---
/**
 * /ebook/zugang — Recovery-Page für verlorene Zugangs-Links.
 *
 * User kann seine Email eingeben. Backend checkt ob es einen paid-Kauf gibt
 * und verschickt ggf. eine neue Access-Mail. Response ist IMMER neutral
 * (keine Info darüber ob Kauf existiert — Security/GDPR).
 *
 * Rate-Limit (3/h pro IP) setzt das Backend.
 */
export const prerender = false;

import BaseLayout from '../../layouts/BaseLayout.astro';

const url = Astro.url;
const hinweis = url.searchParams.get('hinweis') || '';
const fehler = url.searchParams.get('fehler') || '';

const title = 'Zugang zur Herzblatt-Methode | Herzblatt Journal';
const description = 'Du hast deinen Zugangs-Link verloren? Hier kannst du ihn neu anfordern.';

let initialNote: { type: 'info' | 'error'; text: string } | null = null;
if (fehler === 'token') {
  initialNote = {
    type: 'error',
    text: 'Dein Zugangs-Link ist nicht mehr gültig. Gib bitte deine E-Mail ein — wir senden dir einen neuen Link.',
  };
} else if (fehler === 'netz') {
  initialNote = {
    type: 'error',
    text: 'Die Verbindung zum Server hat gerade nicht geklappt. Bitte versuch es gleich erneut.',
  };
} else if (hinweis === 'login') {
  initialNote = {
    type: 'info',
    text: 'Um deine Herzblatt-Methode zu lesen, brauchst du einen Zugangs-Link. Gib einfach die E-Mail ein, mit der du gekauft hast.',
  };
}
---
<BaseLayout title={title} description={description} noindex>

  <section class="min-h-[70vh] py-16 px-4" style="background: linear-gradient(180deg, var(--color-primary-50) 0%, #fff 60%);">
    <div class="max-w-xl mx-auto">
      <div class="text-center mb-8">
        <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-5" style="background: var(--color-primary-100); color: var(--color-primary-700);">
          Lese-Zugang
        </span>
        <h1 class="font-extrabold mb-3" style="font-family: var(--font-serif); font-size: clamp(1.75rem, 4vw, 2.5rem); color: var(--text); letter-spacing: -0.02em; line-height: 1.15;">
          Neuen Zugangs-Link<br/>anfordern
        </h1>
        <p class="text-base" style="color: var(--text-muted); line-height: 1.6;">
          Gib die E-Mail ein, mit der du die Herzblatt-Methode gekauft hast. Wir senden dir deinen persönlichen Lese-Link zu.
        </p>
      </div>

      {initialNote && (
        <div class={`mb-5 p-4 rounded-lg text-sm ${initialNote.type === 'error' ? 'border border-red-200 bg-red-50 text-red-900' : 'border border-blue-200 bg-blue-50 text-blue-900'}`} role="status">
          {initialNote.text}
        </div>
      )}

      <form id="ebook-access-form" class="bg-white p-6 sm:p-8 rounded-xl shadow-sm border" style="border-color: var(--border);">
        <label for="email" class="block text-sm font-semibold mb-2" style="color: var(--text);">
          Deine E-Mail-Adresse
        </label>
        <input
          type="email"
          id="email"
          name="email"
          required
          autocomplete="email"
          placeholder="z.B. vorname@mail.de"
          class="w-full px-4 py-3 rounded-lg border text-base focus:outline-none focus:ring-2"
          style="border-color: var(--border);"
        />
        <button
          type="submit"
          id="submit-btn"
          class="w-full mt-4 px-6 py-3 rounded-lg font-bold text-white text-base cursor-pointer"
          style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-600)); border: none;"
        >
          Zugangs-Link senden
        </button>
        <p class="mt-3 text-xs" style="color: var(--text-muted);">
          Du erhältst den Link innerhalb weniger Minuten. Kein Spam — wir versenden ausschließlich deinen Zugangs-Link.
        </p>
      </form>

      <div id="result-box" class="hidden mt-5 p-4 rounded-lg text-sm" role="status" aria-live="polite"></div>

      <div class="mt-10 text-center">
        <p class="text-sm" style="color: var(--text-muted);">
          Noch nicht gekauft?
          <a href="/ebook" class="font-semibold" style="color: var(--color-primary-600); text-decoration: underline;">Zur Herzblatt-Methode</a>
        </p>
        <p class="mt-3 text-xs" style="color: var(--text-muted);">
          Fragen? <a href="mailto:service@herzblatt-journal.com" style="color: var(--color-primary-600);">service@herzblatt-journal.com</a>
        </p>
      </div>
    </div>
  </section>

  <script is:inline>
    (function () {
      const form = document.getElementById('ebook-access-form');
      const btn = document.getElementById('submit-btn');
      const box = document.getElementById('result-box');
      const emailInput = document.getElementById('email');
      if (!form || !btn || !box || !emailInput) return;

      function show(type, text) {
        box.className = 'mt-5 p-4 rounded-lg text-sm ' + (type === 'error'
          ? 'border border-red-200 bg-red-50 text-red-900'
          : 'border border-green-200 bg-green-50 text-green-900');
        box.textContent = text;
        box.classList.remove('hidden');
      }

      form.addEventListener('submit', async (e) => {
        e.preventDefault();
        const email = String(emailInput.value || '').trim().toLowerCase();
        if (!email || !/^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email)) {
          show('error', 'Bitte gib eine gültige E-Mail-Adresse ein.');
          return;
        }

        btn.disabled = true;
        const originalText = btn.textContent;
        btn.textContent = 'Wird gesendet…';
        box.classList.add('hidden');

        try {
          const res = await fetch('/api/ebook/request-access', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email }),
          });
          const data = await res.json().catch(() => ({}));

          if (res.status === 429) {
            show('error', (data && data.error) || 'Zu viele Anfragen. Bitte warte etwa eine Stunde.');
          } else if (res.ok && data.ok) {
            show('ok', data.message || 'Wenn wir einen Kauf unter dieser E-Mail finden, ist der Zugangs-Link gleich unterwegs.');
            emailInput.value = '';
          } else {
            show('error', 'Es gab ein technisches Problem. Bitte versuch es in ein paar Minuten erneut oder schreib an service@herzblatt-journal.com.');
          }
        } catch (_) {
          show('error', 'Netzwerkfehler. Bitte prüfe deine Verbindung und versuch es erneut.');
        } finally {
          btn.disabled = false;
          btn.textContent = originalText;
        }
      });
    })();
  </script>

</BaseLayout>
