                <div class="px-4 pb-4 space-y-4">
                  <div class="grid grid-cols-2 gap-3">
                    {Object.entries(site.features).map(([key, value]) => (
                      <div class="rounded-lg p-3" style="background: var(--bg-soft); border: 1px solid var(--border);">
                        <p class="text-[10px] font-bold uppercase tracking-wider mb-1" style="color: var(--text-muted);">{key}</p>
                        <p class="text-xs font-medium leading-snug" style="color: var(--text);">{value}</p>
                      </div>
                    ))}
                  </div>
                  <div class="rounded-lg p-4" style="background: var(--bg-soft);">
                    <p class="text-sm leading-relaxed" style="color: var(--text-muted);">{site.review}</p>
                  </div>
                </div>
              </details>
              <div class="rounded-xl overflow-hidden mb-6" style="background: linear-gradient(135deg, #fef3c7, #fde68a); border: 2px dashed #f59e0b;">
                <div class="flex flex-col sm:flex-row items-start sm:items-center gap-4 sm:gap-6 px-5 py-4">
                  <div class="flex items-center gap-3">
                    <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="#d97706" stroke-width="1.5"><path d="M21 5H3a2 2 0 0 0-2 2v4a2 2 0 0 1 2 2 2 2 0 0 1-2 2v4a2 2 0 0 0 2 2h18a2 2 0 0 0 2-2v-4a2 2 0 0 1-2-2 2 2 0 0 1 2-2V7a2 2 0 0 0-2-2z"/><path d="M12 5v2"/><path d="M12 17v2"/><path d="M12 11v2"/></svg>
                    <div>
                      <p class="text-xs font-bold uppercase tracking-wider" style="color: #92400e;">Exklusiver Code</p>
                      <p class="text-sm font-bold" style="color: #78350f;">25% Bonus beim Kauf</p>
                    </div>
                  </div>
                  <button onclick={`navigator.clipboard.writeText('Herzblatt25'); const el = this; el.textContent = '✓ Kopiert!'; el.style.background = '#16a34a'; el.style.color = 'white'; setTimeout(() => { el.textContent = 'Herzblatt25'; el.style.background = '#fffbeb'; el.style.color = '#92400e'; }, 2000);`} class="shrink-0 px-4 py-2 rounded-lg text-sm font-mono font-bold cursor-pointer transition-all hover:scale-105" style="background: #fffbeb; color: #92400e; border: 2px solid #f59e0b;">Herzblatt25</button>
                </div>
              </div>
              <div class="flex flex-col sm:flex-row gap-3">
