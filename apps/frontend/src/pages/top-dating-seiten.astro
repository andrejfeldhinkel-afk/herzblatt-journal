    review: 'Single69 setzt auf Quantität — und das ist in diesem Fall ein Kompliment. Mit über 200.000 aktiven Mitgliedern bietet die Plattform den größten Nutzerpool unter den Casual-Dating-Seiten im deutschsprachigen Raum. Die Rechnung ist einfach: Mehr Nutzer bedeuten mehr Matches, und mehr Matches bedeuten mehr Dates. In unserem Test hat das funktioniert — bereits am ersten Tag hatten wir in Berlin über 30 potenzielle Matches. Die Bedienung ist kinderleicht und erfordert keine Einarbeitungszeit. Die Suchfunktion ist solide, und die Profile lassen sich nach Alter, Standort, Interessen und weiteren Kriterien filtern. Die Altersstruktur ist breit gefächert, wobei der Schwerpunkt bei 22-38 liegt. Was weniger überzeugt: Die Gratisversion enthält deutlich mehr Werbung als bei vergleichbaren Plattformen, was auf Dauer nervig werden kann. Auch die Profilqualität schwankt — neben ausführlichen Profilen mit echten Fotos gibt es auch viele minimale Profile. Wer bereit ist, 11,99€ pro Monat für Premium zu investieren, bekommt eine deutlich bessere Erfahrung ohne Werbung und mit vollem Funktionsumfang. Für alle, die eine breite Auswahl und schnelle Ergebnisse suchen, ist Single69 eine der effektivsten Optionen.',
    ctaText: 'Jetzt bei Single69 anmelden →',
    testimonials: [
      { name: 'Patrick, 30', city: 'Stuttgart', text: 'Riesige Auswahl an Profilen. Man findet schnell Leute in der Nähe. Mit Premium wird es richtig gut — keine Werbung mehr und unbegrenztes Chatten.' },
      { name: 'Jana, 24', city: 'Leipzig', text: 'Einfach zu bedienen und so viele aktive Nutzer! Werbung nervt ohne Premium etwas, aber die Auswahl an Profilen ist einfach unschlagbar.' },
      { name: 'Sven, 36', city: 'Frankfurt', text: 'Habe Single69 parallel mit 2 anderen Apps getestet. Hier hatte ich mit Abstand die meisten Matches und Dates. Die Masse machts.' },
    ],
  },
];

const faqItems = [
  {
    question: 'Welche Dating-Seite ist wirklich kostenlos?',
    answer: 'Alle getesteten Plattformen bieten eine kostenlose Basisversion an. xLoves bietet dabei die meisten kostenlosen Funktionen, einschließlich Profil erstellen, Suchen und Basic-Matching. Für erweiterte Features wie unbegrenztes Chatten oder Profilbesucher-Einsicht ist bei allen Plattformen ein Premium-Abo nötig.',
  },
  {
    question: 'Wie sicher sind die Dating-Seiten?',
    answer: 'Alle von uns getesteten Plattformen verwenden SSL-Verschlüsselung und haben Datenschutzrichtlinien gemäß DSGVO. xLoves und MichVerlieben setzen zusätzlich auf Profilverifizierung, was die Sicherheit deutlich erhöht. Wir empfehlen grundsätzlich, keine sensiblen Daten im Profil zu teilen und sich bei ersten Treffen an öffentlichen Orten zu verabreden.',
  },
  {
    question: 'Welche Dating-Seite ist die beste für ernsthafte Beziehungen?',
    answer: 'Für ernsthafte Beziehungen empfehlen wir xLoves und MichVerlieben. Beide Plattformen legen Wert auf Profilqualität und ziehen Menschen an, die nach langfristigen Verbindungen suchen. MichVerlieben bietet zusätzlich einen wissenschaftlichen Persönlichkeitstest für bessere Matches.',
  },
  {
    question: 'Was bedeutet der Gutscheincode Herzblatt25?',
    answer: 'Mit dem exklusiven Code Herzblatt25 erhältst du 25% mehr Coins auf deinen ersten Kauf bei allen unseren Partner-Plattformen. Der Code ist für Herzblatt Journal Leser unbegrenzt gültig und kann bei der Registrierung oder beim ersten Kauf eingelöst werden.',
  },
  {
    question: 'Kann ich mehrere Dating-Seiten gleichzeitig nutzen?',
    answer: 'Ja, wir empfehlen sogar, 2-3 Plattformen parallel zu testen. So findest du heraus, welche Community und welches Konzept am besten zu dir passen. Unser Quiz hilft dir, die besten Plattformen für deine Bedürfnisse vorzufiltern.',
  },
  {
    question: 'Wie haben wir die Dating-Seiten getestet?',
    answer: 'Wir haben jede Plattform über mehrere Wochen mit echten Testprofilen genutzt und dabei Benutzerfreundlichkeit, Profilqualität, Matching-Algorithmen, Kosten-Leistungs-Verhältnis, Sicherheit und Datenschutz bewertet. Die Bewertungen basieren auf einer Skala von 1 bis 5.',
  },
];

function renderStars(rating: number) {
  const full = Math.floor(rating);
  const half = rating % 1 >= 0.3;
  const empty = 5 - full - (half ? 1 : 0);
  return { full, half, empty };
}

const reviewSchemas = datingSites.map((site) => ({
  "@type": "Review",
  "itemReviewed": {
    "@type": "WebApplication",
    "name": site.name,
    "url": site.url.split('?')[0],
    "applicationCategory": "DatingApplication",
  },
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": site.rating,
    "bestRating": 5,
    "worstRating": 1,
  },
  "author": {
    "@type": "Organization",
    "name": "Herzblatt Journal",
  },
  "publisher": {
    "@type": "Organization",
    "name": "Herzblatt Journal",
  },
  "reviewBody": site.review,
  "datePublished": "2026-02-01",
}));

const aggregateSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Top Dating Seiten 2026",
  "description": "Die besten Dating-Plattformen im Vergleich",
  "numberOfItems": datingSites.length,
  "itemListElement": datingSites.map((site, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "WebApplication",
      "name": site.name,
      "url": site.url.split('?')[0],
      "applicationCategory": "DatingApplication",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": site.rating,
        "bestRating": 5,
        "reviewCount": 1,
      },
    },
  })),
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer,
    },
  })),
};
---

<BaseLayout
  title="Top Dating Seiten 2026 im Vergleich — Herzblatt Journal"
  description="Die besten Dating-Plattformen im Test: xLoves, WhatsMeet, MichVerlieben und mehr. Ehrliche Bewertungen mit Vor- und Nachteilen."
  keywords={["dating seiten vergleich", "beste dating seiten 2026", "dating plattformen test", "online dating vergleich"]}
>
  <script type="application/ld+json" set:html={JSON.stringify(aggregateSchema)} />
  {reviewSchemas.map(schema => (
    <script type="application/ld+json" set:html={JSON.stringify({"@context": "https://schema.org", ...schema})} />
  ))}
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-12 sm:py-20">

    <!-- Header -->
    <div class="text-center mb-12">
      <span class="inline-block text-xs font-bold uppercase tracking-widest px-3 py-1 rounded-full mb-4" style="background: var(--color-primary-50); color: var(--color-primary-700);">Vergleich 2026</span>
      <h1 class="text-4xl sm:text-5xl font-bold mb-4" style="color: var(--text); font-family: var(--font-serif); line-height: 1.2; letter-spacing: -0.02em;">Top Dating Seiten im Test</h1>
      <p class="text-lg max-w-2xl mx-auto" style="color: var(--text-muted); line-height: 1.6;">Wir haben die beliebtesten Dating-Plattformen getestet und ehrlich bewertet — damit du die richtige für dich findest.</p>
    </div>

    <!-- Stats Bar -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-3 sm:gap-4 mb-12">
      <div class="rounded-xl p-4 text-center" style="background: var(--color-primary-50); border: 1px solid var(--color-primary-100);">
        <p class="text-2xl font-bold" style="color: var(--color-primary-600); font-family: var(--font-serif);">8 Mio+</p>
        <p class="text-xs font-medium mt-1" style="color: var(--color-primary-600);">Nutzer in DACH</p>
      </div>
      <div class="rounded-xl p-4 text-center" style="background: var(--color-primary-50); border: 1px solid var(--color-primary-100);">
        <p class="text-2xl font-bold" style="color: var(--color-primary-600); font-family: var(--font-serif);">8</p>
        <p class="text-xs font-medium mt-1" style="color: var(--color-primary-600);">Plattformen getestet</p>
      </div>
      <div class="rounded-xl p-4 text-center" style="background: var(--color-primary-50); border: 1px solid var(--color-primary-100);">
        <p class="text-2xl font-bold" style="color: var(--color-primary-600); font-family: var(--font-serif);">120h+</p>
        <p class="text-xs font-medium mt-1" style="color: var(--color-primary-600);">Testzeit investiert</p>
      </div>
      <div class="rounded-xl p-4 text-center" style="background: var(--color-primary-50); border: 1px solid var(--color-primary-100);">
        <p class="text-2xl font-bold" style="color: var(--color-primary-600); font-family: var(--font-serif);">100%</p>
        <p class="text-xs font-medium mt-1" style="color: var(--color-primary-600);">Unabhängig & ehrlich</p>
      </div>
    </div>

    <!-- Quiz CTA Banner -->
    <div class="mb-12 rounded-2xl p-6 sm:p-8 text-center" style="background: linear-gradient(135deg, var(--color-primary-50), var(--color-primary-100)); border: 2px solid var(--color-primary-200);">
      <p class="text-xs font-bold uppercase tracking-widest mb-2" style="color: var(--color-primary-700);">Personalisierte Empfehlung</p>
      <h2 class="text-2xl sm:text-3xl font-bold mb-3" style="color: var(--text); font-family: var(--font-serif); line-height: 1.3;">Unser Quiz zeigt dir die perfekte Plattform</h2>
      <p class="text-sm mb-6 max-w-lg mx-auto" style="color: var(--text-muted);">4 kurze Fragen — wir analysieren deine Wünsche und empfehlen dir die beste Dating-Seite.</p>
      <button onclick="window.openDatingQuiz()" class="inline-flex items-center gap-2 px-6 py-3 rounded-full text-sm font-bold text-white transition-all hover:shadow-lg hover:scale-105" style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-600)); border: none; cursor: pointer;">Quiz starten →</button>
    </div>

    <!-- Quick Jump Pills -->
    <div class="mb-12 overflow-x-auto">
      <div class="flex gap-2 pb-2 min-w-max sm:min-w-0 sm:flex-wrap sm:justify-center">
        {datingSites.map((site, i) => (
          <a href={`#${site.slug}`} class="flex items-center gap-2 px-3 py-2 rounded-full text-sm font-medium transition-all hover:shadow-md shrink-0 sm:shrink" style="background: var(--bg-soft); border: 1px solid var(--border); color: var(--text);">
            <span class="text-xs font-bold w-5 h-5 rounded-full flex items-center justify-center shrink-0" style={`background: ${i === 0 ? 'var(--color-primary-500)' : 'var(--color-primary-100)'}; color: ${i === 0 ? 'white' : 'var(--color-primary-700)'};`}>{i + 1}</span>
            {site.name}
          </a>
        ))}
      </div>
    </div>

    <!-- Comparison Table -->
    <div class="mb-12 rounded-2xl overflow-hidden" style="border: 1px solid var(--border);">
      <div class="px-6 py-4" style="background: var(--bg-soft);">
        <h2 class="text-lg font-bold" style="color: var(--text); font-family: var(--font-serif);">Übersichtstabelle</h2>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm" style="min-width: 560px;">
          <thead>
            <tr style="border-bottom: 1px solid var(--border);">
              <th class="text-left px-4 py-3 font-semibold" style="color: var(--text-muted); width: 25%;">Plattform</th>
              <th class="text-center px-3 py-3 font-semibold" style="color: var(--text-muted); width: 15%;">★ Bewertung</th>
              <th class="text-left px-3 py-3 font-semibold" style="color: var(--text-muted); width: 25%;">Ideal für</th>
              <th class="text-center px-3 py-3 font-semibold" style="color: var(--text-muted); width: 15%;">Bericht</th>
              <th class="px-3 py-3" style="width: 20%;"></th>
            </tr>
          </thead>
          <tbody>
            {datingSites.map((site, i) => (
              <tr style={`border-bottom: 1px solid var(--border); ${i === 0 ? 'background: var(--color-primary-50);' : ''}`}>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-2">
                    <span class="text-xs font-bold w-5 h-5 rounded-full flex items-center justify-center shrink-0" style={`background: ${i === 0 ? 'var(--color-primary-500)' : 'var(--color-primary-100)'}; color: ${i === 0 ? 'white' : 'var(--color-primary-700)'};`}>{i + 1}</span>
                    <img src={`/images/logos/${site.logoFile || (site.slug + '-logo.png')}`} alt={`${site.name}`} class="h-6 w-auto object-contain" loading="lazy" />
                  </div>
                </td>
                <td class="text-center px-3 py-3">
                  <span class="font-bold" style="color: var(--color-primary-600);">{site.rating}</span>
                </td>
                <td class="px-3 py-3 text-xs" style="color: var(--text-muted);">{site.idealFor}</td>
                <td class="text-center px-3 py-3">
                  <a href={`/blog/${site.slug}-test-erfahrungen`} class="inline-flex items-center gap-1 text-xs font-semibold transition-colors hover:underline" style="color: var(--color-primary-600);">Zum Bericht</a>
                </td>
                <td class="px-3 py-3">
                  <a href={site.url} target="_blank" rel="noopener" class="inline-flex items-center gap-1 px-3 py-1.5 rounded-full text-xs font-semibold text-white transition-all hover:shadow-md" style="background: var(--color-primary-500);">Testen →</a>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <!-- Individual Review Cards -->
    <h2 class="text-3xl font-bold mb-8" style="color: var(--text); font-family: var(--font-serif);">Ausführliche Bewertungen</h2>
    <div class="space-y-6">
      {datingSites.map((site, i) => {
        const { full, half, empty } = renderStars(site.rating);
        return (
          <article id={site.slug} class="rounded-2xl overflow-hidden" style={`background: var(--bg-card); border: 2px solid ${i === 0 ? 'var(--color-primary-300)' : 'var(--border)'}; position: relative;`}>
            <div style="position: absolute; left: 0; top: 0; bottom: 0; width: 6px; background: linear-gradient(180deg, var(--color-primary-500), var(--color-primary-600));"></div>
            <div class="p-6 sm:p-8 pl-6 sm:pl-8">
              <!-- Logo -->
              <div class="flex items-center gap-3 mb-4 pb-4" style="border-bottom: 1px solid var(--border);">
                <img src={`/images/logos/${site.logoFile || (site.slug + '-logo.png')}`} alt={`${site.name} Logo`} class="h-8 sm:h-10 w-auto object-contain" loading="lazy" />
              </div>
              <div class="flex flex-col sm:flex-row sm:items-start sm:justify-between gap-4 mb-5">
                <div class="flex items-start gap-4">
                  <div class="text-5xl font-bold" style="color: var(--color-primary-100); line-height: 1;">#<span style="color: var(--color-primary-600);">{i + 1}</span></div>
                  <div class="pt-1">
                    <div class="flex items-center gap-2 flex-wrap gap-y-1 mb-1">
                      <h3 class="text-2xl font-bold" style="color: var(--text); font-family: var(--font-serif);">{site.name}</h3>
                      {site.badge && (
                        <span class="text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full text-white" style={`background: ${site.badgeColor};`}>{site.badge}</span>
                      )}
                    </div>
                    <p class="text-sm" style="color: var(--text-muted); line-height: 1.4;">{site.shortDesc}</p>
                  </div>
                </div>
                <div class="shrink-0 text-center sm:text-right">
                  <div class="text-5xl font-bold" style="color: var(--color-primary-600); font-family: var(--font-serif); line-height: 1;">{site.rating}</div>
                  <div class="flex items-center gap-0.5 mt-1.5 justify-center sm:justify-end">
                    {Array.from({length: full}).map(() => (
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#f43f5e"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
                    {half && (
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none"><defs><linearGradient id={`half-${i}`}><stop offset="50%" stop-color="#f43f5e"/><stop offset="50%" stop-color="#e5e7eb"/></linearGradient></defs><path d={`M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z`} fill={`url(#half-${i})`}/></svg>
                    )}
                    {Array.from({length: empty}).map(() => (
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="#e5e7eb"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
                    ))}
