                  <ul class="space-y-2">
                    {site.pros.map(pro => (
                      <li class="text-sm flex items-start gap-2" style="color: var(--text);"><span class="mt-0.5 shrink-0 font-bold" style="color: #16a34a;">✓</span><span>{pro}</span></li>
                    ))}
