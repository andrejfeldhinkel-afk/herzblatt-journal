---
import BaseLayout from '../layouts/BaseLayout.astro';
import AppCTA from '../components/AppCTA.astro';
import { getCollection } from 'astro:content';

const posts = await getCollection('blog', ({ data }) => !data.draft);
const postCount = posts.length;

// Collect unique tags
const allTags = new Set<string>();
posts.forEach(p => p.data.tags.forEach(t => allTags.add(t)));
---

<BaseLayout
  title="Über uns — Herzblatt Journal | Dein Dating-Ratgeber"
  description="Lerne das Team hinter Herzblatt Journal kennen. Unsere Mission: Ehrliche, fundierte Dating-Tipps für alle, die die Liebe suchen."
  faq={[
    { question: "Wer steckt hinter Herzblatt Journal?", answer: "Herzblatt Journal wird von einem engagierten Team aus Beziehungsexperten, Psychologen und erfahrenen Redakteuren betrieben, die es sich zur Aufgabe gemacht haben, ehrliche und praxisnahe Dating-Ratgeber zu erstellen." },
    { question: "Sind die Inhalte kostenlos?", answer: "Ja, alle unsere Ratgeber, Guides und Tests sind zu 100% kostenlos zugänglich. Wir finanzieren uns über Partnerempfehlungen und Affiliate-Links zu Dating-Plattformen." },
    { question: "Wie kann ich Herzblatt Journal kontaktieren?", answer: "Du erreichst uns per E-Mail an kontakt@herzblatt-journal.com. Wir antworten in der Regel innerhalb von 24 Stunden." }
  ]}
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden py-20 sm:py-28">
    <div class="absolute inset-0" style="background: linear-gradient(135deg, var(--color-primary-50) 0%, var(--color-surface-100) 50%, var(--color-primary-50) 100%);"></div>
    <div class="absolute top-10 left-10 w-72 h-72 rounded-full opacity-20" style="background: var(--color-primary-200); filter: blur(80px);"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 rounded-full opacity-15" style="background: var(--color-primary-300); filter: blur(100px);"></div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold mb-6" style="background: var(--color-primary-100); color: var(--color-primary-700);">
        <span class="heart-pulse">❤️</span> Seit 2024 für dich da
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold mb-6" style="color: var(--text); font-family: var(--font-serif); letter-spacing: -0.03em; line-height: 1.1;">
        Wir helfen dir, die Liebe<br>
        <span style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-700)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">zu finden</span>
      </h1>
      <p class="text-lg sm:text-xl max-w-2xl mx-auto leading-relaxed" style="color: var(--text-muted);">
        Herzblatt Journal ist Deutschlands wachsender Dating-Ratgeber. Ehrlich, fundiert und für alle, die an echte Verbindungen glauben.
      </p>
    </div>
  </section>

  <!-- Numbers Bar -->
  <section class="relative -mt-8 z-10 max-w-5xl mx-auto px-4 sm:px-6">
    <div class="rounded-2xl p-6 sm:p-8 shadow-lg" style="background: var(--bg); border: 1px solid var(--border);">
      <div class="grid grid-cols-2 sm:grid-cols-4 gap-6 text-center">
        <div>
          <p class="text-3xl font-extrabold" style="color: var(--color-primary-600); font-family: var(--font-serif);">{postCount}+</p>
          <p class="text-xs font-medium mt-1" style="color: var(--text-muted);">Ratgeber & Guides</p>
        </div>
        <div>
          <p class="text-3xl font-extrabold" style="color: var(--color-primary-600); font-family: var(--font-serif);">52K+</p>
          <p class="text-xs font-medium mt-1" style="color: var(--text-muted);">Monatliche Leser</p>
        </div>
        <div>
          <p class="text-3xl font-extrabold" style="color: var(--color-primary-600); font-family: var(--font-serif);">{allTags.size}+</p>
          <p class="text-xs font-medium mt-1" style="color: var(--text-muted);">Themengebiete</p>
        </div>
        <div>
          <p class="text-3xl font-extrabold" style="color: var(--color-primary-600); font-family: var(--font-serif);">100%</p>
          <p class="text-xs font-medium mt-1" style="color: var(--text-muted);">Kostenlos</p>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-4xl mx-auto px-4 sm:px-6">

    <!-- Unsere Geschichte -->
    <section class="py-16">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-1 h-8 rounded-full" style="background: linear-gradient(to bottom, var(--color-primary-500), var(--color-primary-300));"></div>
        <h2 class="text-2xl font-bold" style="color: var(--text); font-family: var(--font-serif);">Unsere Geschichte</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-8 items-start">
        <div class="space-y-4 text-base leading-relaxed" style="color: var(--text-muted);">
          <p>
            Alles begann 2024 mit einer einfachen Beobachtung: <strong style="color: var(--text);">Die meisten Dating-Ratgeber im Internet sind entweder oberflächlich, veraltet oder schlicht falsch.</strong> Manipulative Tricks, toxische Pick-Up-Strategien und unrealistische Versprechen überall.
          </p>
          <p>
            Wir wollten einen Ort schaffen, an dem Menschen ehrliche, respektvolle und wissenschaftlich fundierte Tipps finden — egal ob sie gerade ihr erstes Dating-Profil erstellen oder seit 20 Jahren verheiratet sind.
          </p>
          <p>
            Was als kleiner Blog mit einer Handvoll Artikeln begann, ist heute zu einer umfassenden Plattform mit über <strong style="color: var(--text);">{postCount} Ratgebern</strong> gewachsen, die tausenden Menschen dabei hilft, echte Verbindungen aufzubauen.
          </p>
        </div>
        <div class="space-y-4">
          <!-- Animated Timeline -->
          <div id="timeline-container" class="relative pl-8">
            <div class="absolute left-0 top-0 bottom-0 w-[2px]" style="background: var(--color-primary-100);"></div>
            <div id="timeline-line" class="absolute left-0 top-0 w-[2px]" style="background: linear-gradient(to bottom, var(--color-primary-500), var(--color-primary-600)); height: 0;"></div>

            <div class="mb-6 relative timeline-item" data-index="0">
              <div class="timeline-dot absolute -left-[2.35rem] w-4 h-4 rounded-full transition-all duration-500" style="background: var(--color-primary-100); border: 3px solid var(--color-primary-100);"></div>
              <p class="text-xs font-bold uppercase tracking-wider mb-1 transition-colors duration-500" style="color: var(--text-muted);">Frühjahr 2024</p>
              <p class="text-sm" style="color: var(--text-muted);">Idee & erste Artikel — Herzblatt Journal geht online</p>
            </div>
            <div class="mb-6 relative timeline-item" data-index="1">
              <div class="timeline-dot absolute -left-[2.35rem] w-4 h-4 rounded-full transition-all duration-500" style="background: var(--color-primary-100); border: 3px solid var(--color-primary-100);"></div>
              <p class="text-xs font-bold uppercase tracking-wider mb-1 transition-colors duration-500" style="color: var(--text-muted);">Sommer 2024</p>
              <p class="text-sm" style="color: var(--text-muted);">100 Ratgeber veröffentlicht, erste Leser-Community</p>
            </div>
            <div class="mb-6 relative timeline-item" data-index="2">
              <div class="timeline-dot absolute -left-[2.35rem] w-4 h-4 rounded-full transition-all duration-500" style="background: var(--color-primary-100); border: 3px solid var(--color-primary-100);"></div>
              <p class="text-xs font-bold uppercase tracking-wider mb-1 transition-colors duration-500" style="color: var(--text-muted);">Anfang 2025</p>
              <p class="text-sm" style="color: var(--text-muted);">Partnerschaften mit führenden Dating-Plattformen</p>
            </div>
            <div class="mb-6 relative timeline-item" data-index="3">
              <div class="timeline-dot absolute -left-[2.35rem] w-4 h-4 rounded-full transition-all duration-500" style="background: var(--color-primary-100); border: 3px solid var(--color-primary-100);"></div>
              <p class="text-xs font-bold uppercase tracking-wider mb-1 transition-colors duration-500" style="color: var(--text-muted);">2025</p>
              <p class="text-sm" style="color: var(--text-muted);">Relaunch mit neuem Design und interaktiven Features</p>
            </div>
            <div class="relative timeline-item" data-index="4">
              <div class="timeline-dot absolute -left-[2.35rem] w-4 h-4 rounded-full transition-all duration-500" style="background: var(--color-primary-100); border: 3px solid var(--color-primary-100);"></div>
              <p class="text-xs font-bold uppercase tracking-wider mb-1 transition-colors duration-500" style="color: var(--text-muted);">Heute</p>
              <p class="text-sm" style="color: var(--text-muted);">{postCount}+ Ratgeber, wachsende Community und neue Formate</p>
            </div>
          </div>
        </div>
      </div>
    </section>

    <!-- Mission & Werte -->
    <section class="py-16" style="border-top: 1px solid var(--border);">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-1 h-8 rounded-full" style="background: linear-gradient(to bottom, var(--color-primary-500), var(--color-primary-300));"></div>
        <h2 class="text-2xl font-bold" style="color: var(--text); font-family: var(--font-serif);">Unsere Mission & Werte</h2>
      </div>

      <p class="text-base leading-relaxed mb-8" style="color: var(--text-muted);">
        Wir glauben, dass gute Beziehungen mit guter Selbstkenntnis beginnen. Unsere Mission ist es, jedem Menschen die Werkzeuge und das Wissen zu geben, um authentische, gesunde und erfüllende Verbindungen aufzubauen.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div class="rounded-2xl p-6 flex gap-4" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <div class="flex-shrink-0 w-12 h-12 rounded-xl flex items-center justify-center text-xl" style="background: linear-gradient(135deg, #FEE2E2, #FECACA);">🎯</div>
          <div>
            <h3 class="text-sm font-bold mb-1.5" style="color: var(--text);">Ehrlichkeit vor allem</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Keine Clickbait-Titel, keine unrealistischen Versprechen. Wir sagen dir, was wirklich funktioniert — auch wenn es unbequem ist.</p>
          </div>
        </div>
        <div class="rounded-2xl p-6 flex gap-4" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <div class="flex-shrink-0 w-12 h-12 rounded-xl flex items-center justify-center text-xl" style="background: linear-gradient(135deg, #E0E7FF, #C7D2FE);">🧠</div>
          <div>
            <h3 class="text-sm font-bold mb-1.5" style="color: var(--text);">Wissenschaftlich fundiert</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Unsere Ratgeber basieren auf psychologischer Forschung, Studien zur Bindungstheorie und bewährten Kommunikationsmodellen.</p>
          </div>
        </div>
        <div class="rounded-2xl p-6 flex gap-4" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <div class="flex-shrink-0 w-12 h-12 rounded-xl flex items-center justify-center text-xl" style="background: linear-gradient(135deg, #F3E8FF, #E9D5FF);">💜</div>
          <div>
            <h3 class="text-sm font-bold mb-1.5" style="color: var(--text);">Respekt & Vielfalt</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Liebe kennt keine Grenzen. Unsere Tipps sind für alle — unabhängig von Alter, Geschlecht, sexueller Orientierung oder kulturellem Hintergrund.</p>
          </div>
        </div>
        <div class="rounded-2xl p-6 flex gap-4" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <div class="flex-shrink-0 w-12 h-12 rounded-xl flex items-center justify-center text-xl" style="background: linear-gradient(135deg, #DCFCE7, #BBF7D0);">🌱</div>
          <div>
            <h3 class="text-sm font-bold mb-1.5" style="color: var(--text);">Persönliches Wachstum</h3>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Wir glauben: Die beste Beziehung beginnt mit dir selbst. Deshalb legen wir großen Wert auf Selbstentwicklung und emotionale Intelligenz.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Redaktionelle Standards (E-E-A-T) -->
    <section class="py-16" style="border-top: 1px solid var(--border);">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-1 h-8 rounded-full" style="background: linear-gradient(to bottom, var(--color-primary-500), var(--color-primary-300));"></div>
        <h2 class="text-2xl font-bold" style="color: var(--text); font-family: var(--font-serif);">Unsere redaktionellen Standards</h2>
      </div>
      <p class="text-base leading-relaxed mb-8" style="color: var(--text-muted);">
        Beziehung und Psychologie sind sensible Themen — Fehler im Inhalt können echten Schaden anrichten.
        Deshalb folgt jeder Artikel auf Herzblatt Journal einem klaren Qualitätsprozess.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
        <div class="rounded-2xl p-6" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">🔬</span>
            <h3 class="text-base font-bold" style="color: var(--text);">Wissenschaftliche Basis</h3>
          </div>
          <p class="text-sm leading-relaxed" style="color: var(--text-muted);">
            Psychologische Aussagen basieren auf aktueller Fachliteratur (überwiegend jünger als 5 Jahre).
            Wir nutzen primär Quellen wie das <em>Journal of Social and Personal Relationships</em>,
            <em>Attachment & Human Development</em> und Studien führender Beziehungsforscher (John Gottman, Sue Johnson, Daniel Siegel).
          </p>
        </div>

        <div class="rounded-2xl p-6" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">✅</span>
            <h3 class="text-base font-bold" style="color: var(--text);">Fakten-Check durch Fachperson</h3>
          </div>
          <p class="text-sm leading-relaxed" style="color: var(--text-muted);">
            Alle psychologisch relevanten Artikel werden von <strong style="color: var(--text);">Dr. Thomas Peters</strong>
            (promovierter Sozialpsychologe, Universität Hamburg) fachlich überprüft, bevor sie veröffentlicht werden.
            Vereinfachungen werden klar als solche markiert.
          </p>
        </div>

        <div class="rounded-2xl p-6" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">🔄</span>
            <h3 class="text-base font-bold" style="color: var(--text);">Regelmäßige Aktualisierung</h3>
          </div>
          <p class="text-sm leading-relaxed" style="color: var(--text-muted);">
            Inhalte werden regelmäßig überprüft und bei Bedarf aktualisiert. Das jeweils sichtbare
            <em>"Aktualisiert am ..."</em>-Datum zeigt den letzten Review.
            Veraltete Informationen werden korrigiert oder gekennzeichnet.
          </p>
        </div>

        <div class="rounded-2xl p-6" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">🤝</span>
            <h3 class="text-base font-bold" style="color: var(--text);">Transparente Finanzierung</h3>
          </div>
          <p class="text-sm leading-relaxed" style="color: var(--text-muted);">
            Wir finanzieren uns über Affiliate-Empfehlungen zu Dating-Plattformen. Diese Empfehlungen
            <strong style="color: var(--text);">beeinflussen unsere inhaltliche Bewertung nicht</strong>.
            Wir nehmen kein Geld für positive Bewertungen.
          </p>
        </div>

        <div class="rounded-2xl p-6" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">⚠️</span>
            <h3 class="text-base font-bold" style="color: var(--text);">Kein Therapie-Ersatz</h3>
          </div>
          <p class="text-sm leading-relaxed" style="color: var(--text-muted);">
            Unsere Inhalte sind <strong style="color: var(--text);">Bildung und Orientierung</strong>,
            keine Therapie. Bei akuten psychischen Belastungen, Suizidgedanken oder schwerem Trauma
            verweisen wir explizit auf professionelle Hilfe (Telefonseelsorge, Therapeut:innen, Notruf).
          </p>
        </div>

        <div class="rounded-2xl p-6" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <div class="flex items-center gap-3 mb-3">
            <span class="text-2xl">📝</span>
            <h3 class="text-base font-bold" style="color: var(--text);">Korrekturen & Feedback</h3>
          </div>
          <p class="text-sm leading-relaxed" style="color: var(--text-muted);">
            Wenn du einen Fehler entdeckst oder eine Quelle ergänzen möchtest, schreib uns an
            <a href="mailto:kontakt@herzblatt-journal.com" style="color: var(--color-primary-600);">kontakt@herzblatt-journal.com</a>.
            Korrekturen werden zeitnah eingearbeitet und beim Artikel transparent gemacht.
          </p>
        </div>
      </div>
    </section>

    <!-- Team -->
    <section class="py-16" style="border-top: 1px solid var(--border);">
      <div class="flex items-center gap-3 mb-3">
        <div class="w-1 h-8 rounded-full" style="background: linear-gradient(to bottom, var(--color-primary-500), var(--color-primary-300));"></div>
        <h2 class="text-2xl font-bold" style="color: var(--text); font-family: var(--font-serif);">Unser Team</h2>
      </div>
      <p class="text-base mb-8" style="color: var(--text-muted);">
        Hinter Herzblatt Journal steht ein leidenschaftliches Team aus Experten, die eines verbindet: Die Überzeugung, dass jeder Mensch Liebe verdient.
      </p>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        <!-- Team Member 1 -->
        <div class="rounded-2xl p-6 flex gap-5" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <img src="/images/authors/sarah-kellner.webp" alt="Sarah Kellner" class="flex-shrink-0 w-16 h-16 rounded-full object-cover" loading="lazy" />
          <div>
            <h3 class="text-base font-bold" style="color: var(--text);">Sarah Kellner</h3>
            <p class="text-xs font-medium mb-2" style="color: var(--color-primary-600);">Gründerin & Chefredakteurin</p>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Psychologin (M.Sc.) mit Schwerpunkt Beziehungsforschung. Sarah hat selbst das Auf und Ab der modernen Datingwelt durchlebt und bringt Fachkenntnis mit persönlicher Erfahrung zusammen.</p>
          </div>
        </div>

        <!-- Team Member 2 -->
        <div class="rounded-2xl p-6 flex gap-5" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <img src="/images/authors/markus-hoffmann.webp" alt="Markus Hoffmann" class="flex-shrink-0 w-16 h-16 rounded-full object-cover" loading="lazy" />
          <div>
            <h3 class="text-base font-bold" style="color: var(--text);">Markus Hoffmann</h3>
            <p class="text-xs font-medium mb-2" style="color: var(--color-primary-600);">Dating-Coach & Autor</p>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Zertifizierter systemischer Coach mit über 8 Jahren Erfahrung. Markus spezialisiert sich auf Kommunikation, Bindungsangst und die männliche Perspektive beim Dating.</p>
          </div>
        </div>

        <!-- Team Member 3 -->
        <div class="rounded-2xl p-6 flex gap-5" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <img src="/images/authors/laura-weber.webp" alt="Laura Weber" class="flex-shrink-0 w-16 h-16 rounded-full object-cover" loading="lazy" />
          <div>
            <h3 class="text-base font-bold" style="color: var(--text);">Laura Weber</h3>
            <p class="text-xs font-medium mb-2" style="color: var(--color-primary-600);">Redakteurin & Beziehungsexpertin</p>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Journalistin und Buchautorin mit Fokus auf moderne Beziehungsformen. Laura schreibt über alles von Polyamorie bis Patchwork-Familien — immer mit einem offenen Blick.</p>
          </div>
        </div>

        <!-- Team Member 4 -->
        <div class="rounded-2xl p-6 flex gap-5" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <img src="/images/authors/thomas-peters.webp" alt="Dr. Thomas Peters" class="flex-shrink-0 w-16 h-16 rounded-full object-cover" loading="lazy" />
          <div>
            <h3 class="text-base font-bold" style="color: var(--text);">Dr. Thomas Peters</h3>
            <p class="text-xs font-medium mb-2" style="color: var(--color-primary-600);">Wissenschaftlicher Berater</p>
            <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Promovierter Sozialpsychologe und Forscher an der Universität Hamburg. Thomas sorgt dafür, dass unsere Inhalte auf dem neuesten Stand der Wissenschaft basieren.</p>
          </div>
        </div>
      </div>
    </section>

    <!-- Was uns besonders macht -->
    <section class="py-16" style="border-top: 1px solid var(--border);">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-1 h-8 rounded-full" style="background: linear-gradient(to bottom, var(--color-primary-500), var(--color-primary-300));"></div>
        <h2 class="text-2xl font-bold" style="color: var(--text); font-family: var(--font-serif);">Was uns besonders macht</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
        <div class="rounded-2xl p-6 text-center" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <div class="text-3xl mb-3">📊</div>
          <h3 class="text-sm font-bold mb-2" style="color: var(--text);">Datenbasierte Ratgeber</h3>
          <p class="text-sm" style="color: var(--text-muted);">Wir nutzen aktuelle Studien und Statistiken, um unsere Tipps zu untermauern. Keine Bauchgefühl-Ratschläge.</p>
        </div>
        <div class="rounded-2xl p-6 text-center" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <div class="text-3xl mb-3">🔄</div>
          <h3 class="text-sm font-bold mb-2" style="color: var(--text);">Regelmäßig aktualisiert</h3>
          <p class="text-sm" style="color: var(--text-muted);">Dating-Trends ändern sich schnell. Deshalb überarbeiten und erweitern wir unsere Artikel regelmäßig.</p>
        </div>
        <div class="rounded-2xl p-6 text-center" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <div class="text-3xl mb-3">🗺️</div>
          <h3 class="text-sm font-bold mb-2" style="color: var(--text);">Lokal & relevant</h3>
