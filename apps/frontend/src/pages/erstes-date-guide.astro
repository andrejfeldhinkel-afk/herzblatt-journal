---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Erstes Date Guide 2026: Vorbereitung, Outfit, Gespräch';
const description = 'Der komplette Erstes-Date-Guide: Vorbereitung, Outfit, Gesprächsthemen und wie du dir ein zweites Date sicherst. Alle Tipps auf einen Blick.';
const keywords = ['Erstes Date', 'Date-Tipps', 'Date-Ideen', 'Flirten', 'Erstes Treffen'];

const sections = [
  {
    id: 'vorbereitung',
    emoji: '✨',
    title: 'Vorbereitung',
    description: 'Die richtige Vorbereitung ist halbe Miete. Von der perfekten Kleidung über die emotionale Vorbereitung bis zum Erkennen von Interesse — bereite dich richtig vor.',
    links: [
      { slug: 'erstes-date-tipps', title: 'Tipps für ein perfektes erstes Date' },
      { slug: 'erstes-date-outfit', title: 'Das richtige Outfit für dein erstes Date' },
      { slug: 'anzeichen-interesse-erkennen', title: 'Anzeichen von Interesse erkennen' }
    ]
  },
  {
    id: 'date-ideen',
    emoji: '🎯',
    title: 'Date-Ideen',
    description: 'Langweilige Kaffee-Dates waren gestern. Entdecke kreative, individuelle und jahreszeitliche Date-Ideen, die wirklich Eindruck machen.',
    links: [
      { slug: 'date-ideen-kreativ', title: 'Kreative Date-Ideen, die wirklich ankommen' },
      { slug: 'sommer-date-ideen', title: 'Die beste Sommer-Date-Ideen' },
      { slug: 'winter-date-ideen', title: 'Gemütliche Winter-Date-Ideen' }
    ]
  },
  {
    id: 'gespraechsfuehrung',
    emoji: '💭',
    title: 'Gesprächsführung',
    description: 'Richtige Gesprächsthemen machen den Unterschied. Lerne, authentisch zu flirten, Körpersprache zu deuten und tiefe Gespräche zu führen.',
    links: [
      { slug: 'erstes-date-gespraechsthemen', title: 'Perfekte Gesprächsthemen für das erste Date' },
      { slug: 'flirten-lernen', title: 'Flirten lernen – Leicht gemacht' },
      { slug: 'koerpersprache-deuten', title: 'Körpersprache deuten und nutzen' }
    ]
  },
  {
    id: 'psychologie',
    emoji: '🧬',
    title: 'Psychologie der Anziehung',
    description: 'Verstehe die psychologischen Grundlagen von Anziehung. Chemie ist wichtig, aber es gibt auch Techniken, die echte Verbindung fördern.',
    links: [
      { slug: 'psychologie-der-anziehung', title: 'Die Psychologie der Anziehung' },
      { slug: 'dating-psychologie-anziehung', title: 'Dating-Psychologie: Wie Anziehung funktioniert' },
      { slug: 'schuechternheit-ueberwinden-dating', title: 'Schüchternheit überwinden beim Dating' }
    ]
  },
  {
    id: 'nach-dem-date',
    emoji: '💌',
    title: 'Nach dem Date',
    description: 'Wie man ein positives Momentum bewahrt. Von der richtigen Folge-Nachricht bis zum Sichern eines zweiten Dates — der Abschluss ist entscheidend.',
    links: [
      { slug: 'zweites-date-tipps', title: 'Zweites Date sichern – Strategien und Tipps' },
      { slug: 'anzeichen-interesse-erkennen', title: 'Wie oft sollte er oder sie schreiben?' },
      { slug: 'ghosting-umgehen', title: 'Ghosting erkennen und vermeiden' }
    ]
  },
  {
    id: 'typische-fehler',
    emoji: '⚠️',
    title: 'Typische Fehler vermeiden',
    description: 'Lerne aus den häufigsten Fehlern, die Menschen beim ersten Date machen. So umgehst du Fettnäpfchen und machst einen bleibenden Eindruck.',
    links: [
      { slug: 'dating-fehler-maenner', title: 'Die größten Dating-Fehler von Männern' },
      { slug: 'dating-fehler-frauen', title: 'Die größten Dating-Fehler von Frauen' },
      { slug: 'moderne-dating-regeln', title: 'Moderne Dating-Regeln – was ist noch relevant?' }
    ]
  }
];

const faqData = [
  {
    question: 'Wie lange sollte ein erstes Date dauern?',
    answer: 'Idealerweise 1-2 Stunden. Das ist lang genug, um ein echtes Gefühl für die Person zu bekommen, aber nicht so lang, dass es unbequem wird, falls die Chemie nicht stimmt. Wenn alles läuft, könnt ihr ja noch verlängern! Eine gute Daumenregel: Lieber zu früh gehen als zu spät bleiben.'
  },
  {
    question: 'Wer sollte die Rechnung zahlen beim ersten Date?',
    answer: 'Die beste Regel: Wer eingeladen hat, zahlt. Das ist klar und respektvoll. Alternativ könnt ihr auch splitten oder abwechseln. Das Wichtigste ist, dass ihr euch nicht unwohl fühlt. Wenn dich jemand einlädt, solltest du dich nicht schuldig fühlen — akzeptiere ihre Großzügigkeit. Umgekehrt, wenn du jemanden einladst, zahle gerne.'
  },
  {
    question: 'Wie viel sollte ich über mich selbst erzählen?',
    answer: 'Balance ist wichtig! Erzähle von dir, stelle aber auch viele Fragen. Eine gute Faustregel: 40% über dich, 60% über dein Date. Dies zeigt echtes Interesse und gibt dir Zeit zu sehen, ob diese Person wirklich zu dir passt. Halte auch einige Überraschungen zurück — Mystik ist attraktiv!'
  }
];

const breadcrumbs = [
  { name: 'Startseite', url: '/' },
  { name: 'Erstes Date Guide', url: '/erstes-date-guide' }
];
---

<BaseLayout 
  title={title}
  description={description}
  keywords={keywords}
  breadcrumbs={breadcrumbs}
  faq={faqData}
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden" style="min-height: 500px;">
    <div class="absolute inset-0" style="background: url('/images/erstes-date-hero.webp') center/cover no-repeat;"></div>
    <div class="absolute inset-0" style="background: linear-gradient(135deg, rgba(190,24,93,0.55) 0%, rgba(136,19,55,0.65) 100%);"></div>
    
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 py-20 sm:py-32">
      <div class="max-w-3xl">
        <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-sm font-medium mb-6" style="background: rgba(255,255,255,0.15); color: white; border: 1px solid rgba(255,255,255,0.2); backdrop-filter: blur(8px);">
          <span class="w-2 h-2 rounded-full animate-pulse bg-white"></span>
          Schritt für Schritt
        </div>
        
        <h1 class="text-4xl sm:text-5xl lg:text-6xl font-extrabold leading-[1.1] mb-6 text-white" style="font-family: var(--font-serif); letter-spacing: -0.03em; text-shadow: 0 2px 20px rgba(0,0,0,0.3);">
          Erstes Date Guide
        </h1>
        
        <p class="text-lg sm:text-xl leading-relaxed mb-8 max-w-lg text-white/90">
          Von der perfekten Vorbereitung über inspirierende Date-Ideen bis zum Sichern eines zweiten Treffens — dein kompletter Ratgeber für ein unvergessliches erstes Date.
        </p>
        
        <div class="flex flex-wrap gap-3">
          <a href="/top-dating-seiten" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-full text-sm font-bold text-white transition-all hover:shadow-lg hover:-translate-y-0.5" style="background: var(--color-primary-500); border: none;">
            Date Matches finden
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="/dating-typ-test" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-full text-sm font-medium transition-all text-white" style="border: 1px solid rgba(255,255,255,0.3); background: rgba(255,255,255,0.1); backdrop-filter: blur(8px);">
            Dein Typ Test
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Sections Grid -->
  <section class="py-16 sm:py-24" style="background: var(--bg);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid gap-8 md:gap-10">
        {sections.map((section, idx) => (
          <div class="fade-in" style={`animation-delay: ${idx * 100}ms;`}>
            <div class="grid md:grid-cols-12 gap-8 items-start">
              <!-- Content Side -->
              <div class="md:col-span-8">
                <div class="flex items-start gap-4 mb-6">
                  <div class="text-4xl" style="line-height: 1;">{section.emoji}</div>
                  <div class="flex-1">
                    <h2 class="text-2xl sm:text-3xl font-bold mb-3" style="color: var(--text); font-family: var(--font-serif);">
                      {section.title}
                    </h2>
                    <p class="text-base leading-relaxed" style="color: var(--text-muted);">
                      {section.description}
                    </p>
                  </div>
                </div>
              </div>
              
              <!-- Links Side -->
              <div class="md:col-span-4">
                <div class="space-y-3">
                  {section.links.map((link) => (
                    <a 
                      href={`/blog/${link.slug}`}
                      class="flex items-start gap-3 p-4 rounded-lg transition-all hover:shadow-md hover:-translate-y-0.5 group"
                      style="background: var(--bg-soft); border: 1px solid var(--border); color: var(--text);"
                    >
                      <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="flex-shrink: 0; margin-top: 2px; color: var(--color-primary-600);" class="group-hover:translate-x-1 transition-transform">
                        <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
                      </svg>
                      <span class="font-medium text-sm">{link.title}</span>
                    </a>
                  ))}
                </div>
              </div>
            </div>
            
            {idx < sections.length - 1 && (
              <div class="mt-12 mb-8" style="border-bottom: 1px solid var(--border);"></div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Stats Section -->
  <section class="py-12 sm:py-16" style="background: var(--bg-soft); border-top: 1px solid var(--border); border-bottom: 1px solid var(--border);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="grid grid-cols-2 md:grid-cols-3 gap-8 text-center">
        <div>
          <p class="text-3xl sm:text-4xl font-bold mb-2" style="color: var(--color-primary-600); font-family: var(--font-serif);">60+</p>
          <p class="text-sm font-medium" style="color: var(--text-muted);">Date-Tipps</p>
        </div>
        <div>
          <p class="text-3xl sm:text-4xl font-bold mb-2" style="color: var(--color-primary-600); font-family: var(--font-serif);">30K+</p>
          <p class="text-sm font-medium" style="color: var(--text-muted);">Erfolgreiche Dates</p>
        </div>
        <div>
          <p class="text-3xl sm:text-4xl font-bold mb-2" style="color: var(--color-primary-600); font-family: var(--font-serif);">92%</p>
          <p class="text-sm font-medium" style="color: var(--text-muted);">Zweites Date gesichert</p>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  <section class="py-16 sm:py-20" style="background: var(--bg);">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="rounded-2xl p-8 sm:p-12 text-center fade-in" style="background: linear-gradient(135deg, var(--color-primary-50) 0%, var(--bg-soft) 100%); border: 1px solid var(--border);">
        <h2 class="text-2xl sm:text-3xl font-bold mb-4" style="color: var(--text); font-family: var(--font-serif);">
          Bereit für dein bestes erstes Date?
        </h2>
        <p class="text-base leading-relaxed mb-8 max-w-2xl mx-auto" style="color: var(--text-muted);">
          Mit unseren bewährten Tipps, kreativen Ideen und psychologischen Einblicken wirst du authentisch, selbstbewusst und unwiderstehlich. Dein nächstes Date wird unvergesslich.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a href="/dating-typ-test" class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-full text-base font-bold text-white transition-all hover:shadow-lg hover:-translate-y-0.5" style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-600)); border: none;">
            Date finden
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a href="/blog" class="inline-flex items-center justify-center gap-2 px-7 py-4 rounded-full text-base font-medium transition-all" style="color: var(--color-primary-600); background: var(--color-primary-50); border: 1px solid var(--color-primary-100);">
            Alle Artikel
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Weiter lesen: Related Guides -->
  <section class="py-16 sm:py-20" style="background: var(--bg);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-10">
        <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full text-xs font-semibold mb-4" style="background: var(--color-primary-50); color: var(--color-primary-700);">
          📚 Weiter lesen
        </div>
        <h2 class="text-2xl sm:text-3xl font-extrabold mb-3" style="color: var(--text); font-family: var(--font-serif);">Passende Guides für dich</h2>
        <p class="text-base max-w-2xl mx-auto" style="color: var(--text-muted);">Vom ersten Date zum starken Paar — das sind die Guides, die dich weiterbringen.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        <a href="/dating-typ-test" class="group rounded-2xl p-6 transition-all hover:-translate-y-1 hover:shadow-lg" style="background: var(--bg-card); border: 1px solid var(--border); text-decoration: none; color: inherit;">
          <div class="text-3xl mb-3">🎯</div>
          <h3 class="text-lg font-bold mb-2" style="color: var(--color-primary-600); font-family: var(--font-serif);">Dating-Typ Test</h3>
          <p class="text-sm" style="color: var(--text-muted);">Welcher der 6 Dating-Typen bist du? 2-Min-Test.</p>
        </a>
        <a href="/date-ideen" class="group rounded-2xl p-6 transition-all hover:-translate-y-1 hover:shadow-lg" style="background: var(--bg-card); border: 1px solid var(--border); text-decoration: none; color: inherit;">
          <div class="text-3xl mb-3">💡</div>
          <h3 class="text-lg font-bold mb-2" style="color: var(--color-primary-600); font-family: var(--font-serif);">100+ Date-Ideen</h3>
          <p class="text-sm" style="color: var(--text-muted);">Was beim ersten Date machen? Hier findest du Inspiration.</p>
        </a>
        <a href="/flirten-lernen-guide" class="group rounded-2xl p-6 transition-all hover:-translate-y-1 hover:shadow-lg" style="background: var(--bg-card); border: 1px solid var(--border); text-decoration: none; color: inherit;">
          <div class="text-3xl mb-3">✨</div>
          <h3 class="text-lg font-bold mb-2" style="color: var(--color-primary-600); font-family: var(--font-serif);">Flirten lernen</h3>
          <p class="text-sm" style="color: var(--text-muted);">Körpersprache, Smalltalk und der Weg zum nächsten Treffen.</p>
        </a>
        <a href="/online-dating-guide" class="group rounded-2xl p-6 transition-all hover:-translate-y-1 hover:shadow-lg" style="background: var(--bg-card); border: 1px solid var(--border); text-decoration: none; color: inherit;">
          <div class="text-3xl mb-3">📱</div>
          <h3 class="text-lg font-bold mb-2" style="color: var(--color-primary-600); font-family: var(--font-serif);">Online-Dating</h3>
          <p class="text-sm" style="color: var(--text-muted);">Vom Match zum Date: der komplette Online-Dating-Guide.</p>
        </a>
        <a href="/bindungsstile" class="group rounded-2xl p-6 transition-all hover:-translate-y-1 hover:shadow-lg" style="background: var(--bg-card); border: 1px solid var(--border); text-decoration: none; color: inherit;">
          <div class="text-3xl mb-3">🧬</div>
          <h3 class="text-lg font-bold mb-2" style="color: var(--color-primary-600); font-family: var(--font-serif);">Bindungsstile verstehen</h3>
          <p class="text-sm" style="color: var(--text-muted);">Warum datest du so, wie du datest? Die Psychologie dahinter.</p>
        </a>
        <a href="/red-flags" class="group rounded-2xl p-6 transition-all hover:-translate-y-1 hover:shadow-lg" style="background: var(--bg-card); border: 1px solid var(--border); text-decoration: none; color: inherit;">
          <div class="text-3xl mb-3">🚩</div>
          <h3 class="text-lg font-bold mb-2" style="color: var(--color-primary-600); font-family: var(--font-serif);">Red Flags erkennen</h3>
          <p class="text-sm" style="color: var(--text-muted);">Warnsignale beim ersten Date früh erkennen.</p>
        </a>
      </div>
    </div>
  </section>

  <!-- FAQ Section -->
  <section class="py-16 sm:py-24" style="background: var(--bg-soft); border-top: 1px solid var(--border);">
    <div class="max-w-3xl mx-auto px-4 sm:px-6">
      <h2 class="text-3xl font-bold text-center mb-4" style="color: var(--text); font-family: var(--font-serif);">
        Häufig gestellte Fragen
      </h2>
      <p class="text-center mb-12" style="color: var(--text-muted);">
        Antworten auf deine wichtigsten Fragen zum ersten Date
      </p>
      
      <div class="space-y-6">
        {faqData.map((item, idx) => (
          <details class="fade-in" style={`animation-delay: ${idx * 100}ms;`}>
            <summary class="flex items-center justify-between p-6 rounded-lg cursor-pointer font-semibold transition-all hover:bg-opacity-80" style="background: var(--bg); color: var(--text); border: 1px solid var(--border);">
              <span>{item.question}</span>
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" style="transition: transform 0.3s; color: var(--color-primary-600);" class="group-open:rotate-180">
                <path d="m6 9 6 6 6-6"/>
              </svg>
            </summary>
            <div class="px-6 pb-6" style="color: var(--text-muted);">
              {item.answer}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <style>
    details[open] summary {
      background: var(--color-primary-50);
      color: var(--text);
      border-color: var(--color-primary-200);
    }
    
    details[open] summary svg {
      transform: rotate(180deg);
    }
    
    .fade-in {
      opacity: 0;
      animation: fadeInUp 0.6s ease forwards;
    }
    
    @keyframes fadeInUp {
      from {
        opacity: 0;
        transform: translateY(20px);
      }
      to {
        opacity: 1;
        transform: translateY(0);
      }
    }
  </style>
</BaseLayout>
