          <!-- Decorative rose circle ornaments -->
          <div aria-hidden="true" class="absolute top-10 right-10 w-24 h-24 rounded-full pointer-events-none opacity-40" style="border: 1.5px dashed #e11d48;"></div>
          <div aria-hidden="true" class="absolute bottom-20 left-0 w-40 h-40 rounded-full pointer-events-none opacity-30" style="border: 1px solid #e11d48;"></div>
          <div aria-hidden="true" class="hidden lg:block absolute top-0 left-1/4 text-[8rem] leading-none opacity-[0.04] pointer-events-none select-none" style="color: #e11d48; font-family: var(--font-serif); font-weight: 900; font-style: italic;">&ldquo;</div>

          <!-- Book container with explicit dimensions -->
