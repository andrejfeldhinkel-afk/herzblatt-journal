            <!-- Book Spine Hint (left edge) -->
            <div aria-hidden="true" class="absolute top-2 -left-2 bottom-2 w-3 rounded-l z-0" style="background: linear-gradient(90deg, #1a0a14, rgba(26,10,20,0));"></div>

            <!-- Book Cover — explicit aspect ratio via padding-bottom -->
            <div class="relative overflow-hidden w-full" style="padding-bottom: 140%;
                background: linear-gradient(165deg, #1a0a14 0%, #3d0a1f 30%, #e11d48 85%, #be123c 100%);
                border-radius: 4px 10px 10px 4px;
                transform: perspective(1200px) rotateY(-11deg) rotateX(1.5deg);
                transform-origin: center center;">

              <!-- Subtle texture on cover -->
