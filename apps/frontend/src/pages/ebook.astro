---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = "Die Herzblatt-Methode — Der komplette Kurs für erfüllte Liebe | 89,99€";
const description = "Die Herzblatt-Methode: 200+ Seiten Hauptbuch, 5 Bonus-Materialien, lebenslange Updates. Das komplette System für ein erfülltes Liebesleben — wissenschaftsfundiert, sofort umsetzbar.";

// Optional: Digistore24 Buy-URL. Wenn gesetzt → direkter Kauf-Button statt Warteliste.
// Setze in Railway-Frontend-Env: DIGISTORE_BUY_URL=https://www.digistore24.com/product/...
const buyUrl = (import.meta.env.DIGISTORE_BUY_URL || process.env.DIGISTORE_BUY_URL || '').trim();
const hasLiveCheckout = buyUrl.length > 0;

// 15 Kapitel des Hauptbuchs
const chapters = [
  { num: '01', title: 'Selbstkenntnis: Wer bist du — und was willst du wirklich?', desc: 'Die 30-Fragen-Werteanalyse und warum 80 % aller Dating-Fehler aus unklarer Selbstwahrnehmung entstehen.' },
  { num: '02', title: 'Dein Bindungsstil — und der Schlüssel, den er dir gibt', desc: 'Sicher, ängstlich, vermeidend, desorganisiert: Wie du deinen Stil erkennst und warum das alles verändert.' },
  { num: '03', title: 'Altlasten loslassen: Heilung vor neuer Liebe', desc: 'Das 21-Tage-Ritual, um alte Beziehungen wirklich abzuschließen — und warum ohne diesen Schritt jede neue scheitert.' },
  { num: '04', title: 'Das magnetische Dating-Profil', desc: '12 Prinzipien für Fotos und Bio, die die richtigen Menschen anziehen — nicht die meisten.' },
  { num: '05', title: 'Die erste Nachricht, die Antworten bringt', desc: 'Die 5 Opener-Formeln, die in unseren Tests 4-fach höhere Antwortquoten erzielt haben.' },
  { num: '06', title: 'Vom Chat zum Date: Timing & Taktik', desc: 'Wann schlägst du ein Treffen vor? Die 3-Tage-Regel ist tot — hier ist, was wirklich funktioniert.' },
  { num: '07', title: 'Das perfekte erste Date', desc: 'Location, Gesprächsthemen, Körpersprache, die 10 häufigsten Fehler und wie du Chemie erkennst.' },
  { num: '08', title: 'Red Flags & Green Flags', desc: 'Die 20 Warnsignale, die du nicht übersehen darfst — und die 12 Zeichen für echte Verbindung.' },
  { num: '09', title: 'Nach dem Date: Follow-Up & zweites Date', desc: 'Die Kunst der Balance: nicht verschwinden, nicht drängen. Mit echten Nachrichten-Beispielen.' },
  { num: '10', title: 'Vom Dating zur Beziehung: Das Commitment-Gespräch', desc: 'Wann ist es Zeit? Wie führst du das Gespräch ohne Druck — und was tun, wenn die Antwort "noch nicht" heißt?' },
  { num: '11', title: 'Die ersten 100 Tage Beziehung', desc: 'Die heikelste Phase jeder Beziehung — und die 7 Entscheidungen, die über Scheitern oder Gelingen entscheiden.' },
  { num: '12', title: 'Gesunde Kommunikation von Anfang an', desc: 'Die 4-Teile-Formel der gewaltfreien Kommunikation, konkret für Paare übersetzt. Mit 30 Alltagsbeispielen.' },
  { num: '13', title: 'Grenzen setzen ohne Streit', desc: 'Wie du deine Bedürfnisse aussprichst, ohne anzugreifen — und warum klare Grenzen Beziehungen schützen, statt sie zu belasten.' },
  { num: '14', title: 'Die 5 Love Languages in der Praxis', desc: 'Gary Chapmans Konzept übersetzt in konkrete Alltagshandlungen. Mit 75 Umsetzungs-Ideen je Sprache.' },
  { num: '15', title: 'Der jährliche Beziehungs-Check-In', desc: 'Das 90-Minuten-Ritual, das Langzeitpaare über Jahrzehnte zusammenhält — Schritt für Schritt.' },
];

// 5 Bonus-Produkte mit Wertangaben
const bonuses = [
  { num: 1, title: 'Das 80-Seiten-Workbook', desc: 'Arbeitsblätter und Übungen zu jedem Kapitel — zum Ausdrucken oder digital ausfüllen. Damit wird Lesen zu Veränderung.', value: '39€' },
  { num: 2, title: '30 Nachrichten-Vorlagen', desc: 'Erprobte Texte für Online-Dating, nach dem ersten Date, in schwierigen Phasen und für jährliche Liebesbekundungen.', value: '29€' },
  { num: 3, title: 'Die Red-Flag-Checkliste als A4-Poster', desc: 'Die 20 häufigsten Warnsignale auf einen Blick — als Druckversion für deinen Kühlschrank oder Badspiegel.', value: '19€' },
  { num: 4, title: 'Der Bindungsstil-Test Premium', desc: 'Die ausführliche Version mit 60 Fragen, individueller Auswertung und Handlungsempfehlungen pro Stil (30 Seiten PDF).', value: '49€' },
  { num: 5, title: 'Lebenslange Updates', desc: 'Wenn die Methode erweitert wird — bei neuen Erkenntnissen, neuen Kapiteln, neuen Übungen — bekommst du alles automatisch.', value: '49€' },
];

// Social Proof Testimonials
const testimonials = [
  { name: 'Julia, 32', city: 'München', quote: 'Ich habe nach drei gescheiterten Beziehungen verstanden, dass das Problem nicht die Männer waren — sondern mein Bindungsstil. Kapitel 2 und 3 haben bei mir etwas ausgelöst, das ich in zehn Jahren Therapie nicht geschafft habe.', rating: 5 },
  { name: 'Markus, 38', city: 'Hamburg', quote: 'Nach meiner Scheidung war ich komplett verloren im Online-Dating. Die Kapitel zu Profil und ersten Nachrichten haben meine Antwortquote verdreifacht. Heute bin ich seit 8 Monaten wieder in einer Beziehung.', rating: 5 },
  { name: 'Sabrina, 29', city: 'Berlin', quote: 'Das Commitment-Gespräch aus Kapitel 10 habe ich mit meinem Freund geführt — und es war eines der besten Gespräche unserer Beziehung. Kein Druck, keine Angst, nur Klarheit.', rating: 5 },
  { name: 'Thomas, 45', city: 'Köln', quote: 'Ich hätte nie gedacht, dass ein E-Book mein Leben verändert. Aber die Kapitel zu Kommunikation haben meine Ehe gerettet. Wir streiten heute noch — aber anders, respektvoller, lösungsorientierter.', rating: 5 },
];

// FAQ
const faqs = [
  { q: 'Für wen ist die Herzblatt-Methode gedacht?', a: 'Für Menschen zwischen 25 und 55, die bewusst eine erfüllte Beziehung aufbauen wollen — ob Single, im Dating oder bereits in Partnerschaft. Du musst nicht alle Kapitel chronologisch lesen; jedes Kapitel funktioniert für sich.' },
  { q: 'Wie lange dauert es, die Methode durchzuarbeiten?', a: 'Das Hauptbuch liest sich in 6–8 Stunden. Wer die Übungen mitmacht, arbeitet meist 4–6 Wochen intensiv damit. Danach dient es als Nachschlagewerk — du wirst immer wieder zurückkehren.' },
  { q: 'Was bekomme ich nach dem Kauf?', a: 'Sofort nach Zahlung erhältst du per E-Mail einen Zugang zu deinem Kundenbereich. Dort findest du das Hauptbuch als PDF, das Workbook, alle Bonus-Materialien und deine persönlichen Updates.' },
  { q: 'Ist das Buch auch für Männer geeignet?', a: 'Ja. Die Methode ist bewusst geschlechterneutral formuliert. Jedes Kapitel ist für Männer und Frauen gleichermaßen relevant. Die Beispiele wechseln zwischen männlichen und weiblichen Perspektiven.' },
  { q: 'Was, wenn es mir nicht gefällt?', a: 'Du hast 30 Tage volle Geld-zurück-Garantie, ohne Wenn und Aber. Eine kurze E-Mail an service@herzblatt-journal.com — und du bekommst den vollen Kaufpreis zurück. Ohne Rückfragen.' },
  { q: 'Gibt es einen Ratenkauf?', a: 'Ja. Alternativ zur Einmalzahlung von 89,99 € kannst du in 3 Raten à 32,99 € zahlen. Die Option wählst du im Checkout.' },
  { q: 'Ersetzt das Buch eine Paartherapie?', a: 'Nein, und das will es auch nicht. Die Herzblatt-Methode ist eine Selbst-Bildungs-Ressource. In Krisenzeiten oder bei ernsten Konflikten empfehlen wir immer professionelle Begleitung — das Buch kann sie ergänzen, aber nicht ersetzen.' },
  { q: 'Wer steckt hinter der Methode?', a: 'Die Methode wurde von unserer Chefredakteurin Sarah Kellner entwickelt, gemeinsam mit Dr. Thomas Peters (Psychologe) und dem Dating-Coach Markus Hoffmann. Sie basiert auf über 1.800 recherchierten Artikeln und den Fragen von Tausenden Lesern.' },
];
---

<BaseLayout title={title} description={description}>

  <!-- HERO -->
  <section class="relative overflow-hidden" style="background: linear-gradient(140deg, var(--color-primary-50) 0%, #fff 55%);">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14 sm:py-20">
      <div class="grid md:grid-cols-2 gap-10 lg:gap-16 items-center">
        <div>
          <span class="inline-flex items-center gap-2 px-3 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-5" style="background: var(--color-primary-600); color: white;">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            Neu · Version 2026
          </span>
          <h1 class="text-[2rem] sm:text-5xl lg:text-[3.5rem] font-extrabold leading-[1.05] mb-5" style="color: var(--text); font-family: var(--font-serif); letter-spacing: -0.025em;">
            Die<br/>
            <span style="color: var(--color-primary-600);">Herzblatt-Methode</span>
          </h1>
          <p class="text-lg sm:text-xl font-medium mb-3" style="color: var(--text);">
            Der komplette Kurs für ein erfülltes Liebesleben.
          </p>
          <p class="text-base sm:text-lg leading-relaxed mb-7" style="color: var(--text-muted);">
            200+ Seiten Hauptbuch, 5 Bonus-Materialien, lebenslange Updates. Alles, was du je über Dating, Beziehung und echte Verbindung wissen musst — wissenschaftsfundiert, ohne Floskeln, sofort umsetzbar.
          </p>

          <!-- Trust Row -->
          <div class="flex flex-wrap items-center gap-5 mb-7 text-sm" style="color: var(--text-muted);">
            <div class="flex items-center gap-1.5">
              <span style="color: #f59e0b; letter-spacing: 1px; font-size: 1rem;">★★★★★</span>
              <span class="font-semibold" style="color: var(--text);">4,8/5</span>
              <span>(342 Bewertungen)</span>
            </div>
            <div class="flex items-center gap-1.5">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6 9 17l-5-5"/></svg>
              <span>30 Tage Geld-zurück</span>
            </div>
          </div>

          <!-- Preis + CTA -->
          <div class="rounded-2xl p-6 mb-4" style="background: var(--bg-card); border: 1px solid var(--border); box-shadow: 0 4px 24px rgba(244,63,94,0.08);">
            <div class="flex items-baseline gap-3 mb-4">
              <span class="text-4xl font-extrabold" style="color: var(--color-primary-600); font-family: var(--font-serif);">89,99 €</span>
              <span class="text-lg line-through" style="color: var(--text-muted);">149 €</span>
              <span class="text-xs font-bold px-2 py-0.5 rounded-full" style="background: #fef3c7; color: #b45309;">−40 %</span>
            </div>
            <a href="#kaufen" class="inline-flex w-full items-center justify-center gap-2 px-6 py-4 rounded-full text-base font-bold text-white transition-all hover:shadow-xl hover:-translate-y-0.5" style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-700));">
              Jetzt Zugang sichern
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
            </a>
            <p class="text-xs text-center mt-3" style="color: var(--text-muted);">Sofortzugang · Sichere Zahlung · 30 Tage Rückgaberecht</p>
          </div>

          <p class="text-xs" style="color: var(--text-muted);">
            Auch in 3 Raten à 32,99 € verfügbar.
          </p>
        </div>

        <!-- Book Mockup -->
        <div class="relative flex justify-center">
          <div class="relative" style="filter: drop-shadow(0 30px 50px rgba(244,63,94,0.25));">
            <div class="aspect-[3/4] w-full max-w-sm rounded-lg overflow-hidden relative" style="background: linear-gradient(155deg, #1a1a2e 0%, #2d1b3d 40%, var(--color-primary-700) 100%); transform: perspective(1000px) rotateY(-8deg);">
              <!-- Cover Design -->
              <div class="absolute inset-0 flex flex-col justify-between p-8 sm:p-10 text-white">
                <div>
                  <div class="text-xs tracking-[0.3em] uppercase opacity-70 mb-2">Herzblatt Journal</div>
                  <div class="w-12 h-0.5" style="background: rgba(255,255,255,0.4);"></div>
                </div>
                <div class="text-center">
                  <div class="text-5xl sm:text-6xl mb-3">💞</div>
                  <h2 class="text-2xl sm:text-3xl font-extrabold leading-tight" style="font-family: var(--font-serif); letter-spacing: -0.02em;">
                    Die Herzblatt-<br/>Methode
                  </h2>
                  <p class="text-xs sm:text-sm mt-3 opacity-70 max-w-[180px] mx-auto leading-relaxed">
                    Der komplette Kurs für erfüllte Liebe
                  </p>
                </div>
                <div class="text-right">
                  <div class="text-xs tracking-[0.2em] uppercase opacity-60">Edition 2026</div>
                </div>
              </div>
              <!-- Accent line -->
              <div class="absolute top-0 left-0 right-0 h-1" style="background: linear-gradient(90deg, var(--color-primary-400), var(--color-primary-600));"></div>
            </div>
            <!-- Floating badge -->
            <div class="absolute -top-4 -right-4 sm:-right-6 w-20 h-20 sm:w-24 sm:h-24 rounded-full flex flex-col items-center justify-center text-center text-white font-extrabold shadow-xl" style="background: linear-gradient(135deg, #fbbf24, #f59e0b); transform: rotate(12deg); font-family: var(--font-serif);">
              <div class="text-[0.65rem] uppercase tracking-wider leading-tight opacity-90">Gesamt-<br/>wert</div>
              <div class="text-lg sm:text-xl leading-tight">403€</div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- SCHMERZ-AGITATION -->
  <section class="py-16 sm:py-20" style="background: var(--bg);">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 text-center">
      <h2 class="text-2xl sm:text-3xl font-extrabold mb-6" style="color: var(--text); font-family: var(--font-serif); letter-spacing: -0.02em;">
        Erkennst du dich in einem dieser Sätze?
      </h2>
      <div class="space-y-3 text-left mt-10">
        <div class="p-4 sm:p-5 rounded-xl flex gap-3 items-start" style="background: var(--bg-card); border: 1px solid var(--border);">
          <span class="text-xl flex-shrink-0">😔</span>
          <p class="text-base" style="color: var(--text);"><span style="color: var(--color-primary-600); font-weight: 700;">Du datest seit Jahren — und fragst dich, warum es nie wirklich funktioniert.</span> Du hast alles probiert: neue Apps, neue Strategien, neue Outfits. Und doch endet jede Beziehung ähnlich.</p>
        </div>
        <div class="p-4 sm:p-5 rounded-xl flex gap-3 items-start" style="background: var(--bg-card); border: 1px solid var(--border);">
          <span class="text-xl flex-shrink-0">💔</span>
          <p class="text-base" style="color: var(--text);"><span style="color: var(--color-primary-600); font-weight: 700;">Du ziehst immer denselben Partner-Typ an — obwohl du es anders willst.</span> Der emotional unverfügbare. Der Narzisst. Der, der nach drei Monaten abtaucht. Als wäre es ein Muster.</p>
        </div>
        <div class="p-4 sm:p-5 rounded-xl flex gap-3 items-start" style="background: var(--bg-card); border: 1px solid var(--border);">
          <span class="text-xl flex-shrink-0">😶</span>
          <p class="text-base" style="color: var(--text);"><span style="color: var(--color-primary-600); font-weight: 700;">In deiner Beziehung fehlt etwas — aber du kannst es nicht benennen.</span> Du liebst ihn oder sie. Es gibt keinen Streit. Aber du fühlst dich oft einsam, und du weißt nicht, wie du das ansprechen sollst.</p>
        </div>
        <div class="p-4 sm:p-5 rounded-xl flex gap-3 items-start" style="background: var(--bg-card); border: 1px solid var(--border);">
          <span class="text-xl flex-shrink-0">🔁</span>
          <p class="text-base" style="color: var(--text);"><span style="color: var(--color-primary-600); font-weight: 700;">Du weißt: Da ist etwas in dir, das immer wieder dasselbe erschafft.</span> Vielleicht ein alter Bindungsstil. Vielleicht ein unverarbeiteter Schmerz. Vielleicht einfach Muster, die keiner dir erklärt hat.</p>
        </div>
      </div>

      <p class="text-lg mt-10 font-medium" style="color: var(--text);">
        Dann ist die Herzblatt-Methode für dich geschrieben.
      </p>
    </div>
  </section>

  <!-- LÖSUNG / POSITIONIERUNG -->
  <section class="py-16 sm:py-20" style="background: linear-gradient(180deg, var(--color-primary-50), #fff);">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <span class="inline-block text-xs font-bold uppercase tracking-wider mb-3" style="color: var(--color-primary-600);">Die Methode</span>
        <h2 class="text-2xl sm:text-4xl font-extrabold mb-6" style="color: var(--text); font-family: var(--font-serif); letter-spacing: -0.02em;">
          Schluss mit Zufallsliebe.<br/>Willkommen bei bewusster Beziehung.
        </h2>
        <p class="text-base sm:text-lg leading-relaxed max-w-2xl mx-auto" style="color: var(--text-muted);">
          Die meisten Ratgeber behandeln ein einzelnes Symptom: erstes Date, Trennung, Streit. Wir zeigen dir das komplette System — von der Selbstkenntnis über das bewusste Dating bis in die gelebte Beziehung. Kein Theaterdonner. Keine Floskeln. Nur das, was wirklich funktioniert.
        </p>
      </div>

      <!-- 3 Kernprinzipien -->
      <div class="grid sm:grid-cols-3 gap-4 mt-12">
        <div class="p-6 rounded-xl text-center" style="background: var(--bg-card); border: 1px solid var(--border);">
          <div class="w-12 h-12 rounded-full mx-auto mb-4 flex items-center justify-center" style="background: var(--color-primary-100);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-600)" stroke-width="2" stroke-linecap="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="4"/></svg>
          </div>
          <h3 class="text-base font-bold mb-2" style="color: var(--text);">Tiefe statt Oberfläche</h3>
          <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Wir gehen an die Wurzeln. Bindungsstile, Werte, unbewusste Muster. Keine Tricks, sondern echte Selbstkenntnis.</p>
        </div>
        <div class="p-6 rounded-xl text-center" style="background: var(--bg-card); border: 1px solid var(--border);">
          <div class="w-12 h-12 rounded-full mx-auto mb-4 flex items-center justify-center" style="background: var(--color-primary-100);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-600)" stroke-width="2" stroke-linecap="round"><path d="M14 4h6v6"/><path d="M10 20H4v-6"/><path d="m14 10 6-6"/><path d="m4 20 6-6"/></svg>
          </div>
          <h3 class="text-base font-bold mb-2" style="color: var(--text);">Praxis statt Theorie</h3>
          <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Zu jedem Kapitel konkrete Übungen, Sätze, Vorlagen. Du kannst alles ab dem ersten Tag anwenden.</p>
        </div>
        <div class="p-6 rounded-xl text-center" style="background: var(--bg-card); border: 1px solid var(--border);">
          <div class="w-12 h-12 rounded-full mx-auto mb-4 flex items-center justify-center" style="background: var(--color-primary-100);">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-600)" stroke-width="2" stroke-linecap="round"><path d="M20 7h-9"/><path d="M14 17H5"/><circle cx="17" cy="17" r="3"/><circle cx="7" cy="7" r="3"/></svg>
          </div>
          <h3 class="text-base font-bold mb-2" style="color: var(--text);">Forschung statt Meinung</h3>
          <p class="text-sm leading-relaxed" style="color: var(--text-muted);">Basierend auf Bindungsforschung, Gottman-Institut, Gewaltfreie Kommunikation. Jede Empfehlung ist belegt.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- KAPITEL -->
  <section class="py-16 sm:py-20">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <span class="inline-block text-xs font-bold uppercase tracking-wider mb-3" style="color: var(--color-primary-600);">Der Inhalt</span>
        <h2 class="text-2xl sm:text-3xl font-extrabold mb-4" style="color: var(--text); font-family: var(--font-serif); letter-spacing: -0.02em;">15 Kapitel. 200+ Seiten.<br/>Alles, was du brauchst.</h2>
        <p class="text-base" style="color: var(--text-muted);">Vom ersten Match bis zum jährlichen Beziehungs-Check-In — jede Lebensphase der Liebe abgedeckt.</p>
      </div>
      <div class="space-y-3">
        {chapters.map(ch => (
          <div class="flex gap-4 sm:gap-5 p-4 sm:p-5 rounded-xl transition-all hover:-translate-y-px hover:shadow-md" style="background: var(--bg-card); border: 1px solid var(--border);">
            <div class="shrink-0 w-11 h-11 sm:w-12 sm:h-12 rounded-xl flex items-center justify-center text-sm font-extrabold" style="background: var(--color-primary-50); color: var(--color-primary-600); font-family: var(--font-serif);">
              {ch.num}
            </div>
            <div>
              <h3 class="text-base sm:text-lg font-bold mb-1" style="color: var(--text);">{ch.title}</h3>
              <p class="text-sm sm:text-base leading-relaxed" style="color: var(--text-muted);">{ch.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- BONUS-MATERIAL -->
  <section class="py-16 sm:py-20" style="background: linear-gradient(180deg, #fff, var(--color-primary-50));">
    <div class="max-w-4xl mx-auto px-4 sm:px-6">
      <div class="text-center mb-12">
        <span class="inline-block px-3 py-1 rounded-full text-xs font-bold uppercase tracking-wider mb-3" style="background: #fef3c7; color: #b45309;">Inklusive · Wert 185 €</span>
        <h2 class="text-2xl sm:text-3xl font-extrabold mb-4" style="color: var(--text); font-family: var(--font-serif); letter-spacing: -0.02em;">5 Bonus-Materialien, die alles verändern</h2>
        <p class="text-base max-w-xl mx-auto" style="color: var(--text-muted);">Weil Lesen nicht reicht. Diese Werkzeuge machen aus Wissen Veränderung.</p>
      </div>
      <div class="space-y-4">
        {bonuses.map(bonus => (
          <div class="flex gap-4 sm:gap-5 p-5 sm:p-6 rounded-2xl" style="background: var(--bg-card); border: 1px solid var(--border); box-shadow: 0 2px 12px rgba(0,0,0,0.04);">
            <div class="shrink-0 w-14 h-14 rounded-full flex items-center justify-center text-white text-lg font-extrabold" style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-700)); font-family: var(--font-serif);">
