    }
    .pay-logos {
      display: inline-flex; align-items: center; justify-content: center;
      gap: 0.4rem;
      height: 22px;
    }
    .pay-logos svg { display: block; }
    .pay-label {
      font-size: 0.78rem; line-height: 1.1;
      font-weight: 600;
    }
    @media (max-width: 380px) {
      .pay-btn { min-height: 78px; padding: 0.6rem 0.35rem 0.55rem; }
      .pay-label { font-size: 0.72rem; }
    }
  </style>

  <!-- Schema.org Product -->
  <script type="application/ld+json" is:inline set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Die Herzblatt-Methode — Der komplette Kurs für erfüllte Liebe",
    "description": description,
    "brand": { "@type": "Brand", "name": "Herzblatt Journal" },
    "offers": {
      "@type": "Offer",
      "url": "https://herzblatt-journal.com/ebook",
      "priceCurrency": "EUR",
      "price": "89.99",
      "availability": "https://schema.org/InStock"
    },
    "aggregateRating": {
      "@type": "AggregateRating",
      "ratingValue": "4.8",
      "reviewCount": "342"
    }
  })}></script>

  <script>
    // Wait-List-Form (wenn kein Live-Checkout aktiv)
    const form = document.getElementById('preorder-form');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const input = form.querySelector('input[type="email"]');
      const btn = form.querySelector('button');
      const email = input?.value;
      if (!email) return;
      btn.textContent = 'Wird gesendet…';
      btn.disabled = true;
      try {
        const res = await fetch('/api/newsletter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email, source: 'ebook-waitlist' }),
        });
        const data = await res.json();
        if (data.success) {
          btn.textContent = '✓ Du bist dabei! Check deine E-Mails.';
          btn.style.background = '#16a34a';
          input.value = '';
          // Conversion-Event fire-and-forget
          fetch('/api/track-click', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            keepalive: true,
            body: JSON.stringify({ target: 'ebook-waitlist', source: '/ebook' }),
          }).catch(() => {});
        } else {
          btn.textContent = data.message || 'Bitte versuch es erneut.';
          btn.disabled = false;
        }
      } catch {
        btn.textContent = 'Fehler — bitte nochmal versuchen.';
        btn.disabled = false;
      }
    });

    // Conversion-Tracking helper (sendBeacon wegen Redirect/Popup)
    function trackEbookBuyClick(target) {
      const body = JSON.stringify({ target, source: '/ebook' });
      try {
        if (navigator.sendBeacon) {
          navigator.sendBeacon(
            '/api/track-click',
            new Blob([body], { type: 'application/json' }),
          );
        } else {
          fetch('/api/track-click', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            keepalive: true,
            body,
          }).catch(() => {});
        }
      } catch { /* noop */ }
    }

    // Whop-Checkout: Kreditkarte ist jetzt ein direkter Redirect-Link (<a href>)
    // statt Modal-Overlay. Click-Tracking für Analytics weiterhin aktiv.
    const cardBtn = document.getElementById('checkout-card-btn');
    cardBtn?.addEventListener('click', () => {
      trackEbookBuyClick('ebook-buy-whop-redirect');
    });
    // Legacy-Modal-Backwards-Compat: Falls openWhopModal anderswo aufgerufen wird
    // (z.B. aus Exit-Intent), als Fallback leiten wir zum Whop weiter.
    function openWhopModal() {
      trackEbookBuyClick('ebook-buy-whop-redirect-fallback');
      window.location.href = cardBtn && cardBtn.getAttribute('href') || 'https://whop.com/checkout/plan_SstCjxgym14Nn';
    }

    // Whop Erfolg-Callback — loader.js ruft das global auf
    window.onWhopCheckoutComplete = function (planId, receiptId) {
      trackEbookBuyClick('ebook-buy-whop-complete');
      closeWhopModal();
      const url = new URL(window.location.href);
      url.searchParams.set('status', 'success');
      if (receiptId) url.searchParams.set('receipt', String(receiptId));
      url.hash = '';
      window.location.href = url.toString();
    };

    // Micropayment — Backend signiert URL, dann Redirect
    async function startMicropaymentCheckout(method) {
      const errEl = document.getElementById('checkout-error');
      const btn = document.getElementById(
        method === 'sofort' ? 'checkout-sofort-btn' : 'checkout-paysafe-btn',
      );
      if (errEl) {
        errEl.classList.add('hidden');
        errEl.textContent = '';
      }
      if (btn) {
        btn.disabled = true;
        btn.style.opacity = '0.7';
      }
      trackEbookBuyClick('ebook-buy-' + method);
      try {
        const res = await fetch('/api/checkout/micropayment', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ method }),
        });
        const data = await res.json().catch(() => ({}));
        if (!res.ok || !data?.url) {
          throw new Error(data?.error || 'Checkout konnte nicht gestartet werden.');
        }
        window.location.href = data.url;
      } catch (err) {
        if (btn) {
          btn.disabled = false;
          btn.style.opacity = '1';
        }
        if (errEl) {
          errEl.textContent =
            (err && typeof err === 'object' && 'message' in err ? String(err.message) : '')
            || 'Fehler beim Starten des Checkouts. Bitte versuch es erneut.';
          errEl.classList.remove('hidden');
        }
      }
    }

    document
      .getElementById('checkout-sofort-btn')
      ?.addEventListener('click', () => startMicropaymentCheckout('sofort'));
    document
      .getElementById('checkout-paysafe-btn')
      ?.addEventListener('click', () => startMicropaymentCheckout('paysafe'));

    // Social-Proof-Counter — fetcht echte Kauf-Zahl der letzten 24h.
    // Wenn count > 0: "🔥 N Käufer in den letzten 24h"
    // Wenn count === 0: "✨ Sichere dir Frühbucher-Vorteile" (neutral)
    // Kein Fake, kein Math.random, kein Dark-Pattern — UWG § 5-konform.
    (function setupSocialProof() {
      const wrap = document.getElementById('ebook-social-proof');
      const txt = document.getElementById('ebook-social-proof-text');
      if (!wrap || !txt) return;

      fetch('/api/ebook/recent-buyers', {
        method: 'GET',
        headers: { Accept: 'application/json' },
      })
        .then((res) => (res.ok ? res.json() : null))
        .then((data) => {
          if (!data || typeof data.count !== 'number') return;
          const count = Math.max(0, Math.floor(data.count));
          if (count > 0) {
            const label = count === 1 ? 'Käufer' : 'Käufer';
            txt.textContent = count + ' ' + label + ' in den letzten 24h';
          } else {
            txt.textContent = 'Einführungspreis — zeitlich begrenzt';
          }
          wrap.style.opacity = '1';
        })
        .catch(() => { /* silent — UI bleibt leer, kein Broken-Look */ });
    })();

    // Exit-Intent-Modal — Desktop-only, Feature-flagged über Präsenz des Modal-Nodes.
    // Trigger: mousemove mit clientY<10 und !relatedTarget.
    // Cooldown: max 1× pro 7 Tage (localStorage).
    (function setupExitIntentModal() {
      const modal = document.getElementById('ebook-exit-intent-modal');
      if (!modal) return; // Feature-flag off → Node existiert nicht
      const closeBtn = document.getElementById('ebook-exit-intent-close');
      const ctaBtn = document.getElementById('ebook-exit-intent-cta');
      const feedback = document.getElementById('ebook-exit-intent-feedback');
      if (!closeBtn || !ctaBtn) return;

      const STORAGE_KEY = 'ebook-exit-intent-seen';
      const COOLDOWN_MS = 7 * 24 * 60 * 60 * 1000; // 7 Tage

      // Mobile skippen — Exit-Intent auf Touch sinnlos
      if (window.innerWidth < 1024) return;

      // Cooldown-Check
      try {
        const raw = localStorage.getItem(STORAGE_KEY);
        if (raw) {
          const ts = Number(raw);
          if (Number.isFinite(ts) && Date.now() - ts < COOLDOWN_MS) return;
        }
      } catch { /* localStorage disabled */ }

      let shown = false;

      function openModal() {
        if (shown) return;
        shown = true;
        modal.style.display = 'flex';
        modal.setAttribute('aria-hidden', 'false');
        document.body.style.overflow = 'hidden';
        try { localStorage.setItem(STORAGE_KEY, String(Date.now())); } catch { /* noop */ }
        trackEbookBuyClick('ebook-exit-intent-shown');
      }

      function closeModal() {
        modal.style.display = 'none';
        modal.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
      }

      function onMouseOut(e) {
        // relatedTarget ist null, wenn Cursor das Viewport-Fenster verlässt (nach oben)
        if (e.clientY <= 10 && !e.relatedTarget) {
          openModal();
          document.removeEventListener('mouseout', onMouseOut);
        }
      }

      // Erst nach 2s aktivieren — verhindert Fehl-Trigger beim Page-Load
      window.setTimeout(() => {
        document.addEventListener('mouseout', onMouseOut);
      }, 2000);

      closeBtn.addEventListener('click', closeModal);
      modal.addEventListener('click', (e) => {
        if (e.target === modal) closeModal();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && shown && modal.style.display === 'flex') closeModal();
      });

      ctaBtn.addEventListener('click', async () => {
        trackEbookBuyClick('ebook-exit-intent-cta');
        // Copy-to-clipboard mit Fallback für ältere Browser
        let copied = false;
        try {
          if (navigator.clipboard && window.isSecureContext) {
            await navigator.clipboard.writeText('HERZBLATT10');
            copied = true;
          } else {
            const ta = document.createElement('textarea');
            ta.value = 'HERZBLATT10';
            ta.style.position = 'fixed';
            ta.style.opacity = '0';
            document.body.appendChild(ta);
            ta.focus();
            ta.select();
            try { copied = document.execCommand('copy'); } catch { copied = false; }
            document.body.removeChild(ta);
          }
        } catch { copied = false; }
        if (feedback) {
          feedback.textContent = copied ? '✓ Code HERZBLATT10 kopiert!' : 'Code: HERZBLATT10 — bitte manuell kopieren.';
        }
        // Kurz anzeigen, dann Whop-Modal öffnen
        window.setTimeout(() => {
          closeModal();
          if (typeof openWhopModal === 'function') {
            openWhopModal();
          } else {
            const card = document.getElementById('checkout-card-btn');
            if (card) card.click();
          }
        }, 500);
      });
    })();

    // Sticky Buy-Bar entfernt — war auf der Kauf-Seite selbst redundant.

    // Status-Banner oben auf der Seite, falls Nutzer von Micropayment zurück kommt
    (function showCheckoutStatusBanner() {
      const params = new URLSearchParams(window.location.search);
      const status = params.get('status');
      if (!status) return;
      const msg = (
        status === 'success'
          ? { t: '✓ Danke! Zahlung erhalten — Download-Link kommt gleich per E-Mail.', c: '#16a34a' }
        : status === 'abbruch'
          ? { t: 'Zahlung abgebrochen. Du kannst jederzeit neu starten.', c: '#f59e0b' }
        : status === 'fehler'
          ? { t: 'Die Zahlung konnte nicht abgeschlossen werden. Bitte versuch es erneut oder wähle eine andere Methode.', c: '#dc2626' }
          : null
      );
      if (!msg) return;
      const banner = document.createElement('div');
      banner.textContent = msg.t;
      banner.style.cssText =
        'position:fixed;top:0;left:0;right:0;z-index:1000;padding:12px 16px;text-align:center;' +
        'font-size:14px;font-weight:600;color:white;background:' + msg.c + ';';
      document.body.prepend(banner);
      setTimeout(() => banner.remove(), 8000);
    })();
  </script>
</BaseLayout>
