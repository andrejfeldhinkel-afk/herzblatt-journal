              <div aria-hidden="true" class="absolute bottom-6 sm:bottom-7 left-7 right-7 h-px" style="background: rgba(255,255,255,0.38);"></div>

              <!-- Cover content — editorial typography -->
              <div class="absolute inset-0 flex flex-col justify-between p-8 sm:p-10 text-white">
                <div>
                  <div class="text-[9px] tracking-[0.32em] uppercase opacity-80 mb-1.5" style="font-weight: 600;">Herzblatt Journal</div>
                  <div class="text-[9px] tracking-[0.32em] uppercase opacity-55" style="font-weight: 500;">Editions · 2026</div>
                </div>

                <div class="text-center">
                  <!-- Decorative ornament above title -->
                  <div class="flex items-center justify-center gap-2 mb-4 opacity-75">
                    <span class="inline-block w-8 h-px bg-white"></span>
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="white"><path d="M12 21.35l-1.45-1.32C5.4 15.36 2 12.28 2 8.5 2 5.42 4.42 3 7.5 3c1.74 0 3.41 0.81 4.5 2.09C13.09 3.81 14.76 3 16.5 3 19.58 3 22 5.42 22 8.5c0 3.78-3.4 6.86-8.55 11.54L12 21.35z"/></svg>
                    <span class="inline-block w-8 h-px bg-white"></span>
                  </div>
                  <h2 class="text-[2rem] sm:text-[2.4rem] leading-[0.95] tracking-tight" style="font-family: var(--font-serif); font-weight: 900;">
                    Die<br/>
                    <span class="italic" style="font-weight: 700;">Herzblatt-</span><br/>
                    Methode
                  </h2>
                  <p class="text-[10px] sm:text-[11px] mt-5 opacity-75 tracking-[0.22em] uppercase" style="font-weight: 500;">Der komplette Kurs</p>
                </div>

                <div class="flex items-end justify-between">
                  <div class="text-[9px] tracking-[0.32em] uppercase opacity-65" style="font-weight: 500;">200+ S.</div>
                  <div class="text-[9px] tracking-[0.32em] uppercase opacity-65" style="font-weight: 500;">ed. 2026</div>
                </div>
              </div>
            </div>

