---

const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/top-dating-seiten', label: 'Top Dating Seiten' },
  { href: '/tags', label: 'Themen' },
  { href: '/ueber-uns', label: 'Über uns' },
];

const ratgeberCategories = [
  { href: '/erstes-date-guide', label: 'Erstes Date Guide', icon: '🦋' },
  { href: '/online-dating-guide', label: 'Online-Dating Guide', icon: '📱' },
  { href: '/beziehungsratgeber', label: 'Beziehungsratgeber', icon: '💑' },
  { href: '/tags/Dating', label: 'Dating', icon: '💕' },
  { href: '/tags/Flirten', label: 'Flirten', icon: '✨' },
  { href: '/tags/Psychologie', label: 'Psychologie', icon: '🧠' },
  { href: '/tags/Selbstliebe', label: 'Selbstliebe', icon: '💖' },
  { href: '/tags/Kommunikation', label: 'Kommunikation', icon: '💬' },
];

const themenCategories = [
  { href: '/tags/Ratgeber', label: 'Ratgeber', icon: '📖' },
  { href: '/tags/Date-Ideen', label: 'Date-Ideen', icon: '🎯' },
  { href: '/tags/Bindungstypen', label: 'Bindungstypen', icon: '🔗' },
  { href: '/tags/Red Flags', label: 'Red Flags', icon: '🚩' },
  { href: '/tags/Single-Leben', label: 'Single-Leben', icon: '🙋' },
  { href: '/tags/Lebensphasen', label: 'Lebensphasen', icon: '🎂' },
  { href: '/tags/Neuanfang', label: 'Neuanfang', icon: '🌅' },
  { href: '/tags/Fernbeziehung', label: 'Fernbeziehung', icon: '✈️' },
  { href: '/tags/Vertrauen', label: 'Vertrauen', icon: '🤝' },
  { href: '/tags/Sicherheit', label: 'Sicherheit', icon: '🛡️' },
];

const mehrCategories = [
  { href: '/quiz', label: 'Dating-Typ Quiz', icon: '❓' },
  { href: '/ebook', label: 'Premium-Guide', icon: '📕' },
  { href: '/erfolgsgeschichten', label: 'Erfolgsgeschichten', icon: '💕' },
  { href: '/glossar', label: 'Glossar', icon: '📚' },
];

const isRatgeberActive = pathname.startsWith('/blog');
const isThemenActive = pathname.startsWith('/tags');
const isMehrActive = ['/quiz','/ebook','/erfolgsgeschichten','/glossar'].includes(pathname.replace(/\/$/, ''));
---

<header class="sticky top-0 z-50 glass" style="border-bottom: 1px solid var(--border);">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group shrink-0">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" class="w-9 h-9" fill="none">
        <defs>
          <linearGradient id="hg" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#f43f5e"/>
            <stop offset="100%" stop-color="#be123c"/>
          </linearGradient>
        </defs>
        <path d="M20 35L4.5 19.8C0.2 15.5 0.2 8.7 4.5 4.4 8.8 0.1 15.6 0.1 19.9 4.4L20 4.5 20.1 4.4C24.4 0.1 31.2 0.1 35.5 4.4 39.8 8.7 39.8 15.5 35.5 19.8L20 35Z" fill="url(#hg)"/>
        <path d="M14 11.5C12 9.5 8.7 9.5 6.7 11.5 5.3 12.9 4.9 14.9 5.5 16.6" stroke="white" stroke-width="2" stroke-linecap="round" opacity="0.35"/>
      </svg>
      <div class="flex flex-col leading-none">
        <span class="text-[17px] font-bold" style="color: var(--text); font-family: var(--font-serif); letter-spacing: -0.03em;">Herzblatt</span>
        <span class="text-[10px] font-medium tracking-[0.2em] uppercase" style="color: var(--text-muted);">Journal</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-1">
      <!-- Home -->
      <a
        href="/"
        class:list={[
          'px-3.5 py-2 rounded-full text-sm font-medium transition-all duration-200',
          pathname === '/' ? 'text-[var(--color-primary-700)]' : 'hover:text-[var(--text)]'
        ]}
        style={pathname === '/' ? 'background: var(--color-primary-50); color: var(--color-primary-700);' : 'color: var(--text-muted);'}
      >
        Home
      </a>

      <!-- Ratgeber Dropdown -->
      <div class="relative" id="ratgeber-dropdown">
        <a
          href="/blog"
          class:list={[
            'px-3.5 py-2 rounded-full text-sm font-medium transition-all duration-200 inline-flex items-center gap-1',
            isRatgeberActive ? 'text-[var(--color-primary-700)]' : 'hover:text-[var(--text)]'
          ]}
          style={isRatgeberActive ? 'background: var(--color-primary-50); color: var(--color-primary-700);' : 'color: var(--text-muted);'}
        >
          Ratgeber
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200" id="ratgeber-chevron"><path d="m6 9 6 6 6-6"/></svg>
        </a>

        <!-- Dropdown Panel -->
        <div id="ratgeber-panel" class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible transition-all duration-200" style="width: 420px;">
          <div class="rounded-2xl p-4 shadow-xl" style="background: var(--bg-card); border: 1px solid var(--border);">
            <div class="grid grid-cols-2 gap-1">
              {ratgeberCategories.map(cat => (
                <a
                  href={cat.href}
                  class="flex items-center gap-2.5 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150 hover:-translate-y-px"
                  style="color: var(--text);"
                  onmouseover="this.style.background='var(--color-primary-50)'"
                  onmouseout="this.style.background='transparent'"
                >
                  <span class="text-lg">{cat.icon}</span>
                  {cat.label}
                </a>
              ))}
            </div>
            <div class="mt-3 pt-3" style="border-top: 1px solid var(--border);">
              <a href="/blog" class="flex items-center justify-center gap-2 py-2 rounded-xl text-sm font-semibold transition-all" style="color: var(--color-primary-600); background: var(--color-primary-50);"
                onmouseover="this.style.background='var(--color-primary-100)'"
                onmouseout="this.style.background='var(--color-primary-50)'"
              >
                Alle Ratgeber ansehen
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Top Dating Seiten -->
      <a
        href="/top-dating-seiten"
        class:list={[
          'px-3.5 py-2 rounded-full text-sm font-medium transition-all duration-200',
          pathname.startsWith('/top-dating-seiten') ? 'text-[var(--color-primary-700)]' : 'hover:text-[var(--text)]'
        ]}
        style={pathname.startsWith('/top-dating-seiten') ? 'background: var(--color-primary-50); color: var(--color-primary-700);' : 'color: var(--text-muted);'}
      >
        Top Dating Seiten
      </a>

      <!-- Themen Dropdown -->
      <div class="relative" id="themen-dropdown">
        <a
          href="/tags"
          class:list={[
            'px-3.5 py-2 rounded-full text-sm font-medium transition-all duration-200 inline-flex items-center gap-1',
            isThemenActive ? 'text-[var(--color-primary-700)]' : 'hover:text-[var(--text)]'
          ]}
          style={isThemenActive ? 'background: var(--color-primary-50); color: var(--color-primary-700);' : 'color: var(--text-muted);'}
        >
          Themen
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200" id="themen-chevron"><path d="m6 9 6 6 6-6"/></svg>
        </a>

        <!-- Dropdown Panel -->
        <div id="themen-panel" class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible transition-all duration-200" style="width: 420px;">
          <div class="rounded-2xl p-4 shadow-xl" style="background: var(--bg-card); border: 1px solid var(--border);">
            <div class="grid grid-cols-2 gap-1">
              {themenCategories.map(cat => (
                <a
                  href={cat.href}
                  class="flex items-center gap-2.5 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150 hover:-translate-y-px"
                  style="color: var(--text);"
                  onmouseover="this.style.background='var(--color-primary-50)'"
                  onmouseout="this.style.background='transparent'"
                >
                  <span class="text-lg">{cat.icon}</span>
                  {cat.label}
                </a>
              ))}
            </div>
            <div class="mt-3 pt-3" style="border-top: 1px solid var(--border);">
              <a href="/tags" class="flex items-center justify-center gap-2 py-2 rounded-xl text-sm font-semibold transition-all" style="color: var(--color-primary-600); background: var(--color-primary-50);"
                onmouseover="this.style.background='var(--color-primary-100)'"
                onmouseout="this.style.background='var(--color-primary-50)'"
              >
                Alle Themen ansehen
                <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
              </a>
            </div>
          </div>
        </div>
      </div>

      <!-- Mehr Dropdown -->
      <div class="relative" id="mehr-dropdown">
        <button
          class:list={[
            'px-3.5 py-2 rounded-full text-sm font-medium transition-all duration-200 inline-flex items-center gap-1',
            isMehrActive ? 'text-[var(--color-primary-700)]' : 'hover:text-[var(--text)]'
          ]}
          style={isMehrActive ? 'background: var(--color-primary-50); color: var(--color-primary-700);' : `color: var(--text-muted); background: none; border: none; cursor: pointer;`}
        >
          Mehr
          <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200" id="mehr-chevron"><path d="m6 9 6 6 6-6"/></svg>
        </button>

        <!-- Dropdown Panel -->
        <div id="mehr-panel" class="absolute top-full left-1/2 -translate-x-1/2 pt-2 opacity-0 invisible transition-all duration-200" style="width: 280px;">
          <div class="rounded-2xl p-4 shadow-xl" style="background: var(--bg-card); border: 1px solid var(--border);">
            <div class="grid grid-cols-1 gap-1">
              {mehrCategories.map(cat => (
                <a
                  href={cat.href}
                  class="flex items-center gap-2.5 px-3 py-2.5 rounded-xl text-sm font-medium transition-all duration-150 hover:-translate-y-px"
                  style="color: var(--text);"
                  onmouseover="this.style.background='var(--color-primary-50)'"
                  onmouseout="this.style.background='transparent'"
                >
                  <span class="text-lg">{cat.icon}</span>
                  {cat.label}
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>

      <!-- Über uns -->
      <a
        href="/ueber-uns"
        class:list={[
          'px-3.5 py-2 rounded-full text-sm font-medium transition-all duration-200',
          pathname.startsWith('/ueber-uns') ? 'text-[var(--color-primary-700)]' : 'hover:text-[var(--text)]'
        ]}
        style={pathname.startsWith('/ueber-uns') ? 'background: var(--color-primary-50); color: var(--color-primary-700);' : 'color: var(--text-muted);'}
      >
        Über uns
      </a>

      <a href="/suche" class="p-2 rounded-full transition-all hover:bg-[var(--color-primary-50)]" style="color: var(--text-muted);" aria-label="Suche">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </a>

      <button onclick="window.openDatingQuiz()" class="ml-2 px-5 py-2 rounded-full text-sm font-semibold text-white transition-all hover:shadow-lg hover:-translate-y-0.5 cursor-pointer" style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-600)); border: none;">
        Jetzt starten
      </button>
    </div>

    <!-- Mobile -->
    <div class="flex items-center gap-2 md:hidden">
      <button id="mobile-menu-btn" class="p-2 rounded-lg" style="color: var(--text);" aria-label="Menü">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" x2="21" y1="6" y2="6"/><line x1="3" x2="21" y1="12" y2="12"/><line x1="3" x2="21" y1="18" y2="18"/></svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden md:hidden px-4 pb-4">
    <div class="flex flex-col gap-1 rounded-2xl p-3" style="background: var(--bg-card); border: 1px solid var(--border); box-shadow: 0 4px 24px rgba(0,0,0,0.08);">
      <a href="/" class="px-4 py-3 rounded-xl text-sm font-medium" style={pathname === '/' ? 'background: var(--color-primary-50); color: var(--color-primary-700);' : 'color: var(--text);'}>
        Home
      </a>

      <!-- Ratgeber mit Unterkategorien -->
      <div>
        <button id="mobile-ratgeber-btn" class="w-full px-4 py-3 rounded-xl text-sm font-medium flex items-center justify-between" style={isRatgeberActive ? 'background: var(--color-primary-50); color: var(--color-primary-700);' : 'color: var(--text);'}>
          Ratgeber
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200" id="mobile-ratgeber-chevron"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div id="mobile-ratgeber-sub" class="hidden pl-4 pb-2">
          <a href="/blog" class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium" style="color: var(--color-primary-600);">
            📖 Alle Ratgeber
          </a>
          {ratgeberCategories.map(cat => (
            <a href={cat.href} class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm" style="color: var(--text-muted);">
              <span>{cat.icon}</span> {cat.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Top Dating Seiten -->
      <a href="/top-dating-seiten" class="px-4 py-3 rounded-xl text-sm font-medium" style={pathname.startsWith('/top-dating-seiten') ? 'background: var(--color-primary-50); color: var(--color-primary-700);' : 'color: var(--text);'}>
        Top Dating Seiten
      </a>

      <!-- Themen mit Unterkategorien -->
      <div>
        <button id="mobile-themen-btn" class="w-full px-4 py-3 rounded-xl text-sm font-medium flex items-center justify-between" style={isThemenActive ? 'background: var(--color-primary-50); color: var(--color-primary-700);' : 'color: var(--text);'}>
          Themen
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200" id="mobile-themen-chevron"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div id="mobile-themen-sub" class="hidden pl-4 pb-2">
          <a href="/tags" class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm font-medium" style="color: var(--color-primary-600);">
            🏷️ Alle Themen
          </a>
          {themenCategories.map(cat => (
            <a href={cat.href} class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm" style="color: var(--text-muted);">
              <span>{cat.icon}</span> {cat.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Mehr mit Unterkategorien -->
      <div>
        <button id="mobile-mehr-btn" class="w-full px-4 py-3 rounded-xl text-sm font-medium flex items-center justify-between" style={isMehrActive ? 'background: var(--color-primary-50); color: var(--color-primary-700);' : 'color: var(--text);'}>
          Mehr
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-200" id="mobile-mehr-chevron"><path d="m6 9 6 6 6-6"/></svg>
        </button>
        <div id="mobile-mehr-sub" class="hidden pl-4 pb-2">
          {mehrCategories.map(cat => (
            <a href={cat.href} class="flex items-center gap-2 px-4 py-2 rounded-lg text-sm" style="color: var(--text-muted);">
              <span>{cat.icon}</span> {cat.label}
            </a>
          ))}
        </div>
      </div>

      <!-- Über uns -->
      <a href="/ueber-uns" class="px-4 py-3 rounded-xl text-sm font-medium" style={pathname.startsWith('/ueber-uns') ? 'background: var(--color-primary-50); color: var(--color-primary-700);' : 'color: var(--text);'}>
        Über uns
      </a>
      <a href="/suche" class="px-4 py-3 rounded-xl text-sm font-medium flex items-center gap-2" style="color: var(--text);">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        Suche
      </a>

      <!-- Newsletter (kompakt) -->
      <div class="mt-2 px-4 py-3 rounded-xl" style="background: var(--bg-soft); border: 1px solid var(--border);">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-base">📬</span>
          <span class="text-sm font-semibold" style="color: var(--text);">Newsletter</span>
        </div>
        <p class="text-xs mb-3" style="color: var(--text-muted);">Neue Ratgeber direkt ins Postfach. Kein Spam.</p>
        <form id="nl-menu-form" class="flex flex-col gap-2">
          <input
            type="email"
            name="email"
            placeholder="deine@email.de"
            required
            class="w-full px-3 py-2 rounded-lg text-sm focus:outline-none"
            style="background: var(--bg-card); color: var(--text); border: 1px solid var(--border);"
          />
          <button
            type="submit"
            id="nl-menu-submit"
            class="w-full px-3 py-2 rounded-lg text-sm font-semibold text-white cursor-pointer"
            style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-600)); border: none;"
          >
            Abonnieren
          </button>
        </form>
        <p id="nl-menu-msg" class="text-[11px] mt-2" style="color: var(--text-muted);">Du kannst dich jederzeit abmelden.</p>
      </div>

      <button onclick="window.openDatingQuiz()" class="mt-2 px-4 py-3 rounded-xl text-sm font-semibold text-center text-white w-full cursor-pointer" style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-600)); border: none;">
        Jetzt starten
      </button>
    </div>
  </div>
</header>

<script is:inline>
  // Mobile menu toggle
  var mBtn = document.getElementById('mobile-menu-btn');
  var mMenu = document.getElementById('mobile-menu');
  if (mBtn && mMenu) mBtn.addEventListener('click', function() { mMenu.classList.toggle('hidden'); });

  // Mobile menu newsletter submit
  var nlMenuForm = document.getElementById('nl-menu-form');
  var nlMenuSubmit = document.getElementById('nl-menu-submit');
  var nlMenuMsg = document.getElementById('nl-menu-msg');
  if (nlMenuForm && nlMenuSubmit && nlMenuMsg) {
    nlMenuForm.addEventListener('submit', async function(e) {
      e.preventDefault();
      var emailInput = nlMenuForm.querySelector('input[name="email"]');
      var email = emailInput ? emailInput.value : '';
      if (!email) return;
      nlMenuSubmit.textContent = '...';
      nlMenuSubmit.disabled = true;
      try {
        var res = await fetch('/api/newsletter', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ email: email, source: 'header-menu' })
        });
        var data = await res.json();
        nlMenuMsg.textContent = data.message || 'Danke!';
        if (data.success) {
          nlMenuForm.reset();
          nlMenuSubmit.textContent = 'Angemeldet ✓';
          nlMenuSubmit.style.background = '#22c55e';
        } else {
          nlMenuSubmit.textContent = 'Abonnieren';
          nlMenuSubmit.disabled = false;
        }
      } catch (err) {
        nlMenuMsg.textContent = 'Fehler. Bitte später erneut versuchen.';
        nlMenuSubmit.textContent = 'Abonnieren';
        nlMenuSubmit.disabled = false;
      }
    });
  }

  // Mobile Ratgeber submenu toggle
  var mRatBtn = document.getElementById('mobile-ratgeber-btn');
  var mRatSub = document.getElementById('mobile-ratgeber-sub');
  var mRatChev = document.getElementById('mobile-ratgeber-chevron');
  if (mRatBtn && mRatSub) {
    mRatBtn.addEventListener('click', function() {
      mRatSub.classList.toggle('hidden');
      if (mRatChev) mRatChev.style.transform = mRatSub.classList.contains('hidden') ? '' : 'rotate(180deg)';
    });
  }

  // Mobile Themen submenu toggle
  var mThBtn = document.getElementById('mobile-themen-btn');
  var mThSub = document.getElementById('mobile-themen-sub');
  var mThChev = document.getElementById('mobile-themen-chevron');
  if (mThBtn && mThSub) {
    mThBtn.addEventListener('click', function() {
      mThSub.classList.toggle('hidden');
      if (mThChev) mThChev.style.transform = mThSub.classList.contains('hidden') ? '' : 'rotate(180deg)';
    });
  }

  // Generic desktop dropdown hover helper
  function setupDropdown(wrapperId, panelId, chevronId) {
    var wrap = document.getElementById(wrapperId);
    var pan = document.getElementById(panelId);
    var chev = document.getElementById(chevronId);
    if (!wrap || !pan) return;
    var timer;
    function show() {
      clearTimeout(timer);
      pan.style.opacity = '1';
      pan.style.visibility = 'visible';
      pan.style.transform = 'translateX(-50%) translateY(0)';
      if (chev) chev.style.transform = 'rotate(180deg)';
    }
    function hide() {
      timer = setTimeout(function() {
        pan.style.opacity = '0';
        pan.style.visibility = 'hidden';
        pan.style.transform = 'translateX(-50%) translateY(-4px)';
        if (chev) chev.style.transform = '';
      }, 150);
    }
    wrap.addEventListener('mouseenter', show);
    wrap.addEventListener('mouseleave', hide);
    pan.addEventListener('mouseenter', show);
    pan.addEventListener('mouseleave', hide);
  }

  // Mobile Mehr submenu toggle
  var mMehrBtn = document.getElementById('mobile-mehr-btn');
  var mMehrSub = document.getElementById('mobile-mehr-sub');
  var mMehrChev = document.getElementById('mobile-mehr-chevron');
  if (mMehrBtn && mMehrSub) {
    mMehrBtn.addEventListener('click', function() {
      mMehrSub.classList.toggle('hidden');
      if (mMehrChev) mMehrChev.style.transform = mMehrSub.classList.contains('hidden') ? '' : 'rotate(180deg)';
    });
  }

  setupDropdown('ratgeber-dropdown', 'ratgeber-panel', 'ratgeber-chevron');
  setupDropdown('themen-dropdown', 'themen-panel', 'themen-chevron');
  setupDropdown('mehr-dropdown', 'mehr-panel', 'mehr-chevron');
</script>
