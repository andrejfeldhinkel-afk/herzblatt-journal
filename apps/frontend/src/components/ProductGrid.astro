---
/**
 * ProductGrid — mehrere Produkte als responsive Grid.
 *
 * Props (eine der folgenden):
 *   slugs: string[]              — spezifische Produkte per Slug
 *   category: string             — alle aktiven Produkte einer Kategorie
 *   featured: boolean            — alle featured Produkte
 *   type: string                 — alle eines Typs (affiliate/digital/...)
 *   limit: number                — max. Anzahl (default 8)
 *   title: string                — optionale Überschrift
 *   intro: string                — optionaler Einleitungstext
 *   variant: 'default' | 'compact'
 */
import ProductCard from './ProductCard.astro';

interface Product {
  slug: string;
  name: string;
  shortDescription?: string | null;
  longDescription?: string | null;
  type: string;
  source: string;
  category?: string | null;
  priceCents?: number | null;
  currency?: string;
  imageUrl?: string | null;
  imageAlt?: string | null;
  targetUrl: string;
  trackingTarget: string;
  ctaLabel?: string;
  badges?: string[];
  rating?: string | null;
  featured?: boolean;
}

interface Props {
  slugs?: string[];
  category?: string;
  featured?: boolean;
  type?: string;
  limit?: number;
  title?: string;
  intro?: string;
  variant?: 'default' | 'compact';
}

const {
  slugs,
  category,
  featured,
  type,
  limit = 8,
  title,
  intro,
  variant = 'default',
} = Astro.props;

// Query-Params zusammenbauen
const params = new URLSearchParams();
if (slugs && slugs.length > 0) {
  params.set('slugs', slugs.join(','));
}
if (category) params.set('category', category);
if (featured) params.set('featured', 'true');
if (type) params.set('type', type);

let products: Product[] = [];
const BACKEND_URL =
  (import.meta.env.BACKEND_URL as string | undefined) ||
  (typeof process !== 'undefined' ? process.env.BACKEND_URL : undefined) ||
  'https://backend-production-c327.up.railway.app';

try {
  const url = `${BACKEND_URL.replace(/\/$/, '')}/products?${params.toString()}`;
  const res = await fetch(url);
  if (res.ok) {
    const data = await res.json() as { ok: boolean; products: Product[] };
    if (data.ok && Array.isArray(data.products)) {
      products = data.products.slice(0, limit);
      // Bei slugs=[...] die Reihenfolge der angegebenen Slugs beibehalten
      if (slugs && slugs.length > 0) {
        const order = new Map(slugs.map((s, i) => [s, i]));
        products.sort((a, b) => (order.get(a.slug) ?? 999) - (order.get(b.slug) ?? 999));
      }
    }
  }
} catch (err) {
  console.warn('[ProductGrid] fetch error:', err);
}
---

{products.length > 0 && (
  <section class={`hz-product-grid-section hz-product-grid-section--${variant}`} aria-labelledby={title ? 'product-grid-title' : undefined}>
    {(title || intro) && (
      <header class="hz-product-grid-header">
        {title && <h2 id="product-grid-title" class="hz-product-grid-title">{title}</h2>}
        {intro && <p class="hz-product-grid-intro">{intro}</p>}
      </header>
    )}

    <div class={`hz-product-grid hz-product-grid--${variant}`}>
      {products.map((product) => (
        <ProductCard product={product} variant={variant === 'compact' ? 'compact' : 'default'} />
      ))}
    </div>
  </section>
)}

<style>
  .hz-product-grid-section {
    margin: 2.5rem 0;
  }
  .hz-product-grid-section--compact {
    margin: 1rem 0;
  }

  .hz-product-grid-header {
    margin-bottom: 1.25rem;
    text-align: center;
  }

  .hz-product-grid-title {
    font-family: 'Playfair Display', Georgia, serif;
    font-size: 1.5rem;
    font-weight: 700;
    letter-spacing: -0.02em;
    color: var(--color-text, #1f2937);
    margin: 0 0 0.5rem;
    position: relative;
    display: inline-block;
  }
  .hz-product-grid-title::after {
    content: '';
    display: block;
    width: 60%;
    height: 3px;
    margin: 0.5rem auto 0;
    background: linear-gradient(90deg, transparent, #f43f5e, transparent);
    border-radius: 2px;
  }

  .hz-product-grid-intro {
    font-size: 0.95rem;
    line-height: 1.55;
    color: var(--color-text-muted, #64748b);
    max-width: 560px;
    margin: 0 auto;
  }

  .hz-product-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1rem;
  }

  /* Bei mehr als 1 Item: 2-Spalten ab Desktop */
  .hz-product-grid:has(> :nth-child(2)) {
    grid-template-columns: repeat(auto-fit, minmax(380px, 1fr));
  }

  /* Compact: kleinere Cards, 2-Spalten ab Tablet */
  .hz-product-grid--compact {
    gap: 0.75rem;
  }
  .hz-product-grid--compact:has(> :nth-child(2)) {
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
  }

  @media (max-width: 640px) {
    .hz-product-grid {
      grid-template-columns: 1fr !important;
    }
    .hz-product-grid-title {
      font-size: 1.25rem;
    }
    .hz-product-grid-section {
      margin: 1.5rem 0;
    }
  }
</style>
