---
import { getCollection } from 'astro:content';

const year = new Date().getFullYear();

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

---

<footer class="ft" style="margin-top: 0;">

  <!-- Newsletter -->
  <div class="ft-nl">
    <div class="ft-nl-inner">
      <div class="ft-nl-content">
        <p class="ft-nl-title">Dating-Tipps direkt ins Postfach</p>
        <p class="ft-nl-sub">Wöchentlich die besten Tipps — kostenlos, kein Spam.</p>
      </div>
      <form class="ft-nl-form" onsubmit="event.preventDefault(); var b=this.querySelector('.ft-nl-btn'); b.textContent='Angemeldet ✓'; b.disabled=true; b.style.opacity='0.6';">
        <input type="email" required placeholder="Deine E-Mail-Adresse" class="ft-nl-input" />
        <button type="submit" class="ft-nl-btn">Anmelden</button>
      </form>
    </div>
  </div>

  <!-- Main -->
  <div class="ft-main">
    <div class="ft-inner">

      <!-- Top: Brand + Links -->
      <div class="ft-top">

        <!-- Brand -->
        <div class="ft-brand">
          <div class="ft-logo">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" width="32" height="32" fill="none">
              <defs><linearGradient id="hgf2" x1="0" y1="0" x2="1" y2="1"><stop offset="0%" stop-color="#fb7185"/><stop offset="100%" stop-color="#f43f5e"/></linearGradient></defs>
              <path d="M20 35L4.5 19.8C0.2 15.5 0.2 8.7 4.5 4.4 8.8 0.1 15.6 0.1 19.9 4.4L20 4.5 20.1 4.4C24.4 0.1 31.2 0.1 35.5 4.4 39.8 8.7 39.8 15.5 35.5 19.8L20 35Z" fill="url(#hgf2)"/>
              <path d="M14 11.5C12 9.5 8.7 9.5 6.7 11.5 5.3 12.9 4.9 14.9 5.5 16.6" stroke="white" stroke-width="2" stroke-linecap="round" opacity="0.4"/>
            </svg>
            <div>
              <span class="ft-logo-name">Herzblatt</span>
              <span class="ft-logo-sub">Journal</span>
            </div>
          </div>
          <p class="ft-brand-text">Dein Ratgeber für Dating, Flirten & echte Beziehungen.</p>
        </div>

        <!-- Link Groups -->
        <div class="ft-links-grid">
          <div class="ft-link-group">
            <p class="ft-link-heading">Ratgeber</p>
            <a href="/blog" class="ft-link">Alle Ratgeber</a>
            <a href="/erstes-date-guide" class="ft-link">Erstes Date Guide</a>
            <a href="/online-dating-guide" class="ft-link">Online-Dating Guide</a>
            <a href="/beziehungsratgeber" class="ft-link">Beziehungsratgeber</a>
            <a href="/top-dating-seiten" class="ft-link">Top Dating Seiten</a>
          </div>
          <div class="ft-link-group">
            <p class="ft-link-heading">Mehr</p>
            <a href="/quiz" class="ft-link">Dating-Quiz</a>
            <a href="/glossar" class="ft-link">Glossar</a>
            <a href="/erfolgsgeschichten" class="ft-link">Erfolgsgeschichten</a>
            <a href="/tags" class="ft-link">Alle Themen</a>
            <a href="/suche" class="ft-link">Suche</a>
          </div>
          <div class="ft-link-group">
            <p class="ft-link-heading">Info</p>
            <a href="/ueber-uns" class="ft-link">Über uns</a>
            <a href="/kontakt" class="ft-link">Kontakt</a>
            <a href="/impressum" class="ft-link">Impressum</a>
            <a href="/datenschutz" class="ft-link">Datenschutz</a>
            <a href="/rss.xml" class="ft-link">RSS Feed</a>
          </div>
        </div>
      </div>

      <!-- Divider -->
      <div class="ft-divider"></div>

      <!-- Bottom -->
      <div class="ft-bottom">
        <p class="ft-copy">&copy; {year} Herzblatt Journal</p>

        <div class="ft-social">
          <a href="https://www.facebook.com/profile.php?id=61586415452972" target="_blank" rel="noopener" aria-label="Facebook" class="ft-social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
          </a>
          <a href="https://www.instagram.com/herzblattjournal" target="_blank" rel="noopener" aria-label="Instagram" class="ft-social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
          </a>
          <a href="https://www.tiktok.com/@herzblattjournal" target="_blank" rel="noopener" aria-label="TikTok" class="ft-social-link">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.43v-7.15a8.16 8.16 0 005.58 2.18V11.2a4.85 4.85 0 01-3.77-1.74V6.69z"/></svg>
          </a>
        </div>
        <button onclick="window.scrollTo({top:0,behavior:'smooth'})" class="ft-top-btn" aria-label="Nach oben">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="18 15 12 9 6 15"/></svg>
        </button>
      </div>

    </div>
  </div>

</footer>

<style>
  /* ── Footer Base ── */
  .ft {
    --ft-bg: #fafafa;
    --ft-text: #1e293b;
    --ft-muted: #64748b;
    --ft-border: #e2e8f0;
    --ft-hover: #f43f5e;
  }
  :global(.dark) .ft {
    --ft-bg: #0f172a;
    --ft-text: rgba(255,255,255,0.92);
    --ft-muted: rgba(255,255,255,0.45);
    --ft-border: rgba(255,255,255,0.08);
    --ft-hover: #f43f5e;
  }

  /* ── Newsletter Strip ── */
  .ft-nl {
    background: linear-gradient(135deg, #e11d48 0%, #be123c 50%, #9f1239 100%);
    position: relative;
    overflow: hidden;
  }
  .ft-nl::before {
    content: '';
    position: absolute;
    top: -60%;
    right: -10%;
    width: 350px;
    height: 350px;
    background: radial-gradient(circle, rgba(255,255,255,0.1) 0%, transparent 70%);
    border-radius: 50%;
    pointer-events: none;
  }
  .ft-nl-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 1.5rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 2rem;
    flex-wrap: wrap;
    position: relative;
  }
  .ft-nl-content { flex: 1; min-width: 220px; }
  .ft-nl-title {
    font-size: 1.05rem;
    font-weight: 700;
    color: white;
    font-family: var(--font-serif);
    margin: 0 0 0.15rem;
  }
  .ft-nl-sub {
    font-size: 0.8rem;
    color: rgba(255,255,255,0.7);
    margin: 0;
  }
  .ft-nl-form {
    display: flex;
    gap: 0.5rem;
    flex-shrink: 0;
  }
  .ft-nl-input {
    padding: 0.6rem 1rem;
    border-radius: 0.6rem;
    border: 1px solid rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.12);
    color: white;
    font-size: 0.82rem;
    width: 240px;
    outline: none;
    backdrop-filter: blur(8px);
    transition: border-color 0.2s;
  }
  .ft-nl-input:focus { border-color: rgba(255,255,255,0.5); }
  .ft-nl-input::placeholder { color: rgba(255,255,255,0.45); }
  .ft-nl-btn {
    padding: 0.6rem 1.4rem;
    border-radius: 0.6rem;
    background: white;
    color: #be123c;
    font-size: 0.82rem;
    font-weight: 700;
    border: none;
    cursor: pointer;
    transition: transform 0.15s, box-shadow 0.15s;
    white-space: nowrap;
  }
  .ft-nl-btn:hover { transform: translateY(-1px); box-shadow: 0 4px 16px rgba(0,0,0,0.15); }

  @media (max-width: 640px) {
    .ft-nl-inner { flex-direction: column; align-items: stretch; gap: 1rem; }
    .ft-nl-form { flex-direction: column; }
    .ft-nl-input { width: 100%; }
  }

  /* ── Main Section ── */
  .ft-main {
    background: var(--ft-bg);
  }
  :global(.dark) .ft-main {
    background: var(--ft-bg);
  }
  .ft-inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 3.5rem 1.5rem 2rem;
  }

  /* ── Top: Brand + Links ── */
  .ft-top {
    display: grid;
    grid-template-columns: 1fr 2fr;
    gap: 4rem;
    margin-bottom: 2.5rem;
  }
  @media (max-width: 768px) {
    .ft-top { grid-template-columns: 1fr; gap: 2.5rem; }
  }

  /* Brand */
  .ft-logo {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    margin-bottom: 0.85rem;
  }
  .ft-logo-name {
    display: block;
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--ft-text);
    font-family: var(--font-serif);
    letter-spacing: -0.03em;
    line-height: 1.1;
  }
  .ft-logo-sub {
    display: block;
    font-size: 0.55rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.2em;
    color: var(--ft-muted);
  }
  .ft-brand-text {
    font-size: 0.85rem;
    line-height: 1.6;
    color: var(--ft-muted);
    margin: 0;
    max-width: 280px;
  }

  /* Links Grid */
  .ft-links-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
  }
  @media (max-width: 480px) {
    .ft-links-grid { grid-template-columns: repeat(2, 1fr); gap: 2rem 1.5rem; }
  }
  .ft-link-group {
    display: flex;
    flex-direction: column;
    gap: 0.55rem;
  }
  .ft-link-heading {
    font-size: 0.7rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--ft-text);
    margin: 0 0 0.3rem;
  }
  .ft-link {
    font-size: 0.82rem;
    color: var(--ft-muted);
    text-decoration: none;
    transition: color 0.15s;
    padding: 0.1rem 0;
  }
  .ft-link:hover { color: var(--ft-hover); }

  /* ── Tags ── */
  .ft-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-bottom: 2.5rem;
  }
  .ft-tag {
    font-size: 0.72rem;
    color: var(--ft-muted);
    text-decoration: none;
    padding: 0.3rem 0.75rem;
    border-radius: 2rem;
    border: 1px solid var(--ft-border);
    transition: all 0.15s;
  }
  .ft-tag:hover {
    color: var(--ft-hover);
    border-color: rgba(244,63,94,0.4);
    background: rgba(244,63,94,0.06);
  }

  /* ── Divider ── */
  .ft-divider {
    height: 1px;
    background: var(--ft-border);
    margin-bottom: 1.5rem;
  }

  /* ── Bottom Bar ── */
  .ft-bottom {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
  }
  .ft-copy {
    font-size: 0.72rem;
    color: var(--ft-muted);
    margin: 0;
  }
  .ft-social {
    display: flex;
    align-items: center;
    gap: 0.2rem;
  }
  .ft-social-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 8px;
    color: var(--ft-muted);
    transition: color 0.15s, background 0.15s;
  }
  .ft-social-link:hover {
    color: var(--ft-hover);
    background: rgba(244,63,94,0.06);
  }
  :global(.dark) .ft-social-link:hover {
    color: white;
    background: rgba(255,255,255,0.06);
  }
  .ft-top-btn {
    width: 36px;
    height: 36px;
    border-radius: 8px;
    border: 1px solid var(--ft-border);
    background: transparent;
    color: var(--ft-muted);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    transition: all 0.15s;
    flex-shrink: 0;
  }
  .ft-top-btn:hover {
    color: var(--ft-text);
    border-color: var(--ft-muted);
    transform: translateY(-2px);
  }
  :global(.dark) .ft-top-btn:hover {
    color: white;
    border-color: rgba(255,255,255,0.2);
  }

  @media (max-width: 640px) {
    .ft-bottom { justify-content: center; text-align: center; }
    .ft-copy { width: 100%; order: 3; }
  }
</style>
