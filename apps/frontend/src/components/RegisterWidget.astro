---
---

<aside class="register-widget rounded-2xl overflow-hidden" style="background: var(--bg-card); border: 1px solid var(--border); box-shadow: 0 4px 24px rgba(0,0,0,0.06);">

  <!-- Top accent bar -->
  <div class="h-1 w-full" style="background: linear-gradient(90deg, var(--color-primary-400), var(--color-primary-600), var(--color-primary-400));"></div>

  <div class="p-6">

    <!-- Header -->
    <div class="text-center mb-5">
      <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="var(--color-primary-500)" stroke="none" class="mx-auto mb-2"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
      <h3 class="text-base font-bold mb-1" style="color: var(--text); font-family: var(--font-serif);">
        Finde dein Herzblatt
      </h3>
      <p class="text-xs" style="color: var(--text-muted);">
        Kostenlos registrieren & sofort loslegen
      </p>
    </div>

    <!-- Social Proof -->
    <div class="flex items-center justify-center gap-2 mb-5 py-2 px-3 rounded-lg" style="background: var(--bg-soft);">
      <div class="flex -space-x-1.5">
        <img src="/images/avatars/avatar-1.jpg" alt="" class="w-5 h-5 rounded-full object-cover ring-1" style="--tw-ring-color: var(--bg-card);" loading="lazy" decoding="async" width="20" height="20" />
        <img src="/images/avatars/avatar-4.jpg" alt="" class="w-5 h-5 rounded-full object-cover ring-1" style="--tw-ring-color: var(--bg-card);" loading="lazy" decoding="async" width="20" height="20" />
        <img src="/images/avatars/avatar-7.jpg" alt="" class="w-5 h-5 rounded-full object-cover ring-1" style="--tw-ring-color: var(--bg-card);" loading="lazy" decoding="async" width="20" height="20" />
      </div>
      <p class="text-[11px] font-medium" style="color: var(--text-muted);">
        <span class="font-bold" style="color: var(--text);">12.847+</span> Singles sind dabei
      </p>
    </div>

    <form id="register-form" class="space-y-3">

      <!-- Gender — compact pill toggle -->
      <div class="grid grid-cols-2 gap-2">
        <div>
          <p class="text-[10px] font-semibold uppercase tracking-wider mb-1.5" style="color: var(--text-muted);">Ich bin</p>
          <div class="gender-toggle flex rounded-lg overflow-hidden" style="border: 1px solid var(--border);">
            <label class="gender-opt flex-1 text-center py-1.5 text-xs font-medium cursor-pointer transition-all" style="color: var(--text-muted);">
              <input type="radio" name="gender" value="1" class="hidden" checked />
              <span>Mann</span>
            </label>
            <label class="gender-opt flex-1 text-center py-1.5 text-xs font-medium cursor-pointer transition-all" style="color: var(--text-muted);">
              <input type="radio" name="gender" value="2" class="hidden" />
              <span>Frau</span>
            </label>
          </div>
        </div>
        <div>
          <p class="text-[10px] font-semibold uppercase tracking-wider mb-1.5" style="color: var(--text-muted);">Ich suche</p>
          <div class="gender-toggle flex rounded-lg overflow-hidden" style="border: 1px solid var(--border);">
            <label class="gender-opt flex-1 text-center py-1.5 text-xs font-medium cursor-pointer transition-all" style="color: var(--text-muted);">
              <input type="radio" name="seeking" value="2" class="hidden" checked />
              <span>Frau</span>
            </label>
            <label class="gender-opt flex-1 text-center py-1.5 text-xs font-medium cursor-pointer transition-all" style="color: var(--text-muted);">
              <input type="radio" name="seeking" value="1" class="hidden" />
              <span>Mann</span>
            </label>
          </div>
        </div>
      </div>

      <!-- Fields -->
      <div class="space-y-2.5">
        <div class="relative">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-1/2 -translate-y-1/2 opacity-50"><path d="M19 21v-2a4 4 0 0 0-4-4H9a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          <input
            type="text"
            name="username"
            placeholder="Benutzername"
            required
            minlength="3"
            class="rw-input w-full pl-9 pr-3 py-2.5 rounded-lg text-xs outline-none transition-all"
            style="background: var(--bg-soft); color: var(--text); border: 1px solid var(--border);"
          />
        </div>

        <div class="relative">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-1/2 -translate-y-1/2 opacity-50"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
          <input
            type="number"
            name="age"
            placeholder="Alter"
            required
            min="18"
            max="99"
            class="rw-input w-full pl-9 pr-3 py-2.5 rounded-lg text-xs outline-none transition-all"
            style="background: var(--bg-soft); color: var(--text); border: 1px solid var(--border);"
          />
        </div>

        <div class="relative">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-1/2 -translate-y-1/2 opacity-50"><rect width="20" height="16" x="2" y="4" rx="2"/><path d="m22 7-8.97 5.7a1.94 1.94 0 0 1-2.06 0L2 7"/></svg>
          <input
            type="email"
            name="email"
            placeholder="E-Mail-Adresse"
            required
            class="rw-input w-full pl-9 pr-3 py-2.5 rounded-lg text-xs outline-none transition-all"
            style="background: var(--bg-soft); color: var(--text); border: 1px solid var(--border);"
          />
        </div>

        <div class="relative">
          <svg xmlns="http://www.w3.org/2000/svg" width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="absolute left-3 top-1/2 -translate-y-1/2 opacity-50"><rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>
          <input
            type="password"
            name="password"
            placeholder="Passwort"
            required
            minlength="6"
            class="rw-input w-full pl-9 pr-9 py-2.5 rounded-lg text-xs outline-none transition-all"
            style="background: var(--bg-soft); color: var(--text); border: 1px solid var(--border);"
          />
          <button type="button" onclick="const i=this.parentElement.querySelector('input');i.type=i.type==='password'?'text':'password';this.querySelector('.eye-open').classList.toggle('hidden');this.querySelector('.eye-closed').classList.toggle('hidden');" class="absolute right-3 top-1/2 -translate-y-1/2 opacity-40 hover:opacity-70 transition-opacity">
            <svg class="eye-open" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"/><circle cx="12" cy="12" r="3"/></svg>
            <svg class="eye-closed hidden" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--text-muted)" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.88 9.88a3 3 0 1 0 4.24 4.24"/><path d="M10.73 5.08A10.43 10.43 0 0 1 12 5c7 0 10 7 10 7a13.16 13.16 0 0 1-1.67 2.68"/><path d="M6.61 6.61A13.526 13.526 0 0 0 2 12s3 7 10 7a9.74 9.74 0 0 0 5.39-1.61"/><line x1="2" x2="22" y1="2" y2="22"/></svg>
          </button>
        </div>
      </div>

      <!-- Submit -->
      <button
        type="submit"
        id="register-btn"
        class="w-full py-3 rounded-lg text-sm font-bold text-white transition-all hover:shadow-md hover:-translate-y-0.5 active:translate-y-0"
        style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-600));"
      >
        Kostenlos registrieren
      </button>

      <!-- Error / Success Messages -->
      <div id="register-msg" class="hidden text-xs text-center py-2 px-3 rounded-lg"></div>

      <!-- Checkmarks -->
      <div class="flex items-center justify-center gap-3 text-[10px]" style="color: var(--text-muted);">
        <span class="flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-500)" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
          Kostenlos
        </span>
        <span class="flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-500)" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
          Diskret
        </span>
        <span class="flex items-center gap-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="11" height="11" viewBox="0 0 24 24" fill="none" stroke="var(--color-primary-500)" stroke-width="2.5"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><path d="m9 11 3 3L22 4"/></svg>
          Sicher
        </span>
      </div>

      <!-- Terms -->
      <p class="text-[9px] text-center leading-relaxed" style="color: var(--text-muted); opacity: 0.6;">
        Mit der Registrierung bestätigst du unsere
        <a href="https://www.dating-tracker.com/cmp/CLQ868/78NZBG/?source_id=herzblatt&sub1=xloves/agb" target="_blank" class="underline hover:opacity-80">AGB</a>,
        <a href="https://www.dating-tracker.com/cmp/CLQ868/78NZBG/?source_id=herzblatt&sub1=xloves/flirthinweise" target="_blank" class="underline hover:opacity-80">Flirthinweise</a> &amp;
        <a href="/datenschutz" class="underline hover:opacity-80">Datenschutz</a>
      </p>
    </form>
  </div>
</aside>

<style>
  .gender-toggle .gender-opt {
    position: relative;
    z-index: 1;
  }
  .gender-toggle .gender-opt:has(input:checked) {
    background: var(--color-primary-500);
    color: white !important;
  }
  .gender-toggle .gender-opt:has(input:checked) span {
    color: white;
  }
  .rw-input:focus {
    border-color: var(--color-primary-400) !important;
    box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-primary-400) 20%, transparent);
  }
  .rw-input::placeholder {
    color: var(--text-muted);
    opacity: 0.5;
  }
</style>

<script is:inline>
document.getElementById('register-form')?.addEventListener('submit', async function(e) {
  e.preventDefault();

  const btn = document.getElementById('register-btn');
  const msg = document.getElementById('register-msg');
  const form = this;

  btn.disabled = true;
  btn.textContent = 'Wird registriert...';
  btn.style.opacity = '0.7';
  msg.className = 'hidden';

  const username = form.username.value.trim();
  const email = form.email.value.trim();
  const password = form.password.value;
  const age = parseInt(form.age.value);
  const gender = form.gender.value;
  const seeking = form.seeking.value;

  const now = new Date();
  const birthYear = now.getFullYear() - age;
  const birthday = `${birthYear}-01-15`;

  const isMobile = /Mobi|Android/i.test(navigator.userAgent);
  const device = isMobile ? 'mobile' : 'desktop';

  try {
    const response = await fetch('/api/register', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'Accept': 'application/json'
      },
      body: JSON.stringify({
        username,
        email,
        password,
        birthday,
        gender: parseInt(gender),
        acceptTerms: 1,
        agree_to_data_protection: 1,
        device,
        country_id: '2',
        campaign_id: '2f2006d0',
        var1: seeking
      })
    });

    const data = await response.json();

    if (response.ok && data) {
      msg.className = 'block text-xs text-center py-2 px-3 rounded-lg';
      msg.style.background = 'var(--color-primary-50)';
      msg.style.color = 'var(--color-primary-700)';
      msg.textContent = 'Erfolgreich registriert! Weiterleitung...';
      setTimeout(() => {
        window.open('https://www.dating-tracker.com/cmp/CLQ868/78NZBG/?source_id=herzblatt&sub1=xloves/dashboard', '_blank');
      }, 1500);
    } else {
      const errorMsg = data?.message || data?.errors ? Object.values(data.errors).flat().join(', ') : 'Registrierung fehlgeschlagen.';
      msg.className = 'block text-xs text-center py-2 px-3 rounded-lg';
      msg.style.background = 'var(--color-primary-50)';
      msg.style.color = '#e11d48';
      msg.textContent = errorMsg;
    }
  } catch (err) {
    msg.className = 'block text-xs text-center py-2 px-3 rounded-lg';
    msg.style.background = 'var(--color-primary-50)';
    msg.style.color = '#e11d48';
    msg.textContent = 'Verbindungsfehler. Bitte versuche es erneut.';
  }

  btn.disabled = false;
  btn.textContent = 'Kostenlos registrieren';
  btn.style.opacity = '1';
});
</script>
