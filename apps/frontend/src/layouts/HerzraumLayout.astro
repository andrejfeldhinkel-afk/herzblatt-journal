  <script is:inline>
    // CSRF-Helper — liest das hz_csrf-Cookie + injiziert x-csrf-token-Header
    // in alle mutierenden fetch()-Requests zu /api/herzraum/*. Admin-Pages
    // nutzen einfach `fetch(...)` wie bisher — dieser Wrapper kümmert sich
    // transparent um den Header.
    (function() {
      function readCsrf() {
        const m = document.cookie.match(/(?:^|; )hz_csrf=([^;]+)/);
        return m ? decodeURIComponent(m[1]) : '';
      }
      const originalFetch = window.fetch.bind(window);
      window.fetch = function(input, init) {
        try {
          const url = typeof input === 'string'
            ? input
            : (input && input.url) || '';
          const method = ((init && init.method)
            || (typeof input === 'object' && input && input.method)
            || 'GET').toUpperCase();
          const isMutation = method === 'POST' || method === 'PATCH' || method === 'DELETE' || method === 'PUT';
          const isHerzraum = typeof url === 'string' && url.indexOf('/api/herzraum/') !== -1;
          if (isMutation && isHerzraum) {
            const csrf = readCsrf();
            if (csrf) {
              const headers = new Headers(
                (init && init.headers)
                  || (typeof input === 'object' && input && input.headers)
                  || {}
              );
              if (!headers.has('x-csrf-token')) {
                headers.set('x-csrf-token', csrf);
              }
              init = Object.assign({}, init || {}, { headers });
            }
          }
        } catch { /* fail-open */ }
        return originalFetch(input, init);
      };
      // Expose für manuelle Nutzung
      window.getCsrfToken = readCsrf;
    })();

    // Live-Clock im Header
    (function() {
      const el = document.getElementById('hz-clock');
      if (!el) return;
      function tick() {
        const d = new Date();
        const s = d.toLocaleString('de-DE', {
          weekday: 'short', day: '2-digit', month: 'short',
          hour: '2-digit', minute: '2-digit', second: '2-digit'
        });
        el.textContent = s;
      }
      tick(); setInterval(tick, 1000);
    })();
    // Sidebar Toggle (mobile)
    (function() {
      const btn = document.getElementById('hz-menu-btn');
      const side = document.getElementById('hz-sidebar');
      if (!btn || !side) return;
      btn.addEventListener('click', () => side.classList.toggle('open'));
      document.addEventListener('click', (e) => {
        if (!side.contains(e.target) && e.target !== btn && !btn.contains(e.target)) {
          side.classList.remove('open');
        }
      });
    })();

    // Logout-Button → POST + Redirect (CSRF-safe, ersetzt alte GET-Variante)
    (function() {
      const btn = document.getElementById('hz-logout-btn');
      if (!btn) return;
      btn.addEventListener('click', async () => {
        btn.disabled = true;
        try {
          await fetch('/api/herzraum/logout', {
            method: 'POST',
            credentials: 'same-origin',
          });
        } catch { /* ignore — wir leiten trotzdem um */ }
        window.location.href = '/herzraum/login';
      });
    })();

    // Sidebar-Badges (Inbox-unread + Todos-open) — alle 60s pollen
    (function() {
      async function loadBadge(apiPath, badgeId, valueKey) {
        try {
          const res = await fetch(apiPath, { credentials: 'same-origin' });
          if (!res.ok) return;
          const data = await res.json();
          const count = data[valueKey] ?? data.count ?? 0;
          const el = document.getElementById(badgeId);
          if (!el) return;
          if (count > 0) {
            el.textContent = count > 99 ? '99+' : String(count);
            el.style.display = 'inline-flex';
          } else {
            el.style.display = 'none';
          }
        } catch { /* silent */ }
      }
      function refresh() {
        loadBadge('/api/herzraum/inbox/unread-count', 'hz-inbox-badge', 'count');
        loadBadge('/api/herzraum/todos?filter=open', 'hz-todos-badge', 'openCount');
      }
      refresh();
      // Sidebar-Badges: pausiert wenn Tab nicht sichtbar — läuft in JEDER
      // Admin-Page, also der größte Polling-Hebel.
      let badgeTimer = null;
      function startBadgePolling() {
        if (badgeTimer) return;
        badgeTimer = setInterval(refresh, 60_000);
      }
      function stopBadgePolling() {
        if (badgeTimer) { clearInterval(badgeTimer); badgeTimer = null; }
      }
      document.addEventListener('visibilitychange', () => {
        if (document.hidden) { stopBadgePolling(); }
        else { refresh(); startBadgePolling(); }
      });
      if (!document.hidden) startBadgePolling();
    })();

    // Cmd+K Quick-Search
    (function() {
      const overlay = document.getElementById('hz-cmdk');
      const input = document.getElementById('hz-cmdk-input');
      const results = document.getElementById('hz-cmdk-results');
      if (!overlay || !input || !results) return;

      // Statische Seiten-Index (für Admin-Navigation)
      const pages = [
        { type: 'page', title: 'Dashboard', href: '/herzraum' },
        { type: 'page', title: 'Todos', href: '/herzraum/todos' },
        { type: 'page', title: 'Artikel', href: '/herzraum/artikel' },
        { type: 'page', title: 'Neuer Artikel', href: '/herzraum/artikel/neu' },
        { type: 'page', title: 'Bilder', href: '/herzraum/bilder' },
        { type: 'page', title: 'Health & SEO', href: '/herzraum/health' },
        { type: 'page', title: 'Produkte', href: '/herzraum/produkte' },
        { type: 'page', title: 'Affiliate-Links', href: '/herzraum/affiliate-links' },
        { type: 'page', title: 'Verkäufe', href: '/herzraum/verkaeufe' },
        { type: 'page', title: 'Postfach', href: '/herzraum/inbox' },
        { type: 'page', title: 'Newsletter', href: '/herzraum/newsletter' },
        { type: 'page', title: 'Email-Templates', href: '/herzraum/email-templates' },
        { type: 'page', title: 'Leser', href: '/herzraum/leser' },
        { type: 'page', title: 'Traffic', href: '/herzraum/traffic' },
        { type: 'page', title: 'Klicks', href: '/herzraum/klicks' },
        { type: 'page', title: 'Autoren', href: '/herzraum/autoren' },
        { type: 'page', title: 'Redirects', href: '/herzraum/redirects' },
        { type: 'page', title: 'Audit-Log', href: '/herzraum/audit' },
        { type: 'page', title: 'Einstellungen', href: '/herzraum/einstellungen' },
      ];

      let articlesCache = null;
      let productsCache = null;
      let selectedIdx = 0;

      async function loadArticles() {
        if (articlesCache) return articlesCache;
        try {
          // SSR-Endpoint nutzt getCollection('blog') direkt — viel schneller
          // als GitHub-Contents-Listing. Wird einmal pro Session gecached.
          const res = await fetch('/api/herzraum/articles/search?limit=200');
          if (!res.ok) throw new Error('HTTP ' + res.status);
          const data = await res.json();
          articlesCache = (data.articles || []).map((a) => ({
            type: 'artikel',
            title: a.title || a.slug,
            slug: a.slug,
            href: '/blog/' + a.slug,
            meta: a.pubDate,
          }));
        } catch (err) {
          console.error('[cmdk] loadArticles failed:', err);
          articlesCache = [];
        }
        return articlesCache;
      }

      async function loadProducts() {
        if (productsCache) return productsCache;
        try {
          const res = await fetch('/api/herzraum/products');
          const data = await res.json();
          productsCache = (data.products || []).map(p => ({
            type: 'produkt',
            title: p.name,
            slug: p.slug,
            href: '/herzraum/produkte',
          }));
        } catch { productsCache = []; }
        return productsCache;
      }

      function fuzzyMatch(query, text) {
        if (!query) return true;
        const q = query.toLowerCase();
        const t = text.toLowerCase();
        if (t.includes(q)) return true;
        // Simple fuzzy: all chars of query appear in order
        let qi = 0;
        for (let i = 0; i < t.length && qi < q.length; i++) {
          if (t[i] === q[qi]) qi++;
        }
        return qi === q.length;
      }

      function render(items) {
        if (items.length === 0) {
          results.innerHTML = '<div style="padding: 2rem 1rem; text-align: center; color: var(--hz-text-dim); font-size: 0.85rem;">Keine Treffer</div>';
          return;
        }
        results.innerHTML = items.slice(0, 20).map((item, i) => {
          const meta = item.slug ? item.slug : '';
          return '<div class="hz-cmdk-item ' + (i === selectedIdx ? 'selected' : '') + '" data-href="' + item.href + '" data-idx="' + i + '">'
            + '<span class="hz-cmdk-item-type">' + item.type + '</span>'
            + '<span class="hz-cmdk-item-title">' + item.title + '</span>'
            + (meta ? '<span class="hz-cmdk-item-meta">' + meta + '</span>' : '')
            + '</div>';
        }).join('');
        document.querySelectorAll('.hz-cmdk-item').forEach((el) => {
          el.addEventListener('click', () => {
            window.location.href = el.dataset.href;
          });
          el.addEventListener('mouseenter', () => {
            selectedIdx = parseInt(el.dataset.idx, 10);
            updateSelected();
          });
        });
      }

      function updateSelected() {
        document.querySelectorAll('.hz-cmdk-item').forEach((el, i) => {
          el.classList.toggle('selected', i === selectedIdx);
        });
      }

      let currentItems = [];
      async function search(q) {
        // Artikel + Produkte parallel laden (cached nach erstem Call)
        const [products, articles] = await Promise.all([loadProducts(), loadArticles()]);
        const all = [...pages, ...products, ...articles];
        currentItems = q
          ? all.filter(i => fuzzyMatch(q, i.title) || (i.slug && fuzzyMatch(q, i.slug)))
          : pages.slice(0, 10);
        selectedIdx = 0;
        render(currentItems);
      }

      function open() {
        overlay.style.display = 'block';
        input.value = '';
        selectedIdx = 0;
        search('');
        setTimeout(() => input.focus(), 50);
      }
      function close() {
        overlay.style.display = 'none';
      }

      input.addEventListener('input', (e) => search(e.target.value.trim()));
      input.addEventListener('keydown', (e) => {
        if (e.key === 'ArrowDown') { e.preventDefault(); selectedIdx = Math.min(selectedIdx + 1, currentItems.length - 1); updateSelected(); }
        else if (e.key === 'ArrowUp') { e.preventDefault(); selectedIdx = Math.max(selectedIdx - 1, 0); updateSelected(); }
        else if (e.key === 'Enter') { e.preventDefault(); const item = currentItems[selectedIdx]; if (item) window.location.href = item.href; }
        else if (e.key === 'Escape') close();
      });

      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) close();
      });

      document.addEventListener('keydown', (e) => {
        if ((e.metaKey || e.ctrlKey) && e.key.toLowerCase() === 'k') {
          e.preventDefault();
          if (overlay.style.display === 'none') open();
          else close();
        }
      });
    })();
  </script>
</body>
</html>
