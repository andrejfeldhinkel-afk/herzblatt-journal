---
/**
 * HerzraumLayout — Dashboard-Layout mit Dark-Sidebar + Header
 *
 * Props:
 *  - title:  Seiten-Titel (wird im Header + im <title> verwendet)
 *  - active: Nav-Key für aktives Highlight ('overview', 'traffic', ...)
 */
export interface Props {
  title: string;
  active:
    | 'overview'
    | 'todos'
    | 'artikel'
    | 'templates'
    | 'email-templates'
    | 'newsletter-broadcasts'
    | 'inbox'
    | 'bilder'
    | 'autoren'
    | 'redirects'
    | 'health'
    | 'traffic'
    | 'klicks'
    | 'newsletter'
    | 'push'
    | 'verkaeufe'
    | 'produkte'
    | 'affiliate-links'
    | 'affiliate-code'
    | 'leser'
    | 'audit'
    | 'einstellungen'
    | 'session-map';
  fullscreen?: boolean;
}

const { title, active, fullscreen = false } = Astro.props;

// Navigation ist in Sektionen gruppiert — bessere Übersicht bei 17 Items.
// Reihenfolge innerhalb jeder Section: häufigste Nutzung zuerst.
const navSections = [
  {
    heading: null, // Top-Level: Dashboard + Todos allein oben
    items: [
      { key: 'overview',   href: '/herzraum',            label: 'Dashboard',    icon: 'dashboard' },
      { key: 'todos',      href: '/herzraum/todos',      label: 'Todos',        icon: 'checklist' },
    ],
  },
  {
    heading: 'Content',
    items: [
      { key: 'artikel',    href: '/herzraum/artikel',    label: 'Artikel',      icon: 'article' },
      { key: 'bilder',     href: '/herzraum/bilder',     label: 'Bilder',       icon: 'image' },
      { key: 'health',     href: '/herzraum/health',     label: 'Health & SEO', icon: 'health' },
    ],
  },
  {
    heading: 'Monetarisierung',
    items: [
      { key: 'produkte',         href: '/herzraum/produkte',         label: 'Produkte',        icon: 'bag' },
      { key: 'affiliate-links',  href: '/herzraum/affiliate-links',  label: 'Affiliate-Links', icon: 'link' },
      { key: 'affiliate-code',   href: '/herzraum/affiliate-code',   label: 'Käufer-Codes',    icon: 'link' },
      { key: 'verkaeufe',        href: '/herzraum/verkaeufe',        label: 'Verkäufe',        icon: 'euro' },
    ],
  },
  {
    heading: 'Kommunikation',
    items: [
      { key: 'inbox',             href: '/herzraum/inbox',                  label: 'Postfach',        icon: 'inbox' },
      { key: 'newsletter',        href: '/herzraum/newsletter',             label: 'Newsletter',      icon: 'mail' },
      { key: 'newsletter-broadcasts', href: '/herzraum/newsletter-broadcasts', label: 'Broadcasts',   icon: 'mail' },
      { key: 'email-templates',   href: '/herzraum/email-templates',        label: 'Email-Templates', icon: 'envelope' },
      { key: 'push',              href: '/herzraum/push',            label: 'Push & App',      icon: 'bell' },
      { key: 'leser',             href: '/herzraum/leser',           label: 'Leser',           icon: 'users' },
    ],
  },
  {
    heading: 'Analytics',
    items: [
      { key: 'traffic',    href: '/herzraum/traffic',    label: 'Traffic',      icon: 'traffic' },
      { key: 'klicks',     href: '/herzraum/klicks',     label: 'Klicks',       icon: 'click' },
    ],
  },
  {
    heading: 'System',
    items: [
      { key: 'autoren',       href: '/herzraum/autoren',       label: 'Autoren',       icon: 'users' },
      { key: 'redirects',     href: '/herzraum/redirects',     label: 'Redirects',     icon: 'arrow' },
      { key: 'session-map',   href: '/herzraum/session-map',   label: 'Session-Map',   icon: 'map' },
      { key: 'audit',         href: '/herzraum/audit',         label: 'Audit-Log',     icon: 'shield' },
      { key: 'einstellungen', href: '/herzraum/einstellungen', label: 'Einstellungen', icon: 'settings' },
    ],
  },
] as const;
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>{title} · Herzraum</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preload" href="/fonts/dm-sans-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/playfair-latin.woff2" as="font" type="font/woff2" crossorigin />
  <style is:global>
    @font-face { font-family: 'DM Sans'; src: url('/fonts/dm-sans-latin.woff2') format('woff2'); font-display: swap; }
    @font-face { font-family: 'Playfair Display'; src: url('/fonts/playfair-latin.woff2') format('woff2'); font-display: swap; font-weight: 400 900; }
    :root {
      --hz-bg: #f7f8fb;
      --hz-bg-2: #eef1f6;
      --hz-surface: #ffffff;
      --hz-surface-2: #f5f7fb;
      --hz-surface-3: #e7ecf3;
      --hz-border: rgba(15,23,42,0.08);
      --hz-border-strong: rgba(15,23,42,0.16);
      --hz-primary: #e11d48;
      --hz-primary-dark: #be123c;
      --hz-primary-glow: rgba(225,29,72,0.18);
      --hz-primary-light: rgba(225,29,72,0.08);
      --hz-accent: #8b5cf6;
      --hz-text: #0f172a;
      --hz-text-muted: #475569;
      --hz-text-dim: #94a3b8;
      --hz-success: #059669;
      --hz-warning: #d97706;
      --hz-danger: #dc2626;
      --hz-info: #0284c7;
      --hz-shadow-sm: 0 1px 2px rgba(15,23,42,0.06);
      --hz-shadow: 0 4px 12px -2px rgba(15,23,42,0.08), 0 2px 4px -2px rgba(15,23,42,0.04);
      --hz-shadow-lg: 0 20px 40px -8px rgba(15,23,42,0.12), 0 8px 16px -4px rgba(15,23,42,0.06);
      --hz-radius: 0.75rem;
      --hz-radius-sm: 0.5rem;
      --hz-radius-lg: 1rem;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body {
      font-family: 'DM Sans', ui-sans-serif, -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif;
      background:
        radial-gradient(circle at 15% 0%, rgba(225,29,72,0.05), transparent 45%),
        radial-gradient(circle at 85% 100%, rgba(139,92,246,0.04), transparent 45%),
        var(--hz-bg);
      background-attachment: fixed;
      color: var(--hz-text);
      -webkit-font-smoothing: antialiased;
      font-size: 14px;
      line-height: 1.55;
      letter-spacing: -0.005em;
    }
    h1, h2, h3, h4 { font-family: 'Playfair Display', Georgia, serif; letter-spacing: -0.025em; font-weight: 700; }
    h1 { font-weight: 800; }
    a { color: inherit; text-decoration: none; transition: color 0.15s; }
    input, select, textarea, button { font-family: inherit; color: inherit; font-size: 14px; }
    code { font-family: 'SF Mono', Menlo, Monaco, monospace; font-size: 0.85em; padding: 0.12em 0.4em; background: var(--hz-surface-2); border-radius: 4px; color: var(--hz-text); border: 1px solid var(--hz-border); }

    /* ── Layout ─────────────────────────────────────────── */
    /* Fullscreen-mode: slot füllt den kompletten Viewport (für Session-Map etc.) */
    body.hz-fullscreen-body { overflow: hidden; }
    .hz-fullscreen-back {
      position: fixed; top: 14px; left: 14px; z-index: 10001;
      display: inline-flex; align-items: center; gap: 6px;
      padding: 6px 12px; border-radius: 999px;
      background: rgba(15,23,42,.55); backdrop-filter: blur(12px);
      border: 1px solid rgba(255,255,255,.18);
      color: #f8fafc; font-size: 11px; font-weight: 600;
      letter-spacing: .06em; text-transform: uppercase;
      transition: all .18s;
    }
    .hz-fullscreen-back:hover {
      color: #ffffff; border-color: var(--hz-primary);
      background: rgba(225,29,72,.35);
    }
    .hz-layout { display: grid; grid-template-columns: 244px 1fr; min-height: 100vh; }
    .hz-sidebar {
      background: rgba(255,255,255,0.85);
      backdrop-filter: blur(16px);
      -webkit-backdrop-filter: blur(16px);
      border-right: 1px solid var(--hz-border);
      padding: 1.25rem 0.875rem;
      position: sticky; top: 0; height: 100vh;
      display: flex; flex-direction: column;
      overflow-y: auto;
    }
    .hz-brand {
      display: flex; align-items: center; gap: 0.65rem;
      padding: 0.25rem 0.5rem 1.25rem;
      border-bottom: 1px solid var(--hz-border);
      margin-bottom: 1rem;
    }
    .hz-brand-mark {
      width: 36px; height: 36px; border-radius: 10px;
      background: linear-gradient(135deg, #fb7185, var(--hz-primary) 60%, var(--hz-primary-dark));
      display: flex; align-items: center; justify-content: center;
      font-size: 17px;
      box-shadow: 0 4px 12px var(--hz-primary-glow), inset 0 1px 0 rgba(255,255,255,0.2);
    }
    .hz-brand-text h2 { font-size: 1rem; font-weight: 800; letter-spacing: -0.03em; }
    .hz-brand-text p { font-size: 0.66rem; color: var(--hz-text-dim); text-transform: uppercase; letter-spacing: 0.18em; margin-top: 2px; font-family: 'DM Sans', sans-serif; font-weight: 500; }

    .hz-nav { flex: 1; display: flex; flex-direction: column; gap: 1px; padding: 0.25rem 0; }
    .hz-nav-section {
      font-size: 0.62rem;
      font-weight: 700;
      text-transform: uppercase;
      letter-spacing: 0.15em;
      color: var(--hz-text-dim);
      padding: 0.9rem 0.75rem 0.35rem;
      margin-top: 0.35rem;
    }
    .hz-nav-section:first-child { margin-top: 0; }
    .hz-nav-badge {
      margin-left: auto;
      min-width: 20px;
      height: 20px;
      padding: 0 6px;
      background: linear-gradient(135deg, var(--hz-primary), var(--hz-primary-dark));
      color: white;
      border-radius: 999px;
      font-size: 0.68rem;
      font-weight: 700;
      display: inline-flex;
      align-items: center;
      justify-content: center;
      line-height: 1;
      font-variant-numeric: tabular-nums;
      box-shadow: 0 2px 6px var(--hz-primary-glow);
    }
    .hz-nav a.active .hz-nav-badge {
      background: rgba(255,255,255,0.15);
      box-shadow: none;
    }
    .hz-nav a {
      display: flex; align-items: center; gap: 0.75rem;
      padding: 0.55rem 0.75rem;
      border-radius: var(--hz-radius-sm);
      color: var(--hz-text-muted);
      font-weight: 500;
      font-size: 0.875rem;
      position: relative;
      transition: all 0.15s cubic-bezier(.4,0,.2,1);
    }
    .hz-nav a:hover {
      background: var(--hz-surface-2);
      color: var(--hz-text);
      transform: translateX(1px);
    }
    .hz-nav a.active {
      background: linear-gradient(90deg, var(--hz-primary-light), transparent 70%);
      color: var(--hz-primary);
      font-weight: 600;
    }
    .hz-nav a.active::before {
      content: ''; position: absolute; left: -0.875rem; top: 25%; bottom: 25%;
      width: 3px; border-radius: 0 3px 3px 0;
      background: var(--hz-primary);
      box-shadow: 0 0 12px var(--hz-primary-glow);
    }
    .hz-nav a svg { width: 16px; height: 16px; flex-shrink: 0; opacity: 0.9; }
    .hz-nav a.active svg { opacity: 1; }

    .hz-logout {
      margin-top: 1rem;
      padding-top: 1rem;
      border-top: 1px solid var(--hz-border);
    }
    .hz-logout a,
    .hz-logout button {
      display: flex; align-items: center; gap: 0.75rem;
      padding: 0.55rem 0.75rem;
      border-radius: var(--hz-radius-sm);
      color: var(--hz-text-dim);
      font-weight: 500;
      font-size: 0.875rem;
      transition: all 0.15s;
      width: 100%;
      background: transparent;
      border: 0;
      cursor: pointer;
      text-align: left;
      font-family: inherit;
    }
    .hz-logout a:hover,
    .hz-logout button:hover { background: rgba(239,68,68,0.08); color: var(--hz-danger); }

    /* ── Main ───────────────────────────────────────────── */
    .hz-main { padding: 1.75rem 2.25rem 4rem; max-width: 1600px; margin-left: auto; margin-right: auto; width: 100%; }
    .hz-header {
      display: flex; justify-content: space-between; align-items: center;
      margin-bottom: 2rem;
    }
    .hz-header h1 { font-size: 1.75rem; font-weight: 800; letter-spacing: -0.03em; }
    .hz-header-meta { text-align: right; font-size: 0.8rem; color: var(--hz-text-muted); display: flex; align-items: center; gap: 1rem; }
    .hz-header-meta time { color: var(--hz-text); font-variant-numeric: tabular-nums; font-weight: 500; }
    .hz-header-meta .hz-chip {
      padding: 0.35rem 0.75rem;
      background: var(--hz-surface);
      border: 1px solid var(--hz-border);
      border-radius: 999px;
      font-size: 0.72rem;
      color: var(--hz-text-muted);
    }
    .hz-header-meta .hz-chip::before {
      content: ''; display: inline-block; width: 6px; height: 6px; border-radius: 50%;
      background: var(--hz-success); margin-right: 0.4rem;
      box-shadow: 0 0 6px var(--hz-success);
      animation: pulse 2s infinite;
    }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:0.5} }

    /* ── Cards ──────────────────────────────────────────── */
    .hz-card {
      background: var(--hz-surface);
      border: 1px solid var(--hz-border);
      border-radius: var(--hz-radius);
      padding: 1.4rem 1.4rem;
      box-shadow: var(--hz-shadow-sm);
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .hz-card:hover { border-color: var(--hz-border-strong); }
    .hz-card + .hz-card { margin-top: 1rem; }
    .hz-card h3 { font-size: 1rem; font-weight: 700; margin-bottom: 1rem; color: var(--hz-text); }

    /* ── KPI Cards ──────────────────────────────────────── */
    .hz-kpi-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap: 1rem; margin-bottom: 1.5rem; }
    .hz-kpi {
      background: linear-gradient(145deg, var(--hz-surface), var(--hz-bg-2));
      border: 1px solid var(--hz-border);
      border-radius: var(--hz-radius);
      padding: 1.15rem 1.25rem;
      position: relative;
      overflow: hidden;
      transition: all 0.2s cubic-bezier(.4,0,.2,1);
    }
    .hz-kpi::before {
      content: ''; position: absolute; top: 0; left: 0; right: 0; height: 1px;
      background: linear-gradient(90deg, transparent, var(--hz-border-strong), transparent);
    }
    .hz-kpi:hover {
      transform: translateY(-2px);
      border-color: var(--hz-border-strong);
      box-shadow: var(--hz-shadow);
    }
    .hz-kpi-label {
      font-size: 0.72rem; color: var(--hz-text-muted);
      text-transform: uppercase; letter-spacing: 0.1em;
      margin-bottom: 0.5rem; font-weight: 600;
    }
    .hz-kpi-value {
      font-size: 1.875rem; font-weight: 800;
      font-family: 'Playfair Display', serif; line-height: 1.1;
      letter-spacing: -0.03em;
      color: var(--hz-text);
      font-variant-numeric: tabular-nums;
      font-feature-settings: "tnum";
    }
    .hz-kpi-delta { font-size: 0.75rem; margin-top: 0.35rem; display: inline-flex; align-items: center; gap: 0.3rem; font-weight: 500; }
    .hz-kpi-delta.up { color: var(--hz-success); }
    .hz-kpi-delta.down { color: var(--hz-danger); }
    .hz-kpi-delta.flat { color: var(--hz-text-dim); }

    /* ── Table ──────────────────────────────────────────── */
    .hz-table { width: 100%; border-collapse: collapse; font-size: 0.875rem; }
    .hz-table th, .hz-table td { padding: 0.8rem 0.85rem; text-align: left; }
    .hz-table thead th {
      background: var(--hz-surface-2);
      color: var(--hz-text-muted);
      font-weight: 600;
      text-transform: uppercase;
      font-size: 0.68rem;
      letter-spacing: 0.1em;
      border-bottom: 1px solid var(--hz-border);
      position: sticky; top: 0;
      z-index: 1;
    }
    .hz-table tbody tr {
      border-bottom: 1px solid var(--hz-border);
      transition: background 0.12s;
    }
    .hz-table tbody tr:hover { background: rgba(244,63,94,0.04); }
    .hz-table tbody tr:last-child { border-bottom: none; }
    .hz-table td a { color: var(--hz-primary); font-weight: 500; }
    .hz-table td a:hover { color: #fb7185; }
    .hz-table .muted { color: var(--hz-text-dim); }
    .hz-table .right { text-align: right; font-variant-numeric: tabular-nums; }

    /* ── Tags / Badges ──────────────────────────────────── */
    .hz-badge {
      display: inline-block;
      padding: 0.22rem 0.6rem;
      border-radius: 999px;
      font-size: 0.68rem;
      font-weight: 600;
      letter-spacing: 0.02em;
      line-height: 1.2;
    }
    .hz-badge.success { background: rgba(16,185,129,0.12); color: var(--hz-success); border: 1px solid rgba(16,185,129,0.25); }
    .hz-badge.warning, .hz-badge.warn { background: rgba(245,158,11,0.12); color: var(--hz-warning); border: 1px solid rgba(245,158,11,0.25); }
    .hz-badge.danger { background: rgba(239,68,68,0.12); color: var(--hz-danger); border: 1px solid rgba(239,68,68,0.25); }
    .hz-badge.info { background: rgba(56,189,248,0.12); color: var(--hz-info); border: 1px solid rgba(56,189,248,0.25); }
    .hz-badge.muted { background: var(--hz-surface-2); color: var(--hz-text-muted); border: 1px solid var(--hz-border); }

    /* ── Buttons ────────────────────────────────────────── */
    .hz-btn {
      display: inline-flex; align-items: center; justify-content: center; gap: 0.45rem;
      padding: 0.55rem 1rem;
      border-radius: var(--hz-radius-sm);
      border: 1px solid var(--hz-border);
      background: var(--hz-surface-2);
      color: var(--hz-text);
      font-weight: 600; font-size: 0.85rem;
      cursor: pointer;
      transition: all 0.15s cubic-bezier(.4,0,.2,1);
      user-select: none;
    }
    .hz-btn:hover:not(:disabled) {
      background: var(--hz-surface-3);
      border-color: var(--hz-border-strong);
      transform: translateY(-1px);
    }
    .hz-btn:active { transform: translateY(0); }
    .hz-btn:disabled { opacity: 0.6; cursor: not-allowed; }
    .hz-btn.primary {
      background: linear-gradient(135deg, var(--hz-primary), var(--hz-primary-dark));
      border: 1px solid rgba(255,255,255,0.1);
      color: white;
      box-shadow: 0 2px 8px var(--hz-primary-glow), inset 0 1px 0 rgba(255,255,255,0.15);
    }
    .hz-btn.primary:hover:not(:disabled) {
      box-shadow: 0 6px 20px var(--hz-primary-glow), inset 0 1px 0 rgba(255,255,255,0.2);
      transform: translateY(-1px);
      filter: brightness(1.05);
    }
    .hz-btn.danger { background: rgba(239,68,68,0.1); color: var(--hz-danger); border-color: rgba(239,68,68,0.25); }
    .hz-btn.danger:hover { background: rgba(239,68,68,0.18); border-color: rgba(239,68,68,0.4); }
    .hz-btn.sm { padding: 0.35rem 0.75rem; font-size: 0.78rem; }

    /* ── Grid Utilities ─────────────────────────────────── */
    .hz-grid-2 { display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; }
    .hz-grid-3 { display: grid; grid-template-columns: repeat(3, 1fr); gap: 1rem; }
    .hz-row { display: flex; gap: 0.75rem; align-items: center; flex-wrap: wrap; }
    .hz-spacer { flex: 1; }

    /* ── Inputs ─────────────────────────────────────────── */
    input[type="text"], input[type="email"], input[type="password"], input[type="search"], input[type="date"], input[type="number"], select, textarea {
      background: var(--hz-bg-2);
      border: 1px solid var(--hz-border);
      border-radius: var(--hz-radius-sm);
      padding: 0.55rem 0.85rem;
      color: var(--hz-text);
      font-size: 0.88rem;
      outline: none;
      transition: all 0.15s;
      font-family: inherit;
    }
    input:focus, select:focus, textarea:focus {
      border-color: var(--hz-primary);
      box-shadow: 0 0 0 3px var(--hz-primary-glow);
      background: var(--hz-surface);
    }
    input::placeholder, textarea::placeholder { color: var(--hz-text-dim); }

    /* ── Detail-Accordion ──────────────────────────────── */
    details summary { list-style: none; cursor: pointer; }
    details summary::-webkit-details-marker { display: none; }
    details summary::before {
      content: '▸'; display: inline-block;
      margin-right: 0.4rem;
      transition: transform 0.15s;
      color: var(--hz-text-dim);
      font-size: 0.7em;
    }
    details[open] summary::before { transform: rotate(90deg); }

    /* ── Responsive ─────────────────────────────────────── */
    @media (max-width: 900px) {
      .hz-layout { grid-template-columns: 1fr; }
      .hz-sidebar {
        position: fixed; top: 0; left: 0;
        width: 244px; z-index: 100;
        transform: translateX(-100%);
        transition: transform 0.25s;
      }
      .hz-sidebar.open { transform: translateX(0); box-shadow: var(--hz-shadow-lg); }
      .hz-menu-btn {
        position: fixed; top: 0.875rem; left: 0.875rem; z-index: 101;
        display: flex; align-items: center; justify-content: center;
        width: 40px; height: 40px;
        border-radius: 0.5rem; border: 1px solid var(--hz-border);
        background: var(--hz-surface); color: var(--hz-text);
        cursor: pointer;
        backdrop-filter: blur(8px);
      }
      .hz-main { padding: 4rem 1rem 3rem; }
      .hz-grid-2, .hz-grid-3 { grid-template-columns: 1fr; }
    }
