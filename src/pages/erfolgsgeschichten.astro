---

<BaseLayout
  title="Erfolgsgeschichten — Herzblatt Journal | Echte Liebesgeschichten unserer Leser"
  description="Lese echte Erfolgsgeschichten von Paaren, die durch Dating-Ratgeber, Tipps und sich selbst die große Liebe gefunden haben. Inspirierende Liebesgeschichten aus dem deutschsprachigen Raum."
>
  <!-- Hero Section -->
  <section class="relative overflow-hidden py-20 sm:py-28">
    <div class="absolute inset-0" style="background: linear-gradient(135deg, var(--color-primary-50) 0%, var(--color-surface-100) 50%, var(--color-primary-50) 100%);"></div>
    <div class="absolute top-10 left-10 w-72 h-72 rounded-full opacity-20" style="background: var(--color-primary-200); filter: blur(80px);"></div>
    <div class="absolute bottom-10 right-10 w-96 h-96 rounded-full opacity-15" style="background: var(--color-primary-300); filter: blur(100px);"></div>

    <div class="relative max-w-4xl mx-auto px-4 sm:px-6 text-center">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-semibold mb-6" style="background: var(--color-primary-100); color: var(--color-primary-700);">
        <span class="heart-pulse">💕</span> Wahre Geschichten
      </div>
      <h1 class="text-4xl sm:text-5xl font-extrabold mb-6" style="color: var(--text); font-family: var(--font-serif); letter-spacing: -0.03em; line-height: 1.1;">
        Echte Liebesgeschichten<br>
        <span style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-700)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">unserer Leser</span>
      </h1>
      <p class="text-lg sm:text-xl max-w-2xl mx-auto leading-relaxed" style="color: var(--text-muted);">
        Inspiration pur: Echte Menschen, echte Begegnungen, echte Liebe. Lese, wie unsere Leser die Partner ihres Lebens gefunden haben — und lass dich von ihren Geschichten inspirieren.
      </p>
    </div>
  </section>

  <!-- Stats Bar -->
  <section class="relative -mt-8 z-10 max-w-5xl mx-auto px-4 sm:px-6">
    <div class="rounded-2xl p-6 sm:p-8 shadow-lg" style="background: var(--bg); border: 1px solid var(--border);">
      <div class="grid grid-cols-2 sm:grid-cols-3 gap-6 text-center">
        <div>
          <p class="text-3xl font-extrabold" style="color: var(--color-primary-600); font-family: var(--font-serif);">250+</p>
          <p class="text-xs font-medium mt-1" style="color: var(--text-muted);">Erfolgsgeschichten</p>
        </div>
        <div>
          <p class="text-3xl font-extrabold" style="color: var(--color-primary-600); font-family: var(--font-serif);">89%</p>
          <p class="text-xs font-medium mt-1" style="color: var(--text-muted);">fanden die große Liebe</p>
        </div>
        <div>
          <p class="text-3xl font-extrabold" style="color: var(--color-primary-600); font-family: var(--font-serif);">Seit 2024</p>
          <p class="text-xs font-medium mt-1" style="color: var(--text-muted);">Begleiten wir dich</p>
        </div>
      </div>
    </div>
  </section>

  <div class="max-w-6xl mx-auto px-4 sm:px-6">

    <!-- Success Stories Grid -->
    <section class="py-16">
      <div class="flex items-center gap-3 mb-8">
        <div class="w-1 h-8 rounded-full" style="background: linear-gradient(to bottom, var(--color-primary-500), var(--color-primary-300));"></div>
        <h2 class="text-2xl font-bold" style="color: var(--text); font-family: var(--font-serif);">Die schönsten Erfolgsgeschichten</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-12">
        {successStories.map((story) => (
          <div class="rounded-2xl p-6 overflow-hidden" style={`background: var(--bg-soft); border: 1px solid var(--border); transition: all 0.3s ease;`}>
            <!-- Header with avatars and metadata -->
            <div class="flex items-start justify-between mb-4">
              <div>
                <h3 class="text-lg font-bold" style="color: var(--text);">{story.names}</h3>
                <p class="text-sm" style="color: var(--text-muted);">{story.ages}</p>
                <p class="text-xs font-medium mt-2" style="color: var(--color-primary-600);">📍 {story.howWeMet}</p>
              </div>
              <div class="flex gap-2">
                <div
                  class="w-12 h-12 rounded-full flex items-center justify-center text-sm font-bold"
                  style={`background: linear-gradient(135deg, ${story.gradientFrom}, ${story.gradientTo}); color: ${story.textColor};`}
                >
                  {story.avatar1}
                </div>
                <div
                  class="w-12 h-12 rounded-full flex items-center justify-center text-sm font-bold"
                  style={`background: linear-gradient(135deg, ${story.gradientFrom}, ${story.gradientTo}); color: ${story.textColor};`}
                >
                  {story.avatar2}
                </div>
              </div>
            </div>

            <!-- Duration badge -->
            <div class="inline-block px-3 py-1 rounded-full text-xs font-semibold mb-4" style={`background: rgba(${story.textColor === '#B91C1C' ? '185, 28, 28' : story.textColor === '#166534' ? '22, 101, 52' : story.textColor === '#4338CA' ? '67, 56, 202' : story.textColor === '#7E22CE' ? '126, 34, 206' : story.textColor === '#B45309' ? '180, 83, 9' : story.textColor === '#991B1B' ? '153, 27, 27' : story.textColor === '#1E40AF' ? '30, 64, 175' : '54, 83, 20'}, 0.15); color: ${story.textColor};`}>
              💕 Zusammen seit {story.duration}
            </div>

            <!-- Story text -->
            <p class="text-sm leading-relaxed mb-4" style="color: var(--text-muted);">
              {story.story}
            </p>

            <!-- Quote -->
            <div class="mb-4 pl-4 border-l-2" style={`border-color: ${story.textColor}; color: var(--text-muted);`}>
              <p class="text-sm italic">"{story.quote}"</p>
            </div>

            <!-- Rating -->
            <div class="flex gap-1 mb-4">
              {[...Array(5)].map((_, i) => (
                <span style={i < story.rating ? "color: #F59E0B;" : "color: #D1D5DB;"}>{i < story.rating ? "★" : "☆"}</span>
              ))}
            </div>

            <!-- Tags -->
            <div class="flex flex-wrap gap-2">
              {story.tags.map((tag) => (
                <span
                  class="text-xs px-2 py-1 rounded-full font-medium"
                  style={`background: ${story.textColor}20; color: ${story.textColor};`}
                >
                  {tag}
                </span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- CTA Section -->
    <section class="relative overflow-hidden rounded-2xl p-8 sm:p-12 mb-12 text-center" style="background: linear-gradient(135deg, var(--color-primary-50), var(--color-surface-100)); border: 1px solid var(--color-primary-100);">
      <div class="absolute -top-10 -right-10 w-40 h-40 rounded-full opacity-10" style="background: var(--color-primary-300); filter: blur(60px);"></div>
      <div class="absolute -bottom-10 -left-10 w-40 h-40 rounded-full opacity-10" style="background: var(--color-primary-200); filter: blur(60px);"></div>

      <div class="relative max-w-2xl mx-auto">
        <h2 class="text-3xl font-extrabold mb-4" style="color: var(--text); font-family: var(--font-serif);">
          Bereit für deine eigene<br>
          <span style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-700)); -webkit-background-clip: text; -webkit-text-fill-color: transparent;">Erfolgsgeschichte?</span>
        </h2>
        <p class="text-base leading-relaxed mb-8" style="color: var(--text-muted);">
          Die Tipps und Ratgeber von Herzblatt Journal haben hunderten geholfen, ihre große Liebe zu finden. Es könnte auch deine Geschichte sein.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href="https://www.dating-tracker.com/cmp/CLQ868/78NZBG/?source_id=erfolgsgeschichten&sub1=cta-button"
            target="_blank"
            rel="nofollow sponsored noopener noreferrer"
            class="inline-flex items-center justify-center gap-2 px-8 py-3 rounded-full text-sm font-bold text-white transition-all hover:shadow-md hover:-translate-y-0.5"
            style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-700));"
          >
            Jetzt starten
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
          </a>
          <a
            href="/top-dating-seiten"
            class="inline-flex items-center justify-center gap-2 px-8 py-3 rounded-full text-sm font-semibold transition-all hover:shadow-md"
            style="color: var(--color-primary-600); background: var(--color-primary-50); border: 1px solid var(--color-primary-200);"
          >
            Alle Plattformen vergleichen
          </a>
        </div>
      </div>
    </section>

    <!-- Form Section -->
    <section class="py-16" style="border-top: 1px solid var(--border);">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-1 h-8 rounded-full" style="background: linear-gradient(to bottom, var(--color-primary-500), var(--color-primary-300));"></div>
        <h2 class="text-2xl font-bold" style="color: var(--text); font-family: var(--font-serif);">Deine Geschichte teilen</h2>
      </div>

      <div class="max-w-2xl">
        <p class="text-base leading-relaxed mb-8" style="color: var(--text-muted);">
          Du hast deine große Liebe gefunden? Inspiriere andere mit deiner Geschichte! Teile, wie du deinen Partner kennengelernt hast und wie die Herzblatt Journal Tipps dir geholfen haben.
        </p>

        <form id="successStoryForm" class="space-y-6">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
            <div>
              <label for="firstName" class="block text-sm font-semibold mb-2" style="color: var(--text);">Euer Namen</label>
              <input
                type="text"
                id="firstName"
                placeholder="z.B. Lisa & Marco"
                class="w-full px-4 py-3 rounded-lg text-sm transition-all"
                style="background: var(--bg); border: 1px solid var(--border); color: var(--text);"
                required
              />
            </div>
            <div>
              <label for="email" class="block text-sm font-semibold mb-2" style="color: var(--text);">Eure E-Mail</label>
              <input
                type="email"
                id="email"
                placeholder="kontakt@example.com"
                class="w-full px-4 py-3 rounded-lg text-sm transition-all"
                style="background: var(--bg); border: 1px solid var(--border); color: var(--text);"
                required
              />
            </div>
          </div>

          <div>
            <label for="story" class="block text-sm font-semibold mb-2" style="color: var(--text);">Eure Geschichte (mindestens 100 Zeichen)</label>
            <textarea
              id="story"
              placeholder="Schreib uns: Wie habt ihr euch kennengelernt? Wie hat Herzblatt Journal euch geholfen? Was hat sich seitdem verändert?"
              rows="6"
              class="w-full px-4 py-3 rounded-lg text-sm transition-all resize-none"
              style="background: var(--bg); border: 1px solid var(--border); color: var(--text);"
              required
            ></textarea>
            <p class="text-xs mt-2" style="color: var(--text-muted);">Datenschutz: Deine Story wird nur mit deiner Zustimmung veröffentlicht.</p>
          </div>

          <button
            type="submit"
            class="w-full px-6 py-3 rounded-full text-sm font-bold text-white transition-all hover:shadow-md hover:-translate-y-0.5 cursor-pointer"
            style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-700)); border: none;"
          >
            Meine Geschichte einreichen
          </button>

          <div id="successMessage" class="hidden p-4 rounded-lg text-center" style="background: var(--color-primary-50); border: 1px solid var(--color-primary-200);">
            <p class="text-sm font-semibold" style="color: var(--color-primary-700);">
              💕 Danke! Deine Geschichte hat uns erreicht. Wir überprüfen sie und melden uns bei dir!
            </p>
          </div>
        </form>
      </div>
    </section>

    <!-- Why Share Section -->
    <section class="py-16" style="border-top: 1px solid var(--border);">
      <div class="flex items-center gap-3 mb-6">
        <div class="w-1 h-8 rounded-full" style="background: linear-gradient(to bottom, var(--color-primary-500), var(--color-primary-300));"></div>
        <h2 class="text-2xl font-bold" style="color: var(--text); font-family: var(--font-serif);">Warum eine Geschichte teilen?</h2>
      </div>

      <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
        <div class="rounded-2xl p-6" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <div class="text-3xl mb-3">💡</div>
          <h3 class="text-sm font-bold mb-2" style="color: var(--text);">Andere inspirieren</h3>
          <p class="text-sm" style="color: var(--text-muted);">Deine Geschichte könnte jemanden Hoffnung geben, der gerade zu zweifeln beginnt.</p>
        </div>
        <div class="rounded-2xl p-6" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <div class="text-3xl mb-3">🎁</div>
          <h3 class="text-sm font-bold mb-2" style="color: var(--text);">Wertvolles Feedback</h3>
          <p class="text-sm" style="color: var(--text-muted);">Hilf uns, unsere Ratgeber noch besser zu machen, indem du teilst, was wirklich funktioniert.</p>
        </div>
        <div class="rounded-2xl p-6" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <div class="text-3xl mb-3">✨</div>
          <h3 class="text-sm font-bold mb-2" style="color: var(--text);">Für die Ewigkeit</h3>
          <p class="text-sm" style="color: var(--text-muted);">Deine Liebesgeschichte wird auf Herzblatt Journal verewigt und inspiriert kommende Generationen.</p>
        </div>
      </div>
    </section>

  </div>

  <style>
    .heart-pulse {
      animation: heartbeat 1.4s ease-in-out infinite;
    }
    @keyframes heartbeat {
      0%, 100% { transform: scale(1); }
      15% { transform: scale(1.25); }
      30% { transform: scale(1); }
      45% { transform: scale(1.2); }
      60% { transform: scale(1); }
    }
    input:focus, textarea:focus {
      outline: none;
      border-color: var(--color-primary-300) !important;
      box-shadow: 0 0 0 3px var(--color-primary-100);
    }
  </style>

  <script>
    document.getElementById('successStoryForm').addEventListener('submit', function(e) {
      e.preventDefault();

      const form = this;
      const successMessage = document.getElementById('successMessage');

      // Validate inputs
      const names = document.getElementById('firstName').value.trim();
      const email = document.getElementById('email').value.trim();
      const story = document.getElementById('story').value.trim();

      if (!names || !email || !story) {
        alert('Bitte alle Felder ausfüllen');
        return;
      }

      if (story.length < 100) {
        alert('Deine Geschichte sollte mindestens 100 Zeichen lang sein');
        return;
      }

      // Show success message and reset form
      form.style.display = 'none';
      successMessage.classList.remove('hidden');

      // Reset form after 3 seconds
      setTimeout(() => {
        form.reset();
        form.style.display = 'block';
        successMessage.classList.add('hidden');
      }, 5000);
    });
  </script>
</BaseLayout>
