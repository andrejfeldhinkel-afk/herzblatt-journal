---
export const prerender = false;

// Wenn bereits eingeloggt → direkt weiter zum Dashboard
import { verifySession, extractToken } from '../../lib/herzraum-auth';
const token = extractToken(Astro.request.headers.get('cookie'));
if (verifySession(token)) {
  return Astro.redirect('/herzraum');
}
---
<!DOCTYPE html>
<html lang="de" class="dark">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex, nofollow" />
  <title>Herzraum · Login</title>
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <link rel="preload" href="/fonts/dm-sans-latin.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/playfair-latin.woff2" as="font" type="font/woff2" crossorigin />
  <style>
    @font-face { font-family: 'DM Sans'; src: url('/fonts/dm-sans-latin.woff2') format('woff2'); font-display: swap; }
    @font-face { font-family: 'Playfair Display'; src: url('/fonts/playfair-latin.woff2') format('woff2'); font-display: swap; font-weight: 400 900; }
    :root {
      --hz-bg: #0f0f13;
      --hz-surface: #1a1a24;
      --hz-border: #2a2a3a;
      --hz-primary: #f43f5e;
      --hz-primary-dark: #e11d48;
      --hz-text: #e2e8f0;
      --hz-text-muted: #94a3b8;
      --hz-danger: #ef4444;
    }
    * { box-sizing: border-box; margin: 0; padding: 0; }
    html, body { height: 100%; }
    body {
      font-family: 'DM Sans', system-ui, -apple-system, sans-serif;
      background: radial-gradient(ellipse at top, #1a0e14 0%, var(--hz-bg) 60%);
      color: var(--hz-text);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 1rem;
      min-height: 100vh;
    }
    .card {
      background: var(--hz-surface);
      border: 1px solid var(--hz-border);
      border-radius: 1rem;
      padding: 2.5rem 2rem;
      width: 100%;
      max-width: 400px;
      box-shadow: 0 20px 60px rgba(244,63,94,0.08), 0 4px 12px rgba(0,0,0,0.25);
    }
    .logo {
      display: flex;
      flex-direction: column;
      align-items: center;
      gap: 0.75rem;
      margin-bottom: 2rem;
    }
    .logo-mark {
      width: 56px;
      height: 56px;
      border-radius: 50%;
      background: linear-gradient(135deg, #fb7185, var(--hz-primary));
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 28px;
    }
    .logo h1 {
      font-family: 'Playfair Display', Georgia, serif;
      font-size: 1.4rem;
      font-weight: 800;
      letter-spacing: -0.02em;
    }
    .logo p {
      font-size: 0.75rem;
      color: var(--hz-text-muted);
      text-transform: uppercase;
      letter-spacing: 0.2em;
    }
    label {
      display: block;
      font-size: 0.85rem;
      color: var(--hz-text-muted);
      margin-bottom: 0.5rem;
      font-weight: 500;
    }
    input[type="password"] {
      width: 100%;
      background: var(--hz-bg);
      border: 1px solid var(--hz-border);
      border-radius: 0.5rem;
      padding: 0.85rem 1rem;
      color: var(--hz-text);
      font-size: 1rem;
      font-family: inherit;
      outline: none;
      transition: border-color 0.15s;
    }
    input[type="password"]:focus {
      border-color: var(--hz-primary);
    }
    button {
      width: 100%;
      margin-top: 1.25rem;
      padding: 0.85rem;
      border: none;
      border-radius: 0.5rem;
      background: linear-gradient(135deg, var(--hz-primary), var(--hz-primary-dark));
      color: white;
      font-weight: 700;
      font-size: 1rem;
      font-family: inherit;
      cursor: pointer;
      transition: transform 0.1s, box-shadow 0.15s;
    }
    button:hover:not(:disabled) {
      transform: translateY(-1px);
      box-shadow: 0 8px 24px rgba(244,63,94,0.3);
    }
    button:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }
    .error {
      margin-top: 1rem;
      padding: 0.75rem 1rem;
      background: rgba(239,68,68,0.1);
      border: 1px solid rgba(239,68,68,0.3);
      border-radius: 0.5rem;
      color: var(--hz-danger);
      font-size: 0.85rem;
      display: none;
    }
    .error.show { display: block; }
    .footer {
      margin-top: 1.5rem;
      text-align: center;
      font-size: 0.75rem;
      color: var(--hz-text-muted);
    }
    .footer a {
      color: var(--hz-text-muted);
      text-decoration: none;
    }
    .footer a:hover { color: var(--hz-primary); }
  </style>
</head>
<body>
  <main class="card" role="main">
    <div class="logo">
      <div class="logo-mark">💕</div>
      <h1>Herzraum</h1>
      <p>Admin Dashboard</p>
    </div>

    <form id="login-form" novalidate>
      <label for="password">Passwort</label>
      <input type="password" id="password" name="password" required autocomplete="current-password" autofocus />
      <button type="submit" id="submit-btn">Anmelden</button>
      <div class="error" id="error-msg" role="alert" aria-live="polite"></div>
    </form>

    <div class="footer">
      <a href="/">← zurück zur Seite</a>
    </div>
  </main>

  <script is:inline>
    (function() {
      const form = document.getElementById('login-form');
      const pw = document.getElementById('password');
      const btn = document.getElementById('submit-btn');
      const err = document.getElementById('error-msg');

      function showError(msg) {
        err.textContent = msg;
        err.classList.add('show');
      }
      function hideError() { err.classList.remove('show'); }

      form.addEventListener('submit', async function(e) {
        e.preventDefault();
        hideError();
        if (!pw.value) { showError('Bitte Passwort eingeben.'); return; }
        btn.disabled = true;
        btn.textContent = 'Prüfe…';
        try {
          const res = await fetch('/api/herzraum/auth', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ password: pw.value }),
          });
          const data = await res.json();
          if (res.ok && data.ok) {
            window.location.href = data.redirect || '/herzraum';
            return;
          }
          showError(data.message || 'Anmeldung fehlgeschlagen.');
        } catch {
          showError('Verbindungsfehler.');
        } finally {
          btn.disabled = false;
          btn.textContent = 'Anmelden';
          pw.value = '';
          pw.focus();
        }
      });
    })();
  </script>
</body>
</html>
