---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => (b.data.date?.valueOf?.() || 0) - (a.data.date?.valueOf?.() || 0));

function getReadingTime(body: string) {
  const words = body.split(/\s+/).length;
  const minutes = Math.ceil(words / 200);
  return `${minutes} Min. Lesezeit`;
}

// Build tag counts
const tagCounts = new Map<string, number>();
posts.forEach(post => {
  (post.data.tags || []).forEach(tag => {
    tagCounts.set(tag, (tagCounts.get(tag) || 0) + 1);
  });
});
const topTags = [...tagCounts.entries()].sort((a, b) => b[1] - a[1]).slice(0, 8);

const categoryIcons: Record<string, string> = {
  'Dating-Tipps': '💡',
  'Online-Dating': '📱',
  'Beziehungen': '💑',
  'Flirten': '✨',
  'Psychologie': '🧠',
  'Ratgeber': '📖',
  'Date-Ideen': '🎯',
  'Erstes Date': '🦋',
  'Selbstbewusstsein': '💪',
  'Kommunikation': '💬',
  'Red-Flags': '🚩',
  'Selbstliebe': '💖',
  'Sicherheit': '🔒',
};

const POSTS_PER_PAGE = 24;
const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);
// Only send the first page + buffer to client for better performance
const postsToDisplay = posts;
---

<BaseLayout title="Dating-Ratgeber — Herzblatt Journal" description="Tipps und Ratgeber rund um Dating, Flirten und Beziehungen.">
  <section class="max-w-5xl mx-auto px-4 sm:px-6 py-16">

    <!-- Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-extrabold mb-2" style="color: var(--text); font-family: var(--font-serif);">Alle Ratgeber</h1>
      <p style="color: var(--text-muted);">
        {posts.length} Artikel rund um Dating, Liebe & Beziehungen
      </p>
    </div>

    <!-- Category Filter -->
    <div class="flex flex-wrap gap-2 mb-10" id="category-filters">
      <button
        class="filter-btn active px-4 py-2 rounded-full text-sm font-medium transition-all"
        data-tag="all"
      >
        Alle
      </button>
      {topTags.map(([tag, count]) => (
        <button
          class="filter-btn px-4 py-2 rounded-full text-sm font-medium transition-all"
          data-tag={tag}
        >
          <span class="mr-1">{categoryIcons[tag] || '♥'}</span>
          {tag}
          <span class="ml-1 opacity-50">{count}</span>
        </button>
      ))}
    </div>

    <!-- Posts Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4" id="posts-grid">
      {postsToDisplay.map((post, i) => (
        <div class="blog-post-item" data-tags={(post.data.tags || []).join(',')} data-index={i}>
          <BlogCard
            title={post.data.title}
            description={post.data.description}
            date={post.data.date}
            tags={post.data.tags}
            slug={post.id}
            readingTime={getReadingTime(post.body || '')}
            image={post.data.image}
            imageAlt={post.data.imageAlt}
          />
        </div>
      ))}
    </div>

    <!-- No results -->
    <div id="no-results" class="hidden text-center py-16">
      <p class="text-lg font-semibold mb-2" style="color: var(--text);">Keine Artikel gefunden</p>
      <p class="text-sm" style="color: var(--text-muted);">Versuche eine andere Kategorie</p>
    </div>

    <!-- Pagination -->
    <div id="pagination-wrapper" class="mt-16 mb-4">
      <div class="flex flex-col items-center gap-5">
        <nav id="pagination" class="flex items-center" aria-label="Seitennavigation">
        </nav>
        <p id="page-info" class="text-sm" style="color: var(--text-muted);"></p>
      </div>
    </div>

  </section>
</BaseLayout>

<style>
  .filter-btn {
    background: var(--bg-card);
    color: var(--text-muted);
    border: 1px solid var(--border);
    cursor: pointer;
  }
  .filter-btn:hover {
    border-color: var(--color-primary-300);
    color: var(--text);
  }
  .filter-btn.active {
    background: var(--color-primary-500);
    color: white;
    border-color: var(--color-primary-500);
  }
  .blog-post-item {
    transition: opacity 0.25s ease, transform 0.25s ease;
  }
  .blog-post-item.hidden-post {
    display: none;
  }
</style>


<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const POSTS_PER_PAGE = 24;
    const buttons = document.querySelectorAll('.filter-btn');
    const allPosts = document.querySelectorAll('.blog-post-item');
    const noResults = document.getElementById('no-results');
    const pagination = document.getElementById('pagination');
    const pageInfo = document.getElementById('page-info');

    let currentTag = 'all';
    let currentPage = 1;

    function getFilteredPosts() {
      return [...allPosts].filter(post => {
        if (currentTag === 'all') return true;
        const postTags = (post.getAttribute('data-tags') || '').split(',');
        return postTags.includes(currentTag);
      });
    }

    function render() {
      const filtered = getFilteredPosts();
      const totalPages = Math.ceil(filtered.length / POSTS_PER_PAGE);

      if (currentPage > totalPages) currentPage = totalPages || 1;

      const start = (currentPage - 1) * POSTS_PER_PAGE;
      const end = start + POSTS_PER_PAGE;
      const visible = new Set(filtered.slice(start, end));

      allPosts.forEach(post => {
        if (visible.has(post)) {
          post.classList.remove('hidden-post');
        } else {
          post.classList.add('hidden-post');
        }
      });

      // No results
      if (noResults) {
        noResults.classList.toggle('hidden', filtered.length > 0);
      }

      // Page info
      if (pageInfo && filtered.length > 0) {
        const showStart = start + 1;
        const showEnd = Math.min(end, filtered.length);
        pageInfo.textContent = `${showStart}–${showEnd} von ${filtered.length} Artikeln`;
      } else if (pageInfo) {
        pageInfo.textContent = '';
      }

      // Pagination buttons (inline styles to avoid CSS scoping issues)
      if (pagination) {
        pagination.innerHTML = '';
        pagination.style.cssText = 'display:flex;align-items:center;gap:4px;';
        if (totalPages <= 1) {
          if (pageInfo) pageInfo.style.display = 'none';
          pagination.style.display = 'none';
          return;
        }
        pagination.style.display = 'flex';
        if (pageInfo) pageInfo.style.display = '';

        const navStyle = 'display:inline-flex;align-items:center;gap:6px;padding:0 18px;height:40px;border-radius:10px;font-size:14px;font-weight:500;color:var(--text-muted);background:transparent;border:none;cursor:pointer;transition:all 0.2s ease;';
        const navDisabled = 'opacity:0.3;cursor:not-allowed;';
        const numStyle = 'display:inline-flex;align-items:center;justify-content:center;width:40px;height:40px;border-radius:50%;font-size:15px;font-weight:600;color:var(--text-muted);background:transparent;border:none;cursor:pointer;transition:all 0.2s ease;';
        const numActive = 'display:inline-flex;align-items:center;justify-content:center;width:40px;height:40px;border-radius:50%;font-size:15px;font-weight:700;color:white;background:var(--color-primary-500);border:none;cursor:pointer;box-shadow:0 2px 8px rgba(244,63,94,0.3);';
        const dotsStyle = 'display:inline-flex;align-items:center;justify-content:center;width:40px;height:40px;color:var(--text-muted);font-size:14px;letter-spacing:2px;user-select:none;';

        // Prev button
        const prevBtn = document.createElement('button');
        prevBtn.style.cssText = navStyle + (currentPage === 1 ? navDisabled : '');
        prevBtn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m15 18-6-6 6-6"/></svg> Zurück';
        prevBtn.disabled = currentPage === 1;
        if (!prevBtn.disabled) {
          prevBtn.onmouseover = function() { this.style.color = 'var(--color-primary-600)'; this.style.background = 'var(--color-primary-50)'; };
          prevBtn.onmouseout = function() { this.style.color = 'var(--text-muted)'; this.style.background = 'transparent'; };
        }
        prevBtn.addEventListener('click', () => { currentPage--; render(); scrollToTop(); });
        pagination.appendChild(prevBtn);

        // Spacer
        const spacerL = document.createElement('div');
        spacerL.style.width = '8px';
        pagination.appendChild(spacerL);

        // Page numbers with smart ellipsis
        const pages = [];
        if (totalPages <= 7) {
          for (let i = 1; i <= totalPages; i++) pages.push(i);
        } else {
          pages.push(1);
          if (currentPage > 3) pages.push('...');
          const rangeStart = Math.max(2, currentPage - 1);
          const rangeEnd = Math.min(totalPages - 1, currentPage + 1);
          for (let i = rangeStart; i <= rangeEnd; i++) pages.push(i);
          if (currentPage < totalPages - 2) pages.push('...');
          pages.push(totalPages);
        }

        pages.forEach(p => {
          if (p === '...') {
            const dots = document.createElement('span');
            dots.style.cssText = dotsStyle;
            dots.textContent = '···';
            pagination.appendChild(dots);
          } else {
            const btn = document.createElement('button');
            btn.style.cssText = p === currentPage ? numActive : numStyle;
            btn.textContent = String(p);
            if (p !== currentPage) {
              btn.onmouseover = function() { this.style.color = 'var(--text)'; this.style.background = 'var(--bg-soft)'; };
              btn.onmouseout = function() { this.style.color = 'var(--text-muted)'; this.style.background = 'transparent'; };
            }
            btn.addEventListener('click', () => { currentPage = p; render(); scrollToTop(); });
            pagination.appendChild(btn);
          }
        });

        // Spacer
        const spacerR = document.createElement('div');
        spacerR.style.width = '8px';
        pagination.appendChild(spacerR);

        // Next button
        const nextBtn = document.createElement('button');
        nextBtn.style.cssText = navStyle + (currentPage === totalPages ? navDisabled : '');
        nextBtn.innerHTML = 'Weiter <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 18 6-6-6-6"/></svg>';
        nextBtn.disabled = currentPage === totalPages;
        if (!nextBtn.disabled) {
          nextBtn.onmouseover = function() { this.style.color = 'var(--color-primary-600)'; this.style.background = 'var(--color-primary-50)'; };
          nextBtn.onmouseout = function() { this.style.color = 'var(--text-muted)'; this.style.background = 'transparent'; };
        }
        nextBtn.addEventListener('click', () => { currentPage++; render(); scrollToTop(); });
        pagination.appendChild(nextBtn);
      }
    }

    function scrollToTop() {
      document.getElementById('posts-grid')?.scrollIntoView({ behavior: 'smooth', block: 'start' });
    }

    // Filter buttons
    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        buttons.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        currentTag = btn.getAttribute('data-tag') || 'all';
        currentPage = 1;
        render();
      });
    });

    // Initial render
    render();
  });
</script>
