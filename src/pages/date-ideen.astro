---
import BaseLayout from '../layouts/BaseLayout.astro';
import BlogCard from '../components/BlogCard.astro';
import AppCTA from '../components/AppCTA.astro';
import { getCollection } from 'astro:content';

const title = 'Date-Ideen 2026: 100+ kreative Ideen für unvergessliche Dates';
const description = 'Die besten Date-Ideen für jede Situation: Erste Dates, Outdoor, Zuhause, romantisch, abenteuerlich oder günstig. Über 100 Ideen für Paare & Singles.';
const keywords = ['date ideen', 'date ideen zuhause', 'erstes date ideen', 'romantische date ideen', 'ausgefallene date ideen', 'date ideen winter', 'date ideen sommer'];

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .sort((a, b) => (b.data.date?.valueOf?.() || 0) - (a.data.date?.valueOf?.() || 0));

function getPostsByTags(tags: string[]) {
  const tagSet = new Set(tags.map(t => t.toLowerCase()));
  return allPosts
    .filter(p => p.data.tags.some((t: string) => tagSet.has(t.toLowerCase())))
    .slice(0, 6);
}

function getReadingTime(body: string) {
  return `${Math.ceil(body.split(/\s+/).length / 200)} Min. Lesezeit`;
}

const categories = [
  {
    id: 'erste-dates',
    emoji: '☕',
    title: 'Ideen fürs erste Date',
    description: 'Beim ersten Treffen zählt eine entspannte Atmosphäre. Diese Ideen sorgen für gute Gespräche ohne Druck.',
    tags: ['erstes date', 'kennenlernen', 'dating-tipps'],
    quickIdeas: ['Kaffee in einem gemütlichen Café', 'Spaziergang im Park', 'Street-Food-Markt besuchen', 'Eisdiele & Stadtbummel', 'Museum mit freiem Eintritt', 'Flohmarkt zusammen stöbern'],
  },
  {
    id: 'romantisch',
    emoji: '🌹',
    title: 'Romantische Date-Ideen',
    description: 'Wenn es kribbeln soll: Diese Dates schaffen eine besondere Atmosphäre für Verliebte.',
    tags: ['romantik', 'date-ideen', 'quality time'],
    quickIdeas: ['Sonnenuntergang am Wasser', 'Candle-Light-Dinner kochen', 'Sternegucken auf dem Land', 'Gondel- oder Bootsfahrt', 'Weinprobe zu zweit', 'Liebesbrief schreiben & vorlesen'],
  },
  {
    id: 'zuhause',
    emoji: '🏠',
    title: 'Date-Ideen für Zuhause',
    description: 'Kein Budget oder schlechtes Wetter? Kein Problem! Die besten Dates finden manchmal auf der Couch statt.',
    tags: ['quality time', 'alltag', 'date-ideen'],
    quickIdeas: ['Gemeinsam ein neues Rezept kochen', 'Film-Marathon mit Snacks', 'Brettspiel-Abend', 'Gemeinsam malen oder basteln', 'Spa-Abend mit Masken & Massage', 'Blind-Tasting Abend'],
  },
  {
    id: 'abenteuer',
    emoji: '🧗',
    title: 'Abenteuerliche & Aktive Dates',
    description: 'Gemeinsame Abenteuer schweißen zusammen. Diese Dates bringen Adrenalin und Endorphine.',
    tags: ['abenteuer', 'outdoor', 'date-ideen', 'aktivitäten'],
    quickIdeas: ['Kletterhalle oder Bouldern', 'Kanu oder SUP fahren', 'Escape Room zu zweit', 'Geocaching/Schnitzeljagd', 'Tanzkurs ausprobieren', 'Nachtwanderung mit Fackeln'],
  },
  {
    id: 'langzeitpaare',
    emoji: '💑',
    title: 'Für Langzeitpaare',
    description: 'Nach Jahren zusammen braucht es frische Impulse. Diese Ideen bringen den Funken zurück.',
    tags: ['langzeitbeziehung', 'beziehung', 'beziehungstipps'],
    quickIdeas: ['Erstes Date nachspielen', 'Bucket-List erstellen', 'Überraschungs-Date planen', 'Neues Hobby zusammen starten', 'Wochenend-Trip ohne Handy', 'Love-Letter-Challenge: 7 Tage, 7 Briefe'],
  },
  {
    id: 'kostenlos',
    emoji: '🆓',
    title: 'Kostenlose Date-Ideen',
    description: 'Die besten Dinge im Leben sind kostenlos — das gilt auch für Dates. Hier sind Ideen die nichts kosten.',
    tags: ['dating-tipps', 'date-ideen', 'kennenlernen'],
    quickIdeas: ['Picknick im Park (von Zuhause)', 'Fotowalk durch die Stadt', 'Bibliothek besuchen & vorlesen', 'Sonnenaufgang zusammen anschauen', 'Gemeinsam Yoga im Park', 'Stadtteile erkunden die ihr nicht kennt'],
  },
];

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Date-Ideen', url: '/date-ideen' },
];
---

<BaseLayout
  title={title}
  description={description}
  keywords={keywords}
  breadcrumbs={breadcrumbs}
  faq={[
    { question: 'Was sind gute Ideen für ein erstes Date?', answer: 'Die besten ersten Dates sind entspannt und ermöglichen echte Gespräche: ein Café, ein Spaziergang im Park, ein Street-Food-Markt oder ein Museum. Vermeide Kino (kein Gespräch möglich) und zu formelle Restaurants (zu viel Druck).' },
    { question: 'Welche Date-Ideen kosten nichts?', answer: 'Viele tolle Dates sind kostenlos: Picknick im Park, Fotospaziergang, Sonnenuntergang am Wasser, gemeinsames Kochen mit vorhandenen Zutaten, Sternegucken, Bibliotheksbesuch oder ein Stadtspaziergang durch neue Viertel.' },
    { question: 'Was kann man als Paar Zuhause machen?', answer: 'Zuhause-Dates können sehr kreativ sein: gemeinsam ein neues Rezept kochen, Blind-Tasting, Spieleabend, Spa-Abend mit Gesichtsmasken, gemeinsam malen, ein Fotobuch erstellen oder einen Themenabend gestalten (z.B. italienischer Abend mit Pasta und Film).' },
  ]}
>
  <!-- Hero -->
  <section class="relative overflow-hidden" style="background: linear-gradient(135deg, var(--color-primary-600), var(--color-primary-800));">
    <div class="max-w-4xl mx-auto px-4 sm:px-6 py-16 sm:py-24 text-center relative">
      <p class="text-xs font-bold uppercase tracking-widest mb-4" style="color: rgba(255,255,255,0.7);">Über 100 Ideen</p>
      <h1 class="text-3xl sm:text-5xl font-extrabold text-white mb-6" style="font-family: var(--font-serif); letter-spacing: -0.02em;">
        Date-Ideen für<br/>jede Situation
      </h1>
      <p class="text-lg max-w-2xl mx-auto" style="color: rgba(255,255,255,0.85);">
        Erstes Date, Regen-Date, Zuhause-Date oder Abenteuer — finde die perfekte Idee für euren nächsten Moment zu zweit.
      </p>
      <div class="flex flex-wrap justify-center gap-2 mt-10">
        {categories.map(c => (
          <a href={`#${c.id}`} class="inline-flex items-center gap-1.5 px-4 py-2 rounded-full text-sm font-medium transition-all hover:-translate-y-0.5" style="background: rgba(255,255,255,0.15); color: white;">
            <span>{c.emoji}</span> {c.title.split(' ').slice(-2).join(' ')}
          </a>
        ))}
      </div>
    </div>
  </section>

  <div class="max-w-5xl mx-auto px-4 sm:px-6 py-16">
    {categories.map((cat, idx) => {
      const posts = getPostsByTags(cat.tags);
      return (
        <section id={cat.id} class="mb-16 scroll-mt-24">
          <div class="flex items-start gap-4 mb-6">
            <div class="shrink-0 w-12 h-12 rounded-2xl flex items-center justify-center text-2xl" style="background: var(--color-primary-50); border: 1px solid var(--color-primary-100);">
              {cat.emoji}
            </div>
            <div>
              <h2 class="text-2xl font-extrabold mb-2" style="color: var(--text); font-family: var(--font-serif);">{cat.title}</h2>
              <p class="text-sm" style="color: var(--text-muted);">{cat.description}</p>
            </div>
          </div>

          <!-- Quick Ideas Grid -->
          <div class="grid grid-cols-2 sm:grid-cols-3 gap-3 mb-8">
            {cat.quickIdeas.map((idea, i) => (
              <div class="rounded-xl p-4 text-center transition-all hover:-translate-y-0.5" style="background: var(--bg-soft); border: 1px solid var(--border);">
                <p class="text-sm font-medium" style="color: var(--text);">{idea}</p>
              </div>
            ))}
          </div>

          <!-- Related Blog Posts -->
          {posts.length > 0 && (
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
              {posts.slice(0, 3).map(p => (
                <BlogCard
                  title={p.data.title}
                  description={p.data.description}
                  date={p.data.date}
                  tags={p.data.tags}
                  slug={p.id}
                  readingTime={getReadingTime(p.body || '')}
                  image={p.data.image}
                  imageAlt={p.data.imageAlt}
                />
              ))}
            </div>
          )}
          {idx < categories.length - 1 && <hr class="mt-12" style="border-color: var(--border);" />}
        </section>
      );
    })}

    <AppCTA variant="inline" />

    <!-- City Links -->
    <section class="mt-16 pt-10" style="border-top: 1px solid var(--border);">
      <h2 class="text-xl font-bold mb-4" style="color: var(--text); font-family: var(--font-serif);">Date-Spots in deiner Stadt</h2>
      <div class="flex flex-wrap gap-2">
        {['Berlin', 'München', 'Hamburg', 'Köln', 'Frankfurt', 'Stuttgart', 'Düsseldorf', 'Leipzig', 'Dresden', 'Nürnberg', 'Freiburg', 'Münster'].map(city => (
          <a href={`/dating-in/${city.toLowerCase().replace('ü', 'ue')}`} class="text-xs font-medium px-3 py-1.5 rounded-full transition-all hover:-translate-y-0.5" style="background: var(--bg-soft); color: var(--text-muted); border: 1px solid var(--border);">
            {city}
          </a>
        ))}
      </div>
    </section>
  </div>
</BaseLayout>
