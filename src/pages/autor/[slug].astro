---
import BaseLayout from '../../layouts/BaseLayout.astro';
import BlogCard from '../../components/BlogCard.astro';
import { getCollection } from 'astro:content';
import { authors, getAuthor, getAllAuthors } from '../../data/authors';

export function getStaticPaths() {
  return Object.values(authors).map(author => ({
    params: { slug: author.slug },
    props: { author },
  }));
}

const { author } = Astro.props;

const allPosts = (await getCollection('blog', ({ data }) => !data.draft))
  .filter(post => (post.data as any).author === author.slug || (!((post.data as any).author) && author.slug === 'redaktion'))
  .sort((a, b) => (b.data.date?.valueOf?.() || 0) - (a.data.date?.valueOf?.() || 0));

function getReadingTime(body: string) {
  return `${Math.ceil(body.split(/\s+/).length / 200)} Min. Lesezeit`;
}

const personSchema = {
  "@context": "https://schema.org",
  "@type": "Person",
  "name": author.name,
  "jobTitle": author.role,
  "description": author.bio,
  "image": `https://herzblatt-journal.com${author.image}`,
  "url": `https://herzblatt-journal.com/autor/${author.slug}`,
  "worksFor": {
    "@type": "Organization",
    "name": "Herzblatt Journal",
    "url": "https://herzblatt-journal.com"
  },
  ...((author as any).knowsAbout ? { "knowsAbout": (author as any).knowsAbout } : {}),
  ...((author as any).alumniOf ? {
    "alumniOf": {
      "@type": "EducationalOrganization",
      "name": (author as any).alumniOf
    }
  } : {}),
  ...((author as any).credentials ? { "hasCredential": (author as any).credentials } : {}),
  "knowsLanguage": "de"
};
---

<BaseLayout
  title={`${author.name} — ${author.role} | Herzblatt Journal`}
  description={author.shortBio}
>
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />

  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-12 sm:py-20">

    <!-- Author Header -->
    <div class="flex flex-col sm:flex-row items-center sm:items-start gap-6 mb-12">
      <img
        src={author.image}
        alt={author.name}
        class="w-28 h-28 rounded-full object-cover shadow-lg"
        style="border: 4px solid var(--color-primary-200);"
        loading="eager"
      />
      <div class="text-center sm:text-left">
        <h1 class="text-3xl sm:text-4xl font-bold mb-1" style="color: var(--text); font-family: var(--font-serif);">{author.name}</h1>
        <p class="text-sm font-semibold mb-3" style="color: var(--color-primary-600);">{author.role}</p>
        <p class="text-sm leading-relaxed max-w-xl" style="color: var(--text-muted);">{author.bio}</p>
        <div class="flex flex-wrap gap-2 mt-4 justify-center sm:justify-start">
          {author.expertise.map(tag => (
            <span class="text-xs px-2.5 py-1 rounded-full font-medium" style="background: var(--color-primary-50); color: var(--color-primary-700); border: 1px solid var(--color-primary-200);">{tag}</span>
          ))}
        </div>
      </div>
    </div>

    <!-- Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-3 gap-4 mb-10">
      <div class="rounded-xl p-4 text-center" style="background: var(--bg-soft); border: 1px solid var(--border);">
        <p class="text-2xl font-bold" style="color: var(--color-primary-600); font-family: var(--font-serif);">{allPosts.length}</p>
        <p class="text-xs font-medium mt-1" style="color: var(--text-muted);">Artikel veröffentlicht</p>
      </div>
      <div class="rounded-xl p-4 text-center" style="background: var(--bg-soft); border: 1px solid var(--border);">
        <p class="text-2xl font-bold" style="color: var(--color-primary-600); font-family: var(--font-serif);">{author.expertise.length}</p>
        <p class="text-xs font-medium mt-1" style="color: var(--text-muted);">Themengebiete</p>
      </div>
      {(author as any).yearsExperience && (
        <div class="rounded-xl p-4 text-center" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <p class="text-2xl font-bold" style="color: var(--color-primary-600); font-family: var(--font-serif);">{(author as any).yearsExperience}+</p>
          <p class="text-xs font-medium mt-1" style="color: var(--text-muted);">Jahre Erfahrung</p>
        </div>
      )}
    </div>

    {(author as any).credentials && (author as any).credentials.length > 0 && (
      <section class="mb-10 rounded-xl p-6" style="background: var(--bg-soft); border: 1px solid var(--border);">
        <h2 class="text-lg font-bold mb-4 flex items-center gap-2" style="color: var(--text); font-family: var(--font-serif);">
          <span style="color: var(--color-primary-600);">🎓</span>
          Qualifikationen & Credentials
        </h2>
        <ul class="space-y-2">
          {(author as any).credentials.map((c: string) => (
            <li class="flex items-start gap-2 text-sm" style="color: var(--text-muted);">
              <span style="color: var(--color-primary-600); flex-shrink: 0; line-height: 1.5;">✓</span>
              <span>{c}</span>
            </li>
          ))}
        </ul>
      </section>
    )}

    {(author as any).knowsAbout && (author as any).knowsAbout.length > 0 && (
      <section class="mb-10 rounded-xl p-6" style="background: var(--bg-soft); border: 1px solid var(--border);">
        <h2 class="text-lg font-bold mb-4 flex items-center gap-2" style="color: var(--text); font-family: var(--font-serif);">
          <span style="color: var(--color-primary-600);">📚</span>
          Fachliche Schwerpunkte
        </h2>
        <div class="flex flex-wrap gap-2">
          {(author as any).knowsAbout.map((k: string) => (
            <span class="text-xs px-3 py-1.5 rounded-full font-medium" style="background: var(--bg); color: var(--text); border: 1px solid var(--border);">{k}</span>
          ))}
        </div>
      </section>
    )}

    <!-- Articles -->
    <h2 class="text-2xl font-bold mb-6" style="color: var(--text); font-family: var(--font-serif);">Alle Artikel von {author.name}</h2>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
      {allPosts.map(post => (
        <BlogCard title={post.data.title} description={post.data.description} date={post.data.date} tags={post.data.tags} slug={post.id} image={post.data.image} imageAlt={post.data.imageAlt} />
      ))}
    </div>

  </section>
</BaseLayout>
