        btn.innerHTML = '<span class="answer-icon">' + a.icon + '</span><span class="answer-text">' + a.text + '</span>';
        btn.onclick = function() {
          userAnswers[currentQ] = a.type;
          currentQ++;
          if (currentQ >= quizQuestions.length) {
            showResults();
          } else {
            renderQ();
            updateProg();
            window.scrollTo({ top: 0, behavior: 'smooth' });
          }
        };
        grid.appendChild(btn);
      });
    }

