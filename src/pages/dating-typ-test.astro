---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Dating-Typ Test – Finde deinen Liebes-Persönlichkeitstyp';
const description = 'Entdecke deinen Dating-Persönlichkeitstyp mit unserem unterhaltsamen Quiz. 10 Fragen, 6 einzigartige Ergebnisse. Kostenlos!';
---

<BaseLayout title={title} description={description} keywords={['Dating Test', 'Persönlichkeitstyp', 'Dating Quiz', 'Liebes Quiz', 'Beziehungen']}>

  <!-- Schema.org Quiz -->
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Quiz",
    "name": title,
    "description": description,
    "url": "https://herzblatt-journal.com/dating-typ-test",
    "author": { "@type": "Organization", "name": "Herzblatt Journal" }
  })} />

  <section class="max-w-3xl mx-auto px-4 sm:px-6 py-12 sm:py-16">

    <!-- Header -->
    <div class="text-center mb-10">
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full text-xs font-bold uppercase tracking-wider mb-4" style="background: var(--color-primary-50); color: var(--color-primary-600); border: 1px solid var(--color-primary-100);">
        <span>💘</span> Persönlichkeitstest
      </div>
      <h1 class="text-3xl sm:text-4xl font-extrabold mb-3" style="color: var(--text); font-family: var(--font-serif); letter-spacing: -0.02em;">
        Welcher Dating-Typ bist du?
      </h1>
      <p class="text-base sm:text-lg" style="color: var(--text-muted);">
        10 Fragen — 6 einzigartige Ergebnisse. Finde heraus, wie du liebst.
      </p>
    </div>

    <!-- Quiz Container -->
    <div id="quizContainer">

      <!-- Progress -->
      <div class="mb-6">
        <div class="flex items-center justify-between mb-2">
          <span id="progressLabel" class="text-xs font-bold uppercase tracking-wider" style="color: var(--color-primary-500);">Frage 1 von 10</span>
          <span id="progressPct" class="text-xs font-semibold" style="color: var(--text-muted);">10%</span>
        </div>
        <div class="h-2 rounded-full overflow-hidden" style="background: var(--bg-soft); border: 1px solid var(--border);">
          <div id="progressFill" class="h-full rounded-full transition-all duration-500 ease-out" style="width: 10%; background: linear-gradient(90deg, var(--color-primary-500), var(--color-primary-600));"></div>
        </div>
      </div>

      <!-- Question Card -->
      <div id="questionCard" class="rounded-2xl p-6 sm:p-8" style="background: var(--bg-card); border: 1px solid var(--border); box-shadow: 0 4px 24px rgba(0,0,0,0.06);">
        <h2 id="questionText" class="text-xl sm:text-2xl font-bold mb-6" style="color: var(--text); font-family: var(--font-serif);"></h2>
        <div id="answersGrid" class="grid gap-3"></div>

        <!-- Navigation: nur Zurück-Button -->
        <div id="navBar" class="flex items-center mt-8 pt-6" style="border-top: 1px solid var(--border);">
          <button id="prevBtn" type="button" class="quiz-nav-btn inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-semibold transition-all" style="color: var(--text-muted); background: var(--bg-soft); border: 1px solid var(--border); cursor: pointer;">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m15 18-6-6 6-6"/></svg>
            Zurück
          </button>
        </div>
      </div>
    </div>

    <!-- Result Container (hidden initially) -->
    <div id="resultContainer" class="quiz-hidden">

      <!-- Ergebnis-Karte -->
      <div class="rounded-2xl overflow-hidden mb-8" style="background: var(--bg-card); border: 1px solid var(--border); box-shadow: 0 4px 24px rgba(0,0,0,0.06);">
        <div class="px-6 sm:px-8 pt-8 pb-6 text-center" style="background: linear-gradient(135deg, var(--color-primary-50), var(--color-surface-100));">
          <div id="resultEmoji" class="text-5xl mb-3"></div>
          <h2 id="resultType" class="text-2xl sm:text-3xl font-extrabold mb-1" style="color: var(--text); font-family: var(--font-serif); letter-spacing: -0.02em;"></h2>
          <p id="resultSubtitle" class="text-sm font-medium" style="color: var(--color-primary-600);"></p>
        </div>
        <div class="p-6 sm:p-8">
          <div class="rounded-xl p-5 mb-6" style="background: var(--bg-soft); border-left: 4px solid var(--color-primary-500);">
            <p id="resultDescription" class="text-sm sm:text-base leading-relaxed" style="color: var(--text-muted);"></p>
          </div>

          <!-- Share -->
          <div class="py-5" style="border-top: 1px solid var(--border);">
            <p class="text-xs font-bold uppercase tracking-wider mb-3" style="color: var(--text-muted);">Ergebnis teilen</p>
            <div class="flex flex-wrap gap-2">
              <button type="button" id="shareWA" class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-semibold text-white transition-all hover:opacity-90" style="background: #25d366; border: none; cursor: pointer;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
                WhatsApp
              </button>
              <button type="button" id="shareFB" class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-semibold text-white transition-all hover:opacity-90" style="background: #1877f2; border: none; cursor: pointer;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
                Facebook
              </button>
              <button type="button" id="copyBtn" class="inline-flex items-center gap-2 px-4 py-2 rounded-full text-sm font-semibold transition-all" style="background: var(--bg-soft); color: var(--text); border: 1px solid var(--border); cursor: pointer;">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect width="14" height="14" x="8" y="8" rx="2"/><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"/></svg>
                Link kopieren
              </button>
            </div>
          </div>
        </div>
      </div>

      <!-- Dating-Seiten Empfehlungen -->
      <div class="mb-8">
        <div class="text-center mb-6">
          <h3 class="text-xl sm:text-2xl font-extrabold mb-2" style="color: var(--text); font-family: var(--font-serif);">Bereit, deinen Match zu finden?</h3>
          <p class="text-sm" style="color: var(--text-muted);">Diese Dating-Seiten passen zu deinem Typ — jetzt kostenlos ausprobieren</p>
        </div>

        <!-- Alle Seiten werden per JS generiert -->
        <div id="sitesContainer"></div>
      </div>

      <!-- Restart + Links -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-3">
        <button type="button" id="restartBtn" class="inline-flex items-center justify-center gap-2 px-6 py-3 rounded-full text-sm font-bold transition-all hover:opacity-90" style="background: var(--bg-soft); color: var(--text); border: 1px solid var(--border); cursor: pointer;">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8"/><path d="M3 3v5h5"/></svg>
          Test wiederholen
        </button>
        <a href="/blog" class="inline-flex items-center gap-1.5 px-5 py-3 rounded-full text-sm font-semibold transition-all hover:-translate-y-0.5" style="color: var(--color-primary-600); background: var(--color-primary-50); border: 1px solid var(--color-primary-100); text-decoration: none;">Alle Ratgeber</a>
        <a href="/top-dating-seiten" class="inline-flex items-center gap-1.5 px-5 py-3 rounded-full text-sm font-semibold transition-all hover:-translate-y-0.5" style="color: var(--color-primary-600); background: var(--color-primary-50); border: 1px solid var(--color-primary-100); text-decoration: none;">Alle Dating-Seiten</a>
      </div>
    </div>

    <!-- FAQ Section -->
    <div class="mt-12 space-y-4">
      <h2 class="text-lg font-bold" style="color: var(--text); font-family: var(--font-serif);">Häufige Fragen</h2>
      <div class="rounded-xl p-5" style="background: var(--bg-card); border: 1px solid var(--border);">
        <p class="font-semibold text-sm mb-1" style="color: var(--text);">Was sind die 6 Dating-Typen?</p>
        <p class="text-sm" style="color: var(--text-muted);">Der Romantiker, Der Abenteurer, Der Analytiker, Der Soziale Schmetterling, Der Tiefgründige und Der Unabhängige.</p>
      </div>
      <div class="rounded-xl p-5" style="background: var(--bg-card); border: 1px solid var(--border);">
        <p class="font-semibold text-sm mb-1" style="color: var(--text);">Ist der Test kostenlos?</p>
        <p class="text-sm" style="color: var(--text-muted);">Ja, der Dating-Typ Test ist komplett kostenlos und du erhältst sofort dein Ergebnis.</p>
      </div>
      <div class="rounded-xl p-5" style="background: var(--bg-card); border: 1px solid var(--border);">
        <p class="font-semibold text-sm mb-1" style="color: var(--text);">Kann ich mein Ergebnis teilen?</p>
        <p class="text-sm" style="color: var(--text-muted);">Ja! Nach Abschluss des Tests kannst du dein Ergebnis über WhatsApp, Facebook teilen oder den Link kopieren.</p>
      </div>
    </div>

  </section>

  <script is:inline>
  (function() {

    /* ============ DATA ============ */

    var datingTypes = {
      'romantiker': { name: 'Der Romantiker', subtitle: 'Sucht die große Liebe', emoji: '💕', description: 'Du glaubst an wahre Liebe und suchst eine tiefe, bedeutungsvolle Beziehung. Für dich zählen emotionale Verbindungen und gemeinsame Träume. Du bist ein Träumer mit einem goldenen Herzen, der bereit ist, alles für die richtige Person zu geben.', bestSite: 'xloves' },
      'abenteurer': { name: 'Der Abenteurer', subtitle: 'Liebt spontane Dates & neue Erfahrungen', emoji: '🚀', description: 'Langweile ist nicht dein Ding! Du liebst spontane Pläne, Überraschungen und neue Erlebnisse. Für dich ist das Dating selbst das Abenteuer — die Reise ist wichtiger als das Ziel. Dein idealer Partner muss flexibel und aufgeschlossen sein.', bestSite: 'onlydates69' },
      'analytiker': { name: 'Der Analytiker', subtitle: 'Geht Dating strategisch an', emoji: '🧠', description: 'Du nimmst das Dating ernst und gehst es mit Kopf vor Herz an. Du analysierst Kompatibilität und suchst nach logischen Gründen, warum eine Beziehung funktioniert. Du glaubst an Planung und Authentizität — keine Spielchen, nur ehrliche Kommunikation.', bestSite: 'michverlieben' },
      'schmetterling': { name: 'Der Soziale Schmetterling', subtitle: 'Liebt Netzwerken & Gruppenaktivitäten', emoji: '🦋', description: 'Du lebst für soziale Verbindungen und große Gruppen. Dein ideales Date ist ein Event mit Freunden, eine Party oder ein gemeinsamer Ausflug. Du brauchst jemanden, der deine Leidenschaft für Menschen und soziale Abenteuer teilt.', bestSite: 'whatsmeet' },
      'tiefgruendig': { name: 'Der Tiefgründige', subtitle: 'Sucht emotionale Verbindung', emoji: '🌙', description: 'Oberflächlichkeit ist nicht dein Ding. Du suchst nach jemandem, mit dem du lange Nächte über Träume, Philosophie und das Leben sprechen kannst. Du brauchst jemanden, der dein tiefes Inneres versteht und schätzt.', bestSite: 'michverlieben' },
      'unabhaengig': { name: 'Der Unabhängige', subtitle: 'Braucht viel Freiraum in Beziehungen', emoji: '🦅', description: 'Du schätzt deine Unabhängigkeit über alles. Eine Beziehung muss dir Raum für deine eigenen Ziele, Hobbys und Freundeskreis geben. Für dich ist ein Partner jemand, der dich ergänzt, nicht dich komplett macht.', bestSite: 'singles69' }
    };

    var datingSites = {
      xloves:        { name: 'xLoves',         url: 'https://xloves.com/?campaign_id=2f2006d0', logo: '/images/logos/xloves-logo.png',         rating: 4.8, desc: 'Moderne Dating-Plattform für echte Verbindungen — diskret, sicher und mit starker Community.',       color: '#f43f5e', tag: 'Beliebteste Wahl' },
      whatsmeet:     { name: 'WhatsMeet',       url: 'https://whatsmeet.com',                    logo: '/images/logos/whatsmeet-logo.png',       rating: 4.3, desc: 'Chat-basiertes Dating mit Fokus auf echte Gespräche statt oberflächliches Swipen.',              color: '#22c55e', tag: 'Für Kommunikative' },
      michverlieben: { name: 'MichVerlieben',   url: 'https://michverlieben.com',                logo: '/images/logos/michverlieben-logo.png',   rating: 4.1, desc: 'Deutsche Plattform mit Fokus auf ernsthafte Beziehungen und Persönlichkeitsmatching.',           color: '#ef4444', tag: 'Für Ernsthafte' },
      onlydates69:   { name: 'OnlyDates69',     url: 'https://onlydates69.com',                  logo: '/images/logos/onlydates69-logo.png',     rating: 3.8, desc: 'Unkompliziertes Dating für spontane Treffen und zwanglose Verabredungen.',                       color: '#3b82f6', tag: 'Für Spontane' },
      singles69:     { name: 'Single69',        url: 'https://single69.de',                      logo: '/images/logos/singles69-logo.png',       rating: 3.6, desc: 'Casual-Dating mit großer Nutzerbasis und schnellem Matching-System.',                            color: '#8b5cf6', tag: 'Große Community' },
      sex69:         { name: 'Sex69',            url: 'https://sex69.de/',                        logo: '/images/logos/sex69-logo.jpg',           rating: 3.5, desc: 'Erwachsenen-Dating-Plattform für offene und abenteuerlustige Singles.',                          color: '#f43f5e', tag: 'Für Abenteurer' }
    };

    var quizQuestions = [
      { id: 1, question: 'Dein perfektes erstes Date wäre...', answers: [
        { text: 'Romantisches Candle-Light-Dinner mit echten Gesprächen', type: 'romantiker', icon: '🕯️' },
        { text: 'Spontan etwas Abenteuerliches wie Klettern oder Wandern', type: 'abenteurer', icon: '🧗' },
        { text: 'Ein Kaffee, um Kompatibilität zu testen', type: 'analytiker', icon: '☕' },
        { text: 'Gruppendate oder Event mit gemeinsamen Freunden', type: 'schmetterling', icon: '🎉' }
      ]},
      { id: 2, question: 'Was ist dir bei einem Partner am wichtigsten?', answers: [
        { text: 'Tiefe, Verständnis und emotionale Verbindung', type: 'tiefgruendig', icon: '💎' },
        { text: 'Gemeinsame Träume und Lebensziele', type: 'romantiker', icon: '🌟' },
        { text: 'Spaß, Spontaneität und gemeinsame Abenteuer', type: 'abenteurer', icon: '🎢' },
        { text: 'Respekt für meine Unabhängigkeit und Freiräume', type: 'unabhaengig', icon: '🦅' }
      ]},
      { id: 3, question: 'Wie reagierst du, wenn dir jemand gefällt?', answers: [
        { text: 'Ich träume von einer Zukunft zusammen', type: 'romantiker', icon: '💭' },
        { text: 'Ich versuche herauszufinden, ob wir kompatibel sind', type: 'analytiker', icon: '🔍' },
        { text: 'Ich werde nervös, aber verschaffe mir Zeit für mich', type: 'unabhaengig', icon: '🧘' },
        { text: 'Ich lade sie zu etwas Spannendem ein', type: 'abenteurer', icon: '🎯' }
      ]},
      { id: 4, question: 'In deiner Freizeit liebst du es...', answers: [
        { text: 'Neue Orte zu erkunden und Abenteuer zu erleben', type: 'abenteurer', icon: '🗺️' },
        { text: 'Mit Freunden Zeit zu verbringen oder neue Leute treffen', type: 'schmetterling', icon: '👥' },
        { text: 'Zeit allein zu verbringen und meine Hobbys genießen', type: 'unabhaengig', icon: '🎨' },
        { text: 'Tiefe Gespräche über Bedeutungsvolles zu führen', type: 'tiefgruendig', icon: '📚' }
      ]},
      { id: 5, question: 'Deine ideale Beziehung ist...', answers: [
        { text: 'Ein Märchen — zwei Menschen, eine große Liebe', type: 'romantiker', icon: '👑' },
        { text: 'Gleichberechtigt, basierend auf Respekt', type: 'analytiker', icon: '⚖️' },
        { text: 'Voller Leidenschaft und emotionaler Tiefe', type: 'tiefgruendig', icon: '🔥' },
        { text: 'Mit viel Raum für individuelle Freiheit', type: 'unabhaengig', icon: '🌊' }
      ]},
      { id: 6, question: 'Was stößt dich beim Dating ab?', answers: [
        { text: 'Mangelnde Authentizität oder Spielchen', type: 'analytiker', icon: '🎭' },
        { text: 'Zu viel Nähe und Abhängigkeit', type: 'unabhaengig', icon: '🔗' },
        { text: 'Oberflächliche oder unauthentische Verbindungen', type: 'tiefgruendig', icon: '💤' },
        { text: 'Zu vorhersehbar und langweilig', type: 'abenteurer', icon: '⏰' }
      ]},
      { id: 7, question: 'Dein perfektes Wochenende?', answers: [
        { text: 'Spontaner Trip mit meinem Partner in die Natur', type: 'abenteurer', icon: '⛰️' },
        { text: 'Großes Treffen mit Freunden, Parties oder Events', type: 'schmetterling', icon: '🎊' },
        { text: 'Gemütlich mit Partner — Netflix, Gespräche, Nähe', type: 'romantiker', icon: '🛋️' },
        { text: 'Zeit allein mit meinen Leidenschaften und Hobbys', type: 'unabhaengig', icon: '🎸' }
      ]},
      { id: 8, question: 'Deine Dating-Strategie?', answers: [
        { text: 'Ich folge meinem Bauch und meinem Herzen', type: 'romantiker', icon: '❤️' },
        { text: 'Offen für Überraschungen und neue Möglichkeiten', type: 'abenteurer', icon: '✨' },
        { text: 'Ich bewerte Kompatibilität systematisch', type: 'analytiker', icon: '📊' },
        { text: 'Partner durch soziale Gruppen kennenlernen', type: 'schmetterling', icon: '🤝' }
      ]},
      { id: 9, question: 'Wie gehst du mit Konflikten um?', answers: [
        { text: 'Durch tiefe Gespräche und Verständnis', type: 'tiefgruendig', icon: '🗣️' },
        { text: 'Brauche Raum für mich, bevor ich diskutiere', type: 'unabhaengig', icon: '🌿' },
        { text: 'Rational analysieren und lösen', type: 'analytiker', icon: '🧩' },
        { text: 'Ablenken mit Abenteuer oder Spaß', type: 'abenteurer', icon: '🎪' }
      ]},
      { id: 10, question: 'Dein Lieblingsaspekt beim Dating?', answers: [
        { text: 'Aufregende neue Erfahrungen und Abenteuer', type: 'abenteurer', icon: '🌈' },
        { text: 'Tiefgreifende Gespräche und emotionale Nähe', type: 'tiefgruendig', icon: '🌌' },
        { text: 'Die Hoffnung auf wahre Liebe', type: 'romantiker', icon: '💘' },
        { text: 'Mein soziales Netzwerk erweitern', type: 'schmetterling', icon: '🌐' }
      ]}
    ];


    /* ============ STATE ============ */

    var currentQ = 0;
    var userAnswers = {};


    /* ============ HELPERS ============ */

    function renderStars(rating, white) {
      var full = Math.floor(rating);
      var half = rating % 1 >= 0.3;
      var empty = 5 - full - (half ? 1 : 0);
      var fillColor = white ? '#fff' : '#f43f5e';
      var emptyColor = white ? 'rgba(255,255,255,0.35)' : '#d1d5db';
      var stars = '';
      for (var i = 0; i < full; i++) stars += '<span style="color:' + fillColor + '">&#9733;</span>';
      if (half) stars += '<span style="color:' + fillColor + ';opacity:0.5">&#9733;</span>';
      for (var j = 0; j < empty; j++) stars += '<span style="color:' + emptyColor + '">&#9733;</span>';
      return stars;
    }


    /* ============ QUIZ LOGIC ============ */

    function initTest() {
      renderQ();
      updateProg();
    }

    function renderQ() {
      var q = quizQuestions[currentQ];
      document.getElementById('questionText').textContent = q.question;
      var grid = document.getElementById('answersGrid');
      grid.innerHTML = '';

      q.answers.forEach(function(ans) {
        var btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'quiz-answer-btn';
        if (userAnswers[currentQ] === ans.type) btn.classList.add('selected');

        btn.innerHTML =
          '<span class="quiz-answer-radio"><span class="quiz-answer-radio-dot"></span></span>' +
          '<span class="quiz-answer-icon">' + ans.icon + '</span>' +
          '<span class="quiz-answer-text">' + ans.text + '</span>' +
          '<span class="quiz-answer-arrow"><svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 18 6-6-6-6"/></svg></span>';

        btn.addEventListener('click', function(e) {
          e.preventDefault();
          e.stopPropagation();
          selectA(ans.type, btn);
        });
        grid.appendChild(btn);
      });

      updateBtns();
    }

    function selectA(type, el) {
      userAnswers[currentQ] = type;
      var all = document.querySelectorAll('.quiz-answer-btn');
      for (var i = 0; i < all.length; i++) all[i].classList.remove('selected');
      el.classList.add('selected');
      updateBtns();

      // Auto-advance nach kurzer Pause
      setTimeout(function() {
        if (currentQ < quizQuestions.length - 1) {
          currentQ++;
          renderQ();
          updateProg();
        } else {
          showResults();
        }
      }, 400);
    }

    function updateBtns() {
      document.getElementById('prevBtn').style.visibility = currentQ === 0 ? 'hidden' : 'visible';
    }

    function updateProg() {
      var pct = Math.round(((currentQ + 1) / quizQuestions.length) * 100);
      document.getElementById('progressFill').style.width = pct + '%';
      document.getElementById('progressLabel').textContent = 'Frage ' + (currentQ + 1) + ' von ' + quizQuestions.length;
      document.getElementById('progressPct').textContent = pct + '%';
    }

    function previousQuestion() {
      if (currentQ > 0) {
        currentQ--;
        renderQ();
        updateProg();
      }
    }

    function showResults() {
      // Ergebnis berechnen
      var counts = {};
      for (var key in userAnswers) {
        var t = userAnswers[key];
        counts[t] = (counts[t] || 0) + 1;
      }
      var winner = Object.keys(counts).reduce(function(a, b) { return counts[a] > counts[b] ? a : b; });
      var result = datingTypes[winner];

      // Ergebnis anzeigen
      document.getElementById('resultEmoji').textContent = result.emoji;
      document.getElementById('resultType').textContent = result.name;
      document.getElementById('resultSubtitle').textContent = result.subtitle;
      document.getElementById('resultDescription').textContent = result.description;

      // Dating-Seiten rendern
      var topKey = result.bestSite;
      var container = document.getElementById('sitesContainer');
      var html = '';

      // Top-Empfehlung
      var top = datingSites[topKey];
      html += '<a href="' + top.url + '" target="_blank" rel="noopener" style="display:block;padding:1.5rem;border-radius:1rem;background:linear-gradient(135deg,var(--color-primary-500),var(--color-primary-700));color:#fff;text-decoration:none;margin-bottom:0.75rem;position:relative;box-shadow:0 8px 32px rgba(244,63,94,0.25);">';
      html += '<span style="position:absolute;top:0.75rem;right:0.75rem;padding:0.25rem 0.75rem;border-radius:999px;font-size:0.7rem;font-weight:700;background:rgba(255,255,255,0.2);backdrop-filter:blur(10px);">Top-Empfehlung</span>';
      html += '<div style="display:flex;align-items:center;gap:1rem;margin-bottom:0.75rem;">';
      html += '<div style="width:52px;height:52px;border-radius:0.75rem;background:#1a1a2e;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><img src="' + top.logo + '" alt="' + top.name + '" style="height:28px;width:auto;object-fit:contain;" /></div>';
      html += '<div><div style="font-size:1.15rem;font-weight:800;">' + top.name + '</div>';
      html += '<div style="display:flex;align-items:center;gap:0.4rem;"><span style="font-size:0.85rem;font-weight:600;color:rgba(255,255,255,0.9);">' + top.rating + '/5</span><span style="font-size:0.85rem;letter-spacing:1px;">' + renderStars(top.rating, true) + '</span></div>';
      html += '</div></div>';
      html += '<p style="font-size:0.875rem;color:rgba(255,255,255,0.85);line-height:1.6;margin-bottom:1rem;">' + top.desc + '</p>';
      html += '<span style="display:inline-flex;align-items:center;gap:0.5rem;padding:0.7rem 1.5rem;border-radius:999px;background:#fff;color:var(--color-primary-600);font-size:0.875rem;font-weight:700;">Kostenlos registrieren &rarr;</span>';
      html += '</a>';

      // Restliche Seiten
      html += '<div style="display:grid;grid-template-columns:1fr;gap:0.5rem;">';
      var siteOrder = ['xloves', 'whatsmeet', 'michverlieben', 'onlydates69', 'singles69', 'sex69'];
      siteOrder.forEach(function(sKey) {
        if (sKey === topKey) return;
        var s = datingSites[sKey];
        html += '<a href="' + s.url + '" target="_blank" rel="noopener" style="display:flex;align-items:center;gap:1rem;padding:1rem 1.25rem;border-radius:0.875rem;border:1px solid var(--border);background:var(--bg-card);text-decoration:none;color:var(--text);transition:all 0.2s;" onmouseover="this.style.borderColor=\'var(--color-primary-300)\';this.style.boxShadow=\'0 4px 16px rgba(244,63,94,0.08)\'" onmouseout="this.style.borderColor=\'var(--border)\';this.style.boxShadow=\'none\'">';
        html += '<div style="width:42px;height:42px;border-radius:0.625rem;background:#1a1a2e;border:1px solid #2a2a3e;display:flex;align-items:center;justify-content:center;flex-shrink:0;"><img src="' + s.logo + '" alt="' + s.name + '" style="height:22px;width:auto;object-fit:contain;" /></div>';
        html += '<div style="flex:1;min-width:0;">';
        html += '<div style="display:flex;align-items:center;gap:0.5rem;flex-wrap:wrap;">';
        html += '<span style="font-size:0.95rem;font-weight:700;">' + s.name + '</span>';
        html += '<span style="font-size:0.6rem;font-weight:700;text-transform:uppercase;letter-spacing:0.03em;color:var(--color-primary-600);background:var(--color-primary-50);padding:0.15rem 0.4rem;border-radius:0.25rem;">' + s.tag + '</span>';
        html += '</div>';
        html += '<div style="display:flex;align-items:center;gap:0.35rem;margin-top:0.15rem;">';
        html += '<span style="font-size:0.8rem;font-weight:600;color:var(--color-primary-600);">' + s.rating + '</span>';
        html += '<span style="font-size:0.75rem;letter-spacing:1px;">' + renderStars(s.rating, false) + '</span>';
        html += '</div>';
        html += '</div>';
        html += '<span style="flex-shrink:0;font-size:0.75rem;font-weight:700;color:var(--color-primary-600);white-space:nowrap;">Testen &rarr;</span>';
        html += '</a>';
      });
      html += '</div>';

      container.innerHTML = html;

      // Toggle sichtbarkeit
      document.getElementById('quizContainer').classList.add('quiz-hidden');
      document.getElementById('resultContainer').classList.remove('quiz-hidden');
      window.scrollTo({ top: 0, behavior: 'smooth' });

      window._quizResult = winner;
    }


    /* ============ SHARE ============ */

    function shareWhatsApp() {
      var r = datingTypes[window._quizResult];
      var text = 'Ich bin "' + r.name + '" im Dating-Typ Test! ' + r.emoji + ' Finde heraus, welcher Typ du bist: https://herzblatt-journal.com/dating-typ-test';
      window.open('https://wa.me/?text=' + encodeURIComponent(text));
    }

    function shareFacebook() {
      window.open('https://www.facebook.com/sharer/sharer.php?u=' + encodeURIComponent('https://herzblatt-journal.com/dating-typ-test'));
    }

    function copyLink() {
      var url = window.location.origin + '/dating-typ-test';
      navigator.clipboard.writeText(url).then(function() {
        var btn = document.getElementById('copyBtn');
        var orig = btn.innerHTML;
        btn.innerHTML = '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="m9 12 2 2 4-4"/></svg> Kopiert!';
        setTimeout(function() { btn.innerHTML = orig; }, 2000);
      });
    }

    function restartTest() {
      currentQ = 0;
      userAnswers = {};
      document.getElementById('resultContainer').classList.add('quiz-hidden');
      document.getElementById('quizContainer').classList.remove('quiz-hidden');
      initTest();
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }


    /* ============ EVENT LISTENERS ============ */

    document.addEventListener('DOMContentLoaded', function() {
      initTest();

      document.getElementById('prevBtn').addEventListener('click', function(e) {
        e.preventDefault();
        previousQuestion();
      });

      document.getElementById('restartBtn').addEventListener('click', function(e) {
        e.preventDefault();
        restartTest();
      });

      document.getElementById('shareWA').addEventListener('click', function(e) {
        e.preventDefault();
        shareWhatsApp();
      });

      document.getElementById('shareFB').addEventListener('click', function(e) {
        e.preventDefault();
        shareFacebook();
      });

      document.getElementById('copyBtn').addEventListener('click', function(e) {
        e.preventDefault();
        copyLink();
      });
    });

  })();
  </script>

  <style is:global>
    /* ====== Antwort-Buttons ====== */
    .quiz-answer-btn {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      width: 100%;
      padding: 1rem 1.25rem;
      border-radius: 0.875rem;
      border: 2px solid #c5c5d0;
      background: #ffffff;
      cursor: pointer;
      transition: all 0.2s ease;
      text-align: left;
      font-size: 0.95rem;
      color: #1a1a2e;
      font-family: inherit;
      line-height: 1.4;
      position: relative;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08), 0 1px 4px rgba(0, 0, 0, 0.05);
    }

    .dark .quiz-answer-btn {
      background: rgba(255, 255, 255, 0.08);
      border-color: rgba(255, 255, 255, 0.2);
      color: #e5e5e5;
      box-shadow: 0 2px 8px rgba(0, 0, 0, 0.25);
    }

    .quiz-answer-btn:hover {
      border-color: #f43f5e;
      background: #fff1f2;
      box-shadow: 0 4px 16px rgba(244, 63, 94, 0.18), 0 2px 6px rgba(0, 0, 0, 0.06);
      transform: translateY(-1px);
    }

    .dark .quiz-answer-btn:hover {
      background: rgba(244, 63, 94, 0.12);
      border-color: #fb7185;
    }

    .quiz-answer-btn.selected {
      border-color: #f43f5e;
      background: #fff1f2;
      box-shadow: 0 0 0 3px rgba(244, 63, 94, 0.18), 0 2px 8px rgba(244, 63, 94, 0.12);
    }

    .dark .quiz-answer-btn.selected {
      background: rgba(244, 63, 94, 0.15);
      border-color: #fb7185;
    }

    /* Radio-Kreis */
    .quiz-answer-radio {
      display: flex;
      align-items: center;
      justify-content: center;
      width: 22px;
      height: 22px;
      border-radius: 50%;
      border: 2px solid #a0a0af;
      flex-shrink: 0;
      transition: all 0.2s ease;
    }

    .dark .quiz-answer-radio {
      border-color: rgba(255, 255, 255, 0.35);
    }

    .quiz-answer-radio-dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: transparent;
      transition: all 0.2s ease;
    }

    .quiz-answer-btn:hover .quiz-answer-radio {
      border-color: #fb7185;
    }

    .quiz-answer-btn.selected .quiz-answer-radio {
      border-color: #f43f5e;
      background: #fff1f2;
    }

    .quiz-answer-btn.selected .quiz-answer-radio-dot {
      background: #f43f5e;
    }

    .quiz-answer-icon {
      font-size: 1.3rem;
      flex-shrink: 0;
      width: 1.8rem;
      text-align: center;
    }

    .quiz-answer-text {
      flex: 1;
    }

    .quiz-answer-arrow {
      flex-shrink: 0;
      color: #999;
      opacity: 0;
      transition: all 0.2s ease;
      transform: translateX(-4px);
    }

    .quiz-answer-btn:hover .quiz-answer-arrow {
      opacity: 1;
      transform: translateX(0);
      color: #f43f5e;
    }

    /* ====== Sichtbarkeit ====== */
    .quiz-hidden {
      display: none !important;
    }

    /* ====== Nav Buttons ====== */
    .quiz-nav-btn:hover {
      opacity: 0.85;
    }

    /* ====== Mobile ====== */
    @media (max-width: 640px) {
      .quiz-answer-btn {
        padding: 0.85rem 1rem;
        font-size: 0.88rem;
      }
      .quiz-answer-icon {
        font-size: 1.1rem;
        width: 1.5rem;
      }
      .quiz-answer-radio {
        width: 20px;
        height: 20px;
      }
      .quiz-answer-radio-dot {
        width: 8px;
        height: 8px;
      }
    }
  </style>

</BaseLayout>
