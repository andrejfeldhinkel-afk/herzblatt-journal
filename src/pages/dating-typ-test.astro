    function renderStars(rating, white) {
      var html = '';
      var full = Math.floor(rating);
      var half = rating % 1 >= 0.3;
      var fillColor = white ? '#fff' : '#f43f5e';
      var emptyColor = white ? 'rgba(255,255,255,0.3)' : 'var(--border)';
      for (var i = 0; i < full; i++) html += '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="' + fillColor + '" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>';
      if (half) html += '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="none"><defs><linearGradient id="sh' + (white?'w':'c') + '"><stop offset="50%" stop-color="' + fillColor + '"/><stop offset="50%" stop-color="' + emptyColor + '"/></linearGradient></defs><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="url(#sh' + (white?'w':'c') + ')"/></svg>';
      var empty = 5 - full - (half ? 1 : 0);
      for (var j = 0; j < empty; j++) html += '<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="' + emptyColor + '" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>';
      return html;
    }

    function renderQ() {
