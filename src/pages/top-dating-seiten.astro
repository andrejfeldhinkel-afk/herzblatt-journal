// Sort sites by click performance (most clicks first)
// Each site gets a slug key for tracking
function getSiteKey(name: string) {
  return name.toLowerCase().replace(/\s+/g, '');
}

const datingSites = [...allSites].sort((a, b) => {
  const clicksA = clickData[getSiteKey(a.name)] || 0;
  const clicksB = clickData[getSiteKey(b.name)] || 0;
  // Sort by clicks desc; if equal, keep original order (by rating)
  if (clicksB !== clicksA) return clicksB - clicksA;
  return b.rating - a.rating;
});

const faqItems = [
  {
    question: 'Welche Dating-Seite ist wirklich kostenlos?',
    answer: 'Alle getesteten Plattformen bieten eine kostenlose Basisversion an. xLoves bietet dabei die meisten kostenlosen Funktionen, einschließlich Profil erstellen, Suchen und Basic-Matching. Für erweiterte Features wie unbegrenztes Chatten oder Profilbesucher-Einsicht ist bei allen Plattformen ein Premium-Abo nötig.',
  },
  {
    question: 'Wie sicher sind die Dating-Seiten?',
    answer: 'Alle von uns getesteten Plattformen verwenden SSL-Verschlüsselung und haben Datenschutzrichtlinien gemäß DSGVO. xLoves und MichVerlieben setzen zusätzlich auf Profilverifizierung, was die Sicherheit deutlich erhöht. Wir empfehlen grundsätzlich, keine sensiblen Daten im Profil zu teilen und sich bei ersten Treffen an öffentlichen Orten zu verabreden.',
  },
  {
    question: 'Welche Dating-Seite ist die beste für ernsthafte Beziehungen?',
    answer: 'Für ernsthafte Beziehungen empfehlen wir xLoves (Platz 1) und MichVerlieben (Platz 3). Beide Plattformen legen Wert auf Profilqualität und ziehen Menschen an, die nach langfristigen Verbindungen suchen. MichVerlieben bietet zusätzlich einen wissenschaftlichen Persönlichkeitstest für bessere Matches.',
  },
  {
    question: 'Was bedeutet der Gutscheincode Herzblatt25?',
    answer: 'Mit dem exklusiven Code Herzblatt25 erhältst du 25% mehr Coins auf deinen ersten Kauf bei allen unseren Partner-Plattformen. Der Code ist für Herzblatt Journal Leser unbegrenzt gültig und kann bei der Registrierung oder beim ersten Kauf eingelöst werden.',
  },
  {
    question: 'Kann ich mehrere Dating-Seiten gleichzeitig nutzen?',
    answer: 'Ja, wir empfehlen sogar, 2-3 Plattformen parallel zu testen. So findest du heraus, welche Community und welches Konzept am besten zu dir passen. Unser Quiz hilft dir, die besten Plattformen für deine Bedürfnisse vorzufiltern.',
  },
  {
    question: 'Wie haben wir die Dating-Seiten getestet?',
    answer: 'Wir haben jede Plattform über mehrere Wochen mit echten Testprofilen genutzt und dabei Benutzerfreundlichkeit, Profilqualität, Matching-Algorithmen, Kosten-Leistungs-Verhältnis, Sicherheit und Datenschutz bewertet. Die Bewertungen basieren auf einer Skala von 1 bis 5.',
  },
];

function renderStars(rating: number) {
  const full = Math.floor(rating);
  const half = rating % 1 >= 0.3;
  const empty = 5 - full - (half ? 1 : 0);
  return { full, half, empty };
}

// Generate Review Schema for each site
const reviewSchemas = datingSites.map((site, i) => ({
  "@type": "Review",
  "itemReviewed": {
    "@type": "WebApplication",
    "name": site.name,
    "url": site.url.split('?')[0],
    "applicationCategory": "DatingApplication",
  },
  "reviewRating": {
    "@type": "Rating",
    "ratingValue": site.rating,
    "bestRating": 5,
    "worstRating": 1,
  },
  "author": {
    "@type": "Organization",
    "name": "Herzblatt Journal",
  },
  "publisher": {
    "@type": "Organization",
    "name": "Herzblatt Journal",
  },
  "reviewBody": site.review,
  "datePublished": "2026-02-01",
}));

const aggregateSchema = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  "name": "Top Dating Seiten 2026",
  "description": "Die besten Dating-Plattformen im Vergleich",
  "numberOfItems": datingSites.length,
  "itemListElement": datingSites.map((site, i) => ({
    "@type": "ListItem",
    "position": i + 1,
    "item": {
      "@type": "WebApplication",
      "name": site.name,
      "url": site.url.split('?')[0],
      "applicationCategory": "DatingApplication",
      "aggregateRating": {
        "@type": "AggregateRating",
        "ratingValue": site.rating,
        "bestRating": 5,
        "reviewCount": 1,
      },
    },
  })),
};

const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": faqItems.map(item => ({
    "@type": "Question",
    "name": item.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": item.answer,
    },
  })),
};
---

<BaseLayout
  title="Top Dating Seiten 2026 im Vergleich — Herzblatt Journal"
  description="Die besten Dating-Plattformen im Test: xLoves, WhatsMeet, MichVerlieben und mehr. Ehrliche Bewertungen mit Vor- und Nachteilen."
  keywords={["dating seiten vergleich", "beste dating seiten 2026", "dating plattformen test", "online dating vergleich"]}
>
  <!-- Schema -->
  <script type="application/ld+json" set:html={JSON.stringify(aggregateSchema)} />
  {reviewSchemas.map(schema => (
    <script type="application/ld+json" set:html={JSON.stringify({"@context": "https://schema.org", ...schema})} />
  ))}
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <section class="max-w-4xl mx-auto px-4 sm:px-6 py-16">

    <!-- Header -->
    <div class="text-center mb-8">
      <span class="inline-block text-xs font-bold uppercase tracking-wider px-3 py-1 rounded-full mb-4" style="background: var(--color-primary-50); color: var(--color-primary-700);">Vergleich 2026</span>
      <h1 class="text-3xl sm:text-4xl font-extrabold mb-4" style="color: var(--text); font-family: var(--font-serif); letter-spacing: -0.02em;">
        Top Dating Seiten im Test
      </h1>
      <p class="text-lg max-w-2xl mx-auto" style="color: var(--text-muted);">
        Wir haben die beliebtesten Dating-Plattformen getestet und ehrlich bewertet — damit du die richtige für dich findest.
      </p>
    </div>

    <!-- Intro Stats -->
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-10">
      <div class="rounded-xl p-4 text-center" style="background: var(--bg-card); border: 1px solid var(--border);">
        <p class="text-2xl font-extrabold" style="color: var(--color-primary-600); font-family: var(--font-serif);">8 Mio+</p>
        <p class="text-[11px] font-medium mt-1" style="color: var(--text-muted);">Deutsche nutzen Dating-Apps</p>
      </div>
      <div class="rounded-xl p-4 text-center" style="background: var(--bg-card); border: 1px solid var(--border);">
        <p class="text-2xl font-extrabold" style="color: var(--color-primary-600); font-family: var(--font-serif);">6</p>
        <p class="text-[11px] font-medium mt-1" style="color: var(--text-muted);">Plattformen getestet</p>
      </div>
      <div class="rounded-xl p-4 text-center" style="background: var(--bg-card); border: 1px solid var(--border);">
        <p class="text-2xl font-extrabold" style="color: var(--color-primary-600); font-family: var(--font-serif);">120h+</p>
        <p class="text-[11px] font-medium mt-1" style="color: var(--text-muted);">Testzeit investiert</p>
      </div>
      <div class="rounded-xl p-4 text-center" style="background: var(--bg-card); border: 1px solid var(--border);">
        <p class="text-2xl font-extrabold" style="color: var(--color-primary-600); font-family: var(--font-serif);">100%</p>
        <p class="text-[11px] font-medium mt-1" style="color: var(--text-muted);">Unabhängig & ehrlich</p>
      </div>
    </div>

    <!-- Quiz CTA -->
    <div class="mb-10 rounded-2xl p-6 sm:p-8 text-center" style="background: linear-gradient(135deg, var(--color-primary-50), var(--color-primary-100)); border: 1px solid var(--color-primary-200);">
      <p class="text-sm font-bold uppercase tracking-wider mb-2" style="color: var(--color-primary-600);">Nicht sicher, welche Seite zu dir passt?</p>
      <h2 class="text-xl sm:text-2xl font-extrabold mb-3" style="color: var(--text); font-family: var(--font-serif);">Mach unser Dating-Quiz in 30 Sekunden</h2>
      <p class="text-sm mb-5 max-w-lg mx-auto" style="color: var(--text-muted);">4 schnelle Fragen — und wir zeigen dir, welche Plattform am besten zu deinen Wünschen und deinem Stil passt.</p>
      <button onclick="openDatingQuiz()" class="inline-flex items-center gap-2 px-8 py-3.5 rounded-full text-sm font-bold text-white cursor-pointer transition-all hover:shadow-lg hover:-translate-y-0.5" style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-700)); border: none;">
        Quiz starten
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </button>
    </div>

    <!-- Quick comparison pills -->
    <div class="mb-8 overflow-x-auto">
      <div class="flex gap-3 pb-2 min-w-max sm:min-w-0 sm:flex-wrap sm:justify-center">
        {datingSites.map((site, i) => (
          <a href={`#${site.name.toLowerCase().replace(/\s/g, '')}`} class="flex items-center gap-2 px-4 py-2.5 rounded-xl text-sm font-medium transition-all hover:-translate-y-0.5" style="background: var(--bg-card); border: 1px solid var(--border); color: var(--text);">
            <span class="text-xs font-bold w-5 h-5 rounded-full flex items-center justify-center" style={`background: ${i === 0 ? 'var(--color-primary-500)' : 'var(--bg-soft)'}; color: ${i === 0 ? 'white' : 'var(--text-muted)'};`}>{i + 1}</span>
            {site.name}
            <span class="text-xs" style="color: var(--color-primary-500);">{site.rating}</span>
          </a>
        ))}
      </div>
    </div>

    <!-- Comparison Table -->
    <div class="mb-12 rounded-2xl overflow-hidden" style="background: var(--bg-card); border: 1px solid var(--border);">
      <div class="px-6 py-4" style="background: linear-gradient(135deg, var(--color-primary-600), var(--color-primary-800));">
        <h2 class="text-base font-bold text-white" style="font-family: var(--font-serif);">Alle Plattformen auf einen Blick</h2>
