        <table class="w-full text-sm" style="min-width: 700px;">
          <thead>
            <tr style="border-bottom: 2px solid var(--border);">
              <th class="text-left px-4 py-3 font-semibold" style="color: var(--text-muted); width: 18%;">Plattform</th>
              <th class="text-center px-3 py-3 font-semibold" style="color: var(--text-muted); width: 10%;">Bewertung</th>
              <th class="text-left px-3 py-3 font-semibold" style="color: var(--text-muted); width: 18%;">Am besten für</th>
              <th class="text-left px-3 py-3 font-semibold" style="color: var(--text-muted); width: 18%;">Kosten</th>
              <th class="text-center px-3 py-3 font-semibold" style="color: var(--text-muted); width: 10%;">App</th>
              <th class="text-center px-3 py-3 font-semibold" style="color: var(--text-muted); width: 12%;">Verifizierung</th>
              <th class="px-3 py-3" style="width: 14%;"></th>
            </tr>
          </thead>
          <tbody>
            {datingSites.map((site, i) => (
              <tr style={`border-bottom: 1px solid var(--border); ${i === 0 ? 'background: rgba(244,63,94,0.04);' : ''}`}>
                <td class="px-4 py-3">
                  <div class="flex items-center gap-2">
                    <span class="text-xs font-bold w-5 h-5 rounded-full flex items-center justify-center shrink-0" style={`background: ${i === 0 ? 'var(--color-primary-500)' : 'var(--bg-soft)'}; color: ${i === 0 ? 'white' : 'var(--text-muted)'};`}>{i + 1}</span>
                    <span class="font-semibold" style="color: var(--text);">{site.name}</span>
                  </div>
                </td>
                <td class="text-center px-3 py-3">
                  <span class="inline-flex items-center gap-1 font-bold" style="color: var(--color-primary-600);">
                    {site.rating}
