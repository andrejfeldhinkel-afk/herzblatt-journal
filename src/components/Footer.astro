---
const year = new Date().getFullYear();
---

<footer class="mt-20" style="background: var(--bg-soft); border-top: 1px solid var(--border);">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 py-14">
    <div class="grid grid-cols-1 md:grid-cols-4 gap-10 mb-12">
      <!-- Brand -->
      <div class="md:col-span-2">
        <div class="flex items-center gap-2.5 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" class="w-9 h-9 shrink-0" fill="none">
            <defs>
              <linearGradient id="hgf" x1="0" y1="0" x2="1" y2="1">
                <stop offset="0%" stop-color="#f43f5e"/>
                <stop offset="100%" stop-color="#be123c"/>
              </linearGradient>
            </defs>
            <path d="M20 35L4.5 19.8C0.2 15.5 0.2 8.7 4.5 4.4 8.8 0.1 15.6 0.1 19.9 4.4L20 4.5 20.1 4.4C24.4 0.1 31.2 0.1 35.5 4.4 39.8 8.7 39.8 15.5 35.5 19.8L20 35Z" fill="url(#hgf)"/>
            <path d="M14 11.5C12 9.5 8.7 9.5 6.7 11.5 5.3 12.9 4.9 14.9 5.5 16.6" stroke="white" stroke-width="2" stroke-linecap="round" opacity="0.35"/>
          </svg>
          <div class="flex flex-col leading-none">
            <span class="text-[17px] font-bold" style="color: var(--text); font-family: var(--font-serif); letter-spacing: -0.03em;">Herzblatt</span>
            <span class="text-[10px] font-medium tracking-[0.2em] uppercase" style="color: var(--text-muted);">Journal</span>
          </div>
        </div>
        <p class="text-sm leading-relaxed max-w-sm mb-4" style="color: var(--text-muted);">
          Dein vertrauenswürdiger Ratgeber für Dating, Flirten und echte Beziehungen. Ehrliche Tipps — ohne Spielchen.
        </p>
        <button onclick="openDatingQuiz()" class="inline-flex items-center gap-2 px-5 py-2.5 rounded-full text-sm font-semibold text-white transition-all hover:opacity-90 cursor-pointer" style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-700)); border: none;">
          Dein Match finden
        </button>
      </div>

      <!-- Links -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider mb-4" style="color: var(--text-muted);">Ratgeber</h3>
        <div class="flex flex-col gap-2.5 text-sm" style="color: var(--text-muted);">
          <a href="/blog" class="hover:text-[var(--color-primary-600)] transition-colors">Alle Ratgeber</a>
          <a href="/erstes-date-guide" class="hover:text-[var(--color-primary-600)] transition-colors">Erstes Date Guide</a>
          <a href="/online-dating-guide" class="hover:text-[var(--color-primary-600)] transition-colors">Online-Dating Guide</a>
          <a href="/beziehungsratgeber" class="hover:text-[var(--color-primary-600)] transition-colors">Beziehungsratgeber</a>
        </div>
      </div>

      <!-- Company -->
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-wider mb-4" style="color: var(--text-muted);">Info</h3>
        <div class="flex flex-col gap-2.5 text-sm" style="color: var(--text-muted);">
          <a href="/ueber-uns" class="hover:text-[var(--color-primary-600)] transition-colors">Über uns</a>
          <a href="/kontakt" class="hover:text-[var(--color-primary-600)] transition-colors">Kontakt</a>
          <a href="/rss.xml" class="hover:text-[var(--color-primary-600)] transition-colors">RSS Feed</a>
        </div>
      </div>
    </div>

    <!-- Newsletter -->
    <div class="mb-12 rounded-2xl p-6 sm:p-8" style="background: linear-gradient(135deg, var(--color-primary-50), var(--color-surface-100)); border: 1px solid var(--color-primary-100);">
      <div class="flex flex-col md:flex-row md:items-center gap-6">
        <div class="flex-1">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-xl">💌</span>
            <h3 class="text-base font-bold" style="color: var(--text); font-family: var(--font-serif);">Dating-Tipps direkt ins Postfach</h3>
          </div>
          <p class="text-sm" style="color: var(--text-muted);">
            Erhalte wöchentlich die besten Tipps für dein Liebesleben — kostenlos & unverbindlich.
          </p>
        </div>
        <form class="flex flex-col sm:flex-row gap-2 w-full md:w-auto" onsubmit="event.preventDefault(); this.querySelector('.nl-btn').textContent = 'Angemeldet ✓'; this.querySelector('.nl-btn').disabled = true;">
          <input
            type="email"
            required
            placeholder="Deine E-Mail-Adresse"
            class="px-4 py-3 rounded-full text-sm w-full sm:w-64 outline-none transition-all focus:ring-2"
            style="background: var(--bg); border: 1px solid var(--border); color: var(--text); --tw-ring-color: var(--color-primary-300);"
          />
          <button
            type="submit"
            class="nl-btn px-6 py-3 rounded-full text-sm font-semibold text-white transition-all hover:opacity-90 shrink-0"
            style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-700));"
          >
            Anmelden
          </button>
        </form>
      </div>
      <p class="text-xs mt-3" style="color: var(--text-muted);">
        Kein Spam. Jederzeit abbestellbar. Wir respektieren deine Privatsphäre.
      </p>
    </div>

    <!-- Social Icons -->
    <div class="flex items-center gap-3 mb-10">
      <a href="https://www.instagram.com/herzblattjournal" target="_blank" rel="noopener" class="footer-social" aria-label="Instagram">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
      </a>
      <a href="https://www.facebook.com/herzblattjournal" target="_blank" rel="noopener" class="footer-social" aria-label="Facebook">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
      </a>
      <a href="https://twitter.com/herzblattjournal" target="_blank" rel="noopener" class="footer-social" aria-label="X / Twitter">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
      </a>
      <a href="https://www.tiktok.com/@herzblattjournal" target="_blank" rel="noopener" class="footer-social" aria-label="TikTok">
        <svg xmlns="http://www.w3.org/2000/svg" width="17" height="17" viewBox="0 0 24 24" fill="currentColor"><path d="M19.59 6.69a4.83 4.83 0 01-3.77-4.25V2h-3.45v13.67a2.89 2.89 0 01-2.88 2.5 2.89 2.89 0 01-2.89-2.89 2.89 2.89 0 012.89-2.89c.28 0 .54.04.79.1v-3.5a6.37 6.37 0 00-.79-.05A6.34 6.34 0 003.15 15.2a6.34 6.34 0 0010.86 4.43v-7.15a8.16 8.16 0 005.58 2.18V11.2a4.85 4.85 0 01-3.77-1.74V6.69z"/></svg>
      </a>
      <a href="https://www.pinterest.de/herzblattjournal" target="_blank" rel="noopener" class="footer-social" aria-label="Pinterest">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0C5.373 0 0 5.372 0 12c0 5.084 3.163 9.426 7.627 11.174-.105-.949-.2-2.405.042-3.441.218-.937 1.407-5.965 1.407-5.965s-.359-.719-.359-1.782c0-1.668.967-2.914 2.171-2.914 1.023 0 1.518.769 1.518 1.69 0 1.029-.655 2.568-.994 3.995-.283 1.194.599 2.169 1.777 2.169 2.133 0 3.772-2.249 3.772-5.495 0-2.873-2.064-4.882-5.012-4.882-3.414 0-5.418 2.561-5.418 5.207 0 1.031.397 2.138.893 2.738a.36.36 0 01.083.345l-.333 1.36c-.053.22-.174.267-.402.161-1.499-.698-2.436-2.889-2.436-4.649 0-3.785 2.75-7.262 7.929-7.262 4.163 0 7.398 2.967 7.398 6.931 0 4.136-2.607 7.464-6.227 7.464-1.216 0-2.359-.631-2.75-1.378l-.748 2.853c-.271 1.043-1.002 2.35-1.492 3.146C9.57 23.812 10.763 24 12 24c6.627 0 12-5.373 12-12 0-6.628-5.373-12-12-12z"/></svg>
      </a>
    </div>

    <!-- Bottom -->
    <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs" style="border-top: 1px solid var(--border); color: var(--text-muted);">
      <p>&copy; {year} Herzblatt Journal. Alle Rechte vorbehalten.</p>
      <div class="flex gap-4">
        <a href="/impressum" class="hover:underline">Impressum</a>
        <a href="/datenschutz" class="hover:underline">Datenschutz</a>
      </div>
    </div>
  </div>
<style>
  .footer-social {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    border-radius: 10px;
    color: var(--text-muted);
    background: var(--bg);
    border: 1px solid var(--border);
    transition: all 0.2s;
  }
  .footer-social:hover {
    color: var(--color-primary-600);
    border-color: var(--color-primary-300);
    transform: translateY(-2px);
  }
</style>
</footer>
