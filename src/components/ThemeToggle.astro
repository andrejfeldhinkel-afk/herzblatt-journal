<button
  class="theme-toggle p-2 rounded-lg transition-colors hover:bg-[var(--code-bg)]"
  style="color: var(--text-muted);"
  aria-label="Theme umschalten"
>
  <!-- Sun icon (shown in dark mode) -->
  <svg class="sun-icon hidden" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/></svg>
  <!-- Moon icon (shown in light mode) -->
  <svg class="moon-icon" xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3a6 6 0 0 0 9 9 9 9 0 1 1-9-9Z"/></svg>
</button>

<script is:inline>
  (function() {
    function updateAllIcons() {
      var isDark = document.documentElement.classList.contains('dark');
      document.querySelectorAll('.sun-icon').forEach(function(el) { el.classList.toggle('hidden', !isDark); });
      document.querySelectorAll('.moon-icon').forEach(function(el) { el.classList.toggle('hidden', isDark); });
    }

    updateAllIcons();

    document.querySelectorAll('.theme-toggle').forEach(function(btn) {
      if (btn.dataset.themeReady) return;
      btn.dataset.themeReady = 'true';
      btn.addEventListener('click', function() {
        var isDark = document.documentElement.classList.toggle('dark');
        localStorage.setItem('theme', isDark ? 'dark' : 'light');
        updateAllIcons();
      });
    });
  })();
</script>
