<section class="rounded-2xl p-8 sm:p-12 text-center" style="background: linear-gradient(135deg, var(--color-primary-600), var(--color-primary-800)); color: white;">
  <h2 class="text-2xl font-bold mb-3">Newsletter</h2>
  <p class="text-sm opacity-90 mb-6 max-w-md mx-auto">
    Erhalte neue Beiträge direkt in dein Postfach. Kein Spam, versprochen.
  </p>
  <form id="newsletter-form" class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto">
    <input 
      type="email" 
      name="email"
      placeholder="deine@email.de" 
      required
      class="flex-1 px-4 py-3 rounded-xl text-sm bg-white/20 text-white placeholder:text-white/60 border border-white/30 focus:outline-none focus:border-white focus:bg-white/25"
    />
    <button 
      type="submit"
      id="nl-submit"
      class="px-6 py-3 rounded-xl text-sm font-semibold bg-white hover:bg-white/90 transition-colors"
      style="color: var(--color-primary-700);"
    >
      Abonnieren
    </button>
  </form>
  <p id="nl-message" class="text-xs mt-4 opacity-70">
    Du kannst dich jederzeit abmelden. Datenschutz ist mir wichtig.
  </p>
</section>

<script>
  const form = document.getElementById('newsletter-form') as HTMLFormElement;
  const msg = document.getElementById('nl-message') as HTMLElement;
  const btn = document.getElementById('nl-submit') as HTMLButtonElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const email = (form.querySelector('input[name="email"]') as HTMLInputElement)?.value;
    if (!email) return;

    btn.textContent = '...';
    btn.disabled = true;

    try {
      const res = await fetch('/api/newsletter', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ email, source: 'newsletter-footer' }),
      });
      const data = await res.json();
      msg.textContent = data.message;
      msg.style.opacity = '1';
      if (data.success) {
        form.reset();
        btn.textContent = 'Angemeldet!';
        btn.style.background = '#22c55e';
        btn.style.color = 'white';
      } else {
        btn.textContent = 'Abonnieren';
        btn.disabled = false;
      }
    } catch {
      msg.textContent = 'Fehler. Bitte versuche es später.';
      btn.textContent = 'Abonnieren';
      btn.disabled = false;
    }
  });
</script>
