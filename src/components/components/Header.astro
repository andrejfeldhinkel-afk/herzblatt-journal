---
import ThemeToggle from './ThemeToggle.astro';

const pathname = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Home' },
  { href: '/blog', label: 'Ratgeber' },
  { href: '/top-dating-seiten', label: 'Top Dating Seiten' },
  { href: '/tags', label: 'Themen' },
  { href: '/ueber-uns', label: 'Über uns' },
];
---

<header class="sticky top-0 z-50 glass" style="border-bottom: 1px solid var(--border);">
  <nav class="max-w-6xl mx-auto px-4 sm:px-6 h-16 flex items-center justify-between">
    <!-- Logo -->
    <a href="/" class="flex items-center gap-2.5 group shrink-0">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 40 40" class="w-9 h-9" fill="none">
        <defs>
          <linearGradient id="hg" x1="0" y1="0" x2="1" y2="1">
            <stop offset="0%" stop-color="#f43f5e"/>
            <stop offset="100%" stop-color="#be123c"/>
          </linearGradient>
        </defs>
        <path d="M20 35L4.5 19.8C0.2 15.5 0.2 8.7 4.5 4.4 8.8 0.1 15.6 0.1 19.9 4.4L20 4.5 20.1 4.4C24.4 0.1 31.2 0.1 35.5 4.4 39.8 8.7 39.8 15.5 35.5 19.8L20 35Z" fill="url(#hg)"/>
        <path d="M14 11.5C12 9.5 8.7 9.5 6.7 11.5 5.3 12.9 4.9 14.9 5.5 16.6" stroke="white" stroke-width="2" stroke-linecap="round" opacity="0.35"/>
      </svg>
      <div class="flex flex-col leading-none">
        <span class="text-[17px] font-bold" style="color: var(--text); font-family: var(--font-serif); letter-spacing: -0.03em;">Herzblatt</span>
        <span class="text-[10px] font-medium tracking-[0.2em] uppercase" style="color: var(--text-muted);">Journal</span>
      </div>
    </a>

    <!-- Desktop Nav -->
    <div class="hidden md:flex items-center gap-1">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[
            'px-3.5 py-2 rounded-full text-sm font-medium transition-all duration-200',
            pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href))
              ? 'text-[var(--color-primary-700)]'
              : 'hover:text-[var(--text)]'
          ]}
          style={`${
            pathname === link.href || (link.href !== '/' && pathname.startsWith(link.href))
              ? 'background: var(--color-primary-50); color: var(--color-primary-700);'
              : 'color: var(--text-muted);'
          }`}
        >
          {link.label}
        </a>
      ))}

      <a href="/suche" class="p-2 rounded-full transition-all hover:bg-[var(--color-primary-50)]" style="color: var(--text-muted);" aria-label="Suche">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
      </a>
      <div class="w-px h-5 mx-2" style="background: var(--border);"></div>
      <ThemeToggle />
      <button onclick="window.openDatingQuiz()" class="ml-2 px-5 py-2 rounded-full text-sm font-semibold text-white transition-all hover:shadow-lg hover:-translate-y-0.5 cursor-pointer" style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-600)); border: none;">
        Jetzt starten
      </button>
    </div>

    <!-- Mobile -->
    <div class="flex items-center gap-2 md:hidden">
      <ThemeToggle />
      <button id="mobile-menu-btn" class="p-2 rounded-lg" style="color: var(--text);" aria-label="Menü">
        <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="3" x2="21" y1="6" y2="6"/><line x1="3" x2="21" y1="12" y2="12"/><line x1="3" x2="21" y1="18" y2="18"/></svg>
      </button>
    </div>
  </nav>

  <!-- Mobile Nav -->
  <div id="mobile-menu" class="hidden md:hidden px-4 pb-4">
    <div class="flex flex-col gap-1 rounded-2xl p-3" style="background: var(--bg-card); border: 1px solid var(--border); box-shadow: 0 4px 24px rgba(0,0,0,0.08);">
      {navLinks.map(link => (
        <a href={link.href} class="px-4 py-3 rounded-xl text-sm font-medium" style={`${pathname === link.href ? 'background: var(--color-primary-50); color: var(--color-primary-700);' : 'color: var(--text);'}`}>
          {link.label}
        </a>
      ))}
      <a href="/suche" class="px-4 py-3 rounded-xl text-sm font-medium flex items-center gap-2" style="color: var(--text);">
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><path d="m21 21-4.3-4.3"/></svg>
        Suche
      </a>
      <button onclick="window.openDatingQuiz()" class="mx-4 my-2 py-3 rounded-xl text-sm font-semibold text-center text-white w-full cursor-pointer" style="background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-600)); border: none;">
        Jetzt starten
      </button>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  btn?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>
