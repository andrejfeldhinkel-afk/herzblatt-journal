---
// Dating Quiz Popup Component
---

<!-- Quiz Modal Overlay -->
<div id="dating-quiz-overlay" class="fixed inset-0 z-[200] hidden" style="background: rgba(0,0,0,0.6); backdrop-filter: blur(6px);">
  <div class="flex items-center justify-center min-h-screen p-4">
    <div id="dating-quiz-modal" class="relative w-full max-w-lg rounded-3xl overflow-hidden shadow-2xl" style="background: var(--bg-card); border: 1px solid var(--border);">

      <!-- Close Button -->
      <button onclick="closeDatingQuiz()" class="absolute top-4 right-4 z-10 w-8 h-8 rounded-full flex items-center justify-center transition-colors" style="background: var(--bg-soft); color: var(--text-muted);" aria-label="Schließen">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
      </button>

      <!-- Progress Bar -->
      <div class="h-1 w-full" style="background: var(--bg-soft);">
        <div id="quiz-progress" class="h-full transition-all duration-500 ease-out rounded-r-full" style="width: 0%; background: linear-gradient(90deg, var(--color-primary-500), var(--color-primary-600));"></div>
      </div>

      <!-- Quiz Content Area -->
      <div id="quiz-content" class="p-6 sm:p-8">
        <!-- Filled by JS -->
      </div>

    </div>
  </div>
</div>

<script is:inline>
(function() {
  const quizData = {
    questions: [
      {
        title: 'Was suchst du?',
        subtitle: 'Wähle, was am besten zu dir passt',
        options: [
          { label: 'Feste Beziehung', icon: 'heart', scores: { xloves: 3, michverlieben: 3, whatsmeet: 1, onlydates69: 0, singles69: 0, sex69: 0 } },
          { label: 'Casual Dating', icon: 'sparkle', scores: { xloves: 0, michverlieben: 0, whatsmeet: 1, onlydates69: 3, singles69: 2, sex69: 1 } },
          { label: 'Neue Leute kennenlernen', icon: 'people', scores: { xloves: 1, michverlieben: 0, whatsmeet: 3, onlydates69: 1, singles69: 3, sex69: 0 } },
          { label: 'Abenteuer', icon: 'flame', scores: { xloves: 0, michverlieben: 0, whatsmeet: 0, onlydates69: 2, singles69: 1, sex69: 3 } },
        ]
      },
      {
        title: 'Wie alt bist du?',
        subtitle: 'Dein Alter hilft uns bei der Empfehlung',
        options: [
          { label: '18–25', icon: 'zap', scores: { xloves: 2, michverlieben: 0, whatsmeet: 2, onlydates69: 2, singles69: 2, sex69: 1 } },
          { label: '26–35', icon: 'target', scores: { xloves: 2, michverlieben: 1, whatsmeet: 2, onlydates69: 2, singles69: 2, sex69: 1 } },
          { label: '36–45', icon: 'coffee', scores: { xloves: 1, michverlieben: 3, whatsmeet: 1, onlydates69: 1, singles69: 1, sex69: 1 } },
          { label: '45+', icon: 'sun', scores: { xloves: 1, michverlieben: 3, whatsmeet: 1, onlydates69: 0, singles69: 1, sex69: 0 } },
        ]
      },
      {
        title: 'Was ist dir am wichtigsten?',
        subtitle: 'Deine Priorität beim Online-Dating',
        options: [
          { label: 'Sicherheit & Verifizierung', icon: 'shield', scores: { xloves: 3, michverlieben: 2, whatsmeet: 1, onlydates69: 0, singles69: 0, sex69: 0 } },
          { label: 'Schneller Kontakt', icon: 'bolt', scores: { xloves: 0, michverlieben: 0, whatsmeet: 1, onlydates69: 3, singles69: 3, sex69: 1 } },
          { label: 'Tiefe Gespräche', icon: 'chat', scores: { xloves: 1, michverlieben: 2, whatsmeet: 3, onlydates69: 0, singles69: 0, sex69: 0 } },
          { label: 'Diskretion', icon: 'lock', scores: { xloves: 1, michverlieben: 0, whatsmeet: 0, onlydates69: 1, singles69: 1, sex69: 3 } },
        ]
      },
      {
        title: 'Wie willst du daten?',
        subtitle: 'Dein bevorzugter Dating-Stil',
        options: [
          { label: 'Swipen & Matchen', icon: 'swipe', scores: { xloves: 3, michverlieben: 0, whatsmeet: 0, onlydates69: 1, singles69: 3, sex69: 1 } },
          { label: 'Chat-basiert', icon: 'message', scores: { xloves: 1, michverlieben: 0, whatsmeet: 3, onlydates69: 1, singles69: 1, sex69: 1 } },
          { label: 'Persönlichkeitstest', icon: 'brain', scores: { xloves: 0, michverlieben: 3, whatsmeet: 1, onlydates69: 0, singles69: 0, sex69: 0 } },
          { label: 'Standort-basiert', icon: 'pin', scores: { xloves: 0, michverlieben: 0, whatsmeet: 0, onlydates69: 3, singles69: 1, sex69: 3 } },
        ]
      }
    ],
    sites: {
      xloves: { name: 'xLoves', url: 'https://xloves.com/?campaign_id=2f2006d0', logo: '/images/logos/xloves-logo.png', rating: 4.8, desc: 'Die moderne Dating-Plattform für echte Verbindungen — diskret, sicher und mit starker Community.', color: '#f43f5e' },
      whatsmeet: { name: 'WhatsMeet', url: 'https://whatsmeet.com', logo: '/images/logos/whatsmeet-logo.png', rating: 4.3, desc: 'Chat-basiertes Dating mit Fokus auf echte Gespräche statt oberflächliches Swipen.', color: '#22c55e' },
      michverlieben: { name: 'MichVerlieben', url: 'https://michverlieben.com', logo: '/images/logos/michverlieben-logo.png', rating: 4.1, desc: 'Deutsche Dating-Plattform mit Fokus auf ernsthafte Beziehungen und Partnervermittlung.', color: '#ef4444' },
      onlydates69: { name: 'OnlyDates69', url: 'https://onlydates69.com', logo: '/images/logos/onlydates69-logo.png', rating: 3.8, desc: 'Unkompliziertes Dating für spontane Treffen und zwanglose Verabredungen.', color: '#3b82f6' },
      singles69: { name: 'Single69', url: 'https://single69.de', logo: '/images/logos/singles69-logo.png', rating: 3.6, desc: 'Casual-Dating-Plattform mit großer Nutzerbasis und schnellem Matching.', color: '#8b5cf6' },
      sex69: { name: 'Sex69', url: 'https://sex69.de/', logo: '/images/logos/sex69-logo.jpg', rating: 3.5, desc: 'Erwachsenen-Dating-Plattform für offene und abenteuerlustige Singles.', color: '#f43f5e' },
    }
  };

  const icons = {
    heart: '<path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>',
    sparkle: '<path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"/>',
    people: '<path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M22 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/>',
    flame: '<path d="M8.5 14.5A2.5 2.5 0 0 0 11 12c0-1.38-.5-2-1-3-1.072-2.143-.224-4.054 2-6 .5 2.5 2 4.9 4 6.5 2 1.6 3 3.5 3 5.5a7 7 0 1 1-14 0c0-1.153.433-2.294 1-3a2.5 2.5 0 0 0 2.5 2.5z"/>',
    zap: '<path d="M4 14a1 1 0 0 1-.78-1.63l9.9-10.2a.5.5 0 0 1 .86.46l-1.92 6.02A1 1 0 0 0 13 10h7a1 1 0 0 1 .78 1.63l-9.9 10.2a.5.5 0 0 1-.86-.46l1.92-6.02A1 1 0 0 0 11 14z"/>',
    target: '<circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/>',
    coffee: '<path d="M10 2v2"/><path d="M14 2v2"/><path d="M16 8a1 1 0 0 1 1 1v8a4 4 0 0 1-4 4H7a4 4 0 0 1-4-4V9a1 1 0 0 1 1-1h14a2 2 0 0 1 2 2v1a2 2 0 0 1-2 2h-1"/><path d="M6 2v2"/>',
    sun: '<circle cx="12" cy="12" r="4"/><path d="M12 2v2"/><path d="M12 20v2"/><path d="m4.93 4.93 1.41 1.41"/><path d="m17.66 17.66 1.41 1.41"/><path d="M2 12h2"/><path d="M20 12h2"/><path d="m6.34 17.66-1.41 1.41"/><path d="m19.07 4.93-1.41 1.41"/>',
    shield: '<path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/><path d="m9 12 2 2 4-4"/>',
    bolt: '<path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"/><circle cx="12" cy="12" r="4"/>',
    chat: '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22z"/>',
    lock: '<rect width="18" height="11" x="3" y="11" rx="2" ry="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/>',
    swipe: '<path d="M18 11V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2"/><path d="M14 10V4a2 2 0 0 0-2-2a2 2 0 0 0-2 2v2"/><path d="M10 10.5V6a2 2 0 0 0-2-2a2 2 0 0 0-2 2v8"/><path d="M18 8a2 2 0 1 1 4 0v6a8 8 0 0 1-8 8h-2c-2.8 0-4.5-.86-5.99-2.34l-3.6-3.6a2 2 0 0 1 2.83-2.82L7 15"/>',
    message: '<path d="M7.9 20A9 9 0 1 0 4 16.1L2 22z"/><path d="M8 12h.01"/><path d="M12 12h.01"/><path d="M16 12h.01"/>',
    brain: '<path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .585-.396"/><path d="M19.938 10.5a4 4 0 0 1 .585.396"/><path d="M6 18a4 4 0 0 1-1.967-.516"/><path d="M19.967 17.484A4 4 0 0 1 18 18"/>',
    pin: '<path d="M20 10c0 4.993-5.539 10.193-7.399 11.799a1 1 0 0 1-1.202 0C9.539 20.193 4 14.993 4 10a8 8 0 0 1 16 0"/><circle cx="12" cy="10" r="3"/>',
  };

  function getIcon(name) {
    return '<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">' + (icons[name] || '') + '</svg>';
  }

  function renderStars(rating) {
    let html = '';
    const full = Math.floor(rating);
    const half = rating % 1 >= 0.3;
    const empty = 5 - full - (half ? 1 : 0);
    for (let i = 0; i < full; i++) html += '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="#f43f5e" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>';
    if (half) html += '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="none"><defs><linearGradient id="qh"><stop offset="50%" stop-color="#f43f5e"/><stop offset="50%" stop-color="var(--border)"/></linearGradient></defs><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" fill="url(#qh)"/></svg>';
    for (let i = 0; i < empty; i++) html += '<svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="var(--border)" stroke="none"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>';
    return html;
  }

  let currentStep = 0;
  let scores = { xloves: 0, whatsmeet: 0, michverlieben: 0, onlydates69: 0, singles69: 0, sex69: 0 };

  function renderQuestion(step) {
    const q = quizData.questions[step];
    const progress = ((step) / quizData.questions.length) * 100;
    document.getElementById('quiz-progress').style.width = progress + '%';

    const content = document.getElementById('quiz-content');
    content.style.opacity = '0';
    setTimeout(() => {
      content.innerHTML = `
        <div style="text-align: center; margin-bottom: 1.5rem;">
          <p style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-primary-500); margin-bottom: 0.5rem;">Frage ${step + 1} von ${quizData.questions.length}</p>
          <h3 style="font-size: 1.4rem; font-weight: 800; color: var(--text); font-family: var(--font-serif); margin-bottom: 0.25rem;">${q.title}</h3>
          <p style="font-size: 0.85rem; color: var(--text-muted);">${q.subtitle}</p>
        </div>
        <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem;">
          ${q.options.map((opt, i) => `
            <button onclick="selectQuizOption(${step}, ${i})" class="quiz-option-btn" style="display: flex; flex-direction: column; align-items: center; gap: 0.6rem; padding: 1.2rem 0.75rem; border-radius: 1rem; border: 2px solid rgba(180,180,190,0.5); background: white; cursor: pointer; transition: all 0.2s ease; color: var(--text); box-shadow: 0 2px 8px rgba(0,0,0,0.06);" onmouseover="this.style.borderColor='var(--color-primary-400)';this.style.transform='translateY(-2px)';this.style.boxShadow='0 4px 12px rgba(244,63,94,0.15)'" onmouseout="this.style.borderColor='rgba(180,180,190,0.5)';this.style.transform='none';this.style.boxShadow='0 2px 8px rgba(0,0,0,0.06)'">
              <span style="color: var(--color-primary-500);">${getIcon(opt.icon)}</span>
              <span style="font-size: 0.85rem; font-weight: 600; line-height: 1.3;">${opt.label}</span>
            </button>
          `).join('')}
        </div>
      `;
      content.style.opacity = '1';
    }, 200);
  }

  function renderResult() {
    document.getElementById('quiz-progress').style.width = '100%';

    // Find winner
    let maxScore = 0;
    let winner = 'xloves';
    for (const key in scores) {
      if (scores[key] > maxScore) {
        maxScore = scores[key];
        winner = key;
      }
    }
    const site = quizData.sites[winner];

    const content = document.getElementById('quiz-content');
    content.style.opacity = '0';
    setTimeout(() => {
      content.innerHTML = `
        <div style="text-align: center;">
          <div style="display: inline-flex; align-items: center; justify-content: center; width: 48px; height: 48px; border-radius: 50%; background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-600)); margin-bottom: 1rem;">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m9 12 2 2 4-4"/><circle cx="12" cy="12" r="10"/></svg>
          </div>
          <p style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; color: var(--color-primary-500); margin-bottom: 0.5rem;">Dein perfektes Match</p>
          <div style="display: flex; align-items: center; justify-content: center; margin-bottom: 1rem;">
            <div style="background: #1a1a2e; border-radius: 0.75rem; padding: 8px 20px; display: inline-flex; align-items: center; justify-content: center;">
              <img src="${site.logo}" alt="${site.name}" style="height: 32px; width: auto;" />
            </div>
          </div>
          <h3 style="font-size: 1.5rem; font-weight: 800; color: var(--text); font-family: var(--font-serif); margin-bottom: 0.25rem;">${site.name}</h3>
          <div style="display: flex; align-items: center; justify-content: center; gap: 0.5rem; margin-bottom: 0.75rem;">
            <span style="font-size: 1.1rem; font-weight: 700; color: var(--color-primary-600);">${site.rating}</span>
            <span style="display: flex; align-items: center; gap: 2px;">${renderStars(site.rating)}</span>
          </div>
          <p style="font-size: 0.9rem; color: var(--text-muted); line-height: 1.6; max-width: 360px; margin: 0 auto 1.5rem;">${site.desc}</p>
          <a href="${site.url}" target="_blank" rel="noopener" onclick="navigator.sendBeacon('/api/track-click', JSON.stringify({site:'${winner}'}))" style="display: inline-flex; align-items: center; gap: 0.5rem; padding: 0.85rem 2rem; border-radius: 9999px; background: linear-gradient(135deg, var(--color-primary-500), var(--color-primary-600)); color: white; font-weight: 700; font-size: 0.95rem; text-decoration: none; transition: all 0.2s; box-shadow: 0 4px 14px rgba(244,63,94,0.3);" onmouseover="this.style.transform='translateY(-2px)';this.style.boxShadow='0 6px 20px rgba(244,63,94,0.4)'" onmouseout="this.style.transform='none';this.style.boxShadow='0 4px 14px rgba(244,63,94,0.3)'">
            Jetzt kostenlos testen
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" x2="21" y1="14" y2="3"/></svg>
          </a>
          <div style="margin-top: 1rem;">
            <button onclick="restartQuiz()" style="font-size: 0.8rem; color: var(--text-muted); background: none; border: none; cursor: pointer; text-decoration: underline; padding: 0.5rem;">Quiz wiederholen</button>
            <span style="color: var(--border); margin: 0 0.25rem;">|</span>
            <a href="/top-dating-seiten" style="font-size: 0.8rem; color: var(--text-muted); text-decoration: underline; padding: 0.5rem;">Alle Seiten vergleichen</a>
          </div>
        </div>
      `;
      content.style.opacity = '1';
    }, 200);
  }

  window.openDatingQuiz = function() {
    currentStep = 0;
    scores = { xloves: 0, whatsmeet: 0, michverlieben: 0, onlydates69: 0, singles69: 0, sex69: 0 };
    const overlay = document.getElementById('dating-quiz-overlay');
    overlay.classList.remove('hidden');
    overlay.style.opacity = '0';
    requestAnimationFrame(() => {
      overlay.style.transition = 'opacity 0.3s ease';
      overlay.style.opacity = '1';
    });
    document.body.style.overflow = 'hidden';
    renderQuestion(0);
  };

  window.closeDatingQuiz = function() {
    const overlay = document.getElementById('dating-quiz-overlay');
    overlay.style.opacity = '0';
    setTimeout(() => {
      overlay.classList.add('hidden');
      overlay.style.transition = '';
      document.body.style.overflow = '';
    }, 300);
  };

  window.selectQuizOption = function(step, optionIndex) {
    const option = quizData.questions[step].options[optionIndex];
    for (const key in option.scores) {
      scores[key] += option.scores[key];
    }
    currentStep++;
    if (currentStep < quizData.questions.length) {
      renderQuestion(currentStep);
    } else {
      renderResult();
    }
  };

  window.restartQuiz = function() {
    currentStep = 0;
    scores = { xloves: 0, whatsmeet: 0, michverlieben: 0, onlydates69: 0, singles69: 0, sex69: 0 };
    renderQuestion(0);
  };

  // Close on overlay click (not modal)
  document.getElementById('dating-quiz-overlay').addEventListener('click', function(e) {
    if (e.target === this) closeDatingQuiz();
  });

  // Close on Escape
  document.addEventListener('keydown', function(e) {
    if (e.key === 'Escape') closeDatingQuiz();
  });
})();
</script>

<style>
  #quiz-content {
    transition: opacity 0.2s ease;
  }
</style>
